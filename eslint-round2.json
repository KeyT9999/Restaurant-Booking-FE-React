on>\r\n                    ))}\r\n                    <Button\r\n                      disabled={page >= totalPages}\r\n                      onClick={() => handlePageChange(page + 1)}\r\n                      variant=\"outline\"\r\n                      size=\"sm\"\r\n                      className=\"border-border text-xs text-white\"\r\n                    >\r\n                      Sau\r\n                    </Button>\r\n                  </div>\r\n                )}\r\n              </>\r\n            )}\r\n          </div>\r\n        </div>\r\n      </main>\r\n\r\n      {/* Footer */}\r\n      <footer className=\"border-t border-border bg-[#090B0E] py-8 text-center text-xs text-muted-foreground mt-16\">\r\n        <div className=\"mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4\">\r\n          <span style={{ fontFamily: \"'Playfair Display', serif\" }} className=\"text-sm font-bold text-white tracking-wider\">BookEat</span>\r\n          <span>в”¬вҢҗ 2026 BookEat. MГҹв•—Г¬i quyГҹв•—Гјn в”ҖГҰв•һв–‘Гҹв•—Гәc bГҹв•‘Гәo lв•һв–‘u.</span>\r\n        </div>\r\n      </footer>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\waitlist\\MyWaitlistsPage.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  40 |\n  41 |   useEffect(() => {\n> 42 |     fetchWaitlists();\n     |     ^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  43 |   }, [fetchWaitlists]);\n  44 |\n  45 |   useEffect(() => {","line":42,"column":5,"endLine":42,"endColumn":19}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useCallback, useEffect, useState } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport toast from 'react-hot-toast';\r\nimport { RefreshCw, Compass } from 'lucide-react';\r\nimport { cancelWaitlist, getMyWaitlists } from '../../api/waitlistApi';\r\nimport WaitlistCard from '../../components/waitlist/WaitlistCard';\r\nimport Header from '../../components/Header';\r\nimport { Button } from '../../components/ui/button';\r\nimport { Card } from '../../components/ui/card';\r\n\r\nconst STATUSES = [\r\n  { value: '', label: 'TГҹв•‘Г‘t cГҹв•‘Гә' },\r\n  { value: 'pending', label: 'в”ҖГүang chГҹв•—ВҘ' },\r\n  { value: 'confirmed', label: 'в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn' },\r\n  { value: 'cancelled', label: 'в”ҖГүв”ңГә hГҹв•—Вәy' },\r\n  { value: 'expired', label: 'HГҹв•‘в”җt hГҹв•‘Гӯn' },\r\n];\r\n\r\nexport default function MyWaitlistsPage() {\r\n  const navigate = useNavigate();\r\n  const [waitlists, setWaitlists] = useState([]);\r\n  const [status, setStatus] = useState('');\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  const fetchWaitlists = useCallback(async () => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await getMyWaitlists({ status: status || undefined, page: 1, limit: 30 });\r\n      if (res.success) {\r\n        setWaitlists(res.data.waitlists || []);\r\n      } else {\r\n        toast.error(res.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch chГҹв•—ВҘ');\r\n      }\r\n    } catch (error) {\r\n      toast.error(error.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch chГҹв•—ВҘ');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [status]);\r\n\r\n  useEffect(() => {\r\n    fetchWaitlists();\r\n  }, [fetchWaitlists]);\r\n\r\n  useEffect(() => {\r\n    const handler = () => fetchWaitlists();\r\n    window.addEventListener('bookeat:waitlist-event', handler);\r\n    return () => window.removeEventListener('bookeat:waitlist-event', handler);\r\n  }, [fetchWaitlists]);\r\n\r\n  // Reset filter is handled via effect or directly inside handler\r\n\r\n  const handleCancel = async (waitlist) => {\r\n    const reason = window.prompt('Lв”ңв•ң do hГҹв•—Вәy danh sв”ңГӯch chГҹв•—ВҘ?', 'Khв”ңГӯch hв”ңГЎng chГҹв•—Вә в”ҖГҰГҹв•—Г–ng hГҹв•—Вәy');\r\n    if (reason === null) return;\r\n\r\n    try {\r\n      const res = await cancelWaitlist(waitlist.id, reason);\r\n      if (res.success) {\r\n        toast.success('в”ҖГүв”ңГә hГҹв•—Вәy yв”ңВ¬u cГҹв•‘Вәu danh sв”ңГӯch chГҹв•—ВҘ');\r\n        fetchWaitlists();\r\n      }\r\n    } catch (error) {\r\n      toast.error(error.message || 'Khв”ңв”Өng thГҹв•—Гў hГҹв•—Вәy yв”ңВ¬u cГҹв•‘Вәu');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n\r\n      <main className=\"flex-1 max-w-4xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-10\">\r\n        {/* Header Title & Refresh */}\r\n        <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-border pb-6 mb-8 text-left\">\r\n          <div>\r\n            <h1 className=\"text-3xl font-extrabold tracking-tight text-white sm:text-4xl\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\r\n              Danh sв”ңГӯch chГҹв•—ВҘ cГҹв•—Вәa tв”ңв”Өi\r\n            </h1>\r\n            <p className=\"mt-2 text-sm text-muted-foreground\">\r\n              Theo dв”ңв•Ўi vГҹв•—ГҜ trв”ңВЎ hв”ңГЎng chГҹв•—ВҘ dГҹв•—в–’ kiГҹв•‘в”җn, mв”ңв”Ӯn в”ҖГўn dГҹв•—ГҜch vГҹв•—Г‘ в”ҖГҰГҹв•‘в•–t trв•һв–‘Гҹв•—Вўc vв”ңГЎ trГҹв•‘Гӯng thв”ңГӯi realtime.\r\n            </p>\r\n          </div>\r\n          <Button\r\n            variant=\"outline\"\r\n            size=\"sm\"\r\n            onClick={fetchWaitlists}\r\n            className=\"border-border text-white hover:bg-secondary text-xs font-semibold self-start sm:self-auto gap-1.5 h-9\"\r\n          >\r\n            <RefreshCw size={14} /> Lв”ңГЎm mГҹв•—Вўi\r\n          </Button>\r\n        </div>\r\n\r\n        {/* Tab Filters */}\r\n        <div className=\"flex flex-wrap gap-1 bg-[#20242D] border border-border p-1 rounded-lg w-fit mb-8 justify-start text-xs font-semibold\">\r\n          {STATUSES.map((item) => (\r\n            <button\r\n              key={item.value}\r\n              role=\"tab\"\r\n              onClick={() => setStatus(item.value)}\r\n              className={`px-4 py-2 rounded-md transition-all cursor-pointer ${\r\n                status === item.value\r\n                  ? 'bg-primary text-background font-bold'\r\n                  : 'text-muted-foreground hover:text-white hover:bg-secondary/40'\r\n              }`}\r\n            >\r\n              {item.label}\r\n            </button>\r\n          ))}\r\n        </div>\r\n\r\n        {/* Waitlists Grid */}\r\n        {loading ? (\r\n          <div className=\"flex flex-col gap-4\">\r\n            {[1, 2].map((n) => (\r\n              <Card key={n} className=\"h-36 bg-card border-border animate-pulse\" />\r\n            ))}\r\n          </div>\r\n        ) : waitlists.length === 0 ? (\r\n          <div className=\"text-center py-20 border border-dashed border-border bg-card/20 rounded-xl flex flex-col items-center justify-center gap-4\">\r\n            <Compass size={48} className=\"text-muted-foreground animate-bounce\" />\r\n            <h3 className=\"text-lg font-bold text-white\">Chв•һв–‘a cв”ңв”Ӯ yв”ңВ¬u cГҹв•‘Вәu danh sв”ңГӯch chГҹв•—ВҘ nв”ңГЎo</h3>\r\n            <p className=\"text-sm text-muted-foreground max-w-sm\">\r\n              Khi nhв”ңГЎ hв”ңГЎng в”ҖГҰв”ңГә hГҹв•‘в”җt bв”ңГЎn trГҹв•—ГҰng, bГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў в”ҖГҰв”ҖГўng kв”ңв•ң hв”ңГЎng chГҹв•—ВҘ xГҹв•‘в”җp hв”ңГЎng trГҹв•—в–’c tuyГҹв•‘в”җn в”ҖГҰГҹв•—Гў nhГҹв•‘ВЎn vГҹв•—ГҜ trв”ңВЎ sГҹв•—Вўm nhГҹв•‘Г‘t.\r\n            </p>\r\n            <Button onClick={() => navigate('/restaurants')} className=\"bg-primary hover:bg-primary/95 text-background text-xs font-bold gap-1.5 h-10 px-5\">\r\n              Khв”ңГӯm phв”ңГӯ nhв”ңГЎ hв”ңГЎng ngay\r\n            </Button>\r\n          </div>\r\n        ) : (\r\n          <section className=\"grid grid-cols-1 gap-4 text-left\">\r\n            {waitlists.map((waitlist) => (\r\n              <WaitlistCard\r\n                key={waitlist.id}\r\n                waitlist={waitlist}\r\n                onView={() => navigate(`/waitlists/${waitlist.id}`)}\r\n                onCancel={handleCancel}\r\n              />\r\n            ))}\r\n          </section>\r\n        )}\r\n      </main>\r\n\r\n      {/* Footer */}\r\n      <footer className=\"border-t border-border bg-[#090B0E] py-8 text-center text-xs text-muted-foreground mt-16\">\r\n        <div className=\"mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4\">\r\n          <span style={{ fontFamily: \"'Playfair Display', serif\" }} className=\"text-sm font-bold text-white tracking-wider\">BookEat</span>\r\n          <span>в”¬вҢҗ 2026 BookEat. MГҹв•—Г¬i quyГҹв•—Гјn в”ҖГҰв•һв–‘Гҹв•—Гәc bГҹв•‘Гәo lв•һв–‘u.</span>\r\n        </div>\r\n      </footer>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\waitlist\\WaitlistDetailPage.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  39 |\n  40 |   useEffect(() => {\n> 41 |     fetchDetail();\n     |     ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  42 |   }, [fetchDetail]);\n  43 |\n  44 |   useEffect(() => {","line":41,"column":5,"endLine":41,"endColumn":16}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useCallback, useEffect, useState } from 'react';\r\nimport { Link, useNavigate, useParams } from 'react-router-dom';\r\nimport toast from 'react-hot-toast';\r\nimport { ArrowLeft, CalendarDays, Clock, ConciergeBell, Users, Utensils, ShieldAlert, Info, ArrowUpRight } from 'lucide-react';\r\nimport { cancelWaitlist, getWaitlistById } from '../../api/waitlistApi';\r\nimport WaitlistStatusBadge from '../../components/waitlist/WaitlistStatusBadge';\r\nimport Header from '../../components/Header';\r\nimport { Button } from '../../components/ui/button';\r\nimport { Card } from '../../components/ui/card';\r\n\r\nconst currency = (value) =>\r\n  new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(Number(value || 0));\r\n\r\nconst formatDate = (value) => value ? new Date(value).toLocaleDateString('vi-VN', {\r\n  weekday: 'long',\r\n  year: 'numeric',\r\n  month: 'long',\r\n  day: 'numeric'\r\n}) : '--';\r\n\r\nexport default function WaitlistDetailPage() {\r\n  const { id } = useParams();\r\n  const navigate = useNavigate();\r\n  const [waitlist, setWaitlist] = useState(null);\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  const fetchDetail = useCallback(async () => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await getWaitlistById(id);\r\n      if (res.success) setWaitlist(res.data.waitlist);\r\n      else toast.error(res.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi chi tiГҹв•‘в”җt hв”ңГЎng chГҹв•—ВҘ');\r\n    } catch (error) {\r\n      toast.error(error.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi chi tiГҹв•‘в”җt hв”ңГЎng chГҹв•—ВҘ');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [id]);\r\n\r\n  useEffect(() => {\r\n    fetchDetail();\r\n  }, [fetchDetail]);\r\n\r\n  useEffect(() => {\r\n    const handler = (event) => {\r\n      const eventId = event.detail?.payload?.waitlistId;\r\n      if (!eventId || eventId === id) fetchDetail();\r\n    };\r\n    window.addEventListener('bookeat:waitlist-event', handler);\r\n    return () => window.removeEventListener('bookeat:waitlist-event', handler);\r\n  }, [fetchDetail, id]);\r\n\r\n  const handleCancel = async () => {\r\n    const reason = window.prompt('Lв”ңв•ң do hГҹв•—Вәy danh sв”ңГӯch chГҹв•—ВҘ?', 'Khв”ңГӯch hв”ңГЎng chГҹв•—Вә в”ҖГҰГҹв•—Г–ng hГҹв•—Вәy');\r\n    if (reason === null) return;\r\n\r\n    try {\r\n      const res = await cancelWaitlist(id, reason);\r\n      if (res.success) {\r\n        toast.success('в”ҖГүв”ңГә hГҹв•—Вәy yв”ңВ¬u cГҹв•‘Вәu danh sв”ңГӯch chГҹв•—ВҘ');\r\n        fetchDetail();\r\n      }\r\n    } catch (error) {\r\n      toast.error(error.message || 'Khв”ңв”Өng thГҹв•—Гў hГҹв•—Вәy yв”ңВ¬u cГҹв•‘Вәu');\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n        <Header />\r\n        <div className=\"flex-1 flex flex-col items-center justify-center gap-3\">\r\n          <div className=\"h-10 w-10 border-4 border-primary border-t-transparent rounded-full animate-spin\" />\r\n          <p className=\"text-sm text-muted-foreground animate-pulse\">в”ҖГүang tГҹв•‘Гәi thв”ңв”Өng tin chi tiГҹв•‘в”җt hв”ңГЎng chГҹв•—ВҘ...</p>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (!waitlist) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n        <Header />\r\n        <div className=\"flex-1 flex flex-col items-center justify-center p-6 gap-4\">\r\n          <ShieldAlert className=\"h-12 w-12 text-rose-500\" />\r\n          <p className=\"text-muted-foreground text-sm\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y yв”ңВ¬u cГҹв•‘Вәu danh sв”ңГӯch chГҹв•—ВҘ nв”ңГЎy.</p>\r\n          <Button onClick={() => navigate('/my-waitlists')} className=\"bg-primary hover:bg-primary/95 text-background font-semibold\">\r\n            <ArrowLeft className=\"h-4 w-4 mr-2\" /> Quay lГҹв•‘Гӯi danh sв”ңГӯch chГҹв•—ВҘ\r\n          </Button>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const total = [...(waitlist.dishes || []), ...(waitlist.services || [])]\r\n    .reduce((sum, item) => sum + Number(item.price || item.priceSnapshot || 0) * Number(item.quantity || 1), 0);\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n\r\n      <main className=\"flex-1 max-w-4xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-10 flex flex-col gap-8\">\r\n        {/* Header with Back button */}\r\n        <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-border pb-6\">\r\n          <div className=\"text-left\">\r\n            <h2 className=\"text-2xl font-extrabold text-white tracking-tight\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\r\n              Chi tiГҹв•‘в”җt yв”ңВ¬u cГҹв•‘Вәu hв”ңГЎng chГҹв•—ВҘ\r\n            </h2>\r\n            <span className=\"text-xs text-muted-foreground mt-1 block\">\r\n              Mв”ңГә yв”ңВ¬u cГҹв•‘Вәu: <strong className=\"font-mono text-white\">#{String(waitlist.id).slice(-6).toUpperCase()}</strong>\r\n            </span>\r\n          </div>\r\n          <Button variant=\"outline\" size=\"sm\" onClick={() => navigate('/my-waitlists')} className=\"border-border hover:bg-secondary text-xs font-semibold self-start sm:self-auto gap-1.5 h-9\">\r\n            <ArrowLeft size={14} /> Hв”ңГЎng chГҹв•—ВҘ cГҹв•—Вәa tв”ңв”Өi\r\n          </Button>\r\n        </div>\r\n\r\n        {/* Detail Card Block */}\r\n        <Card className=\"p-6 bg-card border-border flex flex-col gap-6 text-left\">\r\n          {/* Top header details */}\r\n          <div className=\"flex items-start justify-between gap-4 pb-4 border-b border-border/60\">\r\n            <div>\r\n              <p className=\"text-[10px] text-muted-foreground uppercase font-bold tracking-wider\">Nhв”ңГЎ hв”ңГЎng в”ҖГҰв”ңГә в”ҖГҰв”ҖГўng kв”ңв•ң</p>\r\n              <h1 className=\"text-xl font-extrabold text-white mt-1\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\r\n                {waitlist.restaurant?.name || 'Nhв”ңГЎ hв”ңГЎng'}\r\n              </h1>\r\n            </div>\r\n            <WaitlistStatusBadge status={waitlist.status} />\r\n          </div>\r\n\r\n          {/* Metadata */}\r\n          <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs text-muted-foreground bg-secondary/20 p-4 rounded-xl border border-border/60\">\r\n            <div className=\"flex items-center gap-2 min-w-0\">\r\n              <CalendarDays size={16} className=\"text-primary flex-shrink-0\" />\r\n              <span className=\"truncate\">{formatDate(waitlist.preferredDate)}</span>\r\n            </div>\r\n            <div className=\"flex items-center gap-2 min-w-0\">\r\n              <Clock size={16} className=\"text-primary flex-shrink-0\" />\r\n              <span className=\"font-bold text-white\">{waitlist.preferredTime || '--:--'}</span>\r\n            </div>\r\n            <div className=\"flex items-center gap-2 min-w-0\">\r\n              <Users size={16} className=\"text-primary flex-shrink-0\" />\r\n              <span>{waitlist.numberOfGuests} khв”ңГӯch в”ҖГҰi cв”ңв•Јng</span>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Queue positions stats grid */}\r\n          <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4 text-xs\">\r\n            <div className=\"bg-secondary/40 border border-border p-3.5 rounded-lg flex flex-col gap-1\">\r\n              <span className=\"text-muted-foreground text-[10px] uppercase font-bold\">VГҹв•—ГҜ trв”ңВЎ hв”ңГЎng chГҹв•—ВҘ</span>\r\n              <strong className=\"text-base text-primary font-bold\">{waitlist.queuePositionSnapshot || 'в”ҖГүang tв”ңВЎnh'}</strong>\r\n            </div>\r\n            <div className=\"bg-secondary/40 border border-border p-3.5 rounded-lg flex flex-col gap-1\">\r\n              <span className=\"text-muted-foreground text-[10px] uppercase font-bold\">в•һВ»Гҹв•—Вўc tв”ңВЎnh chГҹв•—ВҘ</span>\r\n              <strong className=\"text-base text-white font-bold\">{waitlist.estimatedWaitMinutes || 0} phв”ңв•‘t</strong>\r\n            </div>\r\n            <div className=\"bg-secondary/40 border border-border p-3.5 rounded-lg flex flex-col gap-1\">\r\n              <span className=\"text-muted-foreground text-[10px] uppercase font-bold\">GiГҹв•—Вўi hГҹв•‘Гӯn thГҹв•—ВҘi gian</span>\r\n              <strong className=\"text-base text-white font-bold\">\r\n                {waitlist.maxWaitUntil ? new Date(waitlist.maxWaitUntil).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) : '--:--'}\r\n              </strong>\r\n            </div>\r\n            <div className=\"bg-secondary/40 border border-border p-3.5 rounded-lg flex flex-col gap-1\">\r\n              <span className=\"text-muted-foreground text-[10px] uppercase font-bold\">TГҹв•‘Гӯm tв”ңВЎnh в”ҖГҰв•һГӯn trв•һв–‘Гҹв•—Вўc</span>\r\n              <strong className=\"text-base text-primary font-bold\">{currency(total)}</strong>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Details columns */}\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 mt-2\">\r\n            {/* Preferred tables */}\r\n            <div className=\"flex flex-col gap-2\">\r\n              <h4 className=\"font-bold text-white text-xs uppercase tracking-wide border-l-2 border-primary pl-2\">Bв”ңГЎn в”ҖГўn в•һв–‘u tiв”ңВ¬n в”ҖГҰв”ңГә chГҹв•—Г¬n</h4>\r\n              {(waitlist.tables || []).length === 0 ? (\r\n                <p className=\"text-xs text-muted-foreground italic mt-1.5\">в”ҖГүГҹв•—Гў nhв”ңГЎ hв”ңГЎng tГҹв•—в–’ в”ҖГҰГҹв•—Г–ng sГҹв•‘В»p xГҹв•‘в”җp bв”ңГЎn trГҹв•—ГҰng thв”ңВЎch hГҹв•—Гәp.</p>\r\n              ) : (\r\n                <ul className=\"text-xs text-muted-foreground space-y-1.5 list-disc pl-4 mt-2\">\r\n                  {waitlist.tables.map((table) => (\r\n                    <li key={table.id}>\r\n                      Bв”ңГЎn <strong className=\"text-white\">{table.tableNumber}</strong> ({table.capacity} chГҹв•—Г№) в”¬в•–{' '}\r\n                      <span className=\"capitalize\">{table.selectionType === 'manual' ? 'tГҹв•—в–’ chГҹв•—Г¬n' : 'в”ҖГҰГҹв•—Гј xuГҹв•‘Г‘t'}</span>\r\n                    </li>\r\n                  ))}\r\n                </ul>\r\n              )}\r\n            </div>\r\n\r\n            {/* Dishes */}\r\n            <div className=\"flex flex-col gap-2\">\r\n              <h4 className=\"font-bold text-white text-xs uppercase tracking-wide border-l-2 border-primary pl-2 flex items-center gap-1.5\">\r\n                <Utensils size={14} className=\"text-primary\" /> Mв”ңв”Ӯn в”ҖГўn в”ҖГҰГҹв•‘в•–t trв•һв–‘Гҹв•—Вўc\r\n              </h4>\r\n              {(waitlist.dishes || []).length === 0 ? (\r\n                <p className=\"text-xs text-muted-foreground italic mt-1.5\">Khв”ңв”Өng в”ҖГҰв”ҖГўng kв”ңв•ң в”ҖГҰГҹв•‘в•–t trв•һв–‘Гҹв•—Вўc mв”ңв”Ӯn в”ҖГўn nв”ңГЎo.</p>\r\n              ) : (\r\n                <ul className=\"text-xs text-muted-foreground space-y-1.5 list-disc pl-4 mt-2\">\r\n                  {waitlist.dishes.map((item) => (\r\n                    <li key={item.id}>\r\n                      <strong className=\"text-white\">{item.name}</strong> x{item.quantity} в”¬в•–{' '}\r\n                      <span className=\"text-primary font-medium\">{currency(item.price)}</span>\r\n                    </li>\r\n                  ))}\r\n                </ul>\r\n              )}\r\n            </div>\r\n\r\n            {/* Services */}\r\n            <div className=\"flex flex-col gap-2\">\r\n              <h4 className=\"font-bold text-white text-xs uppercase tracking-wide border-l-2 border-primary pl-2 flex items-center gap-1.5\">\r\n                <ConciergeBell size={14} className=\"text-primary\" /> DГҹв•—ГҜch vГҹв•—Г‘ phГҹв•—Г‘ trГҹв•—Гә\r\n              </h4>\r\n              {(waitlist.services || []).length === 0 ? (\r\n                <p className=\"text-xs text-muted-foreground italic mt-1.5\">Khв”ңв”Өng в”ҖГҰв”ҖГўng kв”ңв•ң dГҹв•—ГҜch vГҹв•—Г‘ в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t.</p>\r\n              ) : (\r\n                <ul className=\"text-xs text-muted-foreground space-y-1.5 list-disc pl-4 mt-2\">\r\n                  {waitlist.services.map((item) => (\r\n                    <li key={item.id}>\r\n                      <strong className=\"text-white\">{item.name}</strong> x{item.quantity} в”¬в•–{' '}\r\n                      <span className=\"text-primary font-medium\">{currency(item.price)}</span>\r\n                    </li>\r\n                  ))}\r\n                </ul>\r\n              )}\r\n            </div>\r\n\r\n            {/* Notes */}\r\n            <div className=\"flex flex-col gap-2\">\r\n              <h4 className=\"font-bold text-white text-xs uppercase tracking-wide border-l-2 border-primary pl-2\">Ghi chв”ңв•‘ gГҹв•—ВЎi kв”ңВҝm</h4>\r\n              <p className=\"text-xs text-muted-foreground italic mt-1.5 leading-relaxed bg-secondary/20 p-2.5 rounded border border-border/40\">\r\n                {waitlist.note ? `\"${waitlist.note}\"` : 'Khв”ңв”Өng cв”ңв”Ӯ ghi chв”ңв•‘ nв”ңГЎo в”ҖГҰв•һв–‘Гҹв•—Гәc в”ҖГҰГҹв•—Гў lГҹв•‘Гӯi.'}\r\n              </p>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Converted Booking link warning */}\r\n          {waitlist.convertedBookingId && (\r\n            <div className=\"flex items-center justify-between p-4 bg-emerald-500/5 border border-emerald-500/20 rounded-xl mt-4\">\r\n              <div className=\"flex gap-2.5 items-start text-xs text-emerald-400\">\r\n                <Info size={16} className=\"flex-shrink-0 mt-0.5\" />\r\n                <span>\r\n                  в”ҖГүв”ҖГўng kв”ңв•ң hв”ңГЎng chГҹв•—ВҘ в”ҖГҰв”ңГә в”ҖГҰв•һв–‘Гҹв•—Гәc duyГҹв•—Г§t vв”ңГЎ chuyГҹв•—Гўn в”ҖГҰГҹв•—ГІi thв”ңГЎnh в”ҖГҰв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn thв”ңГЎnh cв”ңв”Өng!\r\n                </span>\r\n              </div>\r\n              <Link\r\n                to={`/bookings/${waitlist.convertedBookingId}`}\r\n                className=\"text-xs font-bold text-primary hover:underline flex items-center gap-1 shrink-0\"\r\n              >\r\n                Xem в”ҖГҰв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn <ArrowUpRight size={14} />\r\n              </Link>\r\n            </div>\r\n          )}\r\n\r\n          {/* Cancel waitlist action */}\r\n          {waitlist.status === 'pending' && (\r\n            <div className=\"mt-4 pt-4 border-t border-border/60 flex justify-end\">\r\n              <Button\r\n                variant=\"destructive\"\r\n                onClick={handleCancel}\r\n                className=\"bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white text-xs font-bold uppercase tracking-wider h-10 px-6 cursor-pointer\"\r\n              >\r\n                HГҹв•—Вәy в”ҖГҰв”ҖГўng kв”ңв•ң hв”ңГЎng chГҹв•—ВҘ\r\n              </Button>\r\n            </div>\r\n          )}\r\n        </Card>\r\n      </main>\r\n\r\n      {/* Footer */}\r\n      <footer className=\"border-t border-border bg-[#090B0E] py-8 text-center text-xs text-muted-foreground mt-16\">\r\n        <div className=\"mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4\">\r\n          <span style={{ fontFamily: \"'Playfair Display', serif\" }} className=\"text-sm font-bold text-white tracking-wider\">BookEat</span>\r\n          <span>в”¬вҢҗ 2026 BookEat. MГҹв•—Г¬i quyГҹв•—Гјn в”ҖГҰв•һв–‘Гҹв•—Гәc bГҹв•‘Гәo lв•һв–‘u.</span>\r\n        </div>\r\n      </footer>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\waitlist\\WaitlistFormPage.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  112 |   useEffect(() => {\n  113 |     if (!user) return;\n> 114 |     setForm((current) => ({\n      |     ^^^^^^^ Avoid calling setState() directly within an effect\n  115 |       ...current,\n  116 |       customerName: current.customerName || user.fullName || '',\n  117 |       customerPhone: current.customerPhone || user.phoneNumber || '',","line":114,"column":5,"endLine":114,"endColumn":12}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Fragment, useCallback, useEffect, useMemo, useState } from 'react';\r\nimport { useLocation, useNavigate, useParams } from 'react-router-dom';\r\nimport toast from 'react-hot-toast';\r\nimport {\r\n  ArrowLeft,\r\n  ArrowRight,\r\n  CalendarDays,\r\n  Check,\r\n  Clock,\r\n  ConciergeBell,\r\n  Minus,\r\n  Plus,\r\n  Users,\r\n  Utensils,\r\n  MapPin,\r\n  Info\r\n} from 'lucide-react';\r\nimport { getPublicRestaurantDetail } from '../../api/restaurantApi';\r\nimport { getPublicMenu } from '../../api/menuApi';\r\nimport { getPublicTables } from '../../api/tableApi';\r\nimport { getPublicServices } from '../../api/restaurantServiceApi';\r\nimport { createWaitlist } from '../../api/waitlistApi';\r\nimport { useAuth } from '../../context/useAuth';\r\nimport Header from '../../components/Header';\r\nimport { Button } from '../../components/ui/button';\r\nimport { Card } from '../../components/ui/card';\r\nimport { Input } from '../../components/ui/input';\r\nimport { cn } from '../../components/ui/utils';\r\n\r\nconst currency = (value) =>\r\n  new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(Number(value || 0));\r\n\r\nconst todayString = () => new Date().toISOString().split('T')[0];\r\n\r\nconst maxDateString = () => {\r\n  const value = new Date();\r\n  value.setDate(value.getDate() + 30);\r\n  return value.toISOString().split('T')[0];\r\n};\r\n\r\nexport default function WaitlistFormPage() {\r\n  const { id: restaurantId } = useParams();\r\n  const navigate = useNavigate();\r\n  const location = useLocation();\r\n  const { user } = useAuth();\r\n  const initial = location.state || {};\r\n\r\n  const [loading, setLoading] = useState(true);\r\n  const [submitting, setSubmitting] = useState(false);\r\n  const [step, setStep] = useState(1);\r\n  const [restaurant, setRestaurant] = useState(null);\r\n  const [tables, setTables] = useState([]);\r\n  const [menuItems, setMenuItems] = useState([]);\r\n  const [services, setServices] = useState([]);\r\n  const [createdWaitlist, setCreatedWaitlist] = useState(null);\r\n\r\n  const [form, setForm] = useState({\r\n    preferredDate: initial.bookingDate || '',\r\n    preferredTime: initial.bookingTime || '',\r\n    numberOfGuests: initial.numberOfGuests || 2,\r\n    customerName: initial.customerName || user?.fullName || '',\r\n    customerPhone: initial.customerPhone || user?.phoneNumber || '',\r\n    customerEmail: initial.customerEmail || user?.email || '',\r\n    note: initial.specialRequests || '',\r\n    maxWaitMinutes: 45,\r\n  });\r\n\r\n  const [selectedTableIds, setSelectedTableIds] = useState([]);\r\n  const [dishQty, setDishQty] = useState({});\r\n  const [serviceQty, setServiceQty] = useState({});\r\n  const [errors, setErrors] = useState({});\r\n\r\n  useEffect(() => {\r\n    let ignore = false;\r\n\r\n    const loadData = async () => {\r\n      try {\r\n        setLoading(true);\r\n        const [restaurantRes, tablesRes, menuRes, servicesRes] = await Promise.allSettled([\r\n          getPublicRestaurantDetail(restaurantId),\r\n          getPublicTables(restaurantId, { status: 'available' }),\r\n          getPublicMenu(restaurantId),\r\n          getPublicServices(restaurantId, { availableOnly: 'true' }),\r\n        ]);\r\n\r\n        if (ignore) return;\r\n\r\n        if (restaurantRes.status === 'fulfilled' && restaurantRes.value.success) {\r\n          setRestaurant(restaurantRes.value.data);\r\n        } else {\r\n          toast.error('Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi thв”ңв”Өng tin nhв”ңГЎ hв”ңГЎng');\r\n          navigate('/restaurants');\r\n          return;\r\n        }\r\n\r\n        if (tablesRes.status === 'fulfilled') setTables(tablesRes.value.data?.tables || []);\r\n        if (menuRes.status === 'fulfilled') setMenuItems(menuRes.value.data?.items || []);\r\n        if (servicesRes.status === 'fulfilled') setServices(servicesRes.value.data?.services || []);\r\n      } catch (error) {\r\n        toast.error(error.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi dГҹв•—В» liГҹв•—Г§u danh sв”ңГӯch chГҹв•—ВҘ');\r\n      } finally {\r\n        if (!ignore) setLoading(false);\r\n      }\r\n    };\r\n\r\n    loadData();\r\n    return () => {\r\n      ignore = true;\r\n    };\r\n  }, [navigate, restaurantId]);\r\n\r\n  useEffect(() => {\r\n    if (!user) return;\r\n    setForm((current) => ({\r\n      ...current,\r\n      customerName: current.customerName || user.fullName || '',\r\n      customerPhone: current.customerPhone || user.phoneNumber || '',\r\n      customerEmail: current.customerEmail || user.email || '',\r\n    }));\r\n  }, [user]);\r\n\r\n  const updateForm = (key, value) => {\r\n    setForm((current) => ({ ...current, [key]: value }));\r\n    setErrors((current) => ({ ...current, [key]: null }));\r\n  };\r\n\r\n  const selectedDishes = useMemo(() => (\r\n    Object.entries(dishQty)\r\n      .filter(([, quantity]) => quantity > 0)\r\n      .map(([id, quantity]) => {\r\n        const item = menuItems.find((menuItem) => menuItem.id === id);\r\n        return item ? { ...item, quantity } : null;\r\n      })\r\n      .filter(Boolean)\r\n  ), [dishQty, menuItems]);\r\n\r\n  const selectedServices = useMemo(() => (\r\n    Object.entries(serviceQty)\r\n      .filter(([, quantity]) => quantity > 0)\r\n      .map(([id, quantity]) => {\r\n        const item = services.find((service) => service.id === id);\r\n        return item ? { ...item, quantity } : null;\r\n      })\r\n      .filter(Boolean)\r\n  ), [serviceQty, services]);\r\n\r\n  const selectedTables = useMemo(() => (\r\n    tables.filter((table) => selectedTableIds.includes(table.id))\r\n  ), [selectedTableIds, tables]);\r\n\r\n  const estimatedTotal = useMemo(() => {\r\n    const dishesTotal = selectedDishes.reduce((sum, item) => sum + item.price * item.quantity, 0);\r\n    const servicesTotal = selectedServices.reduce((sum, item) => sum + item.price * item.quantity, 0);\r\n    return dishesTotal + servicesTotal;\r\n  }, [selectedDishes, selectedServices]);\r\n\r\n  const validateStep = useCallback((targetStep = step) => {\r\n    const nextErrors = {};\r\n\r\n    if (targetStep === 1) {\r\n      if (!form.preferredDate) nextErrors.preferredDate = 'Vui lв”ңв–“ng chГҹв•—Г¬n ngв”ңГЎy';\r\n      if (!form.preferredTime) nextErrors.preferredTime = 'Vui lв”ңв–“ng chГҹв•—Г¬n giГҹв•—ВҘ';\r\n      if (!form.numberOfGuests || Number(form.numberOfGuests) < 1) nextErrors.numberOfGuests = 'SГҹв•—ГҰ khв”ңГӯch phГҹв•‘Гәi lГҹв•—Вўn hв•һГӯn 0';\r\n      if (!form.customerName.trim()) nextErrors.customerName = 'Vui lв”ңв–“ng nhГҹв•‘ВЎp hГҹв•—Г¬ tв”ңВ¬n';\r\n      if (!/^(0[35789][0-9]{8}|02[0-9]{9})$/.test(form.customerPhone.trim())) nextErrors.customerPhone = 'SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi khв”ңв”Өng hГҹв•—Гәp lГҹв•—Г§';\r\n      if (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(form.customerEmail.trim())) nextErrors.customerEmail = 'Email khв”ңв”Өng hГҹв•—Гәp lГҹв•—Г§';\r\n    }\r\n\r\n    setErrors(nextErrors);\r\n    return Object.keys(nextErrors).length === 0;\r\n  }, [form, step]);\r\n\r\n  const nextStep = () => {\r\n    if (!validateStep(step)) return;\r\n    setStep((current) => Math.min(4, current + 1));\r\n  };\r\n\r\n  const changeQuantity = (setter, id, delta) => {\r\n    setter((current) => {\r\n      const nextValue = Math.max(0, Math.min(20, Number(current[id] || 0) + delta));\r\n      const next = { ...current };\r\n      if (nextValue === 0) delete next[id];\r\n      else next[id] = nextValue;\r\n      return next;\r\n    });\r\n  };\r\n\r\n  const toggleTable = (tableId) => {\r\n    setSelectedTableIds((current) => (\r\n      current.includes(tableId)\r\n        ? current.filter((id) => id !== tableId)\r\n        : [...current, tableId]\r\n    ));\r\n  };\r\n\r\n  const submitWaitlist = async () => {\r\n    if (!validateStep(1)) {\r\n      setStep(1);\r\n      return;\r\n    }\r\n\r\n    setSubmitting(true);\r\n    try {\r\n      const payload = {\r\n        restaurantId,\r\n        preferredDate: form.preferredDate,\r\n        preferredTime: form.preferredTime,\r\n        numberOfGuests: Number(form.numberOfGuests),\r\n        customerName: form.customerName.trim(),\r\n        customerPhone: form.customerPhone.trim(),\r\n        customerEmail: form.customerEmail.trim(),\r\n        note: form.note || null,\r\n        maxWaitMinutes: Number(form.maxWaitMinutes || 45),\r\n        tables: selectedTableIds.map((tableId) => ({ tableId })),\r\n        dishes: selectedDishes.map((item) => ({ menuItemId: item.id, quantity: item.quantity })),\r\n        services: selectedServices.map((item) => ({ serviceId: item.id, quantity: item.quantity })),\r\n      };\r\n\r\n      const res = await createWaitlist(payload);\r\n      if (res.success) {\r\n        setCreatedWaitlist(res.data.waitlist);\r\n        toast.success('в”ҖГүв”ңГә gГҹв•—ВЎi yв”ңВ¬u cГҹв•‘Вәu danh sв”ңГӯch chГҹв•—ВҘ');\r\n      } else {\r\n        toast.error(res.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гӯo danh sв”ңГӯch chГҹв•—ВҘ');\r\n      }\r\n    } catch (error) {\r\n      toast.error(error.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гӯo danh sв”ңГӯch chГҹв•—ВҘ');\r\n    } finally {\r\n      setSubmitting(false);\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n        <Header />\r\n        <div className=\"flex-1 flex flex-col items-center justify-center gap-3\">\r\n          <div className=\"h-10 w-10 border-4 border-primary border-t-transparent rounded-full animate-spin\" />\r\n          <p className=\"text-sm text-muted-foreground animate-pulse\">в”ҖГүang tГҹв•‘Гәi biГҹв•—Гўu mГҹв•‘ВҪu danh sв”ңГӯch chГҹв•—ВҘ...</p>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (createdWaitlist) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n        <Header />\r\n        <div className=\"flex-1 flex items-center justify-center p-4\">\r\n          <Card className=\"max-w-md w-full p-8 border-border bg-card flex flex-col items-center text-center shadow-2xl\">\r\n            <div className=\"h-16 w-16 rounded-full bg-emerald-500/15 text-emerald-400 flex items-center justify-center mb-6\">\r\n              <Check size={36} />\r\n            </div>\r\n            <h1 className=\"text-2xl font-extrabold text-white tracking-tight\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\r\n              в”ҖГүв”ңГә tham gia hв”ңГЎng chГҹв•—ВҘ\r\n            </h1>\r\n            <p className=\"text-xs text-muted-foreground mt-2 leading-relaxed\">\r\n              Nhв”ңГЎ hв”ңГЎng sГҹв•‘в•ң gГҹв•—ВЎi thв”ңв”Өng bв”ңГӯo в”ҖГҰГҹв•‘в”җn bГҹв•‘Гӯn ngay khi cв”ңв”Ӯ bв”ңГЎn trГҹв•—ГҰng phв”ңв•Ј hГҹв•—Гәp vГҹв•—Вўi cв”ңГӯc tiв”ңВ¬u chв”ңВЎ lГҹв•—в–’a chГҹв•—Г¬n.\r\n            </p>\r\n            \r\n            <div className=\"w-full bg-secondary/35 border border-border/80 rounded-xl p-5 my-6 flex flex-col gap-3.5 text-xs text-left\">\r\n              <div className=\"flex justify-between border-b border-border/40 pb-2.5\">\r\n                <span className=\"text-muted-foreground\">Nhв”ңГЎ hв”ңГЎng:</span>\r\n                <span className=\"font-bold text-white truncate max-w-[65%]\">{restaurant?.name}</span>\r\n              </div>\r\n              <div className=\"flex justify-between border-b border-border/40 pb-2.5\">\r\n                <span className=\"text-muted-foreground\">ThГҹв•—ВҘi gian mong muГҹв•—ГҰn:</span>\r\n                <span className=\"font-semibold text-white\">\r\n                  {form.preferredTime} - {new Date(form.preferredDate).toLocaleDateString('vi-VN')}\r\n                </span>\r\n              </div>\r\n              <div className=\"flex justify-between border-b border-border/40 pb-2.5\">\r\n                <span className=\"text-muted-foreground\">SГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng khв”ңГӯch:</span>\r\n                <span className=\"font-semibold text-white\">{form.numberOfGuests} ngв•һв–‘Гҹв•—ВҘi</span>\r\n              </div>\r\n              <div className=\"flex justify-between items-center pt-1\">\r\n                <span className=\"text-muted-foreground\">VГҹв•—ГҜ trв”ңВЎ hв”ңГЎng chГҹв•—ВҘ hiГҹв•—Г§n tГҹв•‘Гӯi:</span>\r\n                <span className=\"px-2.5 py-1 text-xs font-bold bg-primary/25 text-primary border border-primary/20 rounded-full\">\r\n                  SГҹв•—ГҰ {createdWaitlist.queuePositionSnapshot || 'в”ҖГүang tв”ңВЎnh'}\r\n                </span>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"grid grid-cols-2 gap-3 w-full\">\r\n              <Button variant=\"outline\" onClick={() => navigate('/my-waitlists')} className=\"border-border text-white hover:bg-secondary text-xs font-semibold h-10\">\r\n                Hв”ңГЎng chГҹв•—ВҘ cГҹв•—Вәa tв”ңв”Өi\r\n              </Button>\r\n              <Button onClick={() => navigate(`/waitlists/${createdWaitlist.id}`)} className=\"bg-primary hover:bg-primary/95 text-background text-xs font-bold h-10\">\r\n                Chi tiГҹв•‘в”җt hв”ңГЎng chГҹв•—ВҘ\r\n              </Button>\r\n            </div>\r\n          </Card>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const steps = [\r\n    { num: 1, label: 'Thв”ңв”Өng tin' },\r\n    { num: 2, label: 'Bв”ңГЎn в•һв–‘u tiв”ңВ¬n' },\r\n    { num: 3, label: 'Mв”ңв”Ӯn & dГҹв•—ГҜch vГҹв•—Г‘' },\r\n    { num: 4, label: 'Xв”ңГӯc nhГҹв•‘ВЎn' }\r\n  ];\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n      \r\n      <main className=\"flex-1 max-w-4xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-10 flex flex-col gap-8\">\r\n        {/* Header Title with Back button */}\r\n        <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-border pb-6\">\r\n          <div className=\"text-left\">\r\n            <h2 className=\"text-2xl font-extrabold text-white tracking-tight\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\r\n              в”ҖГүв”ҖГўng kв”ңв•ң danh sв”ңГӯch chГҹв•—ВҘ\r\n            </h2>\r\n            <p className=\"text-xs text-muted-foreground mt-1 flex items-center gap-1\">\r\n              <MapPin size={13} className=\"text-primary flex-shrink-0\" />\r\n              <span className=\"truncate\">{restaurant?.address?.fullAddress || restaurant?.address?.street || 'BookEat restaurant'}</span>\r\n            </p>\r\n          </div>\r\n          <Button variant=\"outline\" size=\"sm\" onClick={() => navigate(-1)} className=\"border-border hover:bg-secondary text-xs font-semibold self-start sm:self-auto gap-1\">\r\n            <ArrowLeft size={14} /> Quay lГҹв•‘Гӯi\r\n          </Button>\r\n        </div>\r\n\r\n        {/* Steps navigation bar */}\r\n        <div className=\"flex justify-between items-center w-full px-2 sm:px-8 py-4 bg-secondary/25 border border-border rounded-xl\">\r\n          {steps.map((s, idx) => (\r\n            <Fragment key={s.num}>\r\n              {idx > 0 && <div className={`flex-1 h-0.5 mx-2 sm:mx-4 ${step >= s.num ? 'bg-primary' : 'bg-border/60'}`} />}\r\n              <button\r\n                type=\"button\"\r\n                onClick={() => {\r\n                  if (s.num === 1 || validateStep(1)) setStep(s.num);\r\n                }}\r\n                className=\"flex flex-col sm:flex-row items-center gap-1.5 sm:gap-2 focus:outline-none cursor-pointer\"\r\n              >\r\n                <div className={`h-7 w-7 rounded-full flex items-center justify-center text-xs font-bold transition-all ${\r\n                  step >= s.num ? 'bg-primary text-background' : 'bg-secondary border border-border text-muted-foreground'\r\n                }`}>\r\n                  {s.num}\r\n                </div>\r\n                <span className={`text-[10px] sm:text-xs font-medium tracking-wide transition-colors ${\r\n                  step >= s.num ? 'text-white' : 'text-muted-foreground'\r\n                }`}>\r\n                  {s.label}\r\n                </span>\r\n              </button>\r\n            </Fragment>\r\n          ))}\r\n        </div>\r\n\r\n        {/* Dynamic content cards */}\r\n        <div className=\"w-full\">\r\n          {step === 1 && (\r\n            <Card className=\"p-6 bg-card border-border flex flex-col gap-6\">\r\n              <div className=\"border-b border-border/60 pb-3\">\r\n                <h3 className=\"font-bold text-white text-sm\">\r\n                  вүЎЖ’ГҙВҘ Bв•һв–‘Гҹв•—Вўc 1: Thв”ңв”Өng tin liв”ңВ¬n hГҹв•—Г§ vв”ңГЎ lГҹв•—ГҜch mong muГҹв•—ГҰn\r\n                </h3>\r\n              </div>\r\n\r\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-5 text-left text-xs\">\r\n                {/* Date select */}\r\n                <div className=\"flex flex-col gap-1.5\">\r\n                  <label className=\"text-muted-foreground font-semibold flex items-center gap-1.5\">\r\n                    <CalendarDays size={14} className=\"text-primary\" /> Ngв”ңГЎy mong muГҹв•—ГҰn *\r\n                  </label>\r\n                  <input\r\n                    type=\"date\"\r\n                    min={todayString()}\r\n                    max={maxDateString()}\r\n                    value={form.preferredDate}\r\n                    onChange={(event) => updateForm('preferredDate', event.target.value)}\r\n                    className={cn(\r\n                      \"w-full bg-secondary/40 border border-border rounded-lg px-3.5 py-2 text-xs text-white focus:outline-none focus:ring-1 focus:ring-primary cursor-pointer\",\r\n                      errors.preferredDate && \"border-rose-500/50\"\r\n                    )}\r\n                  />\r\n                  {errors.preferredDate && <span className=\"text-[10px] text-rose-400 font-semibold\">{errors.preferredDate}</span>}\r\n                </div>\r\n\r\n                {/* Time select */}\r\n                <div className=\"flex flex-col gap-1.5\">\r\n                  <label className=\"text-muted-foreground font-semibold flex items-center gap-1.5\">\r\n                    <Clock size={14} className=\"text-primary\" /> GiГҹв•—ВҘ mong muГҹв•—ГҰn *\r\n                  </label>\r\n                  <input\r\n                    type=\"time\"\r\n                    value={form.preferredTime}\r\n                    onChange={(event) => updateForm('preferredTime', event.target.value)}\r\n                    className={cn(\r\n                      \"w-full bg-secondary/40 border border-border rounded-lg px-3.5 py-2 text-xs text-white focus:outline-none focus:ring-1 focus:ring-primary cursor-pointer\",\r\n                      errors.preferredTime && \"border-rose-500/50\"\r\n                    )}\r\n                  />\r\n                  {errors.preferredTime && <span className=\"text-[10px] text-rose-400 font-semibold\">{errors.preferredTime}</span>}\r\n                </div>\r\n\r\n                {/* Number of guests */}\r\n                <div className=\"flex flex-col gap-1.5\">\r\n                  <label className=\"text-muted-foreground font-semibold flex items-center gap-1.5\">\r\n                    <Users size={14} className=\"text-primary\" /> SГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng khв”ңГӯch в”ҖГҰi cв”ңв•Јng *\r\n                  </label>\r\n                  <div className=\"flex items-center gap-1 bg-secondary/40 border border-border rounded-lg p-1 w-fit\">\r\n                    <button\r\n                      type=\"button\"\r\n                      onClick={() => updateForm('numberOfGuests', Math.max(1, Number(form.numberOfGuests) - 1))}\r\n                      disabled={Number(form.numberOfGuests) <= 1}\r\n                      className=\"h-8 w-8 rounded text-sm text-muted-foreground hover:text-white hover:bg-[#20242D] transition disabled:opacity-30 disabled:pointer-events-none cursor-pointer\"\r\n                    >\r\n                      -\r\n                    </button>\r\n                    <span className=\"px-4 text-xs font-bold text-white min-w-[70px] text-center\">{form.numberOfGuests} khв”ңГӯch</span>\r\n                    <button\r\n                      type=\"button\"\r\n                      onClick={() => updateForm('numberOfGuests', Math.min(100, Number(form.numberOfGuests) + 1))}\r\n                      disabled={Number(form.numberOfGuests) >= 100}\r\n                      className=\"h-8 w-8 rounded text-sm text-muted-foreground hover:text-white hover:bg-[#20242D] transition disabled:opacity-30 disabled:pointer-events-none cursor-pointer\"\r\n                    >\r\n                      +\r\n                    </button>\r\n                  </div>\r\n                  {errors.numberOfGuests && <span className=\"text-[10px] text-rose-400 font-semibold\">{errors.numberOfGuests}</span>}\r\n                </div>\r\n\r\n                {/* Max wait time */}\r\n                <div className=\"flex flex-col gap-1.5\">\r\n                  <label className=\"text-muted-foreground font-semibold\">ThГҹв•—ВҘi gian chГҹв•—ВҘ tГҹв•—ГҰi в”ҖГҰa (phв”ңв•‘t)</label>\r\n                  <select\r\n                    value={form.maxWaitMinutes}\r\n                    onChange={(event) => updateForm('maxWaitMinutes', event.target.value)}\r\n                    className=\"w-full bg-secondary/40 border border-border rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:ring-1 focus:ring-primary cursor-pointer\"\r\n                  >\r\n                    <option value=\"30\" className=\"bg-card\">30 phв”ңв•‘t</option>\r\n                    <option value=\"45\" className=\"bg-card\">45 phв”ңв•‘t</option>\r\n                    <option value=\"60\" className=\"bg-card\">60 phв”ңв•‘t</option>\r\n                    <option value=\"90\" className=\"bg-card\">90 phв”ңв•‘t</option>\r\n                    <option value=\"120\" className=\"bg-card\">120 phв”ңв•‘t</option>\r\n                  </select>\r\n                </div>\r\n\r\n                {/* Customer name */}\r\n                <div className=\"flex flex-col gap-1.5\">\r\n                  <label className=\"text-muted-foreground font-semibold\">HГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n *</label>\r\n                  <Input\r\n                    type=\"text\"\r\n                    value={form.customerName}\r\n                    onChange={(event) => updateForm('customerName', event.target.value)}\r\n                    placeholder=\"NhГҹв•‘ВЎp hГҹв•—Г¬ tв”ңВ¬n в”ҖГҰГҹв•‘Вәy в”ҖГҰГҹв•—Вә\"\r\n                    className={cn(\"bg-secondary/40 border-border text-xs focus-visible:ring-1 focus-visible:ring-primary h-10\", errors.customerName && \"border-rose-500/50\")}\r\n                  />\r\n                  {errors.customerName && <span className=\"text-[10px] text-rose-400 font-semibold\">{errors.customerName}</span>}\r\n                </div>\r\n\r\n                {/* Customer phone */}\r\n                <div className=\"flex flex-col gap-1.5\">\r\n                  <label className=\"text-muted-foreground font-semibold\">SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi *</label>\r\n                  <Input\r\n                    type=\"tel\"\r\n                    value={form.customerPhone}\r\n                    onChange={(event) => updateForm('customerPhone', event.target.value)}\r\n                    placeholder=\"NhГҹв•‘ВЎp sГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi\"\r\n                    className={cn(\"bg-secondary/40 border-border text-xs focus-visible:ring-1 focus-visible:ring-primary h-10\", errors.customerPhone && \"border-rose-500/50\")}\r\n                  />\r\n                  {errors.customerPhone && <span className=\"text-[10px] text-rose-400 font-semibold\">{errors.customerPhone}</span>}\r\n                </div>\r\n\r\n                {/* Customer email */}\r\n                <div className=\"flex flex-col gap-1.5 sm:col-span-2\">\r\n                  <label className=\"text-muted-foreground font-semibold\">Email nhГҹв•‘ВЎn thв”ңв”Өng bв”ңГӯo *</label>\r\n                  <Input\r\n                    type=\"email\"\r\n                    value={form.customerEmail}\r\n                    onChange={(event) => updateForm('customerEmail', event.target.value)}\r\n                    placeholder=\"NhГҹв•‘ВЎp в”ҖГҰГҹв•—ГҜa chГҹв•—Г« email\"\r\n                    className={cn(\"bg-secondary/40 border-border text-xs focus-visible:ring-1 focus-visible:ring-primary h-10\", errors.customerEmail && \"border-rose-500/50\")}\r\n                  />\r\n                  {errors.customerEmail && <span className=\"text-[10px] text-rose-400 font-semibold\">{errors.customerEmail}</span>}\r\n                </div>\r\n\r\n                {/* Ghi chв”ңв•‘ */}\r\n                <div className=\"flex flex-col gap-1.5 sm:col-span-2\">\r\n                  <label className=\"text-muted-foreground font-semibold\">Ghi chв”ңв•‘ cho nhв”ңГЎ hв”ңГЎng</label>\r\n                  <textarea\r\n                    rows=\"3\"\r\n                    maxLength=\"500\"\r\n                    value={form.note}\r\n                    onChange={(event) => updateForm('note', event.target.value)}\r\n                    placeholder=\"Cв”ңГӯc yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t nhв•һв–‘ vГҹв•—ГҜ trв”ңВЎ mong muГҹв•—ГҰn, dГҹв•—ГҜ Гҹв•—вҢҗng mв”ңв”Ӯn в”ҖГўn, ghГҹв•‘в”җ em bв”ңвҢҗ hoГҹв•‘в•–c lв”ңв•ң do cГҹв•‘Вәn bв”ңГЎn sГҹв•—Вўm...\"\r\n                    className=\"w-full bg-secondary/40 border border-border rounded-lg p-3 text-xs text-white focus:outline-none focus:ring-1 focus:ring-primary leading-relaxed\"\r\n                  />\r\n                </div>\r\n              </div>\r\n            </Card>\r\n          )}\r\n\r\n          {step === 2 && (\r\n            <Card className=\"p-6 bg-card border-border flex flex-col gap-6\">\r\n              <div className=\"border-b border-border/60 pb-3\">\r\n                <h3 className=\"font-bold text-white text-sm\">\r\n                  вүЎЖ’В¬ГҰ Bв•һв–‘Гҹв•—Вўc 2: ChГҹв•—Г¬n vГҹв•—ГҜ trв”ңВЎ bв”ңГЎn в•һв–‘u tiв”ңВ¬n (Tв”ңв•Јy chГҹв•—Г¬n)\r\n                </h3>\r\n              </div>\r\n              \r\n              <div className=\"flex flex-col gap-5 text-left text-xs leading-relaxed\">\r\n                <p className=\"text-muted-foreground\">\r\n                  BГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў tв”ңв•Јy в”ңв•ң chГҹв•—Г¬n vГҹв•—ГҜ trв”ңВЎ bв”ңГЎn mong muГҹв•—ГҰn dв•һв–‘Гҹв•—Вўi в”ҖГҰв”ңГіy. QuГҹв•‘Гәn lв”ңв•ң nhв”ңГЎ hв”ңГЎng sГҹв•‘в•ң sГҹв•‘В»p xГҹв•‘в”җp dГҹв•—в–’a trв”ңВ¬n mГҹв•—вҢҗc в”ҖГҰГҹв•—Г– в•һв–‘u tiв”ңВ¬n nв”ңГЎy khi cв”ңв”Ӯ bв”ңГЎn trГҹв•—ГҰng.\r\n                </p>\r\n                \r\n                {tables.length === 0 ? (\r\n                  <div className=\"text-center py-12 border border-dashed border-border rounded-xl\">\r\n                    <p className=\"text-muted-foreground\">Nhв”ңГЎ hв”ңГЎng chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt sв•һГӯ в”ҖГҰГҹв•—Гҙ bв”ңГЎn trГҹв•—ГҰng trГҹв•—в–’c tuyГҹв•‘в”җn.</p>\r\n                  </div>\r\n                ) : (\r\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4\">\r\n                    {tables.map((table) => {\r\n                      const isSelected = selectedTableIds.includes(table.id);\r\n                      return (\r\n                        <button\r\n                          type=\"button\"\r\n                          key={table.id}\r\n                          onClick={() => toggleTable(table.id)}\r\n                          className={cn(\r\n                            \"relative text-left p-4 rounded-xl border transition-all select-none hover:border-primary/50 cursor-pointer\",\r\n                            isSelected\r\n                              ? \"border-primary bg-primary/5 ring-1 ring-primary\"\r\n                              : \"border-border bg-secondary/20\"\r\n                          )}\r\n                          aria-pressed={isSelected}\r\n                        >\r\n                          <div className=\"flex items-center justify-between\">\r\n                            <h4 className=\"text-sm font-bold text-white\">Bв”ңГЎn {table.tableNumber}</h4>\r\n                            <span className=\"text-[10px] text-muted-foreground font-semibold bg-secondary px-2 py-0.5 rounded\">\r\n                              {table.zone || 'Khu chung'}\r\n                            </span>\r\n                          </div>\r\n                          <div className=\"mt-3 flex flex-col gap-1 text-[11px] text-muted-foreground\">\r\n                            <div>SГҹв•—вҢҗc chГҹв•—вҢҗa: <strong className=\"text-white\">{table.capacity} chГҹв•—Г№</strong></div>\r\n                            {table.depositAmount > 0 && (\r\n                              <div className=\"text-primary font-bold\">в”ҖГүГҹв•‘в•–t cГҹв•—Г¬c: {currency(table.depositAmount)}</div>\r\n                            )}\r\n                          </div>\r\n                        </button>\r\n                      );\r\n                    })}\r\n                  </div>\r\n                )}\r\n              </div>\r\n            </Card>\r\n          )}\r\n\r\n          {step === 3 && (\r\n            <Card className=\"p-6 bg-card border-border flex flex-col gap-6\">\r\n              <div className=\"border-b border-border/60 pb-3\">\r\n                <h3 className=\"font-bold text-white text-sm\">\r\n                  вүЎЖ’Г¬в•ңвҲ©в••Г… Bв•һв–‘Гҹв•—Вўc 3: в”ҖГүГҹв•‘в•–t trв•һв–‘Гҹв•—Вўc mв”ңв”Ӯn в”ҖГўn & DГҹв•—ГҜch vГҹв•—Г‘ tiГҹв•—Г§n в”ңВЎch (Tв”ңв•Јy chГҹв•—Г¬n)\r\n                </h3>\r\n              </div>\r\n\r\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 text-left text-xs\">\r\n                {/* Mв”ңв”Ӯn в”ҖГўn */}\r\n                <div className=\"flex flex-col gap-4\">\r\n                  <h4 className=\"font-bold text-white flex items-center gap-1.5 pb-2 border-b border-border/60\">\r\n                    <Utensils size={15} className=\"text-primary\" /> Mв”ңв”Ӯn в”ҖГўn в”ҖГҰГҹв•‘в•–c trв•һв–‘ng\r\n                  </h4>\r\n                  <div className=\"flex flex-col gap-3 max-h-[300px] overflow-y-auto pr-1\">\r\n                    {menuItems.length === 0 ? (\r\n                      <div className=\"text-center py-8 text-muted-foreground italic\">Khв”ңв”Өng cв”ңв”Ӯ danh sв”ңГӯch mв”ңв”Ӯn в”ҖГўn khГҹв•‘Гә dГҹв•—Г‘ng.</div>\r\n                    ) : (\r\n                      menuItems.map((item) => (\r\n                        <div key={item.id} className=\"flex justify-between items-center p-3 rounded-lg border border-border bg-secondary/15 hover:border-primary/10 transition\">\r\n                          <div>\r\n                            <strong className=\"block text-white font-medium\">{item.name}</strong>\r\n                            <span className=\"text-[11px] text-primary font-semibold mt-0.5 block\">{currency(item.price)}</span>\r\n                          </div>\r\n                          <div className=\"flex items-center gap-1 bg-secondary/40 border border-border rounded p-0.5\">\r\n                            <button\r\n                              type=\"button\"\r\n                              onClick={() => changeQuantity(setDishQty, item.id, -1)}\r\n                              className=\"h-6 w-6 rounded flex items-center justify-center hover:bg-[#20242D] text-muted-foreground hover:text-white transition cursor-pointer\"\r\n                              aria-label={`GiГҹв•‘Гәm sГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng ${item.name}`}\r\n                            >\r\n                              <Minus size={12} />\r\n                            </button>\r\n                            <span className=\"w-8 text-center text-xs font-bold text-white\">{dishQty[item.id] || 0}</span>\r\n                            <button\r\n                              type=\"button\"\r\n                              onClick={() => changeQuantity(setDishQty, item.id, 1)}\r\n                              className=\"h-6 w-6 rounded flex items-center justify-center hover:bg-[#20242D] text-muted-foreground hover:text-white transition cursor-pointer\"\r\n                              aria-label={`Tв”ҖГўng sГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng ${item.name}`}\r\n                            >\r\n                              <Plus size={12} />\r\n                            </button>\r\n                          </div>\r\n                        </div>\r\n                      ))\r\n                    )}\r\n                  </div>\r\n                </div>\r\n\r\n                {/* DГҹв•—ГҜch vГҹв•—Г‘ */}\r\n                <div className=\"flex flex-col gap-4\">\r\n                  <h4 className=\"font-bold text-white flex items-center gap-1.5 pb-2 border-b border-border/60\">\r\n                    <ConciergeBell size={15} className=\"text-primary\" /> DГҹв•—ГҜch vГҹв•—Г‘ в”ҖГҰi kв”ңВҝm\r\n                  </h4>\r\n                  <div className=\"flex flex-col gap-3 max-h-[300px] overflow-y-auto pr-1\">\r\n                    {services.length === 0 ? (\r\n                      <div className=\"text-center py-8 text-muted-foreground italic\">Khв”ңв”Өng cв”ңв”Ӯ dГҹв•—ГҜch vГҹв•—Г‘ в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t khГҹв•‘Гә dГҹв•—Г‘ng.</div>\r\n                    ) : (\r\n                      services.map((item) => (\r\n                        <div key={item.id} className=\"flex justify-between items-center p-3 rounded-lg border border-border bg-secondary/15 hover:border-primary/10 transition\">\r\n                          <div>\r\n                            <strong className=\"block text-white font-medium\">{item.name}</strong>\r\n                            <span className=\"text-[11px] text-primary font-semibold mt-0.5 block\">{currency(item.price)}</span>\r\n                          </div>\r\n                          <div className=\"flex items-center gap-1 bg-secondary/40 border border-border rounded p-0.5\">\r\n                            <button\r\n                              type=\"button\"\r\n                              onClick={() => changeQuantity(setServiceQty, item.id, -1)}\r\n                              className=\"h-6 w-6 rounded flex items-center justify-center hover:bg-[#20242D] text-muted-foreground hover:text-white transition cursor-pointer\"\r\n                              aria-label={`GiГҹв•‘Гәm sГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng ${item.name}`}\r\n                            >\r\n                              <Minus size={12} />\r\n                            </button>\r\n                            <span className=\"w-8 text-center text-xs font-bold text-white\">{serviceQty[item.id] || 0}</span>\r\n                            <button\r\n                              type=\"button\"\r\n                              onClick={() => changeQuantity(setServiceQty, item.id, 1)}\r\n                              className=\"h-6 w-6 rounded flex items-center justify-center hover:bg-[#20242D] text-muted-foreground hover:text-white transition cursor-pointer\"\r\n                              aria-label={`Tв”ҖГўng sГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng ${item.name}`}\r\n                            >\r\n                              <Plus size={12} />\r\n                            </button>\r\n                          </div>\r\n                        </div>\r\n                      ))\r\n                    )}\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </Card>\r\n          )}\r\n\r\n          {step === 4 && (\r\n            <Card className=\"p-6 bg-card border-border flex flex-col gap-6\">\r\n              <div className=\"border-b border-border/60 pb-3\">\r\n                <h3 className=\"font-bold text-white text-sm\">\r\n                  вүЎЖ’ГҙГҜ Bв•һв–‘Гҹв•—Вўc 4: KiГҹв•—Гўm tra thв”ңв”Өng tin tв”ңв”Ӯm tГҹв•‘В»t & Xв”ңГӯc nhГҹв•‘ВЎn hв”ңГЎng chГҹв•—ВҘ\r\n                </h3>\r\n              </div>\r\n\r\n              <div className=\"flex flex-col gap-5 text-left text-xs\">\r\n                {/* Summary Details */}\r\n                <div className=\"bg-secondary/35 border border-border p-5 rounded-xl flex flex-col gap-3.5\">\r\n                  <div className=\"flex justify-between pb-2 border-b border-border/40\">\r\n                    <span className=\"text-muted-foreground\">Nhв”ңГЎ hв”ңГЎng:</span>\r\n                    <span className=\"font-bold text-white\">{restaurant?.name}</span>\r\n                  </div>\r\n                  <div className=\"flex justify-between pb-2 border-b border-border/40\">\r\n                    <span className=\"text-muted-foreground\">ThГҹв•—ВҘi gian:</span>\r\n                    <span className=\"font-semibold text-white\">{form.preferredTime} - {new Date(form.preferredDate).toLocaleDateString('vi-VN')}</span>\r\n                  </div>\r\n                  <div className=\"flex justify-between pb-2 border-b border-border/40\">\r\n                    <span className=\"text-muted-foreground\">SГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng khв”ңГӯch:</span>\r\n                    <span className=\"font-semibold text-white\">{form.numberOfGuests} ngв•һв–‘Гҹв•—ВҘi</span>\r\n                  </div>\r\n                  <div className=\"flex justify-between pb-2 border-b border-border/40\">\r\n                    <span className=\"text-muted-foreground\">Bв”ңГЎn в•һв–‘u tiв”ңВ¬n:</span>\r\n                    <span className=\"font-bold text-primary\">\r\n                      {selectedTables.length ? selectedTables.map((table) => table.tableNumber).join(', ') : 'TГҹв•—в–’ в”ҖГҰГҹв•—Г–ng xГҹв•‘в”җp bв”ңГЎn trГҹв•—ГҰng'}\r\n                    </span>\r\n                  </div>\r\n                  <div className=\"flex justify-between pb-2 border-b border-border/40\">\r\n                    <span className=\"text-muted-foreground\">Mв”ңв”Ӯn в”ҖГўn в”ҖГҰв”ңГә chГҹв•—Г¬n trв•һв–‘Гҹв•—Вўc:</span>\r\n                    <span className=\"font-semibold text-white\">{selectedDishes.length} mв”ңв”Ӯn</span>\r\n                  </div>\r\n                  <div className=\"flex justify-between pb-2 border-b border-border/40\">