hat can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  262 |   useEffect(() => {\n  263 |     if (bookingTime && timeSlots.length > 0 && !timeSlots.includes(bookingTime)) {\n> 264 |       setBookingTime('');\n      |       ^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  265 |     }\n  266 |   }, [bookingTime, timeSlots]);\n  267 |","line":264,"column":7,"endLine":264,"endColumn":21}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Fragment, useCallback, useEffect, useMemo, useState } from 'react';\r\nimport { useNavigate, useParams } from 'react-router-dom';\r\nimport {\r\n  AlertTriangle,\r\n  ArrowLeft,\r\n  ArrowRight,\r\n  Armchair,\r\n  Calendar as CalendarIcon,\r\n  Check,\r\n  CheckCircle2,\r\n  Clock,\r\n  Info,\r\n  Loader2,\r\n  MapPin,\r\n  Minus,\r\n  Plus,\r\n  Search,\r\n  ShieldCheck,\r\n  Store,\r\n  Ticket,\r\n  Users,\r\n} from 'lucide-react';\r\nimport toast from 'react-hot-toast';\r\nimport { checkAvailability, createBooking } from '../../api/bookingApi';\r\nimport { getPublicRestaurantDetail } from '../../api/restaurantApi';\r\nimport ApplyVoucher from '../../components/booking/ApplyVoucher';\r\nimport Header from '../../components/Header';\r\nimport TableSelectionModal from '../../components/tables/TableSelectionModal';\r\nimport { Badge } from '../../components/ui/badge';\r\nimport { Button } from '../../components/ui/button';\r\nimport { Card } from '../../components/ui/card';\r\nimport { Input } from '../../components/ui/input';\r\nimport { cn } from '../../components/ui/utils';\r\nimport { useAuth } from '../../context/useAuth';\r\n\r\nconst FALLBACK_RESTAURANT_IMAGE =\r\n  'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1600&q=80';\r\n\r\nconst SLOT_INTERVAL_MINUTES = 30;\r\nconst MIN_BOOKING_ADVANCE_MINUTES = 30;\r\nconst MAX_BOOKING_ADVANCE_DAYS = 30;\r\nconst DEFAULT_OPERATING_HOURS = { open: '10:00', close: '22:00', closed: false };\r\n\r\nconst steps = [\r\n  { num: 1, label: 'ThГҹв•—ВҘi gian', description: 'Ngв”ңГЎy, giГҹв•—ВҘ, sГҹв•—ГҰ khв”ңГӯch' },\r\n  { num: 2, label: 'ChГҹв•—Г¬n bв”ңГЎn', description: 'GГҹв•—Гәi в”ңв•ң hoГҹв•‘в•–c tГҹв•—в–’ chГҹв•—Г¬n' },\r\n  { num: 3, label: 'Liв”ңВ¬n hГҹв•—Г§', description: 'Thв”ңв”Өng tin ngв•һв–‘Гҹв•—ВҘi в”ҖГҰГҹв•‘в•–t' },\r\n  { num: 4, label: 'Xв”ңГӯc nhГҹв•‘ВЎn', description: 'KiГҹв•—Гўm tra lГҹв•‘Вәn cuГҹв•—ГҰi' },\r\n];\r\n\r\nconst occasionOptions = [\r\n  { value: 'birthday', label: 'Sinh nhГҹв•‘ВЎt' },\r\n  { value: 'anniversary', label: 'KГҹв•—в•– niГҹв•—Г§m' },\r\n  { value: 'business', label: 'Cв”ңв”Өng viГҹв•—Г§c' },\r\n  { value: 'date', label: 'HГҹв•‘в•Јn hв”ңв–“' },\r\n  { value: 'family', label: 'Gia в”ҖГҰв”ңВјnh' },\r\n  { value: 'other', label: 'Khв”ңГӯc' },\r\n];\r\n\r\nconst occasionLabels = occasionOptions.reduce((map, item) => {\r\n  map[item.value] = item.label;\r\n  return map;\r\n}, {});\r\n\r\nfunction formatAddress(address) {\r\n  if (!address) return 'в”ҖГүГҹв•—ГҜa chГҹв•—Г« в”ҖГҰang cГҹв•‘ВЎp nhГҹв•‘ВЎt';\r\n  if (typeof address === 'string') return address;\r\n\r\n  const direct =\r\n    address.fullAddress ||\r\n    address.formattedAddress ||\r\n    address.displayAddress ||\r\n    address.addressLine;\r\n\r\n  if (direct) return direct;\r\n\r\n  const parts = [\r\n    address.street,\r\n    address.ward,\r\n    address.district,\r\n    address.city,\r\n    address.province,\r\n    address.country,\r\n  ].filter(Boolean);\r\n\r\n  return parts.length > 0 ? parts.join(', ') : 'в”ҖГүГҹв•—ГҜa chГҹв•—Г« в”ҖГҰang cГҹв•‘ВЎp nhГҹв•‘ВЎt';\r\n}\r\n\r\nfunction formatCurrency(amount) {\r\n  const value = Number(amount || 0);\r\n  return `${new Intl.NumberFormat('vi-VN').format(value)}в”ҖГҰ`;\r\n}\r\n\r\nfunction toDateInputValue(date) {\r\n  const localDate = new Date(date.getTime() - date.getTimezoneOffset() * 60000);\r\n  return localDate.toISOString().split('T')[0];\r\n}\r\n\r\nfunction getTodayString() {\r\n  return toDateInputValue(new Date());\r\n}\r\n\r\nfunction getMaxDateString() {\r\n  const maxDate = new Date();\r\n  maxDate.setDate(maxDate.getDate() + MAX_BOOKING_ADVANCE_DAYS);\r\n  return toDateInputValue(maxDate);\r\n}\r\n\r\nfunction toMinutes(value) {\r\n  const [hour = 0, minute = 0] = String(value || '').split(':').map(Number);\r\n  if (Number.isNaN(hour) || Number.isNaN(minute)) return 0;\r\n  return hour * 60 + minute;\r\n}\r\n\r\nfunction getDateAtMinutes(dateValue, minutes) {\r\n  const date = new Date(`${dateValue}T00:00:00`);\r\n  date.setMinutes(date.getMinutes() + minutes);\r\n  return date;\r\n}\r\n\r\nfunction getTableId(table) {\r\n  return table?.id || table?._id || table?.tableNumber;\r\n}\r\n\r\nfunction getTableCapacity(table) {\r\n  return Number(table?.capacity || 0);\r\n}\r\n\r\nfunction getSelectedCapacity(tables) {\r\n  return tables.reduce((sum, table) => sum + getTableCapacity(table), 0);\r\n}\r\n\r\nfunction getDepositAmount(tables) {\r\n  return tables.reduce((sum, table) => sum + Number(table?.depositAmount || 0), 0);\r\n}\r\n\r\nfunction formatBookingCode(id) {\r\n  if (!id) return '#BOOKEAT';\r\n  return `#${String(id).slice(-6).toUpperCase()}`;\r\n}\r\n\r\nexport default function BookingFormPage() {\r\n  const { id: restaurantId } = useParams();\r\n  const navigate = useNavigate();\r\n  const { user } = useAuth();\r\n\r\n  const [restaurant, setRestaurant] = useState(null);\r\n  const [loading, setLoading] = useState(true);\r\n  const [loadError, setLoadError] = useState('');\r\n  const [currentStep, setCurrentStep] = useState(1);\r\n\r\n  const [bookingDate, setBookingDate] = useState(() => getTodayString());\r\n  const [bookingTime, setBookingTime] = useState('');\r\n  const [numberOfGuests, setNumberOfGuests] = useState(2);\r\n  const [minBookableTime] = useState(() => {\r\n    const now = new Date();\r\n    return new Date(now.getTime() + MIN_BOOKING_ADVANCE_MINUTES * 60 * 1000);\r\n  });\r\n\r\n  const [isTableModalOpen, setIsTableModalOpen] = useState(false);\r\n  const [availableTables, setAvailableTables] = useState([]);\r\n  const [suggestedTables, setSuggestedTables] = useState([]);\r\n  const [selectedTables, setSelectedTables] = useState([]);\r\n  const [checkingTables, setCheckingTables] = useState(false);\r\n  const [tablesUnavailable, setTablesUnavailable] = useState(false);\r\n\r\n  const [customerName, setCustomerName] = useState(user?.fullName || user?.name || '');\r\n  const [customerPhone, setCustomerPhone] = useState(user?.phoneNumber || user?.phone || '');\r\n  const [customerEmail, setCustomerEmail] = useState(user?.email || '');\r\n  const [specialRequests, setSpecialRequests] = useState('');\r\n  const [occasion, setOccasion] = useState('');\r\n  const [appliedVoucher, setAppliedVoucher] = useState(null);\r\n  const [discountAmount, setDiscountAmount] = useState(0);\r\n  const [fieldErrors, setFieldErrors] = useState({});\r\n\r\n  const [createdBooking, setCreatedBooking] = useState(null);\r\n  const [isSubmitting, setIsSubmitting] = useState(false);\r\n\r\n  const restaurantAddress = useMemo(() => formatAddress(restaurant?.address), [restaurant?.address]);\r\n  const selectedCapacity = useMemo(() => getSelectedCapacity(selectedTables), [selectedTables]);\r\n  const depositAmount = useMemo(() => getDepositAmount(selectedTables), [selectedTables]);\r\n  const restaurantImage = restaurant?.coverImage || restaurant?.image || restaurant?.logo || FALLBACK_RESTAURANT_IMAGE;\r\n  const cuisineText = Array.isArray(restaurant?.cuisineTypes)\r\n    ? restaurant.cuisineTypes.join(', ')\r\n    : restaurant?.cuisineType || restaurant?.cuisine || 'Гҹв•‘Вҝm thГҹв•—в–’c chГҹв•—Г¬n lГҹв•—Г¬c';\r\n\r\n  const fetchRestaurant = useCallback(async () => {\r\n    if (!restaurantId) {\r\n      setLoadError('Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y mв”ңГә nhв”ңГЎ hв”ңГЎng.');\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    setLoading(true);\r\n    setLoadError('');\r\n\r\n    try {\r\n      const res = await getPublicRestaurantDetail(restaurantId);\r\n      if (!res?.success) {\r\n        throw new Error(res?.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi thв”ңв”Өng tin nhв”ңГЎ hв”ңГЎng.');\r\n      }\r\n\r\n      setRestaurant(res.data?.restaurant || res.data);\r\n    } catch (err) {\r\n      console.error(err);\r\n      setLoadError(err.message || 'Cв”ңв”Ӯ lГҹв•—Г№i xГҹв•‘Гәy ra khi tГҹв•‘Гәi thв”ңв”Өng tin в”ҖГҰГҹв•‘в•–t bв”ңГЎn.');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [restaurantId]);\r\n\r\n  useEffect(() => {\r\n    fetchRestaurant();\r\n  }, [fetchRestaurant]);\r\n\r\n  useEffect(() => {\r\n    if (!user) return;\r\n\r\n    setCustomerName((current) => current || user.fullName || user.name || '');\r\n    setCustomerPhone((current) => current || user.phoneNumber || user.phone || '');\r\n    setCustomerEmail((current) => current || user.email || '');\r\n  }, [user]);\r\n\r\n  const getOperatingHoursForDate = useCallback((dateValue) => {\r\n    const hoursConfig = restaurant?.operatingHours || restaurant?.openingHours;\r\n    if (!dateValue || !hoursConfig) return DEFAULT_OPERATING_HOURS;\r\n\r\n    const daysOfWeek = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];\r\n    const dayName = daysOfWeek[new Date(`${dateValue}T00:00:00`).getDay()];\r\n    const dayHours = hoursConfig[dayName] || DEFAULT_OPERATING_HOURS;\r\n\r\n    return {\r\n      open: dayHours.open || dayHours.openTime || DEFAULT_OPERATING_HOURS.open,\r\n      close: dayHours.close || dayHours.closeTime || DEFAULT_OPERATING_HOURS.close,\r\n      closed: Boolean(dayHours.closed || dayHours.isClosed || dayHours.isOpen === false),\r\n    };\r\n  }, [restaurant]);\r\n\r\n  const selectedDateHours = useMemo(\r\n    () => getOperatingHoursForDate(bookingDate),\r\n    [bookingDate, getOperatingHoursForDate]\r\n  );\r\n\r\n  const timeSlots = useMemo(() => {\r\n    if (!bookingDate || selectedDateHours.closed) return [];\r\n\r\n    let start = toMinutes(selectedDateHours.open);\r\n    let end = toMinutes(selectedDateHours.close);\r\n    if (end <= start) end += 24 * 60;\r\n\r\n    const slots = [];\r\n    for (let cursor = start; cursor <= end; cursor += SLOT_INTERVAL_MINUTES) {\r\n      if (getDateAtMinutes(bookingDate, cursor) < minBookableTime) continue;\r\n\r\n      const hour = Math.floor((cursor % (24 * 60)) / 60);\r\n      const minute = cursor % 60;\r\n      slots.push(`${String(hour).padStart(2, '0')}:${String(minute).padStart(2, '0')}`);\r\n    }\r\n    return slots;\r\n  }, [bookingDate, minBookableTime, selectedDateHours]);\r\n\r\n  useEffect(() => {\r\n    if (bookingTime && timeSlots.length > 0 && !timeSlots.includes(bookingTime)) {\r\n      setBookingTime('');\r\n    }\r\n  }, [bookingTime, timeSlots]);\r\n\r\n  const validateStepOne = () => {\r\n    const nextErrors = {};\r\n    if (!bookingDate) nextErrors.bookingDate = 'Vui lв”ңв–“ng chГҹв•—Г¬n ngв”ңГЎy dв”ңв•Јng bГҹв•—В»a.';\r\n    if (!bookingTime) nextErrors.bookingTime = 'Vui lв”ңв–“ng chГҹв•—Г¬n giГҹв•—ВҘ dв”ңв•Јng bГҹв•—В»a.';\r\n    if (bookingDate && timeSlots.length === 0) nextErrors.bookingTime = 'Nhв”ңГЎ hв”ңГЎng khв”ңв”Өng phГҹв•—Г‘c vГҹв•—Г‘ vв”ңГЎo ngв”ңГЎy в”ҖГҰв”ңГә chГҹв•—Г¬n.';\r\n    if (!numberOfGuests || numberOfGuests < 1) nextErrors.numberOfGuests = 'SГҹв•—ГҰ khв”ңГӯch phГҹв•‘Гәi lГҹв•—Вўn hв•һГӯn 0.';\r\n\r\n    setFieldErrors((current) => ({\r\n      ...current,\r\n      bookingDate: nextErrors.bookingDate || null,\r\n      bookingTime: nextErrors.bookingTime || null,\r\n      numberOfGuests: nextErrors.numberOfGuests || null,\r\n    }));\r\n\r\n    return Object.keys(nextErrors).length === 0;\r\n  };\r\n\r\n  const isValidEmail = (value) => /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(value.trim());\r\n  const isValidPhone = (value) => /^[0-9+\\-\\s()]{8,15}$/.test(value.trim());\r\n\r\n  const validateContactInfo = () => {\r\n    const nextErrors = {};\r\n    if (!customerName.trim()) nextErrors.customerName = 'Vui lв”ңв–“ng nhГҹв•‘ВЎp hГҹв•—Г¬ tв”ңВ¬n.';\r\n    if (!isValidPhone(customerPhone)) nextErrors.customerPhone = 'SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi khв”ңв”Өng hГҹв•—Гәp lГҹв•—Г§.';\r\n    if (!isValidEmail(customerEmail)) nextErrors.customerEmail = 'Email khв”ңв”Өng hГҹв•—Гәp lГҹв•—Г§.';\r\n\r\n    setFieldErrors((current) => ({\r\n      ...current,\r\n      customerName: nextErrors.customerName || null,\r\n      customerPhone: nextErrors.customerPhone || null,\r\n      customerEmail: nextErrors.customerEmail || null,\r\n    }));\r\n\r\n    return Object.keys(nextErrors).length === 0;\r\n  };\r\n\r\n  const handleCheckTables = async () => {\r\n    if (!validateStepOne()) {\r\n      toast.error('Vui lв”ңв–“ng chГҹв•—Г¬n ngв”ңГЎy, giГҹв•—ВҘ vв”ңГЎ sГҹв•—ГҰ khв”ңГӯch trв•һв–‘Гҹв•—Вўc.');\r\n      return;\r\n    }\r\n\r\n    setFieldErrors({});\r\n    setCheckingTables(true);\r\n    setTablesUnavailable(false);\r\n\r\n    try {\r\n      const res = await checkAvailability({\r\n        restaurantId,\r\n        bookingDate,\r\n        bookingTime,\r\n        numberOfGuests,\r\n      });\r\n\r\n      if (!res?.success) {\r\n        throw new Error(res?.message || 'Khв”ңв”Өng thГҹв•—Гў kiГҹв•—Гўm tra bв”ңГЎn trГҹв•—ГҰng.');\r\n      }\r\n\r\n      const availability = res.data || {};\r\n      const nextAvailableTables = availability.availableTables || [];\r\n      const nextSuggestedTables = availability.suggestedTables || [];\r\n\r\n      setAvailableTables(nextAvailableTables);\r\n      setSuggestedTables(nextSuggestedTables);\r\n      setSelectedTables(nextSuggestedTables);\r\n      setTablesUnavailable(!availability.available);\r\n      setCurrentStep(2);\r\n\r\n      if (!availability.available) {\r\n        toast('Khung giГҹв•—ВҘ nв”ңГЎy в”ҖГҰв”ңГә hГҹв•‘в”җt bв”ңГЎn phв”ңв•Ј hГҹв•—Гәp. BГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў tham gia danh sв”ңГӯch chГҹв•—ВҘ.');\r\n      }\r\n    } catch (err) {\r\n      console.error(err);\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў kiГҹв•—Гўm tra bв”ңГЎn trГҹв•—ГҰng tГҹв•‘Гӯi thГҹв•—ВҘi в”ҖГҰiГҹв•—Гўm nв”ңГЎy.');\r\n    } finally {\r\n      setCheckingTables(false);\r\n    }\r\n  };\r\n\r\n  const handleApplySuccess = ({ voucherCode, discountAmount }) => {\r\n    setAppliedVoucher(voucherCode);\r\n    setDiscountAmount(discountAmount || 0);\r\n  };\r\n\r\n  const handleRemoveVoucher = () => {\r\n    setAppliedVoucher(null);\r\n    setDiscountAmount(0);\r\n  };\r\n\r\n  const handleContactContinue = () => {\r\n    if (!validateContactInfo()) {\r\n      toast.error('Vui lв”ңв–“ng kiГҹв•—Гўm tra lГҹв•‘Гӯi thв”ңв”Өng tin liв”ңВ¬n hГҹв•—Г§.');\r\n      return;\r\n    }\r\n\r\n    setFieldErrors({});\r\n    setCurrentStep(4);\r\n  };\r\n\r\n  const goToWaitlist = () => {\r\n    navigate(`/restaurants/${restaurantId}/waitlist`, {\r\n      state: {\r\n        bookingDate,\r\n        bookingTime,\r\n        numberOfGuests,\r\n        customerName,\r\n        customerPhone,\r\n        customerEmail,\r\n        specialRequests,\r\n      },\r\n    });\r\n  };\r\n\r\n  const handleSubmitBooking = async () => {\r\n    if (!validateStepOne() || !validateContactInfo()) {\r\n      toast.error('Vui lв”ңв–“ng kiГҹв•—Гўm tra lГҹв•‘Гӯi thв”ңв”Өng tin в”ҖГҰГҹв•‘в•–t bв”ңГЎn.');\r\n      return;\r\n    }\r\n\r\n    setIsSubmitting(true);\r\n\r\n    try {\r\n      const payload = {\r\n        restaurantId,\r\n        bookingDate,\r\n        bookingTime,\r\n        numberOfGuests,\r\n        customerName: customerName.trim(),\r\n        customerPhone: customerPhone.trim(),\r\n        customerEmail: customerEmail.trim(),\r\n        specialRequests: specialRequests.trim() || null,\r\n        occasion: occasion || null,\r\n        tableNumbers: selectedTables.map((table) => table.tableNumber).filter(Boolean),\r\n        voucherCode: appliedVoucher,\r\n      };\r\n\r\n      const res = await createBooking(payload);\r\n      if (!res?.success) {\r\n        throw new Error(res?.message || 'в”ҖГүГҹв•‘в•–t bв”ңГЎn thГҹв•‘Г‘t bГҹв•‘Гӯi.');\r\n      }\r\n\r\n      setCreatedBooking(res.data);\r\n      toast.success('в”ҖГүГҹв•‘в•–t bв”ңГЎn thв”ңГЎnh cв”ңв”Өng.');\r\n    } catch (err) {\r\n      console.error(err);\r\n      toast.error(err.message || 'Cв”ңв”Ӯ lГҹв•—Г№i xГҹв•‘Гәy ra khi tГҹв•‘Гӯo в”ҖГҰГҹв•‘в•–t bв”ңГЎn.');\r\n    } finally {\r\n      setIsSubmitting(false);\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return <BookingLoadingState />;\r\n  }\r\n\r\n  if (loadError || !restaurant) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n        <Header />\r\n        <main className=\"flex-1 max-w-[1280px] w-full mx-auto px-4 sm:px-6 lg:px-8 py-12\">\r\n          <Card className=\"max-w-2xl mx-auto bg-card border-border p-8 text-center\">\r\n            <div className=\"mx-auto h-12 w-12 rounded-xl bg-rose-500/10 text-rose-400 flex items-center justify-center\">\r\n              <AlertTriangle size={24} />\r\n            </div>\r\n            <div className=\"space-y-2\">\r\n              <h1 className=\"font-serif text-3xl font-bold text-white\">Khв”ңв”Өng thГҹв•—Гў mГҹв•—Ж’ trang в”ҖГҰГҹв•‘в•–t bв”ңГЎn</h1>\r\n              <p className=\"text-sm text-muted-foreground leading-relaxed\">\r\n                {loadError || 'Nhв”ңГЎ hв”ңГЎng nв”ңГЎy chв•һв–‘a sГҹв•‘в•Ўn sв”ңГЎng nhГҹв•‘ВЎn в”ҖГҰГҹв•‘в•–t bв”ңГЎn. Vui lв”ңв–“ng thГҹв•—ВЎ lГҹв•‘Гӯi sau.'}\r\n              </p>\r\n            </div>\r\n            <div className=\"flex flex-col sm:flex-row items-center justify-center gap-3\">\r\n              <Button variant=\"outline\" className=\"border-border text-white hover:bg-secondary\" onClick={() => navigate(-1)}>\r\n                <ArrowLeft size={16} /> Quay lГҹв•‘Гӯi\r\n              </Button>\r\n              <Button className=\"bg-primary text-background hover:bg-primary/95\" onClick={() => navigate('/restaurants')}>\r\n                Xem nhв”ңГЎ hв”ңГЎng khв”ңГӯc\r\n              </Button>\r\n            </div>\r\n          </Card>\r\n        </main>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (createdBooking) {\r\n    return (\r\n      <BookingSuccessState\r\n        booking={createdBooking}\r\n        restaurant={restaurant}\r\n        restaurantAddress={restaurantAddress}\r\n        onHome={() => navigate('/')}\r\n        onBookings={() => navigate('/my-bookings')}\r\n      />\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n\r\n      <main className=\"flex-1 max-w-[1280px] w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10\">\r\n        <button\r\n          type=\"button\"\r\n          onClick={() => navigate(`/restaurants/${restaurantId}`)}\r\n          className=\"mb-5 inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-white transition-colors\"\r\n        >\r\n          <ArrowLeft size={16} />\r\n          Quay vГҹв•—Гј chi tiГҹв•‘в”җt nhв”ңГЎ hв”ңГЎng\r\n        </button>\r\n\r\n        <section className=\"relative overflow-hidden rounded-xl border border-border bg-card\">\r\n          <div className=\"absolute inset-0\">\r\n            <img src={restaurantImage} alt=\"\" className=\"h-full w-full object-cover opacity-25\" />\r\n            <div className=\"absolute inset-0 bg-gradient-to-r from-background via-background/85 to-background/55\" />\r\n          </div>\r\n\r\n          <div className=\"relative grid gap-6 p-5 sm:p-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-end\">\r\n            <div className=\"max-w-3xl space-y-5\">\r\n              <Badge className=\"bg-primary/10 text-primary border-primary/25 rounded-md px-3 py-1 uppercase tracking-[0.18em] text-[10px]\">\r\n                в”ҖГүГҹв•‘в•–t bв”ңГЎn BookEat\r\n              </Badge>\r\n              <div className=\"space-y-3\">\r\n                <h1 className=\"font-serif text-4xl sm:text-5xl font-bold leading-tight text-white\">\r\n                  GiГҹв•—В» chГҹв•—Г№ tГҹв•‘Гӯi {restaurant.name}\r\n                </h1>\r\n                <p className=\"max-w-2xl text-base sm:text-lg text-muted-foreground leading-relaxed\">\r\n                  ChГҹв•—Г¬n thГҹв•—ВҘi gian, bв”ңГЎn phв”ңв•Ј hГҹв•—Гәp vв”ңГЎ gГҹв•—ВЎi yв”ңВ¬u cГҹв•‘Вәu xв”ңГӯc nhГҹв•‘ВЎn. Nhв”ңГЎ hв”ңГЎng sГҹв•‘в•ң phГҹв•‘Гәn hГҹв•—Гҙi trГҹв•‘Гӯng thв”ңГӯi в”ҖГҰГҹв•‘в•–t bв”ңГЎn trong hГҹв•—Г§ thГҹв•—ГҰng BookEat.\r\n                </p>\r\n              </div>\r\n              <div className=\"flex flex-wrap gap-3 text-sm text-muted-foreground\">\r\n                <span className=\"inline-flex items-center gap-2 rounded-md border border-border bg-card/70 px-3 py-2\">\r\n                  <Store size={15} className=\"text-primary\" /> {cuisineText}\r\n                </span>\r\n                <span className=\"inline-flex items-center gap-2 rounded-md border border-border bg-card/70 px-3 py-2\">\r\n                  <MapPin size={15} className=\"text-primary\" /> {restaurantAddress}\r\n                </span>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"rounded-xl border border-border bg-card/85 p-4 backdrop-blur-sm\">\r\n              <div className=\"flex items-start gap-3\">\r\n                <div className=\"h-11 w-11 rounded-lg bg-primary/10 text-primary flex items-center justify-center\">\r\n                  <ShieldCheck size={22} />\r\n                </div>\r\n                <div className=\"space-y-1\">\r\n                  <p className=\"text-sm font-bold text-white\">Xв”ңГӯc nhГҹв•‘ВЎn qua nhв”ңГЎ hв”ңГЎng</p>\r\n                  <p className=\"text-xs text-muted-foreground leading-relaxed\">\r\n                    Booking mГҹв•—Вўi sГҹв•‘в•ң Гҹв•—Ж’ trГҹв•‘Гӯng thв”ңГӯi chГҹв•—ВҘ duyГҹв•—Г§t, giв”ңв•‘p nhв”ңГЎ hв”ңГЎng kiГҹв•—Гўm tra bв”ңГЎn vв”ңГЎ liв”ңВ¬n hГҹв•—Г§ khi cГҹв•‘Вәn.\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        <div className=\"mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start\">\r\n          <div className=\"space-y-6\">\r\n            <StepProgress currentStep={currentStep} />\r\n\r\n            {currentStep === 1 && (\r\n              <Card className=\"bg-card border-border p-5 sm:p-6\">\r\n                <StepHeader\r\n                  icon={CalendarIcon}\r\n                  eyebrow=\"Bв•һв–‘Гҹв•—Вўc 1\"\r\n                  title=\"ChГҹв•—Г¬n ngв”ңГЎy, giГҹв•—ВҘ vв”ңГЎ sГҹв•—ГҰ khв”ңГӯch\"\r\n                  description=\"Cв”ңГӯc khung giГҹв•—ВҘ в”ҖГҰв•һв–‘Гҹв•—Гәc tГҹв•‘Гӯo tГҹв•—ВҪ lГҹв•—ГҜch hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng hiГҹв•—Г§n tГҹв•‘Гӯi cГҹв•—Вәa nhв”ңГЎ hв”ңГЎng.\"\r\n                />\r\n\r\n                <div className=\"grid gap-6\">\r\n                  <div className=\"grid gap-4 md:grid-cols-[260px_minmax(0,1fr)]\">\r\n                    <div className=\"space-y-2\">\r\n                      <label htmlFor=\"booking-date\" className=\"flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground\">\r\n                        <CalendarIcon size={14} className=\"text-primary\" /> Ngв”ңГЎy dв”ңв•Јng bГҹв•—В»a\r\n                      </label>\r\n                      <Input\r\n                        id=\"booking-date\"\r\n                        type=\"date\"\r\n                        min={getTodayString()}\r\n                        max={getMaxDateString()}\r\n                        value={bookingDate}\r\n                        onChange={(event) => {\r\n                          setBookingDate(event.target.value);\r\n                          setFieldErrors((current) => ({ ...current, bookingDate: null, bookingTime: null }));\r\n                          setBookingTime('');\r\n                        }}\r\n                        className={cn(\r\n                          'h-11 bg-secondary/40 border-border text-white focus-visible:ring-primary/40',\r\n                          fieldErrors.bookingDate && 'border-rose-500/60'\r\n                        )}\r\n                      />\r\n                      <FieldError message={fieldErrors.bookingDate} />\r\n                    </div>\r\n\r\n                    <div className=\"space-y-2\">\r\n                      <label className=\"flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground\">\r\n                        <Clock size={14} className=\"text-primary\" /> Khung giГҹв•—ВҘ в”ҖГўn\r\n                      </label>\r\n\r\n                      {!bookingDate ? (\r\n                        <div className=\"rounded-xl border border-dashed border-border bg-secondary/20 p-5 text-sm text-muted-foreground\">\r\n                          ChГҹв•—Г¬n ngв”ңГЎy dв”ңв•Јng bГҹв•—В»a в”ҖГҰГҹв•—Гў xem cв”ңГӯc khung giГҹв•—ВҘ в”ҖГҰang nhГҹв•‘ВЎn в”ҖГҰГҹв•‘в•–t bв”ңГЎn.\r\n                        </div>\r\n                      ) : timeSlots.length === 0 ? (\r\n                        <InfoPanel\r\n                          tone=\"danger\"\r\n                          icon={AlertTriangle}\r\n                          title={selectedDateHours.closed ? 'Nhв”ңГЎ hв”ңГЎng khв”ңв”Өng phГҹв•—Г‘c vГҹв•—Г‘ ngв”ңГЎy nв”ңГЎy' : 'Khв”ңв”Өng cв”ңв–“n khung giГҹв•—ВҘ phв”ңв•Ј hГҹв•—Гәp'}\r\n                          description={\r\n                            selectedDateHours.closed\r\n                              ? 'BГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў chГҹв•—Г¬n mГҹв•—Г–t ngв”ңГЎy khв”ңГӯc trong vв”ңв–“ng 30 ngв”ңГЎy tГҹв•—Вўi.'\r\n                              : 'Cв”ңГӯc khung giГҹв•—ВҘ cв”ңв–“n lГҹв•‘Гӯi hв”ңв”Өm nay в”ҖГҰв”ңГә qua hoГҹв•‘в•–c quв”ңГӯ sв”ңГӯt giГҹв•—ВҘ dв”ңв•Јng bГҹв•—В»a. Vui lв”ңв–“ng chГҹв•—Г¬n ngв”ңГЎy khв”ңГӯc.'\r\n                          }\r\n                        />\r\n                      ) : (\r\n                        <div className=\"grid grid-cols-2 sm:grid-cols-4 xl:grid-cols-6 gap-2\">\r\n                          {timeSlots.map((slot) => (\r\n                            <button\r\n                              key={slot}\r\n                              type=\"button\"\r\n                              aria-pressed={bookingTime === slot}\r\n                              onClick={() => {\r\n                                setBookingTime(slot);\r\n                                setFieldErrors((current) => ({ ...current, bookingTime: null }));\r\n                              }}\r\n                              className={cn(\r\n                                'h-10 rounded-md border text-sm font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-primary/45',\r\n                                bookingTime === slot\r\n                                  ? 'bg-primary text-background border-primary'\r\n                                  : 'bg-secondary/40 text-muted-foreground border-border hover:bg-secondary hover:text-white'\r\n                              )}\r\n                            >\r\n                              {slot}\r\n                            </button>\r\n                          ))}\r\n                        </div>\r\n                      )}\r\n                      <FieldError message={fieldErrors.bookingTime} />\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"rounded-xl border border-border bg-secondary/20 p-4\">\r\n                    <div className=\"flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between\">\r\n                      <div>\r\n                        <label className=\"flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground\">\r\n                          <Users size={14} className=\"text-primary\" /> SГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng khв”ңГӯch\r\n                        </label>\r\n                        <p className=\"mt-1 text-sm text-muted-foreground\">Nhв”ңГЎ hв”ңГЎng sГҹв•‘в•ң dв”ңв•Јng sГҹв•—ГҰ khв”ңГӯch в”ҖГҰГҹв•—Гў gГҹв•—Гәi в”ңв•ң bв”ңГЎn cв”ңв”Ӯ sГҹв•—вҢҗc chГҹв•—вҢҗa phв”ңв•Ј hГҹв•—Гәp.</p>\r\n                      </div>\r\n\r\n                      <div className=\"flex items-center gap-2 rounded-lg border border-border bg-card p-1\">\r\n                        <button\r\n                          type=\"button\"\r\n                          aria-label=\"GiГҹв•‘Гәm sГҹв•—ГҰ khв”ңГӯch\"\r\n                          disabled={numberOfGuests <= 1}\r\n                          onClick={() => setNumberOfGuests((value) => Math.max(1, value - 1))}\r\n                          className=\"h-9 w-9 rounded-md text-muted-foreground hover:bg-secondary hover:text-white disabled:opacity-40 disabled:hover:bg-transparent\"\r\n                        >\r\n                          <Minus size={15} className=\"mx-auto\" />\r\n                        </button>\r\n                        <span className=\"min-w-24 text-center text-sm font-bold text-white\">{numberOfGuests} khв”ңГӯch</span>\r\n                        <button\r\n                          type=\"button\"\r\n                          aria-label=\"Tв”ҖГўng sГҹв•—ГҰ khв”ңГӯch\"\r\n                          disabled={numberOfGuests >= 100}\r\n                          onClick={() => setNumberOfGuests((value) => Math.min(100, value + 1))}\r\n                          className=\"h-9 w-9 rounded-md text-muted-foreground hover:bg-secondary hover:text-white disabled:opacity-40 disabled:hover:bg-transparent\"\r\n                        >\r\n                          <Plus size={15} className=\"mx-auto\" />\r\n                        </button>\r\n                      </div>\r\n                    </div>\r\n                    <FieldError message={fieldErrors.numberOfGuests} />\r\n                  </div>\r\n                </div>\r\n\r\n                <StepActions>\r\n                  <Button\r\n                    type=\"button\"\r\n                    disabled={!bookingDate || !bookingTime || checkingTables}\r\n                    onClick={handleCheckTables}\r\n                    className=\"bg-primary hover:bg-primary/95 text-background font-bold h-11 px-5\"\r\n                  >\r\n                    {checkingTables ? (\r\n                      <>\r\n                        <Loader2 size={16} className=\"animate-spin\" /> в”ҖГүang kiГҹв•—Гўm tra bв”ңГЎn\r\n                      </>\r\n                    ) : (\r\n                      <>\r\n                        KiГҹв•—Гўm tra bв”ңГЎn trГҹв•—ГҰng <ArrowRight size={16} />\r\n                      </>\r\n                    )}\r\n                  </Button>\r\n                </StepActions>\r\n              </Card>\r\n            )}\r\n\r\n            {currentStep === 2 && (\r\n              <Card className=\"bg-card border-border p-5 sm:p-6\">\r\n                <StepHeader\r\n                  icon={Armchair}\r\n                  eyebrow=\"Bв•һв–‘Гҹв•—Вўc 2\"\r\n                  title=\"ChГҹв•—Г¬n vГҹв•—ГҜ trв”ңВЎ bв”ңГЎn в”ҖГўn\"\r\n                  description=\"BГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў dв”ңв•Јng gГҹв•—Гәi в”ңв•ң cГҹв•—Вәa hГҹв•—Г§ thГҹв•—ГҰng hoГҹв•‘в•–c в”ҖГҰГҹв•—Гў nhв”ңГЎ hв”ңГЎng tГҹв•—в–’ xГҹв•‘в”җp bв”ңГЎn khi xв”ңГӯc nhГҹв•‘ВЎn.\"\r\n                />\r\n\r\n                <div className=\"grid gap-5\">\r\n                  {tablesUnavailable && (\r\n                    <InfoPanel\r\n                      tone=\"warning\"\r\n                      icon={AlertTriangle}\r\n                      title=\"Khung giГҹв•—ВҘ nв”ңГЎy в”ҖГҰв”ңГә hГҹв•‘в”җt bв”ңГЎn phв”ңв•Ј hГҹв•—Гәp\"\r\n                      description=\"BГҹв•‘Гӯn cв”ңв”Ӯ thГҹв•—Гў tham gia danh sв”ңГӯch chГҹв•—ВҘ в”ҖГҰГҹв•—Гў nhв”ңГЎ hв”ңГЎng liв”ңВ¬n hГҹв•—Г§ khi cв”ңв”Ӯ bв”ңГЎn trГҹв•—ГҰng.\"\r\n                      action={\r\n                        <Button onClick={goToWaitlist} className=\"bg-primary text-background hover:bg-primary/95\">\r\n                          Tham gia danh sв”ңГӯch chГҹв•—ВҘ\r\n                        </Button>\r\n                      }\r\n                    />\r\n                  )}\r\n\r\n                  <div className=\"rounded-xl border border-border bg-secondary/20 p-5\">\r\n                    <div className=\"flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between\">\r\n                      <div className=\"space-y-1\">\r\n                        <p className=\"text-sm font-bold text-white\">Bв”ңГЎn в”ҖГҰв”ңГә chГҹв•—Г¬n</p>\r\n                        <p className=\"text-sm text-muted-foreground\">\r\n                          CГҹв•‘Вәn tГҹв•—ГҰi thiГҹв•—Гўu {numberOfGuests} chГҹв•—Г№, hiГҹв•—Г§n в”ҖГҰв”ңГә chГҹв•—Г¬n {selectedCapacity} chГҹв•—Г№.\r\n                        </p>\r\n                      </div>\r\n                      <Badge\r\n                        variant=\"outline\"\r\n                        className={cn(\r\n                          'rounded-md border px-3 py-1',\r\n                          selectedCapacity >= numberOfGuests\r\n                            ? 'border-emerald-500/30 bg-emerald-500/10 text-emerald-400'\r\n                            : 'border-amber-500/30 bg-amber-500/10 text-amber-400'\r\n                        )}\r\n                      >\r\n                        {selectedCapacity >= numberOfGuests ? 'в”ҖГүГҹв•—Вә sГҹв•—вҢҗc chГҹв•—вҢҗa' : 'Chв•һв–‘a в”ҖГҰГҹв•—Вә sГҹв•—вҢҗc chГҹв•—вҢҗa'}\r\n                      </Badge>\r\n                    </div>\r\n\r\n                    <div className=\"mt-4\">\r\n                      {selectedTables.length > 0 ? (\r\n                        <div className=\"flex flex-wrap gap-2\">\r\n                          {selectedTables.map((table) => (\r\n                            <Badge key={getTableId(table)} variant=\"secondary\" className=\"gap-2 border border-border bg-card text-white px-3 py-1.5\">\r\n                              Bв”ңГЎn {table.tableNumber} ({getTableCapacity(table)} chГҹв•—Г№)\r\n                              <button\r\n                                type=\"button\"\r\n                                aria-label={`BГҹв•—Г… chГҹв•—Г¬n bв”ңГЎn ${table.tableNumber}`}\r\n                                onClick={() => setSelectedTables((current) => current.filter((item) => getTableId(item) !== getTableId(table)))}\r\n                                className=\"text-muted-foreground hover:text-rose-400\"\r\n                              >\r\n                                в”ңГ№\r\n                              </button>\r\n                            </Badge>\r\n                          ))}\r\n                        </div>\r\n                      ) : (\r\n                        <div className=\"rounded-lg border border-dashed border-border bg-card/50 p-4 text-sm text-muted-foreground\">\r\n                          Chв•һв–‘a chГҹв•—Г¬n bв”ңГЎn cГҹв•—Г‘ thГҹв•—Гў. NГҹв•‘в”җu tiГҹв•‘в”җp tГҹв•—Г‘c, nhв”ңГЎ hв”ңГЎng sГҹв•‘в•ң tГҹв•—в–’ xГҹв•‘в”җp bв”ңГЎn phв”ңв•Ј hГҹв•—Гәp khi xв”ңГӯc nhГҹв•‘ВЎn.\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n\r\n                    <Button\r\n                      variant=\"outline\"\r\n                      type=\"button\"\r\n                      onClick={() => setIsTableModalOpen(true)}\r\n                      className=\"mt-5 w-full border-border text-white hover:bg-secondary h-11\"\r\n                    >\r\n                      <Search size={16} className=\"text-primary\" />\r\n                      {selectedTables.length > 0 ? 'Thay в”ҖГҰГҹв•—ГІi bв”ңГЎn в”ҖГҰв”ңГә chГҹв•—Г¬n' : 'TГҹв•—в–’ chГҹв•—Г¬n bв”ңГЎn trГҹв•—в–’c quan'}\r\n                    </Button>\r\n                  </div>\r\n                </div>\r\n\r\n                <StepActions>\r\n                  <Button variant=\"outline\" onClick={() => setCurrentStep(1)} className=\"border-border text-white hover:bg-secondary h-11\">\r\n                    <ArrowLeft size={16} /> Quay lГҹв•‘Гӯi\r\n                  </Button>\r\n                  <Button\r\n                    onClick={() => setCurrentStep(3)}\r\n                    disabled={tablesUnavailable || (selectedTables.length > 0 && selectedCapacity < numberOfGuests)}\r\n                    className=\"bg-primary hover:bg-primary/95 text-background font-bold h-11 px-5\"\r\n                  >\r\n                    TiГҹв•‘в”җp tГҹв•—Г‘c <ArrowRight size={16} />\r\n                  </Button>\r\n                </StepActions>\r\n              </Card>\r\n            )}\r\n\r\n            {currentStep === 3 && (\r\n              <Card className=\"bg-card border-border p-5 sm:p-6\">\r\n                <StepHeader\r\n                  icon={Users}\r\n                  eyebrow=\"Bв•һв–‘Гҹв•—Вўc 3\"\r\n                  title=\"Thв”ңв”Өng tin liв”ңВ¬n hГҹв•—Г§\"\r\n                  description=\"Thв”ңв”Өng tin nв”ңГЎy giв”ңв•‘p nhв”ңГЎ hв”ңГЎng xв”ңГӯc nhГҹв•‘ВЎn vв”ңГЎ liв”ңВ¬n hГҹв•—Г§ khi cГҹв•‘Вәn.\"\r\n                />\r\n\r\n                <div className=\"grid gap-5\">\r\n                  <div className=\"grid gap-4 sm:grid-cols-2\">\r\n                    <FormField label=\"HГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n ngв•һв–‘Гҹв•—ВҘi в”ҖГҰГҹв•‘в•–t\" htmlFor=\"customer-name\" required error={fieldErrors.customerName}>\r\n                      <Input\r\n                        id=\"customer-name\"\r\n                        value={customerName}\r\n                        onChange={(event) => {\r\n                          setCustomerName(event.target.value);\r\n                          setFieldErrors((current) => ({ ...current, customerName: null }));\r\n                        }}\r\n                        placeholder=\"NhГҹв•‘ВЎp hГҹв•—Г¬ tв”ңВ¬n\"\r\n                        className={cn('h-11 bg-secondary/40 border-border text-white focus-visible:ring-primary/40', fieldErrors.customerName && 'border-rose-500/60')}\r\n                      />\r\n                    </FormField>\r\n\r\n                    <FormField label=\"SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi\" htmlFor=\"customer-phone\" required error={fieldErrors.customerPhone}>\r\n                      <Input\r\n                        id=\"customer-phone\"\r\n                        type=\"tel\"\r\n                        value={customerPhone}\r\n                        onChange={(event) => {\r\n                          setCustomerPhone(event.target.value);\r\n                          setFieldErrors((current) => ({ ...current, customerPhone: null }));\r\n                        }}\r\n                        placeholder=\"NhГҹв•‘ВЎp sГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi\"\r\n                        className={cn('h-11 bg-secondary/40 border-border text-white focus-visible:ring-primary/40', fieldErrors.customerPhone && 'border-rose-500/60')}\r\n                      />\r\n                    </FormField>\r\n                  </div>\r\n\r\n                  <FormField label=\"Email nhГҹв•‘ВЎn thв”ңв”Өng tin в”ҖГҰГҹв•‘в•–t bв”ңГЎn\" htmlFor=\"customer-email\" required error={fieldErrors.customerEmail}>\r\n                    <Input\r\n                      id=\"customer-email\"\r\n                      type=\"email\"\r\n                      value={customerEmail}\r\n                      onChange={(event) => {\r\n                        setCustomerEmail(event.target.value);\r\n                        setFieldErrors((current) => ({ ...current, customerEmail: null }));\r\n                      }}\r\n                      placeholder=\"ten@email.com\"\r\n                      className={cn('h-11 bg-secondary/40 border-border text-white focus-visible:ring-primary/40', fieldErrors.customerEmail && 'border-rose-500/60')}\r\n                    />\r\n                  </FormField>\r\n\r\n                  <div className=\"space-y-2\">\r\n                    <label className=\"text-sm font-semibold text-white\">DГҹв•—ГҜp в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t</label>\r\n                    <div className=\"grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-6\">\r\n                      {occasionOptions.map((item) => (\r\n                        <button\r\n                          key={item.value}\r\n                          type=\"button\"\r\n                          onClick={() => setOccasion((current) => (current === item.value ? '' : item.value))}\r\n                          className={cn(\r\n                            'h-10 rounded-md border text-sm font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-primary/40',\r\n                            occasion === item.value\r\n                              ? 'border-primary bg-primary/10 text-primary'\r\n                              : 'border-border bg-secondary/35 text-muted-foreground hover:bg-secondary hover:text-white'\r\n                          )}\r\n                        >\r\n                          {item.label}\r\n                        </button>\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"space-y-2\">\r\n                    <label htmlFor=\"special-requests\" className=\"text-sm font-semibold text-white\">\r\n                      Yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t\r\n                    </label>\r\n                    <textarea\r\n                      id=\"special-requests\"\r\n                      rows={4}\r\n                      maxLength={500}\r\n                      value={specialRequests}\r\n                      onChange={(event) => setSpecialRequests(event.target.value)}\r\n                      placeholder=\"Vв”ңВЎ dГҹв•—Г‘: bв”ңГЎn yв”ңВ¬n tв”ҖвҢҗnh, gГҹв•‘Вәn cГҹв•—ВЎa sГҹв•—ГІ, ghГҹв•‘в”җ trГҹв•‘в•— em, dГҹв•—ГҜ Гҹв•—вҢҗng thГҹв•—в–’c phГҹв•‘вҢҗm...\"\r\n                      className=\"w-full rounded-md border border-border bg-secondary/40 p-3 text-sm text-white placeholder:text-muted-foreground outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/30\"\r\n                    />\r\n                    <div className=\"text-right text-xs text-muted-foreground\">{specialRequests.length}/500 kв”ңв•ң tГҹв•—в–’</div>\r\n                  </div>\r\n\r\n                  <div className=\"rounded-xl border border-border bg-secondary/20 p-4\">\r\n                    <ApplyVoucher\r\n                      restaurantId={restaurantId}\r\n                      bookingAmount={depositAmount}\r\n                      onApplySuccess={handleApplySuccess}\r\n                      onRemove={handleRemoveVoucher}\r\n                    />\r\n                  </div>\r\n                </div>\r\n\r\n                <StepActions>\r\n                  <Button variant=\"outline\" onClick={() => setCurrentStep(2)} className=\"border-border text-white hover:bg-secondary h-11\">\r\n                    <ArrowLeft size={16} /> Quay lГҹв•‘Гӯi\r\n                  </Button>\r\n                  <Button onClick={handleContactContinue} className=\"bg-primary hover:bg-primary/95 text-background font-bold h-11 px-5\">\r\n                    Xem tв”ңв”Ӯm tГҹв•‘В»t <ArrowRight size={16} />\r\n                  </Button>\r\n                </StepActions>\r\n              </Card>\r\n            )}\r\n\r\n            {currentStep === 4 && (\r\n              <Card className=\"bg-card border-border p-5 sm:p-6\">\r\n                <StepHeader\r\n                  icon={CheckCircle2}\r\n                  eyebrow=\"Bв•һв–‘Гҹв•—Вўc 4\"\r\n                  title=\"KiГҹв•—Гўm tra vв”ңГЎ xв”ңГӯc nhГҹв•‘ВЎn\"\r\n                  description=\"Xem lГҹв•‘Гӯi thв”ңв”Өng tin trв•һв–‘Гҹв•—Вўc khi gГҹв•—ВЎi yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в”җn nhв”ңГЎ hв”ңГЎng.\"\r\n                />\r\n\r\n                <SummaryPanel\r\n                  restaurant={restaurant}\r\n                  restaurantAddress={restaurantAddress}\r\n                  bookingDate={bookingDate}\r\n                  bookingTime={bookingTime}\r\n                  numberOfGuests={numberOfGuests}\r\n                  selectedTables={selectedTables}\r\n                  customerName={customerName}\r\n                  customerPhone={customerPhone}\r\n                  customerEmail={customerEmail}\r\n                  specialRequests={specialRequests}\r\n                  occasion={occasion}\r\n                  appliedVoucher={appliedVoucher}\r\n                  discountAmount={discountAmount}\r\n                />\r\n\r\n                <InfoPanel\r\n                  icon={Info}\r\n                  title=\"Lв•һв–‘u в”ңв•ң trв•һв–‘Гҹв•—Вўc khi gГҹв•—ВЎi\"\r\n                  description=\"Yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в•–t bв”ңГЎn sГҹв•‘в•ң в”ҖГҰв•һв–‘Гҹв•—Гәc gГҹв•—ВЎi Гҹв•—Ж’ trГҹв•‘Гӯng thв”ңГӯi chГҹв•—ВҘ duyГҹв•—Г§t. Nhв”ңГЎ hв”ңГЎng cв”ңв”Ӯ thГҹв•—Гў xв”ңГӯc nhГҹв•‘ВЎn, в”ҖГҰГҹв•—ГІi bв”ңГЎn hoГҹв•‘в•–c liв”ңВ¬n hГҹв•—Г§ bГҹв•‘Гӯn nГҹв•‘в”җu cГҹв•‘Вәn thв”ңВ¬m thв”ңв”Өng tin.\"\r\n                />\r\n\r\n                <StepActions>\r\n                  <Button variant=\"outline\" onClick={() => setCurrentStep(3)} disabled={isSubmitting} className=\"border-border text-white hover:bg-secondary h-11\">\r\n                    <ArrowLeft size={16} /> Quay lГҹв•‘Гӯi\r\n                  </Button>\r\n                  <Button\r\n                    onClick={handleSubmitBooking}\r\n                    disabled={isSubmitting}\r\n                    className=\"bg-primary hover:bg-primary/95 text-background font-bold h-11 px-6\"\r\n                  >\r\n                    {isSubmitting ? (\r\n                      <>\r\n                        <Loader2 size={16} className=\"animate-spin\" /> в”ҖГүang gГҹв•—ВЎi yв”ңВ¬u cГҹв•‘Вәu\r\n                      </>\r\n                    ) : (\r\n                      <>\r\n                        Xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰГҹв•‘в•–t bв”ңГЎn <Check size={16} />\r\n                      </>\r\n                    )}\r\n                  </Button>\r\n                </StepActions>\r\n              </Card>\r\n            )}\r\n          </div>\r\n\r\n          <aside className=\"lg:sticky lg:top-24\">\r\n            <BookingAside\r\n              restaurant={restaurant}\r\n              restaurantAddress={restaurantAddress}\r\n              currentStep={currentStep}\r\n              bookingDate={bookingDate}\r\n              bookingTime={bookingTime}\r\n              numberOfGuests={numberOfGuests}\r\n              selectedTables={selectedTables}\r\n              depositAmount={depositAmount}\r\n              discountAmount={discountAmount}\r\n              appliedVoucher={appliedVoucher}\r\n            />\r\n          </aside>\r\n        </div>\r\n      </main>\r\n\r\n      <TableSelectionModal\r\n        isOpen={isTableModalOpen}\r\n        onClose={() => setIsTableModalOpen(false)}\r\n        tables={availableTables}\r\n        suggestedTables={suggestedTables}\r\n        selectedTables={selectedTables}\r\n        onConfirm={(tables) => setSelectedTables(tables)}\r\n        numberOfGuests={numberOfGuests}\r\n      />\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction BookingLoadingState() {\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n      <main className=\"flex-1 max-w-[1280px] w-full mx-auto px-4 sm:px-6 lg:px-8 py-10\">\r\n        <div className=\"rounded-xl border border-border bg-card p-6 sm:p-8\">\r\n          <div className=\"animate-pulse space-y-6\">\r\n            <div className=\"h-4 w-36 rounded bg-secondary\" />\r\n            <div className=\"space-y-3\">\r\n              <div className=\"h-10 w-full max-w-xl rounded bg-secondary\" />\r\n              <div className=\"h-4 w-full max-w-2xl rounded bg-secondary/80\" />\r\n              <div className=\"h-4 w-2/3 rounded bg-secondary/70\" />\r\n            </div>\r\n            <div className=\"grid gap-4 md:grid-cols-4\">\r\n              {[0, 1, 2, 3].map((item) => (\r\n                <div key={item} className=\"h-20 rounded-xl bg-secondary/60\" />\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </main>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction BookingSuccessState({ booking, restaurant, restaurantAddress, onHome, onBookings }) {\r\n  const bookingDateText = booking?.bookingDate\r\n    ? new Date(booking.bookingDate).toLocaleDateString('vi-VN', {\r\n        weekday: 'long',\r\n        day: 'numeric',\r\n        month: 'long',\r\n        year: 'numeric',\r\n      })\r\n    : 'Ngв”ңГЎy dв”ңв•Јng bГҹв•—В»a';\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n      <main className=\"flex-1 max-w-[1280px] w-full mx-auto px-4 sm:px-6 lg:px-8 py-12\">\r\n        <Card className=\"max-w-2xl mx-auto bg-card border-border p-6 sm:p-8 text-center shadow-2xl\">\r\n          <div className=\"mx-auto h-16 w-16 rounded-full bg-emerald-500/10 text-emerald-400 flex items-center justify-center\">\r\n            <Check size={34} />\r\n          </div>\r\n          <div className=\"space-y-2\">\r\n            <h1 className=\"font-serif text-3xl sm:text-4xl font-bold text-white\">в”ҖГүГҹв•‘в•–t bв”ңГЎn thв”ңГЎnh cв”ңв”Өng</h1>\r\n            <p className=\"text-sm text-muted-foreground leading-relaxed\">\r\n              Yв”ңВ¬u cГҹв•‘Вәu cГҹв•—Вәa bГҹв•‘Гӯn в”ҖГҰв”ңГә в”ҖГҰв•һв–‘Гҹв•—Гәc gГҹв•—ВЎi в”ҖГҰГҹв•‘в”җn nhв”ңГЎ hв”ңГЎng. TrГҹв•‘Гӯng thв”ңГӯi hiГҹв•—Г§n tГҹв•‘Гӯi lв”ңГЎ chГҹв•—ВҘ duyГҹв•—Г§t.\r\n            </p>\r\n          </div>\r\n\r\n          <div className=\"w-full rounded-xl border border-border bg-secondary/25 p-5 text-left\">\r\n            <div className=\"grid gap-4 sm:grid-cols-2\">\r\n              <DetailRow label=\"Mв”ңГә в”ҖГҰГҹв•‘в•–t bв”ңГЎn\" value={formatBookingCode(booking?.id || booking?._id)} mono />\r\n              <DetailRow label=\"TrГҹв•‘Гӯng thв”ңГӯi\" value=\"ChГҹв•—ВҘ duyГҹв•—Г§t\" accent />\r\n              <DetailRow label=\"Nhв”ңГЎ hв”ңГЎng\" value={restaurant?.name || 'Nhв”ңГЎ hв”ңГЎng'} />\r\n              <DetailRow label=\"ThГҹв•—ВҘi gian\" value={`${booking?.bookingTime || ''} - ${bookingDateText}`} />\r\n              <DetailRow label=\"SГҹв•—ГҰ khв”ңГӯch\" value={`${booking?.numberOfGuests || 0} ngв•һв–‘Гҹв•—ВҘi`} />\r\n              <DetailRow label=\"в”ҖГүГҹв•—ГҜa chГҹв•—Г«\" value={restaurantAddress} />\r\n            </div>\r\n            {booking?.tableNumbers?.length > 0 && (\r\n              <div className=\"mt-4 border-t border-border/60 pt-4\">\r\n                <DetailRow label=\"Bв”ңГЎn в”ҖГҰв”ңГә chГҹв•—Г¬n\" value={booking.tableNumbers.join(', ')} accent />\r\n              </div>\r\n            )}\r\n          </div>\r\n\r\n          <div className=\"grid gap-3 sm:grid-cols-2\">\r\n            <Button variant=\"outline\" onClick={onHome} className=\"border-border text-white hover:bg-secondary h-11\">\r\n              VГҹв•—Гј trang chГҹв•—Вә\r\n            </Button>\r\n            <Button onClick={onBookings} className=\"bg-primary hover:bg-primary/95 text-background font-bold h-11\">\r\n              в”ҖГүв•һГӯn в”ҖГҰГҹв•‘в•–t cГҹв•—Вәa tв”ңв”Өi\r\n            </Button>\r\n          </div>\r\n        </Card>\r\n      </main>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction StepProgress({ currentStep }) {\r\n  return (\r\n    <nav aria-label=\"TiГҹв•‘в”җn trв”ңВјnh в”ҖГҰГҹв•‘в•–t bв”ңГЎn\" className=\"rounded-xl border border-border bg-card p-3 sm:p-4\">\r\n      <div className=\"flex items-center\">\r\n        {steps.map((step, index) => (\r\n          <Fragment key={step.num}>\r\n            {index > 0 && (\r\n              <div className={cn('mx-2 h-px flex-1 sm:mx-4', currentStep >= step.num ? 'bg-primary' : 'bg-border')} />\r\n            )}\r\n            <div className=\"flex min-w-0 flex-col items-center gap-2 sm:flex-row\">\r\n              <div\r\n                className={cn(\r\n                  'h-9 w-9 rounded-full border flex items-center justify-center text-sm font-bold transition-colors',\r\n                  currentStep >= step.num\r\n                    ? 'border-primary bg-primary text-background'\r\n                    : 'border-border bg-secondary/40 text-muted-foreground'\r\n                )}\r\n              >\r\n                {currentStep > step.num ? <Check size={16} /> : step.num}\r\n              </div>\r\n              <div className=\"hidden min-w-0 sm:block\">\r\n                <p className={cn('text-sm font-bold', currentStep >= step.num ? 'text-white' : 'text-muted-foreground')}>\r\n                  {step.label}\r\n                </p>\r\n                <p className=\"text-xs text-muted-foreground\">{step.description}</p>\r\n              </div>\r\n            </div>\r\n          </Fragment>\r\n        ))}\r\n      </div>\r\n    </nav>\r\n  );\r\n}\r\n\r\nfunction StepHeader({ icon: Icon, eyebrow, title, description }) {\r\n  return (\r\n    <div className=\"flex items-start gap-4 border-b border-border/70 pb-5\">\r\n      <div className=\"h-11 w-11 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0\">\r\n        <Icon size={22} />\r\n      </div>\r\n      <div className=\"space-y-1\">\r\n        <p className=\"text-xs font-semibold uppercase tracking-[0.18em] text-primary\">{eyebrow}</p>\r\n        <h2 className=\"font-serif text-2xl sm:text-3xl font-bold text-white\">{title}</h2>\r\n        <p className=\"text-sm text-muted-foreground leading-relaxed\">{description}</p>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction StepActions({ children }) {\r\n  return (\r\n    <div className=\"flex flex-col-reverse gap-3 border-t border-border/70 pt-5 sm:flex-row sm:items-center sm:justify-between\">\r\n      {children}\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction FormField({ label, htmlFor, required, error, children }) {\r\n  return (\r\n    <div className=\"space-y-2\">\r\n      <label htmlFor={htmlFor} className=\"text-sm font-semibold text-white\">\r\n        {label} {required && <span className=\"text-primary\">*</span>}\r\n      </label>\r\n      {children}\r\n      <FieldError message={error} />\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction FieldError({ message }) {\r\n  if (!message) return null;\r\n  return <p className=\"text-xs font-semibold text-rose-400\">{message}</p>;\r\n}\r\n\r\nfunction InfoPanel({ icon: Icon = Info, title, description, action, tone = 'default' }) {\r\n  const toneClass = {\r\n    default: 'border-border bg-secondary/25 text-muted-foreground',\r\n    warning: 'border-amber-500/25 bg-amber-500/10 text-amber-100',\r\n    danger: 'border-rose-500/25 bg-rose-500/10 text-rose-100',\r\n  }[tone];\r\n\r\n  const iconClass = {\r\n    default: 'text-primary',\r\n    warning: 'text-amber-400',\r\n    danger: 'text-rose-400',\r\n  }[tone];\r\n\r\n  return (\r\n    <div className={cn('rounded-xl border p-4', toneClass)}>\r\n      <div className=\"flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between\">\r\n        <div className=\"flex gap-3\">\r\n          <Icon className={cn('h-5 w-5 shrink-0 mt-0.5', iconClass)} />\r\n          <div className=\"space-y-1\">\r\n            <p className=\"text-sm font-bold text-white\">{title}</p>\r\n            <p className=\"text-sm leading-relaxed text-muted-foreground\">{description}</p>\r\n          </div>\r\n        </div>\r\n        {action && <div className=\"shrink-0\">{action}</div>}\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction SummaryPanel({\r\n  restaurant,\r\n  restaurantAddress,\r\n  bookingDate,\r\n  bookingTime,\r\n  numberOfGuests,\r\n  selectedTables,\r\n  customerName,\r\n  customerPhone,\r\n  customerEmail,\r\n  specialRequests,\r\n  occasion,\r\n  appliedVoucher,\r\n  discountAmount,\r\n}) {\r\n  const formattedDate = bookingDate\r\n    ? new Date(`${bookingDate}T00:00:00`).toLocaleDateString('vi-VN', {\r\n        weekday: 'long',\r\n        day: 'numeric',\r\n        month: 'long',\r\n        year: 'numeric',\r\n      })\r\n    : 'Chв•һв–‘a chГҹв•—Г¬n ngв”ңГЎy';\r\n\r\n  const depositAmount = getDepositAmount(selectedTables);\r\n\r\n  return (\r\n    <section className=\"rounded-xl border border-border bg-secondary/20 p-5\">\r\n      <div className=\"flex items-center gap-3 border-b border-border/60 pb-4\">\r\n        <div className=\"h-10 w-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center\">\r\n          <Store size={20} />\r\n        </div>\r\n        <div className=\"min-w-0\">\r\n          <p className=\"text-sm font-bold text-white truncate\">{restaurant?.name || 'Nhв”ңГЎ hв”ңГЎng'}</p>\r\n          <p className=\"text-xs text-muted-foreground truncate\">{restaurantAddress}</p>\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"mt-4 grid gap-4 sm:grid-cols-2\">\r\n        <DetailRow label=\"Ngв”ңГЎy dв”ңв•Јng bГҹв•—В»a\" value={formattedDate} />\r\n        <DetailRow label=\"GiГҹв•—ВҘ dв”ңв•Јng bГҹв•—В»a\" value={bookingTime || 'Chв•һв–‘a chГҹв•—Г¬n'} accent />\r\n        <DetailRow label=\"SГҹв•—ГҰ khв”ңГӯch\" value={`${numberOfGuests} ngв•һв–‘Гҹв•—ВҘi`} />\r\n        <DetailRow\r\n          label=\"Bв”ңГЎn\"\r\n          value={selectedTables.length > 0 ? selectedTables.map((table) => table.tableNumber).join(', ') : 'Nhв”ңГЎ hв”ңГЎng tГҹв•—в–’ xГҹв•‘в”җp'}\r\n          accent={selectedTables.length > 0}\r\n        />\r\n        <DetailRow label=\"Ngв•һв–‘Гҹв•—ВҘi в”ҖГҰГҹв•‘в•–t\" value={customerName || 'Chв•һв–‘a nhГҹв•‘ВЎp'} />\r\n        <DetailRow label=\"SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi\" value={customerPhone || 'Chв•һв–‘a nhГҹв•‘ВЎp'} />\r\n        <DetailRow label=\"Email\" value={customerEmail || 'Chв•һв–‘a nhГҹв•‘ВЎp'} />\r\n        <DetailRow label=\"DГҹв•—ГҜp в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t\" value={occasion ? occasionLabels[occasion] : 'Khв”ңв”Өng cв”ңв”Ӯ'} />\r\n      </div>\r\n\r\n      {(specialRequests || appliedVoucher || depositAmount > 0) && (\r\n        <div className=\"mt-4 space-y-3 border-t border-border/60 pt-4\">\r\n          {specialRequests && <DetailRow label=\"Yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t\" value={specialRequests} />}\r\n          {appliedVoucher && <DetailRow label={`Voucher ${appliedVoucher}`} value={`-${formatCurrency(discountAmount)}`} success />}\r\n          <DetailRow label=\"TiГҹв•—Гјn cГҹв•—Г¬c dГҹв•—в–’ kiГҹв•‘в”җn\" value={depositAmount > 0 ? formatCurrency(Math.max(depositAmount - discountAmount, 0)) : '0в”ҖГҰ'} accent />\r\n        </div>\r\n      )}\r\n    </section>\r\n  );\r\n}\r\n\r\nfunction BookingAside({\r\n  restaurant,\r\n  restaurantAddress,\r\n  currentStep,\r\n  bookingDate,\r\n  bookingTime,\r\n  numberOfGuests,\r\n  selectedTables,\r\n  depositAmount,\r\n  discountAmount,\r\n  appliedVoucher,\r\n}) {\r\n  const currentStepMeta = steps.find((step) => step.num === currentStep);\r\n  const finalDeposit = Math.max(depositAmount - discountAmount, 0);\r\n\r\n  return (\r\n    <Card className=\"bg-card border-border p-5\">\r\n      <div className=\"space-y-5\">\r\n        <div>\r\n          <p className=\"text-xs font-semibold uppercase tracking-[0.18em] text-primary\">Tв”ңв”Ӯm tГҹв•‘В»t</p>\r\n          <h2 className=\"mt-1 font-serif text-2xl font-bold text-white\">Thв”ңв”Өng tin в”ҖГҰГҹв•‘в•–t bв”ңГЎn</h2>\r\n        </div>\r\n\r\n        <div className=\"rounded-xl border border-border bg-secondary/20 p-4\">\r\n          <p className=\"text-sm font-bold text-white truncate\">{restaurant?.name || 'Nhв”ңГЎ hв”ңГЎng'}</p>\r\n          <p className=\"mt-1 flex items-start gap-2 text-xs text-muted-foreground leading-relaxed\">\r\n            <MapPin size={13} className=\"text-primary shrink-0 mt-0.5\" /> {restaurantAddress}\r\n          </p>\r\n        </div>\r\n\r\n        <div className=\"space-y-3\">\r\n          <DetailRow label=\"Bв•һв–‘Гҹв•—Вўc hiГҹв•—Г§n tГҹв•‘Гӯi\" value={currentStepMeta?.label || 'в”ҖГүГҹв•‘в•–t bв”ңГЎn'} accent />\r\n          <DetailRow label=\"Ngв”ңГЎy\" value={bookingDate || 'Chв•һв–‘a chГҹв•—Г¬n'} />\r\n          <DetailRow label=\"GiГҹв•—ВҘ\" value={bookingTime || 'Chв•һв–‘a chГҹв•—Г¬n'} />\r\n          <DetailRow label=\"SГҹв•—ГҰ khв”ңГӯch\" value={`${numberOfGuests} ngв•һв–‘Гҹв•—ВҘi`} />\r\n          <DetailRow\r\n            label=\"Bв”ңГЎn\"\r\n            value={selectedTables.length > 0 ? selectedTables.map((table) => table.tableNumber).join(', ') : 'Chв•һв–‘a chГҹв•—Г¬n'}\r\n          />\r\n        </div>\r\n\r\n        <div className=\"rounded-xl border border-border bg-secondary/20 p-4 space-y-3\">\r\n          <div className=\"flex items-center gap-2 text-sm font-bold text-white\">\r\n            <Ticket size={16} className=\"text-primary\" /> Chi phв”ңВЎ dГҹв•—в–’ kiГҹв•‘в”җn\r\n          </div>\r\n          <DetailRow label=\"TiГҹв•—Гјn cГҹв•—Г¬c\" value={formatCurrency(depositAmount)} />\r\n          {appliedVoucher && <DetailRow label=\"Voucher\" value={`-${formatCurrency(discountAmount)}`} success />}\r\n          <div className=\"border-t border-border/60 pt-3\">\r\n            <DetailRow label=\"TГҹв•‘Гӯm tв”ңВЎnh\" value={formatCurrency(finalDeposit)} accent />\r\n          </div>\r\n        </div>\r\n\r\n        <p className=\"text-xs text-muted-foreground leading-relaxed\">\r\n          SГҹв•—ГҰ tiГҹв•—Гјn cГҹв•—Г¬c cв”ңв”Ӯ thГҹв•—Гў bГҹв•‘в–’ng 0 nГҹв•‘в”җu nhв”ңГЎ hв”ңГЎng khв”ңв”Өng yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в•–t cГҹв•—Г¬c cho bв”ңГЎn в”ҖГҰв”ңГә chГҹв•—Г¬n.\r\n        </p>\r\n      </div>\r\n    </Card>\r\n  );\r\n}\r\n\r\nfunction DetailRow({ label, value, accent, success, mono }) {\r\n  return (\r\n    <div className=\"min-w-0\">\r\n      <p className=\"text-[11px] font-semibold uppercase tracking-wide text-muted-foreground\">{label}</p>\r\n      <p\r\n        className={cn(\r\n          'mt-1 text-sm font-semibold text-white break-words',\r\n          accent && 'text-primary',\r\n          success && 'text-emerald-400',\r\n          mono && 'font-mono'\r\n        )}\r\n      >\r\n        {value}\r\n      </p>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\booking\\MyBookingsPage.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'RefreshCw' is defined but never used.","line":5,"column":37,"messageId":"unusedVar","endLine":5,"endColumn":46,"suggestions":[{"messageId":"removeVar","data":{"varName":"RefreshCw"},"fix":{"range":[277,288],"text":""},"desc":"Remove unused variable 'RefreshCw'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'Badge' is defined but never used.","line":9,"column":10,"messageId":"unusedVar","endLine":9,"endColumn":15,"suggestions":[{"messageId":"removeVar","data":{"varName":"Badge"},"fix":{"range":[464,514],"text":""},"desc":"Remove unused variable 'Badge'."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useCallback } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport { getMyBookings, cancelBooking } from '../../api/bookingApi';\r\nimport BookingCard from '../../components/booking/BookingCard';\r\nimport { AlertTriangle, X, Compass, RefreshCw } from 'lucide-react';\r\nimport Header from '../../components/Header';\r\nimport { Button } from '../../components/ui/button';\r\nimport { Card } from '../../components/ui/card';\r\nimport { Badge } from '../../components/ui/badge';\r\nimport toast from 'react-hot-toast';\r\nimport { ReviewFormModal } from '../../components/booking/ReviewFormModal';\r\n\r\nexport default function MyBookingsPage() {\r\n  const navigate = useNavigate();\r\n  \r\n  const [bookings, setBookings] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [filter, setFilter] = useState('all'); // all, upcoming, past, cancelled\r\n  \r\n  // Pagination\r\n  const [page, setPage] = useState(1);\r\n  const [totalPages, setTotalPages] = useState(1);\r\n  const [totalElements, setTotalElements] = useState(0);\r\n\r\n  // Cancel dialog state\r\n  const [cancellingId, setCancellingId] = useState(null);\r\n  const [cancelReason, setCancelReason] = useState('');\r\n  const [isCancelling, setIsCancelling] = useState(false);\r\n\r\n  // Review modal state\r\n  const [isReviewOpen, setIsReviewOpen] = useState(false);\r\n  const [selectedBookingForReview, setSelectedBookingForReview] = useState(null);\r\n\r\n  const handleReviewClick = (booking) => {\r\n    setSelectedBookingForReview(booking);\r\n    setIsReviewOpen(true);\r\n  };\r\n\r\n  const fetchBookings = useCallback(async () => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await getMyBookings({\r\n        filter,\r\n        page,\r\n        limit: 5,\r\n      });\r\n\r\n      if (res.success) {\r\n        setBookings(res.data.bookings || []);\r\n        setTotalPages(res.data.totalPages || 1);\r\n        setTotalElements(res.data.total || 0);\r\n      } else {\r\n        toast.error(res.message || 'LГҹв•—Г№i khi tГҹв•‘Гәi lГҹв•—ГҜch sГҹв•—ВЎ в”ҖГҰГҹв•‘в•–t bв”ңГЎn');\r\n      }\r\n    } catch (err) {\r\n      console.error(err);\r\n      toast.error('Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi lГҹв•—ГҜch sГҹв•—ВЎ в”ҖГҰГҹв•‘в•–t bв”ңГЎn');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [filter, page]);\r\n\r\n  useEffect(() => {\r\n    const timeoutId = window.setTimeout(() => {\r\n      fetchBookings();\r\n    }, 0);\r\n\r\n    return () => window.clearTimeout(timeoutId);\r\n  }, [fetchBookings]);\r\n\r\n  useEffect(() => {\r\n    const handleBookingEvent = () => {\r\n      fetchBookings();\r\n    };\r\n\r\n    window.addEventListener('bookeat:booking-event', handleBookingEvent);\r\n    return () => window.removeEventListener('bookeat:booking-event', handleBookingEvent);\r\n  }, [fetchBookings]);\r\n\r\n  // Reset page when filter changes\r\n  useEffect(() => {\r\n    const timeoutId = window.setTimeout(() => {\r\n      setPage(1);\r\n    }, 0);\r\n\r\n    return () => window.clearTimeout(timeoutId);\r\n  }, [filter]);\r\n\r\n  const handleCancelClick = (id) => {\r\n    setCancellingId(id);\r\n    setCancelReason('');\r\n  };\r\n\r\n  const handleConfirmCancel = async () => {\r\n    setIsCancelling(true);\r\n    try {\r\n      const res = await cancelBooking(cancellingId, cancelReason);\r\n      if (res.success) {\r\n        toast.success('в”ҖГүв”ңГә hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn thв”ңГЎnh cв”ңв”Өng');\r\n        setCancellingId(null);\r\n        fetchBookings(); // refresh\r\n      } else {\r\n        toast.error(res.message || 'Khв”ңв”Өng thГҹв•—Гў hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn');\r\n      }\r\n    } catch (err) {\r\n      console.error(err);\r\n      toast.error(err.message || 'LГҹв•—Г№i khi hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn');\r\n    } finally {\r\n      setIsCancelling(false);\r\n    }\r\n  };\r\n\r\n  const handleViewDetail = (id) => {\r\n    navigate(`/bookings/${id}`);\r\n  };\r\n\r\n  const renderPagination = () => {\r\n    if (totalPages <= 1) return null;\r\n    return (\r\n      <div className=\"mt-8 flex justify-center items-center gap-1.5\">\r\n        <Button\r\n          disabled={page <= 1}\r\n          onClick={() => setPage(page - 1)}\r\n          variant=\"outline\"\r\n          size=\"sm\"\r\n          className=\"border-border text-xs text-white\"\r\n        >\r\n          Trв•һв–‘Гҹв•—Вўc\r\n        </Button>\r\n        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (\r\n          <Button\r\n            key={p}\r\n            variant={p === page ? 'default' : 'outline'}\r\n            size=\"icon\"\r\n            className={`h-8 w-8 text-xs ${\r\n              p === page ? 'bg-primary text-background font-bold' : 'border-border text-white'\r\n            }`}\r\n            onClick={() => setPage(p)}\r\n          >\r\n            {p}\r\n          </Button>\r\n        ))}\r\n        <Button\r\n          disabled={page >= totalPages}\r\n          onClick={() => setPage(page + 1)}\r\n          variant=\"outline\"\r\n          size=\"sm\"\r\n          className=\"border-border text-xs text-white\"\r\n        >\r\n          Sau\r\n        </Button>\r\n      </div>\r\n    );\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n\r\n      <main className=\"flex-1 max-w-4xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-10\">\r\n        {/* Header Title */}\r\n        <div className=\"mb-8 text-left\">\r\n          <h2 className=\"text-3xl font-extrabold tracking-tight text-white sm:text-4xl\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\r\n            вүЎЖ’ГҙГҜ в”ҖГүГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa tв”ңв”Өi\r\n          </h2>\r\n          <p className=\"mt-2 text-sm text-muted-foreground\">\r\n            Xem, theo dв”ңв•Ўi trГҹв•‘Гӯng thв”ңГӯi, chi tiГҹв•‘в”җt cв”ңГӯc в”ҖГҰв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn hoГҹв•‘в•–c hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn trГҹв•—в–’c tuyГҹв•‘в”җn cГҹв•—Вәa bГҹв•‘Гӯn.\r\n          </p>\r\n        </div>\r\n\r\n        {/* Tab Filters */}\r\n        <div className=\"flex flex-wrap gap-1 bg-[#20242D] border border-border p-1 rounded-lg w-fit mb-8 justify-start text-xs font-semibold\">\r\n          {[\r\n            { value: 'all', label: 'TГҹв•‘Г‘t cГҹв•‘Гә в”ҖГҰв•һГӯn в”ҖГҰГҹв•‘в•–t' },\r\n            { value: 'upcoming', label: 'в”ҖГүang chГҹв•—ВҘ / SГҹв•‘В»p tГҹв•—Вўi' },\r\n            { value: 'past', label: 'в”ҖГүв”ңГә hoв”ңГЎn tГҹв•‘Г‘t' },\r\n            { value: 'cancelled', label: 'в”ҖГүв”ңГә hГҹв•—Вәy' },\r\n          ].map((tab) => (\r\n            <button\r\n              key={tab.value}\r\n              role=\"tab\"\r\n              onClick={() => setFilter(tab.value)}\r\n              className={`px-4 py-2 rounded-md transition-all cursor-pointer ${\r\n                filter === tab.value\r\n                  ? 'bg-primary text-background font-bold'\r\n                  : 'text-muted-foreground hover:text-white hover:bg-secondary/40'\r\n              }`}\r\n            >\r\n              {tab.label}\r\n            </button>\r\n          ))}\r\n        </div>\r\n\r\n        {/* Dynamic content listing */}\r\n        {loading ? (\r\n          <div className=\"flex flex-col gap-4\">\r\n            {[1, 2].map((n) => (\r\n              <Card key={n} className=\"h-32 bg-card border-border animate-pulse\" />\r\n            ))}\r\n          </div>\r\n        ) : bookings.length === 0 ? (\r\n          <div className=\"text-center py-20 border border-dashed border-border bg-card/20 rounded-xl flex flex-col items-center justify-center gap-4\">\r\n            <Compass size={48} className=\"text-muted-foreground animate-bounce\" />\r\n            <h3 className=\"text-lg font-bold text-white\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y в”ҖГҰГҹв•‘в•–t bв”ңГЎn nв”ңГЎo</h3>\r\n            <p className=\"text-sm text-muted-foreground max-w-sm\">\r\n              BГҹв•‘Гӯn chв•һв–‘a thГҹв•—в–’c hiГҹв•—Г§n в”ҖГҰв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn nв”ңГЎo tв•һв–‘в•һГӯng Гҹв•—вҢҗng vГҹв•—Вўi bГҹв•—Г– lГҹв•—Г¬c nв”ңГЎy.\r\n            </p>\r\n            <Button onClick={() => navigate('/')} className=\"bg-primary hover:bg-primary/95 text-background text-xs font-bold gap-1.5 h-10 px-5\">\r\n              вүЎЖ’Г¶Г¬ Khв”ңГӯm phв”ңГӯ nhв”ңГЎ hв”ңГЎng & в”ҖГҰГҹв•‘в•–t bв”ңГЎn ngay\r\n            </Button>\r\n          </div>\r\n        ) : (\r\n          <div className=\"flex flex-col gap-4 text-left\">\r\n            <p className=\"text-xs text-muted-foreground\">\r\n              Tв”ңВјm thГҹв•‘Г‘y <strong className=\"text-white font-bold\">{totalElements}</strong> kГҹв•‘в”җt quГҹв•‘Гә в”ҖГҰГҹв•‘в•–t bв”ңГЎn\r\n            </p>\r\n            {bookings.map((booking) => (\r\n              <BookingCard\r\n                key={booking.id}\r\n                booking={booking}\r\n                onViewDetail={handleViewDetail}\r\n                onCancel={handleCancelClick}\r\n                onReview={handleReviewClick}\r\n              />\r\n            ))}\r\n            {renderPagination()}\r\n          </div>\r\n        )}\r\n      </main>\r\n\r\n      {/* Cancel Confirmation Dialog */}\r\n      {cancellingId && (\r\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/75 backdrop-blur-xs animate-in fade-in duration-200\">\r\n          <div className=\"absolute inset-0 z-0\" onClick={() => setCancellingId(null)} />\r\n          \r\n          <Card className=\"relative z-10 w-full max-w-md p-6 bg-card border-border shadow-2xl flex flex-col gap-4 animate-in zoom-in-95 duration-150\">\r\n            <div className=\"flex items-center justify-between pb-3 border-b border-border/60\">\r\n              <h4 className=\"font-bold text-rose-400 flex items-center gap-2 text-sm\">\r\n                <AlertTriangle size={18} /> Xв”ңГӯc nhГҹв•‘ВЎn hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn\r\n              </h4>\r\n              <button\r\n                onClick={() => setCancellingId(null)}\r\n                className=\"p-1 rounded text-muted-foreground hover:text-white hover:bg-secondary transition focus:outline-none\"\r\n              >\r\n                <X size={18} />\r\n              </button>\r\n            </div>\r\n            \r\n            <div className=\"flex flex-col gap-4 text-xs text-left\">\r\n              <p className=\"text-muted-foreground leading-relaxed\">\r\n                BГҹв•‘Гӯn cв”ңв”Ӯ chГҹв•‘В»c chГҹв•‘В»n muГҹв•—ГҰn hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn nв”ңГЎy khв”ңв”Өng? Hв”ңГЎnh в”ҖГҰГҹв•—Г–ng nв”ңГЎy sГҹв•‘в•ң gГҹв•—ВЎi yв”ңВ¬u cГҹв•‘Вәu hГҹв•—Вәy tГҹв•—Вўi nhв”ңГЎ hв”ңГЎng vв”ңГЎ khв”ңв”Өng thГҹв•—Гў tГҹв•—в–’ hoв”ңГЎn tв”ңГӯc.\r\n              </p>\r\n              \r\n              <div className=\"flex flex-col gap-1.5\">\r\n                <label className=\"text-muted-foreground font-semibold\">Lв”ңв•ң do hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn (tв”ңв•Јy chГҹв•—Г¬n):</label>\r\n                <textarea\r\n                  rows=\"3\"\r\n                  maxLength=\"200\"\r\n                  placeholder=\"NhГҹв•‘ВЎp lв”ңв•ң do hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn tГҹв•‘Гӯi в”ҖГҰв”ңГіy...\"\r\n                  value={cancelReason}\r\n                  onChange={(e) => setCancelReason(e.target.value)}\r\n                  className=\"w-full bg-secondary/40 border border-border rounded-lg p-2.5 text-xs text-white focus:outline-none focus:ring-1 focus:ring-primary leading-relaxed\"\r\n                />\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"flex justify-end gap-2.5 pt-3 border-t border-border/40 text-xs\">\r\n              <Button variant=\"outline\" onClick={() => setCancellingId(null)} disabled={isCancelling} className=\"border-border text-white hover:bg-secondary h-9 text-xs font-semibold\">\r\n                Quay lГҹв•‘Гӯi\r\n              </Button>\r\n              <Button onClick={handleConfirmCancel} disabled={isCancelling} className=\"bg-rose-500 hover:bg-rose-600 text-white h-9 text-xs font-bold px-4\">\r\n                {isCancelling ? 'в”ҖГүang hГҹв•—Вәy...' : 'Xв”ңГӯc nhГҹв•‘ВЎn hГҹв•—Вәy в”ҖГҰГҹв•‘в•–t bв”ңГЎn'}\r\n              </Button>\r\n            </div>\r\n          </Card>\r\n        </div>\r\n      )}\r\n\r\n      {/* Review Form Dialog */}\r\n      {isReviewOpen && (\r\n        <ReviewFormModal\r\n          isOpen={isReviewOpen}\r\n          onClose={() => setIsReviewOpen(false)}\r\n          booking={selectedBookingForReview}\r\n          onSubmitSuccess={fetchBookings}\r\n        />\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\chat\\CustomerChatPage.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\home\\HomePage.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'Link' is defined but never used.","line":2,"column":10,"messageId":"unusedVar","endLine":2,"endColumn":14,"suggestions":[{"messageId":"removeVar","data":{"varName":"Link"},"fix":{"range":[55,60],"text":""},"desc":"Remove unused variable 'Link'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'Calendar' is defined but never used.","line":6,"column":26,"messageId":"unusedVar","endLine":6,"endColumn":34,"suggestions":[{"messageId":"removeVar","data":{"varName":"Calendar"},"fix":{"range":[309,319],"text":""},"desc":"Remove unused variable 'Calendar'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'Clock' is defined but never used.","line":6,"column":70,"messageId":"unusedVar","endLine":6,"endColumn":75,"suggestions":[{"messageId":"removeVar","data":{"varName":"Clock"},"fix":{"range":[353,360],"text":""},"desc":"Remove unused variable 'Clock'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'toast' is defined but never used.","line":11,"column":8,"messageId":"unusedVar","endLine":11,"endColumn":13,"suggestions":[{"messageId":"removeVar","data":{"varName":"toast"},"fix":{"range":[656,667],"text":""},"desc":"Remove unused variable 'toast'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'isAuthenticated' is assigned a value but never used.","line":14,"column":11,"messageId":"unusedVar","endLine":14,"endColumn":26,"suggestions":[{"messageId":"removeVar","data":{"varName":"isAuthenticated"},"fix":{"range":[729,767],"text":""},"desc":"Remove unused variable 'isAuthenticated'."}]}],"suppressedMessages":[],"errorCount":5,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { Link, useNavigate } from 'react-router-dom';\r\nimport { useAuth } from '../../context/useAuth';\r\nimport Header from '../../components/Header';\r\nimport { getPublicRestaurants, getPublicCuisineTypes } from '../../api/restaurantApi';\r\nimport { Search, MapPin, Calendar, Users, Star, Heart, ChevronRight, Clock, Utensils, Sparkles, AlertTriangle } from 'lucide-react';\r\nimport { Section, PhaseLabel } from '../../components/bookeat/Section';\r\nimport { Card } from '../../components/ui/card';\r\nimport { Button } from '../../components/ui/button';\r\nimport { Badge } from '../../components/ui/badge';\r\nimport toast from 'react-hot-toast';\r\n\r\nexport default function HomePage() {\r\n  const { isAuthenticated } = useAuth();\r\n  const navigate = useNavigate();\r\n\r\n  // API Data states\r\n  const [featuredRestaurants, setFeaturedRestaurants] = useState([]);\r\n  const [tonightRestaurants, setTonightRestaurants] = useState([]);\r\n  const [cuisines, setCuisines] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  // Search Fields states\r\n  const [searchQuery, setSearchQuery] = useState('');\r\n  const [selectedCuisine, setSelectedCuisine] = useState('');\r\n  const [guestsCount, setGuestsCount] = useState('2');\r\n\r\n  useEffect(() => {\r\n    const loadData = async () => {\r\n      try {\r\n        setLoading(true);\r\n        // Fetch cuisine types\r\n        const cuisineRes = await getPublicCuisineTypes();\r\n        if (cuisineRes && cuisineRes.success) {\r\n          setCuisines(cuisineRes.data.slice(0, 6) || []);\r\n        }\r\n\r\n        // Fetch featured restaurants (highest rating)\r\n        const featuredRes = await getPublicRestaurants({ limit: 3, sortBy: 'averageRating', sortDir: 'desc' });\r\n        if (featuredRes && featuredRes.success) {\r\n          setFeaturedRestaurants(featuredRes.data.restaurants || []);\r\n        }\r\n\r\n        // Fetch tonight's restaurants (most bookings/active)\r\n        const tonightRes = await getPublicRestaurants({ limit: 4, sortBy: 'totalBookings', sortDir: 'desc' });\r\n        if (tonightRes && tonightRes.success) {\r\n          setTonightRestaurants(tonightRes.data.restaurants || []);\r\n        }\r\n      } catch (err) {\r\n        console.error('Failed to load homepage data:', err.message);\r\n      } finally {\r\n        setLoading(false);\r\n      }\r\n    };\r\n    loadData();\r\n  }, []);\r\n\r\n  const handleSearchSubmit = (e) => {\r\n    e.preventDefault();\r\n    const params = new URLSearchParams();\r\n    if (searchQuery) params.append('search', searchQuery);\r\n    if (selectedCuisine) params.append('cuisineType', selectedCuisine);\r\n    navigate(`/restaurants?${params.toString()}`);\r\n  };\r\n\r\n  const selectCuisineAndSearch = (cuisine) => {\r\n    navigate(`/restaurants?cuisineType=${encodeURIComponent(cuisine)}`);\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n\r\n      {/* Hero Section */}\r\n      <section className=\"relative overflow-hidden pt-20 pb-28 md:pt-28 md:pb-40\" aria-label=\"Hero\">\r\n        {/* Background Overlay */}\r\n        <div className=\"absolute inset-0 z-0\">\r\n          <img\r\n            src=\"https://images.unsplash.com/photo-1559329007-40df8a9345d8?w=1800&q=80\"\r\n            alt=\"Hero background\"\r\n            className=\"w-full h-full object-cover opacity-20\"\r\n            loading=\"eager\"\r\n          />\r\n          <div className=\"absolute inset-0 bg-gradient-to-b from-[#0F1115]/30 via-[#0F1115]/80 to-[#0F1115]\" />\r\n        </div>\r\n\r\n        <div className=\"relative z-10 mx-auto max-w-[1280px] px-6 text-left\">\r\n          <div className=\"max-w-4xl\">\r\n            <PhaseLabel>NghГҹв•—Г§ thuГҹв•‘ВЎt Гҹв•‘вҢҗm thГҹв•—в–’c в”¬в•– tГҹв•—ВҪ 2026</PhaseLabel>\r\n\r\n            <h1\r\n              className=\"mt-6 text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-white leading-[1.05]\"\r\n              style={{ fontFamily: \"'Playfair Display', serif\" }}\r\n            >\r\n              в”ҖГүГҹв•‘в•–t bв”ңГЎn tГҹв•‘Гӯi nhГҹв•—В»ng nhв”ңГЎ hв”ңГЎng <br className=\"hidden sm:inline\" />\r\n              <span className=\"text-primary italic\">в”ҖГҰГҹв•‘в”Ӯng cГҹв•‘Г‘p</span> nhГҹв•‘Г‘t thГҹв•‘в”җ giГҹв•—Вўi.\r\n            </h1>\r\n\r\n            <p className=\"mt-6 max-w-2xl text-sm md:text-base text-[#A5ADBA] leading-relaxed\">\r\n              TГҹв•—ВҪ nhв”ңГЎ hв”ңГЎng sao Michelin danh giв”ңГӯ в”ҖГҰГҹв•‘в”җn quв”ңГӯn в”ҖГўn quen thuГҹв•—Г–c tinh tГҹв•‘в”җ О“ГҮГ¶\r\n              giГҹв•—В» chГҹв•—Г№ hoв”ңГЎn hГҹв•‘Гәo chГҹв•—Г« trong vв”ңГЎi giв”ңГіy vГҹв•—Вўi xв”ңГӯc nhГҹв•‘ВЎn tГҹв•—вҢҗc thГҹв•—ВҘi tГҹв•—ВҪ hГҹв•—Г§ thГҹв•—ГҰng BookEat.\r\n            </p>\r\n\r\n            {/* Floating Search Card */}\r\n            <Card className=\"mt-16 p-2.5 bg-card/95 border-border backdrop-blur-md max-w-4xl shadow-2xl hover:border-primary/20 transition-all duration-300\">\r\n              <form onSubmit={handleSearchSubmit} className=\"grid grid-cols-1 md:grid-cols-[1.4fr_1.1fr_1.1fr_auto] gap-2 items-center\">\r\n                {/* Search query */}\r\n                <div className=\"flex items-center gap-3 px-3.5 py-2 rounded-lg hover:bg-white/5 border border-border/40 md:border-none focus-within:ring-1 focus-within:ring-primary/40 focus-within:bg-white/5 transition duration-150\">\r\n                  <Search className=\"h-4 w-4 text-primary flex-shrink-0\" />\r\n                  <div className=\"min-w-0 flex-1\">\r\n                    <label htmlFor=\"hero-search-input\" className=\"block text-[10px] uppercase tracking-wider text-[#A5ADBA] font-semibold\">в”ҖГүГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm / Nhв”ңГЎ hв”ңГЎng</label>\r\n                    <input\r\n                      id=\"hero-search-input\"\r\n                      aria-label=\"NhГҹв•‘ВЎp tв”ңВ¬n nhв”ңГЎ hв”ңГЎng hoГҹв•‘в•–c thв”ңГЎnh phГҹв•—ГҰ\"\r\n                      type=\"text\"\r\n                      value={searchQuery}\r\n                      onChange={(e) => setSearchQuery(e.target.value)}\r\n                      placeholder=\"Tв”ңВјm tв”ңВ¬n nhв”ңГЎ hв”ңГЎng, thв”ңГЎnh phГҹв•—ГҰ...\"\r\n                      className=\"w-full bg-transparent text-xs text-white placeholder-[#A5ADBA] focus:outline-none border-none p-0 mt-0.5\"\r\n                    />\r\n                  </div>\r\n                </div>\r\n\r\n                {/* Cuisine Selector */}\r\n                <div className=\"flex items-center gap-3 px-3.5 py-2 rounded-lg hover:bg-white/5 border border-border/40 md:border-none focus-within:ring-1 focus-within:ring-primary/40 focus-within:bg-white/5 transition duration-150\">\r\n                  <Utensils className=\"h-4 w-4 text-primary flex-shrink-0\" />\r\n                  <div className=\"min-w-0 flex-1\">\r\n                    <label htmlFor=\"hero-cuisine-select\" className=\"block text-[10px] uppercase tracking-wider text-[#A5ADBA] font-semibold\">Гҹв•‘Вҝm thГҹв•—в–’c</label>\r\n                    <select\r\n                      id=\"hero-cuisine-select\"\r\n                      aria-label=\"ChГҹв•—Г¬n loГҹв•‘Гӯi hв”ңВјnh Гҹв•‘вҢҗm thГҹв•—в–’c\"\r\n                      value={selectedCuisine}\r\n                      onChange={(e) => setSelectedCuisine(e.target.value)}\r\n                      className=\"w-full bg-transparent text-xs text-white focus:outline-none border-none p-0 mt-0.5 cursor-pointer focus:ring-0\"\r\n                    >\r\n                      <option value=\"\" className=\"bg-[#1A1D24] text-white\">TГҹв•‘Г‘t cГҹв•‘Гә phong cв”ңГӯch</option>\r\n                      {cuisines.map((c) => (\r\n                        <option key={c} value={c} className=\"bg-[#1A1D24] text-white\">{c}</option>\r\n                      ))}\r\n                    </select>\r\n                  </div>\r\n                </div>\r\n\r\n                {/* Guests */}\r\n                <div className=\"flex items-center gap-3 px-3.5 py-2 rounded-lg hover:bg-white/5 border border-border/40 md:border-none focus-within:ring-1 focus-within:ring-primary/40 focus-within:bg-white/5 transition duration-150\">\r\n                  <Users className=\"h-4 w-4 text-primary flex-shrink-0\" />\r\n                  <div className=\"min-w-0 flex-1\">\r\n                    <label htmlFor=\"hero-guests-select\" className=\"block text-[10px] uppercase tracking-wider text-[#A5ADBA] font-semibold\">SГҹв•—ГҰ khв”ңГӯch</label>\r\n                    <select\r\n                      id=\"hero-guests-select\"\r\n                      aria-label=\"ChГҹв•—Г¬n sГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng khв”ңГӯch в”ҖГҰГҹв•‘в•–t bв”ңГЎn\"\r\n                      value={guestsCount}\r\n                      onChange={(e) => setGuestsCount(e.target.value)}\r\n                      className=\"w-full bg-transparent text-xs text-white focus:outline-none border-none p-0 mt-0.5 cursor-pointer focus:ring-0\"\r\n                    >\r\n                      <option value=\"1\" className=\"bg-[#1A1D24] text-white\">1 ngв•һв–‘Гҹв•—ВҘi</option>\r\n                      <option value=\"2\" className=\"bg-[#1A1D24] text-white\">2 ngв•һв–‘Гҹв•—ВҘi</option>\r\n                      <option value=\"4\" className=\"bg-[#1A1D24] text-white\">4 ngв•һв–‘Гҹв•—ВҘi</option>\r\n                      <option value=\"6\" className=\"bg-[#1A1D24] text-white\">6 ngв•һв–‘Гҹв•—ВҘi</option>\r\n                      <option value=\"8\" className=\"bg-[#1A1D24] text-white\">8+ ngв•һв–‘Гҹв•—ВҘi</option>\r\n                    </select>\r\n                  </div>\r\n                </div>\r\n\r\n                <Button type=\"submit\" className=\"bg-primary hover:bg-[#E0A968] text-background font-semibold h-11 px-6 rounded-lg transition-all duration-200 focus:ring-1 focus:ring-primary/50 w-full md:w-auto\">\r\n                  Tв”ңВјm kiГҹв•‘в”җm bв”ңГЎn\r\n                </Button>\r\n              </form>\r\n            </Card>\r\n\r\n            {/* Quick Suggestions */}\r\n            <div className=\"mt-6 flex flex-wrap gap-2 items-center\">\r\n              <span className=\"text-xs text-muted-foreground mr-1\">GГҹв•—Гәi в”ңв•ң tв”ңВјm nhanh:</span>\r\n              {['Mв”ңв”Ӯn ViГҹв•—Г§t', 'HГҹв•‘Гәi sГҹв•‘Гәn', 'Bв”ңВЎt tГҹв•‘в”җt', 'Mв”ңв”Ӯn Phв”ңГӯp', 'ThuГҹв•‘Вәn chay'].map((cuisine) => (\r\n                <button\r\n                  key={cuisine}\r\n                  onClick={() => selectCuisineAndSearch(cuisine)}\r\n                  className=\"px-3.5 py-1.5 rounded-full bg-white/5 hover:bg-white/10 border border-white/10 text-xs text-muted-foreground hover:text-white transition duration-200\"\r\n                >\r\n                  {cuisine}\r\n                </button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* Main Page Body */}\r\n      <div className=\"mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 py-16 space-y-24 flex-1 w-full\">\r\n        {/* Featured Section */}\r\n        <Section\r\n          title=\"NГҹв•—ГІi bГҹв•‘ВЎt tuГҹв•‘Вәn nв”ңГЎy\"\r\n          subtitle=\"NhГҹв•—В»ng в”ҖГҰГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm Гҹв•‘вҢҗm thГҹв•—в–’c в”ҖГҰГҹв•‘в•–c sГҹв•‘В»c do biв”ңВ¬n tГҹв•‘ВЎp viв”ңВ¬n tuyГҹв•—Гўn chГҹв•—Г¬n\"\r\n          action={\r\n            <Button\r\n              variant=\"ghost\"\r\n              onClick={() => navigate('/restaurants')}\r\n              className=\"text-primary hover:text-[#D49653] hover:bg-[#20242D] focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-2 gap-1.5 text-xs font-semibold px-3 py-2 rounded-md transition-all\"\r\n            >\r\n              Xem tГҹв•‘Г‘t cГҹв•‘Гә <ChevronRight className=\"h-4 w-4\" />\r\n            </Button>\r\n          }\r\n        >\r\n          {loading ? (\r\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\r\n              {[1, 2, 3].map((n) => (\r\n                <Card key={n} className=\"overflow-hidden bg-card border-border animate-pulse h-[340px]\" />\r\n              ))}\r\n            </div>\r\n          ) : featuredRestaurants.length === 0 ? (\r\n            <div className=\"text-center py-12 border border-dashed border-border rounded-xl\">\r\n              <AlertTriangle className=\"mx-auto text-muted-foreground mb-3\" />\r\n              <p className=\"text-muted-foreground\">HiГҹв•—Г§n chв•һв–‘a cв”ңв”Ӯ nhв”ңГЎ hв”ңГЎng nв”ң