mport { useChatSocket } from './useChatSocket';\r\n\r\nexport default function useBookingNotifications() {\r\n  const { isAuthenticated, user } = useAuth();\r\n\r\n  const handleBookingEvent = (eventName, payload) => {\r\n    // 1. Dispatch custom event for active pages to trigger refetches/updates\r\n    const event = new CustomEvent('bookeat:booking-event', {\r\n      detail: { eventName, payload },\r\n    });\r\n    window.dispatchEvent(event);\r\n\r\n    // 2. Display elegant Toast Notifications based on User Role & Event\r\n    const isOwner = user?.role === 'restaurant_owner';\r\n    const isAdmin = user?.role === 'admin';\r\n    const isCustomer = user?.role === 'customer';\r\n\r\n    const { bookingId, customerName, restaurantName, status: _status, message, reason } = payload || {};\r\n\r\n    switch (eventName) {\r\n      case 'booking:created':\r\n        if (isOwner || isAdmin) {\r\n          toast.success(\r\n            `вүЎЖ’Г¶Г¶ в”ҖГүв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn mГҹв•—Вўi! ${customerName || 'Khв”ңГӯch hв”ңГЎng'} vГҹв•—ВҪa в”ҖГҰГҹв•‘в•–t bв”ңГЎn tГҹв•‘Гӯi nhв”ңГЎ hв”ңГЎng cГҹв•—Вәa bГҹв•‘Гӯn.`,\r\n            { id: `booking-created-${bookingId}` }\r\n          );\r\n        } else if (isCustomer) {\r\n          toast.success(\r\n            `вүЎЖ’Г„Г« в”ҖГүГҹв•‘в•–t bв”ңГЎn thв”ңГЎnh cв”ңв”Өng! в”ҖГүв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn tГҹв•‘Гӯi ${restaurantName || 'nhв”ңГЎ hв”ңГЎng'} в”ҖГҰang chГҹв•—ВҘ xв”ңГӯc nhГҹв•‘ВЎn.`,\r\n            { id: `booking-created-${bookingId}` }\r\n          );\r\n        }\r\n        break;\r\n\r\n      case 'booking:confirmed':\r\n        if (isCustomer) {\r\n          toast.success(\r\n            `О“ВЈГ  TuyГҹв•—Г§t vГҹв•—ВҘi! в”ҖГүв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa bГҹв•‘Гӯn tГҹв•‘Гӯi ${restaurantName || 'nhв”ңГЎ hв”ңГЎng'} в”ҖГҰв”ңГә в”ҖГҰв•һв–‘Гҹв•—Гәc Xв”ңГјC NHГҹв•‘ВјN.`,\r\n            { id: `booking-confirmed-${bookingId}`, duration: 5000 }\r\n          );\r\n        } else if (isOwner || isAdmin) {\r\n          toast.success(\r\n            `О“ВЈГ  в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa khв”ңГӯch ${customerName || 'hв”ңГЎng'}.`,\r\n            { id: `booking-confirmed-${bookingId}` }\r\n          );\r\n        }\r\n        break;\r\n\r\n      case 'booking:cancelled': {\r\n        const cancelReasonMsg = reason ? ` Lв”ңв•ң do: \"${reason}\"` : '';\r\n        if (isCustomer) {\r\n          toast.error(\r\n            `О“ВҘГ® RГҹв•‘Г‘t tiГҹв•‘в”җc! в”ҖГүв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa bГҹв•‘Гӯn tГҹв•‘Гӯi ${restaurantName || 'nhв”ңГЎ hв”ңГЎng'} в”ҖГҰв”ңГә bГҹв•—ГҜ HГҹв•—ВӘY.${cancelReasonMsg}`,\r\n            { id: `booking-cancelled-${bookingId}`, duration: 6000 }\r\n          );\r\n        } else {\r\n          toast.error(\r\n            `О“ВҘГ® в”ҖГүв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa khв”ңГӯch ${customerName || 'hв”ңГЎng'} в”ҖГҰв”ңГә bГҹв•—ГҜ HГҹв•—ВӘY.${cancelReasonMsg}`,\r\n            { id: `booking-cancelled-${bookingId}` }\r\n          );\r\n        }\r\n        break;\r\n      }\r\n\r\n      case 'booking:completed':\r\n        if (isCustomer) {\r\n          toast.success(\r\n            `вүЎЖ’Г¬в•ңвҲ©в••Г… CГҹв•‘Гәm в•һГӯn quв”ңв•ң khв”ңГӯch! Chв”ңв•‘c bГҹв•‘Гӯn в”ҖГҰв”ңГә cв”ңв”Ӯ mГҹв•—Г–t bГҹв•—В»a в”ҖГўn ngon miГҹв•—Г§ng tГҹв•‘Гӯi ${restaurantName || 'nhв”ңГЎ hв”ңГЎng'}.`,\r\n            { id: `booking-completed-${bookingId}` }\r\n          );\r\n        } else {\r\n          toast.success(\r\n            `вүЎЖ’Г¬в•ңвҲ©в••Г… в”ҖГүв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa khв”ңГӯch ${customerName || 'hв”ңГЎng'} в”ҖГҰв”ңГә hoв”ңГЎn tГҹв•‘Г‘t dв”ңв•Јng bГҹв•—В»a.`,\r\n            { id: `booking-completed-${bookingId}` }\r\n          );\r\n        }\r\n        break;\r\n\r\n      case 'booking:no_show':\r\n        if (isOwner || isAdmin) {\r\n          toast.error(\r\n            `вүЎЖ’ГҰГұ Khв”ңГӯch hв”ңГЎng ${customerName || ''} vГҹв•‘В»ng mГҹв•‘в•–t (No-Show).`,\r\n            { id: `booking-noshow-${bookingId}` }\r\n          );\r\n        } else if (isCustomer) {\r\n          toast.error(\r\n            `вүЎЖ’ГҰГұ в”ҖГүв•һГӯn в”ҖГҰГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa bГҹв•‘Гӯn в”ҖГҰв”ңГә bГҹв•—ГҜ в”ҖГҰв”ңГӯnh dГҹв•‘Г‘u vГҹв•‘В»ng mГҹв•‘в•–t (No-Show).`,\r\n            { id: `booking-noshow-${bookingId}` }\r\n          );\r\n        }\r\n        break;\r\n\r\n      default:\r\n        if (message) {\r\n          toast(message, { id: `booking-generic-${bookingId || Date.now()}` });\r\n        }\r\n        break;\r\n    }\r\n  };\r\n\r\n  // Connect to the socket for booking updates only if user is logged in\r\n  useChatSocket({\r\n    enabled: !!isAuthenticated,\r\n    onBookingEvent: handleBookingEvent,\r\n  });\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\hooks\\useChatSocket.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\hooks\\useWaitlistNotifications.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\main.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminBookingDetail.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  45 |\n  46 |   useEffect(() => {\n> 47 |     fetchDetail();\n     |     ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  48 |   }, [id]);\n  49 |\n  50 |","line":47,"column":5,"endLine":47,"endColumn":16},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchDetail'. Either include it or remove the dependency array.","line":48,"column":6,"endLine":48,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [fetchDetail, id]","fix":{"range":[1552,1556],"text":"[fetchDetail, id]"}}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { useParams, useNavigate } from 'react-router-dom';\r\nimport { adminApi } from '../../api/adminApi';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport toast from 'react-hot-toast';\r\nimport {\r\n  ArrowLeft, CalendarDays, Clock, Users, User, Store,\r\n  MapPin, Phone, Mail, Save,\r\n} from 'lucide-react';\r\n\r\nconst STATUSES = [\r\n  { value: 'pending', label: 'ChГҹв•—ВҘ xв”ңГӯc nhГҹв•‘ВЎn' },\r\n  { value: 'confirmed', label: 'в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn' },\r\n  { value: 'completed', label: 'в”ҖГүв”ңГә hoв”ңГЎn thв”ңГЎnh' },\r\n  { value: 'cancelled', label: 'в”ҖГүв”ңГә hГҹв•—Вәy' },\r\n  { value: 'no_show', label: 'Khв”ңГӯch khв”ңв”Өng в”ҖГҰГҹв•‘в”җn' },\r\n];\r\n\r\nexport default function AdminBookingDetail() {\r\n  const { id } = useParams();\r\n  const navigate = useNavigate();\r\n  const [booking, setBooking] = useState(null);\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  // Status edit state\r\n  const [status, setStatus] = useState('');\r\n  const [note, setNote] = useState('');\r\n  const [internalNotes, setInternalNotes] = useState('');\r\n  const [saving, setSaving] = useState(false);\r\n\r\n  const fetchDetail = async () => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await adminApi.getBookingById(id);\r\n      setBooking(res.data);\r\n      setStatus(res.data.status);\r\n      setInternalNotes(res.data.internalNotes || '');\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi chi tiГҹв•‘в”җt в”ҖГҰГҹв•‘в•–t bв”ңГЎn');\r\n      navigate('/admin/bookings');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    fetchDetail();\r\n  }, [id]);\r\n\r\n\r\n  const handleUpdateStatus = async () => {\r\n    if (status === booking.status && internalNotes === (booking.internalNotes || '')) {\r\n      toast('Khв”ңв”Өng cв”ңв”Ӯ thay в”ҖГҰГҹв•—ГІi nв”ңГЎo', { icon: 'О“ГӨв•ЈвҲ©в••Г…' });\r\n      return;\r\n    }\r\n\r\n    setSaving(true);\r\n    try {\r\n      const res = await adminApi.updateBookingStatus(id, { status, note, internalNotes });\r\n      toast.success(res.message);\r\n      setBooking(res.data);\r\n      setNote(''); // reset note input after success\r\n    } catch (err) {\r\n      toast.error(err.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setSaving(false);\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <AdminLayout title=\"Chi tiГҹв•‘в”җt в”ҖГүГҹв•‘в•–t bв”ңГЎn\">\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-3 bg-[#1A1D24] border border-zinc-800 rounded-xl\">\r\n          <div className=\"w-8 h-8 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\r\n          <span className=\"text-sm\">в”ҖГүang tГҹв•‘Гәi thв”ңв”Өng tin...</span>\r\n        </div>\r\n      </AdminLayout>\r\n    );\r\n  }\r\n\r\n  if (!booking) return null;\r\n\r\n  const getStatusBadge = (s) => {\r\n    switch (s) {\r\n      case 'pending':\r\n        return <span className=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-500/10 text-amber-400 border border-amber-500/20\">ChГҹв•—ВҘ xв”ңГӯc nhГҹв•‘ВЎn</span>;\r\n      case 'confirmed':\r\n        return <span className=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-500/10 text-blue-450 border border-blue-500/20\">в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn</span>;\r\n      case 'completed':\r\n        return <span className=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-500/10 text-emerald-450 border border-emerald-500/20\">Hoв”ңГЎn thв”ңГЎnh</span>;\r\n      case 'cancelled':\r\n        return <span className=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-rose-500/10 text-rose-450 border border-rose-500/20\">в”ҖГүв”ңГә hГҹв•—Вәy</span>;\r\n      case 'no_show':\r\n      default:\r\n        return <span className=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-zinc-500/10 text-zinc-400 border border-zinc-550/20\">Khв”ңв”Өng в”ҖГҰГҹв•‘в”җn</span>;\r\n    }\r\n  };\r\n\r\n  return (\r\n    <AdminLayout title=\"Chi tiГҹв•‘в”җt в”ҖГүГҹв•‘в•–t bв”ңГЎn\" subtitle={`Mв”ңГә: ${booking.id.substring(0, 8).toUpperCase()}`}>\r\n      <div className=\"mb-6\">\r\n        <button \r\n          className=\"inline-flex items-center gap-1.5 px-3 py-1.5 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 text-xs font-semibold rounded-lg transition duration-150\" \r\n          onClick={() => navigate('/admin/bookings')}\r\n        >\r\n          <ArrowLeft size={14} /> Quay lГҹв•‘Гӯi danh sв”ңГӯch\r\n        </button>\r\n      </div>\r\n\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\r\n        {/* Left Column */}\r\n        <div className=\"lg:col-span-2 space-y-6\">\r\n          {/* Booking Info */}\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n            <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">Thв”ңв”Өng tin в”ҖГүГҹв•‘в•–t bв”ңГЎn</h3>\r\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n              <div className=\"flex flex-col gap-1\">\r\n                <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><CalendarDays size={12} /> Ngв”ңГЎy в”ҖГҰГҹв•‘в•–t</span>\r\n                <span className=\"text-sm font-semibold text-zinc-200\">\r\n                  {new Date(booking.bookingDate).toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}\r\n                </span>\r\n              </div>\r\n              <div className=\"flex flex-col gap-1\">\r\n                <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><Clock size={12} /> GiГҹв•—ВҘ в”ҖГҰГҹв•‘в•–t</span>\r\n                <span className=\"text-sm font-semibold text-amber-500 font-mono\">{booking.bookingTime}</span>\r\n              </div>\r\n              <div className=\"flex flex-col gap-1\">\r\n                <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><Users size={12} /> SГҹв•—ГҰ lв•һв–‘Гҹв•—Гәng khв”ңГӯch</span>\r\n                <span className=\"text-sm text-zinc-200 font-medium\">{booking.numberOfGuests} ngв•һв–‘Гҹв•—ВҘi</span>\r\n              </div>\r\n              <div className=\"flex flex-col gap-1\">\r\n                <span className=\"text-xs text-zinc-500\">DГҹв•—ГҜp в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t (Occasion)</span>\r\n                <span className=\"text-sm text-zinc-200 font-medium capitalize\">{booking.occasion || 'Khв”ңв”Өng cв”ңв”Ӯ'}</span>\r\n              </div>\r\n              <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                <span className=\"text-xs text-zinc-500\">Yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t</span>\r\n                <span className=\"text-xs text-zinc-400 bg-zinc-900/40 border border-zinc-805 p-2.5 rounded-lg leading-relaxed\">\r\n                  {booking.specialRequests || 'Khв”ңв”Өng cв”ңв”Ӯ yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в•–c biГҹв•—Г§t'}\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Customer Info */}\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n            <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">Thв”ңв”Өng tin Khв”ңГӯch hв”ңГЎng</h3>\r\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n              <div className=\"flex flex-col gap-1\">\r\n                <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><User size={12} /> Tв”ңВ¬n khв”ңГӯch hв”ңГЎng</span>\r\n                <span className=\"text-sm font-bold text-zinc-200\">{booking.customerName}</span>\r\n              </div>\r\n              <div className=\"flex flex-col gap-1\">\r\n                <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><Phone size={12} /> в”ҖГүiГҹв•—Г§n thoГҹв•‘Гӯi</span>\r\n                <span className=\"text-sm font-mono text-zinc-200\">{booking.customerPhone}</span>\r\n              </div>\r\n              <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><Mail size={12} /> Email</span>\r\n                <span className=\"text-sm text-zinc-300\">{booking.customerEmail}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Restaurant Info */}\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n            <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">Nhв”ңГЎ hв”ңГЎng</h3>\r\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n              <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><Store size={12} /> Tв”ңВ¬n nhв”ңГЎ hв”ңГЎng</span>\r\n                <span className=\"text-sm font-bold text-amber-500\">{booking.restaurantId?.name || 'N/A'}</span>\r\n              </div>\r\n              <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><MapPin size={12} /> в”ҖГүГҹв•—ГҜa chГҹв•—Г«</span>\r\n                <span className=\"text-sm text-zinc-300 leading-relaxed\">\r\n                  {booking.restaurantId?.address?.fullAddress || \r\n                   `${booking.restaurantId?.address?.street || ''}, ${booking.restaurantId?.address?.district || ''}, ${booking.restaurantId?.address?.city || ''}`}\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Right Column */}\r\n        <div className=\"space-y-6\">\r\n          {/* Status Update */}\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n            <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">TrГҹв•‘Гӯng thв”ңГӯi & CГҹв•‘ВЎp nhГҹв•‘ВЎt</h3>\r\n            \r\n            <div className=\"flex flex-col gap-1 mb-5\">\r\n              <span className=\"text-xs text-zinc-500\">TrГҹв•‘Гӯng thв”ңГӯi hiГҹв•—Г§n tГҹв•‘Гӯi:</span>\r\n              <span className=\"mt-1\">\r\n                {getStatusBadge(booking.status)}\r\n              </span>\r\n            </div>\r\n\r\n            <div className=\"flex flex-col gap-1.5 mb-4\">\r\n              <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">CГҹв•‘ВЎp nhГҹв•‘ВЎt trГҹв•‘Гӯng thв”ңГӯi:</label>\r\n              <select\r\n                className=\"bg-[#13161C] border border-zinc-800 text-zinc-300 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500\"\r\n                value={status}\r\n                onChange={(e) => setStatus(e.target.value)}\r\n              >\r\n                {STATUSES.map(s => (\r\n                  <option key={s.value} value={s.value}>{s.label}</option>\r\n                ))}\r\n              </select>\r\n            </div>\r\n\r\n            {status !== booking.status && (\r\n              <div className=\"flex flex-col gap-1.5 mb-4\">\r\n                <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">Ghi chв”ңв•‘ в”ҖГҰГҹв•—ГІi trГҹв•‘Гӯng thв”ңГӯi (GГҹв•—ВЎi cho khв”ңГӯch/nhв”ңГЎ hв”ңГЎng):</label>\r\n                <input\r\n                  type=\"text\"\r\n                  className=\"bg-[#13161C] border border-zinc-800 text-zinc-200 placeholder-zinc-600 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500\"\r\n                  placeholder=\"Vd: Quв”ңГӯ giГҹв•—ВҘ, Khв”ңГӯch yв”ңВ¬u cГҹв•‘Вәu hГҹв•—Вәy...\"\r\n                  value={note}\r\n                  onChange={(e) => setNote(e.target.value)}\r\n                />\r\n              </div>\r\n            )}\r\n\r\n            <div className=\"flex flex-col gap-1.5 mb-5\">\r\n              <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">Ghi chв”ңв•‘ nГҹв•—Г–i bГҹв•—Г– (ChГҹв•—Г« Admin xem):</label>\r\n              <textarea\r\n                className=\"bg-[#13161C] border border-zinc-800 text-zinc-200 placeholder-zinc-600 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 resize-none\"\r\n                rows={3}\r\n                placeholder=\"Ghi chв”ңв•‘ nГҹв•—Г–i bГҹв•—Г– cho quГҹв•‘Гәn trГҹв•—ГҜ viв”ңВ¬n...\"\r\n                value={internalNotes}\r\n                onChange={(e) => setInternalNotes(e.target.value)}\r\n              />\r\n            </div>\r\n\r\n            <button\r\n              className=\"w-full flex items-center justify-center gap-1.5 py-2.5 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-black font-bold text-xs rounded-lg transition shadow-lg shadow-amber-500/10 disabled:opacity-50\"\r\n              onClick={handleUpdateStatus}\r\n              disabled={saving}\r\n            >\r\n              <Save size={14} /> {saving ? 'в”ҖГүang lв•һв–‘u...' : 'Lв•һв–‘u cГҹв•‘ВЎp nhГҹв•‘ВЎt'}\r\n            </button>\r\n          </div>\r\n\r\n          {/* Status History */}\r\n          {booking.statusHistory && booking.statusHistory.length > 0 && (\r\n            <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n              <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">LГҹв•—ГҜch sГҹв•—ВЎ trГҹв•‘Гӯng thв”ңГӯi</h3>\r\n              <div className=\"relative border-l border-zinc-800 ml-3 pl-6 space-y-5\">\r\n                {booking.statusHistory.slice().reverse().map((hist, idx) => (\r\n                  <div key={idx} className=\"relative\">\r\n                    {/* Dot marker */}\r\n                    <div className=\"absolute -left-[30px] top-1.5 w-2.5 h-2.5 rounded-full bg-amber-500 border border-black shadow\" />\r\n                    \r\n                    <div className=\"space-y-1\">\r\n                      <div className=\"flex flex-wrap items-center gap-2\">\r\n                        {getStatusBadge(hist.status)}\r\n                        <span className=\"text-[10px] text-zinc-500 font-mono\">\r\n                          {new Date(hist.changedAt).toLocaleString('vi-VN')}\r\n                        </span>\r\n                      </div>\r\n                      {hist.note && (\r\n                        <div className=\"text-xs text-zinc-400 italic bg-zinc-900/40 p-2 rounded border border-zinc-805 mt-1\">\r\n                          <strong>Ghi chв”ңв•‘:</strong> {hist.note}\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n      </div>\r\n    </AdminLayout>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminBookings.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminChatPage.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminDashboard.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  30 |\n  31 |   useEffect(() => {\n> 32 |     fetchDashboard();\n     |     ^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  33 |   }, []);\n  34 |\n  35 |   return (","line":32,"column":5,"endLine":32,"endColumn":19}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport { adminApi } from '../../api/adminApi';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport RestaurantStatsCards from '../../components/admin/RestaurantStatsCards';\r\nimport {\r\n  Users, UserCheck, UserX,\r\n  MailCheck, RefreshCw, Loader2\r\n} from 'lucide-react';\r\nimport { Button } from '../../components/ui/button';\r\n\r\nexport default function AdminDashboard() {\r\n  const [loading, setLoading] = useState(true);\r\n  const [error, setError] = useState(null);\r\n  const [data, setData] = useState(null);\r\n  const navigate = useNavigate();\r\n\r\n  const fetchDashboard = async () => {\r\n    setLoading(true);\r\n    setError(null);\r\n    try {\r\n      const res = await adminApi.getDashboard();\r\n      setData(res.data);\r\n    } catch (err) {\r\n      setError(err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi dГҹв•—В» liГҹв•—Г§u');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    fetchDashboard();\r\n  }, []);\r\n\r\n  return (\r\n    <AdminLayout title=\"TГҹв•—ГІng quan\" subtitle=\"HГҹв•—Г§ thГҹв•—ГҰng bв”ңГӯo cв”ңГӯo vв”ңГЎ hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng BookEat\">\r\n      {loading && (\r\n        <div className=\"flex flex-col items-center justify-center py-20 gap-3 text-sm text-muted-foreground\">\r\n          <Loader2 className=\"h-8 w-8 animate-spin text-primary\" />\r\n          <span>в”ҖГүang tГҹв•‘Гәi dГҹв•—В» liГҹв•—Г§u tГҹв•—ГІng quan...</span>\r\n        </div>\r\n      )}\r\n\r\n      {error && (\r\n        <div className=\"p-8 text-center max-w-md mx-auto my-10 border border-destructive/20 bg-destructive/10 rounded-2xl\">\r\n          <p className=\"text-sm text-destructive font-medium mb-4\">{error}</p>\r\n          <Button\r\n            variant=\"outline\"\r\n            size=\"sm\"\r\n            onClick={fetchDashboard}\r\n            className=\"border-destructive/35 text-destructive hover:bg-destructive/10 text-xs gap-1.5\"\r\n          >\r\n            <RefreshCw size={14} /> ThГҹв•—ВЎ lГҹв•‘Гӯi\r\n          </Button>\r\n        </div>\r\n      )}\r\n\r\n      {data && !loading && (\r\n        <div className=\"space-y-6\">\r\n          {/* KPI Cards */}\r\n          <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\r\n            <div \r\n              className=\"bg-card border border-border rounded-xl p-5 flex items-center gap-4 hover:border-primary/30 transition-all cursor-pointer text-left\"\r\n              onClick={() => navigate('/admin/users')}\r\n            >\r\n              <div className=\"w-11 h-11 rounded-lg bg-blue-500/12 text-blue-400 flex items-center justify-center shrink-0\">\r\n                <Users size={20} />\r\n              </div>\r\n              <div className=\"flex flex-col\">\r\n                <span className=\"text-2xl font-bold text-white\">{data.overview.totalUsers}</span>\r\n                <span className=\"text-xs text-muted-foreground mt-0.5\">TГҹв•—ГІng ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng</span>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"bg-card border border-border rounded-xl p-5 flex items-center gap-4 hover:border-emerald-500/35 transition-all text-left\">\r\n              <div className=\"w-11 h-11 rounded-lg bg-emerald-500/12 text-emerald-400 flex items-center justify-center shrink-0\">\r\n                <UserCheck size={20} />\r\n              </div>\r\n              <div className=\"flex flex-col\">\r\n                <span className=\"text-2xl font-bold text-emerald-400\">{data.overview.activeUsers}</span>\r\n                <span className=\"text-xs text-muted-foreground mt-0.5\">в”ҖГүang hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng</span>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"bg-card border border-border rounded-xl p-5 flex items-center gap-4 hover:border-rose-500/35 transition-all text-left\">\r\n              <div className=\"w-11 h-11 rounded-lg bg-rose-500/12 text-rose-450 flex items-center justify-center shrink-0\">\r\n                <UserX size={20} />\r\n              </div>\r\n              <div className=\"flex flex-col\">\r\n                <span className=\"text-2xl font-bold text-rose-450\">{data.overview.inactiveUsers}</span>\r\n                <span className=\"text-xs text-muted-foreground mt-0.5\">в”ҖГүв”ңГә vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa</span>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"bg-card border border-border rounded-xl p-5 flex items-center gap-4 hover:border-amber-500/35 transition-all text-left\">\r\n              <div className=\"w-11 h-11 rounded-lg bg-amber-550/12 text-primary flex items-center justify-center shrink-0\">\r\n                <MailCheck size={20} />\r\n              </div>\r\n              <div className=\"flex flex-col\">\r\n                <span className=\"text-2xl font-bold text-white\">{data.overview.verifiedUsers}</span>\r\n                <span className=\"text-xs text-muted-foreground mt-0.5\">в”ҖГүв”ңГә xв”ңГӯc minh email</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Restaurant Stats */}\r\n          <div>\r\n            <h3 className=\"font-serif text-base font-bold text-white mb-4 text-left\">ThГҹв•—ГҰng kв”ңВ¬ trГҹв•‘Гӯng thв”ңГӯi nhв”ңГЎ hв”ңГЎng</h3>\r\n            <RestaurantStatsCards stats={data.restaurantStats} />\r\n          </div>\r\n\r\n          {/* Role Distribution & Trend */}\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n            {/* Phв”ңГіn bГҹв•—ГҰ theo Role */}\r\n            <div className=\"bg-card border border-border rounded-xl p-6 text-left\">\r\n              <h3 className=\"font-serif text-base font-bold text-white mb-6\">Phв”ңГіn bГҹв•—ГҰ vai trв”ңв–“ (Role)</h3>\r\n              <div className=\"space-y-4\">\r\n                <div className=\"space-y-2\">\r\n                  <div className=\"flex justify-between items-center text-xs\">\r\n                    <span className=\"text-muted-foreground\">Khв”ңГӯch hв”ңГЎng</span>\r\n                    <span className=\"font-bold text-white\">{data.overview.totalCustomers}</span>\r\n                  </div>\r\n                  <div className=\"h-2 bg-[#0F1115] rounded-full overflow-hidden\">\r\n                    <div\r\n                      className=\"h-full bg-gradient-to-r from-blue-600 to-blue-400 rounded-full\"\r\n                      style={{ width: `${data.overview.totalUsers > 0 ? (data.overview.totalCustomers / data.overview.totalUsers) * 100 : 0}%` }}\r\n                    />\r\n                  </div>\r\n                </div>\r\n                <div className=\"space-y-2\">\r\n                  <div className=\"flex justify-between items-center text-xs\">\r\n                    <span className=\"text-muted-foreground\">ChГҹв•—Вә nhв”ңГЎ hв”ңГЎng</span>\r\n                    <span className=\"font-bold text-white\">{data.overview.totalOwners}</span>\r\n                  </div>\r\n                  <div className=\"h-2 bg-[#0F1115] rounded-full overflow-hidden\">\r\n                    <div\r\n                      className=\"h-full bg-gradient-to-r from-emerald-600 to-emerald-400 rounded-full\"\r\n                      style={{ width: `${data.overview.totalUsers > 0 ? (data.overview.totalOwners / data.overview.totalUsers) * 100 : 0}%` }}\r\n                    />\r\n                  </div>\r\n                </div>\r\n                <div className=\"space-y-2\">\r\n                  <div className=\"flex justify-between items-center text-xs\">\r\n                    <span className=\"text-muted-foreground\">QuГҹв•‘Гәn trГҹв•—ГҜ viв”ңВ¬n (Admin)</span>\r\n                    <span className=\"font-bold text-white\">{data.overview.totalAdmins}</span>\r\n                  </div>\r\n                  <div className=\"h-2 bg-[#0F1115] rounded-full overflow-hidden\">\r\n                    <div\r\n                      className=\"h-full bg-gradient-to-r from-amber-600 to-amber-400 rounded-full\"\r\n                      style={{ width: `${data.overview.totalUsers > 0 ? (data.overview.totalAdmins / data.overview.totalUsers) * 100 : 0}%` }}\r\n                    />\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            {/* Registration Trend */}\r\n            <div className=\"bg-card border border-border rounded-xl p-6 text-left\">\r\n              <h3 className=\"font-serif text-base font-bold text-white mb-6\">в”ҖГүв”ҖГўng kв”ңв•ң mГҹв•—Вўi 7 ngв”ңГЎy qua</h3>\r\n              {data.registrationTrend.length === 0 ? (\r\n                <div className=\"p-10 text-center text-xs text-muted-foreground\">Chв•һв–‘a cв”ңв”Ӯ dГҹв•—В» liГҹв•—Г§u thГҹв•—ГҰng kв”ңВ¬</div>\r\n              ) : (\r\n                <div className=\"flex items-end gap-2.5 h-[140px] pt-2\">\r\n                  {data.registrationTrend.map((item) => {\r\n                    const max = Math.max(...data.registrationTrend.map((i) => i.count), 1);\r\n                    return (\r\n                      <div key={item.date} className=\"flex-1 flex flex-col items-center gap-1.5 h-full\">\r\n                        <div className=\"flex-1 w-full flex items-end bg-[#0F1115]/40 rounded-t-md overflow-hidden\">\r\n                          <div\r\n                            className=\"w-full bg-gradient-to-t from-primary/30 to-primary rounded-t-md min-h-[4px]\"\r\n                            style={{ height: `${(item.count / max) * 100}%` }}\r\n                          />\r\n                        </div>\r\n                        <span className=\"text-[10px] font-bold text-white\">{item.count}</span>\r\n                        <span className=\"text-[9px] text-muted-foreground/80\">\r\n                          {new Date(item.date).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' })}\r\n                        </span>\r\n                      </div>\r\n                    );\r\n                  })}\r\n                </div>\r\n              )}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Recent Users */}\r\n          <div className=\"bg-card border border-border rounded-xl p-6 text-left shadow-lg\">\r\n            <div className=\"flex justify-between items-center mb-6\">\r\n              <h3 className=\"font-serif text-base font-bold text-white\">Thв”ңГЎnh viв”ңВ¬n mГҹв•—Вўi nhГҹв•‘Г‘t</h3>\r\n              <Button\r\n                variant=\"link\"\r\n                size=\"sm\"\r\n                onClick={() => navigate('/admin/users')}\r\n                className=\"text-primary hover:underline hover:text-primary/90 p-0 h-auto\"\r\n              >\r\n                Xem tГҹв•‘Г‘t cГҹв•‘Гә О“ГҘГҶ\r\n              </Button>\r\n            </div>\r\n            {data.recentUsers.length === 0 ? (\r\n              <div className=\"p-8 text-center text-xs text-muted-foreground\">Chв•һв–‘a cв”ңв”Ӯ ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng nв”ңГЎo в”ҖГҰв”ҖГўng kв”ңв•ң mГҹв•—Вўi.</div>\r\n            ) : (\r\n              <div className=\"overflow-x-auto\">\r\n                <table className=\"w-full border-collapse text-left\">\r\n                  <thead>\r\n                    <tr className=\"border-b border-border bg-[#0F1115]/50 text-muted-foreground text-xs font-semibold uppercase tracking-wider\">\r\n                      <th className=\"p-4\">Ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng</th>\r\n                      <th className=\"p-4\">Vai trв”ңв–“ (Role)</th>\r\n                      <th className=\"p-4\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n                      <th className=\"p-4\">Ngв”ңГЎy tham gia</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody className=\"divide-y divide-border/60 text-sm\">\r\n                    {data.recentUsers.map((user) => (\r\n                      <tr key={user.id} className=\"hover:bg-secondary/10 transition-colors\">\r\n                        <td className=\"p-4\">\r\n                          <div className=\"flex items-center gap-3\">\r\n                            <div className=\"w-8 h-8 rounded-full bg-primary/10 border border-primary/20 text-primary flex items-center justify-center text-xs font-bold shrink-0\">\r\n                              {user.fullName?.[0]?.toUpperCase() || '?'}\r\n                            </div>\r\n                            <div className=\"min-w-0\">\r\n                              <div className=\"font-semibold text-white truncate max-w-xs\">{user.fullName}</div>\r\n                              <div className=\"text-xs text-muted-foreground truncate max-w-xs mt-0.5\">{user.email}</div>\r\n                            </div>\r\n                          </div>\r\n                        </td>\r\n                        <td className=\"p-4\">\r\n                          <span className={`inline-block px-2.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider border ${\r\n                            user.role === 'admin' \r\n                              ? 'bg-amber-500/15 text-amber-400 border-amber-500/30' \r\n                              : user.role === 'restaurant_owner' \r\n                                ? 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30' \r\n                                : 'bg-blue-500/15 text-blue-400 border-blue-500/30'\r\n                          }`}>\r\n                            {user.role === 'admin' ? 'Admin' : user.role === 'restaurant_owner' ? 'ChГҹв•—Вә nhв”ңГЎ hв”ңГЎng' : 'Khв”ңГӯch hв”ңГЎng'}\r\n                          </span>\r\n                        </td>\r\n                        <td className=\"p-4\">\r\n                          <span className={`inline-flex items-center gap-1.5 text-xs font-medium ${\r\n                            user.active ? 'text-emerald-400' : 'text-rose-450'\r\n                          }`}>\r\n                            <span className={`w-1.5 h-1.5 rounded-full ${user.active ? 'bg-emerald-500' : 'bg-rose-500'}`} />\r\n                            {user.active ? 'HoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng' : 'Vв”ңв”Ө hiГҹв•—Г§u'}\r\n                          </span>\r\n                        </td>\r\n                        <td className=\"p-4 text-xs text-muted-foreground\">\r\n                          {new Date(user.createdAt).toLocaleDateString('vi-VN')}\r\n                        </td>\r\n                      </tr>\r\n                    ))}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n    </AdminLayout>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminRefunds.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  28 |   };\n  29 |\n> 30 |   useEffect(() => { loadRefunds(); }, [filter]);\n     |                     ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  31 |\n  32 |\n  33 |   const handleAction = async () => {","line":30,"column":21,"endLine":30,"endColumn":32},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadRefunds'. Either include it or remove the dependency array.","line":30,"column":39,"endLine":30,"endColumn":47,"suggestions":[{"desc":"Update the dependencies array to be: [filter, loadRefunds]","fix":{"range":[1369,1377],"text":"[filter, loadRefunds]"}}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState } from 'react';\r\nimport { RefreshCw, Check, X, DollarSign } from 'lucide-react';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport { adminGetRefunds, adminApproveRefund, adminRejectRefund, adminProcessRefund } from '../../api/paymentApi';\r\n\r\nconst formatMoney = (v) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND', maximumFractionDigits: 0 }).format(v || 0);\r\nconst formatDate = (d) => d ? new Date(d).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'О“ГҮГ¶';\r\n\r\nexport default function AdminRefunds() {\r\n  const [refunds, setRefunds] = useState([]);\r\n  const [loading, setLoading] = useState(false);\r\n  const [filter, setFilter] = useState('');\r\n  const [actionModal, setActionModal] = useState(null); // { type: 'approve'|'reject'|'process', refund }\r\n  const [note, setNote] = useState('');\r\n  const [refId, setRefId] = useState('');\r\n  const [processing, setProcessing] = useState(false);\r\n\r\n  const loadRefunds = async () => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await adminGetRefunds({ status: filter || undefined, limit: 50 });\r\n      setRefunds(res.data || []);\r\n    } catch (e) {\r\n      console.error(e);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => { loadRefunds(); }, [filter]);\r\n\r\n\r\n  const handleAction = async () => {\r\n    if (!actionModal) return;\r\n    setProcessing(true);\r\n    try {\r\n      if (actionModal.type === 'approve') {\r\n        await adminApproveRefund(actionModal.refund._id, { adminNote: note });\r\n      } else if (actionModal.type === 'reject') {\r\n        await adminRejectRefund(actionModal.refund._id, { adminNote: note });\r\n      } else if (actionModal.type === 'process') {\r\n        await adminProcessRefund(actionModal.refund._id, { adminNote: note, gatewayRefundId: refId });\r\n      }\r\n      setActionModal(null);\r\n      setNote('');\r\n      setRefId('');\r\n      loadRefunds();\r\n    } catch (e) {\r\n      alert(e.message || 'LГҹв•—Г№i xГҹв•—ВЎ lв”ңв•ң');\r\n    } finally {\r\n      setProcessing(false);\r\n    }\r\n  };\r\n\r\n  const statusLabels = {\r\n    requested: 'ChГҹв•—ВҘ duyГҹв•—Г§t',\r\n    approved: 'в”ҖГүв”ңГә duyГҹв•—Г§t',\r\n    rejected: 'TГҹв•—ВҪ chГҹв•—ГҰi',\r\n    refunded: 'в”ҖГүв”ңГә hoв”ңГЎn tiГҹв•—Гјn',\r\n    processing: 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң',\r\n    cancelled: 'в”ҖГүв”ңГә hГҹв•—Вәy',\r\n  };\r\n\r\n  const getStatusClasses = (status) => {\r\n    switch (status) {\r\n      case 'requested':\r\n        return 'bg-amber-500/10 text-amber-400 border border-amber-500/20';\r\n      case 'approved':\r\n        return 'bg-blue-500/10 text-blue-400 border border-blue-500/20';\r\n      case 'refunded':\r\n        return 'bg-emerald-500/10 text-emerald-450 border border-emerald-500/20';\r\n      case 'rejected':\r\n        return 'bg-rose-500/10 text-rose-450 border border-rose-500/20';\r\n      case 'processing':\r\n        return 'bg-purple-500/10 text-purple-400 border border-purple-500/20';\r\n      case 'cancelled':\r\n      default:\r\n        return 'bg-zinc-500/10 text-zinc-400 border border-zinc-550/20';\r\n    }\r\n  };\r\n\r\n  return (\r\n    <AdminLayout title=\"QuГҹв•‘Гәn lв”ңв•ң hoв”ңГЎn tiГҹв•—Гјn\" subtitle=\"QuГҹв•‘Гәn trГҹв•—ГҜ, duyГҹв•—Г§t vв”ңГЎ theo dв”ңв•Ўi trГҹв•‘Гӯng thв”ңГӯi cв”ңГӯc yв”ңВ¬u cГҹв•‘Вәu hoв”ңГЎn tiГҹв•—Гјn cГҹв•—Г¬c\">\r\n      <div className=\"flex flex-col sm:flex-row gap-4 justify-between items-stretch sm:items-center mb-6\">\r\n        <h1 className=\"text-xl font-extrabold text-zinc-100 uppercase tracking-wide flex items-center gap-2\">\r\n          <DollarSign className=\"text-amber-500\" /> HГҹв•—Гҙ sв•һГӯ hoв”ңГЎn tiГҹв•—Гјn\r\n        </h1>\r\n        <button \r\n          className=\"inline-flex items-center gap-1.5 px-4 py-2 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 text-xs font-semibold rounded-lg transition\" \r\n          onClick={loadRefunds}\r\n        >\r\n          <RefreshCw size={14} /> Lв”ңГЎm mГҹв•—Вўi\r\n        </button>\r\n      </div>\r\n\r\n      {/* Filters */}\r\n      <div className=\"flex border-b border-zinc-800 mb-6 overflow-x-auto whitespace-nowrap scrollbar-none gap-2\">\r\n        {['', 'requested', 'approved', 'refunded', 'rejected'].map((s) => (\r\n          <button\r\n            key={s}\r\n            className={`px-4 py-2 text-xs font-semibold tracking-wide uppercase border-b-2 transition duration-200 outline-none ${\r\n              filter === s \r\n                ? 'border-amber-500 text-amber-500' \r\n                : 'border-transparent text-zinc-400 hover:text-zinc-200'\r\n            }`}\r\n            onClick={() => setFilter(s)}\r\n          >\r\n            {s === '' ? 'TГҹв•‘Г‘t cГҹв•‘Гә' : statusLabels[s] || s}\r\n          </button>\r\n        ))}\r\n      </div>\r\n\r\n      {loading ? (\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-3 bg-[#1A1D24] border border-zinc-800 rounded-xl\">\r\n          <div className=\"w-8 h-8 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\r\n          <span className=\"text-sm\">в”ҖГүang tГҹв•‘Гәi...</span>\r\n        </div>\r\n      ) : refunds.length === 0 ? (\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 bg-[#1A1D24] border border-zinc-800 rounded-xl text-sm\">\r\n          Khв”ңв”Өng cв”ңв”Ӯ yв”ңВ¬u cГҹв•‘Вәu hoв”ңГЎn tiГҹв•—Гјn nв”ңГЎo.\r\n        </div>\r\n      ) : (\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\r\n          {refunds.map((r) => (\r\n            <article key={r._id} className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col justify-between\">\r\n              <div>\r\n                <div className=\"flex justify-between items-center mb-4\">\r\n                  <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold ${getStatusClasses(r.status)}`}>\r\n                    {statusLabels[r.status] || r.status}\r\n                  </span>\r\n                  <span className=\"text-xs text-zinc-500 font-mono\">{formatDate(r.createdAt)}</span>\r\n                </div>\r\n\r\n                <div className=\"flex items-baseline justify-between mb-4\">\r\n                  <div className=\"text-xl font-black text-amber-500 font-mono\">{formatMoney(r.amount)}</div>\r\n                </div>\r\n\r\n                <div className=\"text-xs space-y-2 border-t border-zinc-850 pt-3 mb-4 text-zinc-405\">\r\n                  <p><strong className=\"text-zinc-300\">Ngв•һв–‘Гҹв•—ВҘi yв”ңВ¬u cГҹв•‘Вәu:</strong> {r.requestedBy?.fullName || 'О“ГҮГ¶'} ({r.requestedByRole === 'admin' ? 'Admin' : 'ChГҹв•—Вә nhв”ңГЎ hв”ңГЎng'})</p>\r\n                  <p><strong className=\"text-zinc-300\">Lв”ңв•ң do:</strong> {r.reason}</p>\r\n                  {r.bookingId && (\r\n                    <p><strong className=\"text-zinc-300\">в”ҖГүГҹв•‘в•–t bв”ңГЎn:</strong> {formatDate(r.bookingId?.bookingDate)} - {r.bookingId?.customerName}</p>\r\n                  )}\r\n                  {r.bankInfo?.bankName && (\r\n                    <p><strong className=\"text-zinc-300\">Ngв”ңГіn hв”ңГЎng:</strong> {r.bankInfo.bankName} - {r.bankInfo.accountNumber} - {r.bankInfo.accountHolder}</p>\r\n                  )}\r\n                  {r.adminNote && (\r\n                    <p className=\"bg-zinc-900/40 p-2 border border-zinc-855 rounded-lg text-zinc-400 italic\">\r\n                      <strong className=\"text-zinc-305 not-italic block mb-0.5\">Ghi chв”ңв•‘ admin:</strong> {r.adminNote}\r\n                    </p>\r\n                  )}\r\n                </div>\r\n              </div>\r\n\r\n              {/* Action area */}\r\n              <div className=\"flex flex-wrap items-center justify-end gap-2 border-t border-zinc-850 pt-3\">\r\n                {r.status === 'requested' && (\r\n                  <>\r\n                    <button \r\n                      className=\"inline-flex items-center gap-1 px-3 py-1.5 border border-zinc-800 hover:bg-emerald-500/10 hover:text-emerald-400 text-zinc-400 text-xs font-semibold rounded-lg transition\" \r\n                      onClick={() => setActionModal({ type: 'approve', refund: r })}\r\n                    >\r\n                      <Check size={13} /> DuyГҹв•—Г§t\r\n                    </button>\r\n                    <button \r\n                      className=\"inline-flex items-center gap-1 px-3 py-1.5 border border-zinc-800 hover:bg-rose-500/10 hover:text-rose-400 text-zinc-400 text-xs font-semibold rounded-lg transition\" \r\n                      onClick={() => setActionModal({ type: 'reject', refund: r })}\r\n                    >\r\n                      <X size={13} /> TГҹв•—ВҪ chГҹв•—ГҰi\r\n                    </button>\r\n                    <button \r\n                      className=\"inline-flex items-center gap-1 px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-black text-xs font-bold rounded-lg transition\" \r\n                      onClick={() => setActionModal({ type: 'process', refund: r })}\r\n                    >\r\n                      <DollarSign size={13} /> в”ҖГүв”ңГә hoв”ңГЎn tiГҹв•—Гјn\r\n                    </button>\r\n                  </>\r\n                )}\r\n                {r.status === 'approved' && (\r\n                  <button \r\n                    className=\"inline-flex items-center gap-1 px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-black text-xs font-bold rounded-lg transition\" \r\n                    onClick={() => setActionModal({ type: 'process', refund: r })}\r\n                  >\r\n                    <DollarSign size={13} /> Xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв”ңГә chuyГҹв•—Гўn tiГҹв•—Гјn\r\n                  </button>\r\n                )}\r\n              </div>\r\n            </article>\r\n          ))}\r\n        </div>\r\n      )}\r\n\r\n      {/* Action Modal */}\r\n      {actionModal && (\r\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 animate-in fade-in duration-200\" onClick={() => setActionModal(null)}>\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-2xl w-full max-w-md p-6 shadow-2xl animate-in zoom-in-95 duration-200\" onClick={(e) => e.stopPropagation()}>\r\n            <h3 className=\"text-lg font-bold text-zinc-150 mb-2\">\r\n              {actionModal.type === 'approve' && 'DuyГҹв•—Г§t yв”ңВ¬u cГҹв•‘Вәu hoв”ңГЎn tiГҹв•—Гјn'}\r\n              {actionModal.type === 'reject' && 'TГҹв•—ВҪ chГҹв•—ГҰi yв”ңВ¬u cГҹв•‘Вәu hoв”ңГЎn tiГҹв•—Гјn'}\r\n              {actionModal.type === 'process' && 'Xв”ңГӯc nhГҹв•‘ВЎn в”ҖГҰв”ңГә chuyГҹв•—Гўn tiГҹв•—Гјn hoв”ңГЎn'}\r\n            </h3>\r\n            <p className=\"text-sm text-zinc-400 mb-4\">SГҹв•—ГҰ tiГҹв•—Гјn: <strong className=\"text-amber-550 font-mono\">{formatMoney(actionModal.refund.amount)}</strong></p>\r\n\r\n            <form onSubmit={(e) => { e.preventDefault(); handleAction(); }} className=\"space-y-4\">\r\n              <div className=\"flex flex-col gap-1.5\">\r\n                <label className=\"text-xs font-semibold text-zinc-450 tracking-wide uppercase\">Ghi chв”ңв•‘</label>\r\n                <textarea\r\n                  value={note}\r\n                  onChange={(e) => setNote(e.target.value)}\r\n                  placeholder={actionModal.type === 'reject' ? 'Lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi...' : 'Ghi chв”ңв•‘...'}\r\n                  rows={3}\r\n                  className=\"w-full bg-[#13161C] border border-zinc-800 text-zinc-200 placeholder-zinc-650 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 resize-none\"\r\n                />\r\n              </div>\r\n\r\n              {actionModal.type === 'process' && (\r\n                <div className=\"flex flex-col gap-1.5\">\r\n                  <label className=\"text-xs font-semibold text-zinc-450 tracking-wide uppercase\">Mв”ңГә giao dГҹв•—ГҜch chuyГҹв•—Гўn khoГҹв•‘Гәn</label>\r\n                  <input\r\n                    value={refId}\r\n                    onChange={(e) => setRefId(e.target.value)}\r\n                    placeholder=\"VD: FT123456789\"\r\n                    className=\"w-full bg-[#13161C] border border-zinc-800 text-zinc-200 placeholder-zinc-650 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500\"\r\n                  />\r\n                </div>\r\n              )}\r\n\r\n              <div className=\"flex items-center justify-end gap-3 pt-2\">\r\n                <button \r\n                  type=\"button\"\r\n                  className=\"px-4 py-2 border border-zinc-800 hover:bg-zinc-850 text-zinc-300 font-semibold text-xs rounded-lg transition\" \r\n                  onClick={() => setActionModal(null)}\r\n                >\r\n                  HГҹв•—Вәy\r\n                </button>\r\n                <button \r\n                  type=\"submit\"\r\n                  className=\"px-4 py-2 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-black font-bold text-xs rounded-lg transition disabled:opacity-50\"\r\n                  disabled={processing}\r\n                >\r\n                  {processing ? 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң...' : 'Xв”ңГӯc nhГҹв•‘ВЎn'}\r\n                </button>\r\n              </div>\r\n            </form>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </AdminLayout>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminRestaurantDetail.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  79 |\n  80 |   useEffect(() => {\n> 81 |     fetchDetail();\n     |     ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  82 |   }, [id]);\n  83 |\n  84 |   useEffect(() => {","line":81,"column":5,"endLine":81,"endColumn":16},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchDetail'. Either include it or remove the dependency array.","line":82,"column":6,"endLine":82,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [fetchDetail, id]","fix":{"range":[3141,3145],"text":"[fetchDetail, id]"}}]},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  84 |   useEffect(() => {\n  85 |     if (activeTab === 'logs') {\n> 86 |       fetchLogs(1, true);\n     |       ^^^^^^^^^ Avoid calling setState() directly within an effect\n  87 |     }\n  88 |   }, [activeTab, id]);\n  89 |","line":86,"column":7,"endLine":86,"endColumn":16},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchLogs'. Either include it or remove the dependency array.","line":88,"column":6,"endLine":88,"endColumn":21,"suggestions":[{"desc":"Update the dependencies array to be: [activeTab, fetchLogs, id]","fix":{"range":[3244,3259],"text":"[activeTab, fetchLogs, id]"}}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { useParams, useNavigate } from 'react-router-dom';\r\nimport { adminApi } from '../../api/adminApi';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport toast from 'react-hot-toast';\r\nimport {\r\n  ArrowLeft, Store, MapPin, Phone, Mail, Clock,\r\n  CheckCircle, XCircle, PauseCircle, CreditCard,\r\n  FileText, History, Star, Landmark, Eye, Undo, Play, Trash2\r\n} from 'lucide-react';\r\n\r\n// Components & Modals\r\nimport RestaurantStatusBadge from '../../components/admin/RestaurantStatusBadge';\r\nimport ApproveModal from '../../components/admin/ApproveModal';\r\nimport RejectModal from '../../components/admin/RejectModal';\r\nimport SuspendModal from '../../components/admin/SuspendModal';\r\nimport UnsuspendModal from '../../components/admin/UnsuspendModal';\r\nimport DeleteModal from '../../components/admin/DeleteModal';\r\nimport RestoreModal from '../../components/admin/RestoreModal';\r\nimport ActivityTimeline from '../../components/admin/ActivityTimeline';\r\n\r\nexport default function AdminRestaurantDetail() {\r\n  const { id } = useParams();\r\n  const navigate = useNavigate();\r\n  \r\n  // Data state\r\n  const [restaurant, setRestaurant] = useState(null);\r\n  const [loading, setLoading] = useState(true);\r\n  const [activeTab, setActiveTab] = useState('info'); // 'info' | 'financial' | 'logs'\r\n  const [actionLoading, setActionLoading] = useState(false);\r\n\r\n  // Edit settings state\r\n  const [isEditingSettings, setIsEditingSettings] = useState(false);\r\n  const [editCommissionRate, setEditCommissionRate] = useState(10);\r\n  const [editFeatured, setEditFeatured] = useState(false);\r\n\r\n  // Logs state\r\n  const [logs, setLogs] = useState([]);\r\n  const [logsLoading, setLogsLoading] = useState(false);\r\n  const [logsPage, setLogsPage] = useState(1);\r\n  const [logsTotalPages, setLogsTotalPages] = useState(1);\r\n\r\n  // Modals state\r\n  const [activeModal, setActiveModal] = useState(null); // 'approve' | 'reject' | 'suspend' | 'unsuspend' | 'delete' | 'restore'\r\n  const [showLicenseViewer, setShowLicenseViewer] = useState(false);\r\n\r\n  const fetchDetail = async () => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await adminApi.getRestaurantById(id);\r\n      setRestaurant(res.data);\r\n      setEditCommissionRate(res.data.commissionRate ?? 10);\r\n      setEditFeatured(res.data.featured ?? false);\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi chi tiГҹв•‘в”җt nhв”ңГЎ hв”ңГЎng');\r\n      navigate('/admin/restaurants');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const fetchLogs = async (page = 1, isNew = false) => {\r\n    setLogsLoading(true);\r\n    try {\r\n      const res = await adminApi.getActivityLogs(id, { page, limit: 10 });\r\n      if (isNew) {\r\n        setLogs(res.data.logs);\r\n      } else {\r\n        setLogs((prev) => [...prev, ...res.data.logs]);\r\n      }\r\n      setLogsPage(res.data.page);\r\n      setLogsTotalPages(res.data.totalPages);\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi lГҹв•—ГҜch sГҹв•—ВЎ hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng');\r\n    } finally {\r\n      setLogsLoading(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    fetchDetail();\r\n  }, [id]);\r\n\r\n  useEffect(() => {\r\n    if (activeTab === 'logs') {\r\n      fetchLogs(1, true);\r\n    }\r\n  }, [activeTab, id]);\r\n\r\n  const handleLoadMoreLogs = () => {\r\n    if (logsPage < logsTotalPages) {\r\n      fetchLogs(logsPage + 1, false);\r\n    }\r\n  };\r\n\r\n  // Modals confirming callbacks\r\n  const onApproveConfirm = async (id, commissionRate) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.approveRestaurant(id, commissionRate);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә duyГҹв•—Г§t nhв”ңГЎ hв”ңГЎng thв”ңГЎnh cв”ңв”Өng');\r\n      setActiveModal(null);\r\n      fetchDetail();\r\n    } catch (err) {\r\n      toast.error(err.message || 'DuyГҹв•—Г§t nhв”ңГЎ hв”ңГЎng thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onRejectConfirm = async (id, reason) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.rejectRestaurant(id, reason);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә tГҹв•—ВҪ chГҹв•—ГҰi duyГҹв•—Г§t hГҹв•—Гҙ sв•һГӯ');\r\n      setActiveModal(null);\r\n      fetchDetail();\r\n    } catch (err) {\r\n      toast.error(err.message || 'TГҹв•—ВҪ chГҹв•—ГҰi thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onSuspendConfirm = async (id, reason) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.suspendRestaurant(id, reason);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә tГҹв•‘Гӯm ngв•һв–‘ng hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng');\r\n      setActiveModal(null);\r\n      fetchDetail();\r\n    } catch (err) {\r\n      toast.error(err.message || 'TГҹв•‘Гӯm ngв•һв–‘ng thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onUnsuspendConfirm = async (id) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.unsuspendRestaurant(id);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә gГҹв•—Гӯ tГҹв•‘Гӯm ngв•һв–‘ng hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng');\r\n      setActiveModal(null);\r\n      fetchDetail();\r\n    } catch (err) {\r\n      toast.error(err.message || 'GГҹв•—Гӯ tГҹв•‘Гӯm ngв•һв–‘ng thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onDeleteConfirm = async (id, reason) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.deleteRestaurant(id, reason);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә xв”ңв”Ӯa nhв”ңГЎ hв”ңГЎng');\r\n      setActiveModal(null);\r\n      fetchDetail();\r\n    } catch (err) {\r\n      toast.error(err.message || 'Xв”ңв”Ӯa thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onRestoreConfirm = async (id) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.restoreRestaurant(id);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә khв”ңв”Өi phГҹв•—Г‘c nhв”ңГЎ hв”ңГЎng');\r\n      setActiveModal(null);\r\n      fetchDetail();\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өi phГҹв•—Г‘c thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const handleSaveSettings = async () => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.updateRestaurant(id, {\r\n        commissionRate: editCommissionRate,\r\n        featured: editFeatured,\r\n      });\r\n      toast.success(res.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt cГҹв•‘Г‘u hв”ңВјnh thв”ңГЎnh cв”ңв”Өng');\r\n      setIsEditingSettings(false);\r\n      fetchDetail();\r\n    } catch (err) {\r\n      toast.error(err.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt cГҹв•‘Г‘u hв”ңВјnh thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <AdminLayout title=\"Chi tiГҹв•‘в”җt Nhв”ңГЎ hв”ңГЎng\">\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-3 bg-[#1A1D24] border border-zinc-800 rounded-xl\">\r\n          <div className=\"w-8 h-8 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\r\n          <span className=\"text-sm\">в”ҖГүang tГҹв•‘Гәi thв”ңв”Өng tin nhв”ңГЎ hв”ңГЎng...</span>\r\n        </div>\r\n      </AdminLayout>\r\n    );\r\n  }\r\n\r\n  if (!restaurant) return null;\r\n  const isDeleted = !!restaurant.deletedAt;\r\n\r\n  return (\r\n    <AdminLayout title={restaurant.name} subtitle={`QuГҹв•‘Гәn lв”ңв•ң nhв”ңГЎ hв”ңГЎng cГҹв•—Вәa ${restaurant.ownerId?.fullName || 'N/A'}`}>\r\n      <div className=\"flex flex-col sm:flex-row gap-4 justify-between items-stretch sm:items-center mb-6\">\r\n        <button \r\n          className=\"inline-flex items-center gap-1.5 px-3 py-1.5 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 text-xs font-semibold rounded-lg transition duration-150 self-start sm:self-auto\" \r\n          onClick={() => navigate('/admin/restaurants')}\r\n        >\r\n          <ArrowLeft size={14} /> Quay lГҹв•‘Гӯi danh sв”ңГӯch\r\n        </button>\r\n        <div className=\"flex flex-wrap gap-2 items-center\">\r\n          {isDeleted ? (\r\n            <button \r\n              className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-xs rounded-lg transition\" \r\n              onClick={() => setActiveModal('restore')}\r\n            >\r\n              <Undo size={14} /> Khв”ңв”Өi phГҹв•—Г‘c nhв”ңГЎ hв”ңГЎng\r\n            </button>\r\n          ) : (\r\n            <>\r\n              {restaurant.approvalStatus === 'pending' && (\r\n                <>\r\n                  <button \r\n                    className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-xs rounded-lg transition\" \r\n                    onClick={() => setActiveModal('approve')}\r\n                  >\r\n                    <CheckCircle size={14} /> DuyГҹв•—Г§t hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng\r\n                  </button>\r\n                  <button \r\n                    className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white font-semibold text-xs rounded-lg transition\" \r\n                    onClick={() => setActiveModal('reject')}\r\n                  >\r\n                    <XCircle size={14} /> TГҹв•—ВҪ chГҹв•—ГҰi duyГҹв•—Г§t\r\n                  </button>\r\n                </>\r\n              )}\r\n              {restaurant.approvalStatus === 'approved' && (\r\n                <button \r\n                  className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white font-semibold text-xs rounded-lg transition\" \r\n                  onClick={() => setActiveModal('suspend')}\r\n                >\r\n                  <PauseCircle size={14} /> TГҹв•‘Гӯm ngв•һв–‘ng\r\n                </button>\r\n              )}\r\n              {restaurant.approvalStatus === 'suspended' && (\r\n                <button \r\n                  className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-xs rounded-lg transition\" \r\n                  onClick={() => setActiveModal('unsuspend')}\r\n                >\r\n                  <Play size={14} /> GГҹв•—Гӯ tГҹв•‘Гӯm ngв•һв–‘ng\r\n                </button>\r\n              )}\r\n              {restaurant.approvalStatus === 'rejected' && (\r\n                <button \r\n                  className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-xs rounded-lg transition\" \r\n                  onClick={() => setActiveModal('approve')}\r\n                >\r\n                  <CheckCircle size={14} /> DuyГҹв•—Г§t lГҹв•‘Гӯi\r\n                </button>\r\n              )}\r\n              <button \r\n                className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white font-semibold text-xs rounded-lg transition\" \r\n                onClick={() => setActiveModal('delete')}\r\n              >\r\n                <Trash2 size={14} /> Xв”ңв”Ӯa nhв”ңГЎ hв”ңГЎng\r\n              </button>\r\n            </>\r\n          )}\r\n        </div>\r\n      </div>\r\n\r\n      {/* Tabs list */}\r\n      <div className=\"flex border-b border-zinc-800 mb-6 overflow-x-auto whitespace-nowrap scrollbar-none gap-2\">\r\n        <button\r\n          className={`inline-flex items-center gap-1.5 px-4 py-2.5 text-xs font-semibold tracking-wide uppercase border-b-2 transition duration-200 outline-none ${\r\n            activeTab === 'info' \r\n              ? 'border-amber-500 text-amber-500' \r\n              : 'border-transparent text-zinc-400 hover:text-zinc-200'\r\n          }`}\r\n          onClick={() => setActiveTab('info')}\r\n        >\r\n          <Store size={14} /> Thв”ңв”Өng tin\r\n        </button>\r\n        <button\r\n          className={`inline-flex items-center gap-1.5 px-4 py-2.5 text-xs font-semibold tracking-wide uppercase border-b-2 transition duration-200 outline-none ${\r\n            activeTab === 'financial' \r\n              ? 'border-amber-500 text-amber-500' \r\n              : 'border-transparent text-zinc-400 hover:text-zinc-200'\r\n          }`}\r\n          onClick={() => setActiveTab('financial')}\r\n        >\r\n          <CreditCard size={14} /> Tв”ңГЎi chв”ңВЎnh & Phв”ңГӯp lв”ңв•ң\r\n        </button>\r\n        <button\r\n          className={`inline-flex items-center gap-1.5 px-4 py-2.5 text-xs font-semibold tracking-wide uppercase border-b-2 transition duration-200 outline-none ${\r\n            activeTab === 'logs' \r\n              ? 'border-amber-500 text-amber-500' \r\n              : 'border-transparent text-zinc-400 hover:text-zinc-200'\r\n          }`}\r\n          onClick={() => setActiveTab('logs')}\r\n        >\r\n          <History size={14} /> LГҹв•—ГҜch sГҹв•—ВЎ hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng\r\n        </button>\r\n      </div>\r\n\r\n      {/* Tab Contents */}\r\n      <div className=\"space-y-6\">\r\n        \r\n        {/* Tab 1: INFO */}\r\n        {activeTab === 'info' && (\r\n          <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\r\n            <div className=\"lg:col-span-2 space-y-6\">\r\n              {/* Basic Info */}\r\n              <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">Thв”ңв”Өng tin cв•һГӯ bГҹв•‘Гәn</h3>\r\n                \r\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">TrГҹв•‘Гӯng thв”ңГӯi duyГҹв•—Г§t</span>\r\n                    <span className=\"text-sm font-medium\">\r\n                      <RestaurantStatusBadge status={isDeleted ? 'deleted' : restaurant.approvalStatus} />\r\n                    </span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">Ghim nГҹв•—ГІi bГҹв•‘ВЎt</span>\r\n                    <span className=\"text-sm font-medium flex items-center gap-1\">\r\n                      {restaurant.featured ? (\r\n                        <>\r\n                          <Star size={14} fill=\"#fbbf24\" color=\"#fbbf24\" />\r\n                          <span className=\"text-amber-550 font-semibold\">NГҹв•—ГІi bГҹв•‘ВЎt</span>\r\n                        </>\r\n                      ) : (\r\n                        <span className=\"text-zinc-500\">Khв”ңв”Өng</span>\r\n                      )}\r\n                    </span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                    <span className=\"text-xs text-zinc-500\">Tв”ңВ¬n nhв”ңГЎ hв”ңГЎng</span>\r\n                    <span className=\"text-sm font-semibold text-zinc-200\">{restaurant.name}</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                    <span className=\"text-xs text-zinc-500\">Mв”ңв”Ө tГҹв•‘Гә</span>\r\n                    <span className=\"text-xs text-zinc-400 leading-relaxed\">{restaurant.description}</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">Phв”ңГіn khв”ңв•‘c giв”ңГӯ</span>\r\n                    <span className=\"text-sm text-zinc-200 capitalize font-medium\">{restaurant.priceRange}</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">SГҹв•—вҢҗc chГҹв•—вҢҗa tГҹв•—ГҰi в”ҖГҰa</span>\r\n                    <span className=\"text-sm text-zinc-200 font-medium\">{restaurant.capacity} khв”ңГӯch</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                    <span className=\"text-xs text-zinc-500\">LoГҹв•‘Гӯi Гҹв•‘вҢҗm thГҹв•—в–’c</span>\r\n                    <div className=\"flex flex-wrap gap-1.5 mt-1\">\r\n                      {restaurant.cuisineTypes && restaurant.cuisineTypes.length > 0 ? (\r\n                        restaurant.cuisineTypes.map((tag) => (\r\n                          <span key={tag} className=\"px-2 py-0.5 bg-zinc-800 border border-zinc-700/50 rounded text-xs text-zinc-300\">{tag}</span>\r\n                        ))\r\n                      ) : (\r\n                        <span className=\"text-xs text-zinc-500\">Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt</span>\r\n                      )}\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Contact & Location */}\r\n              <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">Liв”ңВ¬n hГҹв•—Г§ & в”ҖГүГҹв•—ГҜa chГҹв•—Г«</h3>\r\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><Phone size={12} /> в”ҖГүiГҹв•—Г§n thoГҹв•‘Гӯi</span>\r\n                    <span className=\"text-sm font-mono text-zinc-200\">{restaurant.phoneNumber}</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><Mail size={12} /> Email</span>\r\n                    <span className=\"text-sm text-zinc-200\">{restaurant.email}</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                    <span className=\"text-xs text-zinc-500 flex items-center gap-1\"><MapPin size={12} /> в”ҖГүГҹв•—ГҜa chГҹв•—Г« chi tiГҹв•‘в”җt</span>\r\n                    <span className=\"text-sm text-zinc-300 leading-relaxed\">{restaurant.address?.fullAddress}</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">TГҹв•—Г«nh / Thв”ңГЎnh phГҹв•—ГҰ</span>\r\n                    <span className=\"text-sm text-zinc-200\">{restaurant.address?.city}</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">QuГҹв•‘ВЎn / HuyГҹв•—Г§n</span>\r\n                    <span className=\"text-sm text-zinc-200\">{restaurant.address?.district}</span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Operating Hours */}\r\n              <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide flex items-center gap-1.5\"><Clock size={14} /> GiГҹв•—ВҘ hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng</h3>\r\n                <div className=\"divide-y divide-zinc-800/60 max-w-md\">\r\n                  {restaurant.operatingHours ? (\r\n                    Object.keys(restaurant.operatingHours).map((day) => {\r\n                      const hours = restaurant.operatingHours[day];\r\n                      const dayLabels = {\r\n                        monday: 'ThГҹв•—вҢҗ Hai', tuesday: 'ThГҹв•—вҢҗ Ba', wednesday: 'ThГҹв•—вҢҗ Tв•һв–‘',\r\n                        thursday: 'ThГҹв•—вҢҗ Nв”ҖГўm', friday: 'ThГҹв•—вҢҗ Sв”ңГӯu', saturday: 'ThГҹв•—вҢҗ BГҹв•‘Гәy', sunday: 'ChГҹв•—Вә NhГҹв•‘ВЎt'\r\n                      };\r\n                      return (\r\n                        <div key={day} className=\"flex justify-between items-center py-2 text-xs\">\r\n                          <span className=\"font-semibold text-zinc-400\">{dayLabels[day] || day}</span>\r\n                          <span className=\"text-zinc-200 font-mono\">\r\n                            {hours.closed ? (\r\n                              <span className=\"px-2 py-0.5 bg-rose-500/10 text-rose-400 border border-rose-500/20 rounded\">в”ҖГүв”ңв”Ӯng cГҹв•—ВЎa</span>\r\n                            ) : (\r\n                              `${hours.open} - ${hours.close}`\r\n                            )}\r\n                          </span>\r\n                        </div>\r\n                      );\r\n                    })\r\n                  ) : (\r\n                    <p className=\"text-xs text-zinc-500\">Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt</p>\r\n                  )}\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"space-y-6\">\r\n              {/* Owner Profile */}\r\n              <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">ChГҹв•—Вә sГҹв•—Ж’ hГҹв•—В»u</h3>\r\n                <div className=\"flex items-center gap-4\">\r\n                  <div className=\"w-14 h-14 rounded-full bg-zinc-800 border border-zinc-700 overflow-hidden flex items-center justify-center text-lg font-bold text-amber-500 uppercase\">\r\n                    {restaurant.ownerId?.fullName?.[0]?.toUpperCase() || '?'}\r\n                  </div>\r\n                  <div className=\"flex-1 min-w-0\">\r\n                    <div className=\"font-bold text-zinc-150 truncate\">{restaurant.ownerId?.fullName || 'N/A'}</div>\r\n                    <div className=\"text-xs text-zinc-400 truncate\">{restaurant.ownerId?.email}</div>\r\n                    <div className=\"text-xs text-zinc-500 mt-1 font-mono\">{restaurant.ownerId?.phoneNumber || 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt Sв”ҖГүT'}</div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Stats overview */}\r\n              <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">ThГҹв•—ГҰng kв”ңВ¬ hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng</h3>\r\n                <div className=\"grid grid-cols-2 gap-3\">\r\n                  <div className=\"bg-[#13161C] border border-zinc-800/60 p-3 rounded-lg flex flex-col\">\r\n                    <span className=\"text-[10px] text-zinc-550 uppercase font-semibold\">TГҹв•—ГІng Booking</span>\r\n                    <span className=\"text-lg font-bold text-zinc-200 mt-0.5\">{restaurant.stats?.totalBookings || 0}</span>\r\n                  </div>\r\n                  <div className=\"bg-[#13161C] border border-zinc-800/60 p-3 rounded-lg flex flex-col\">\r\n                    <span className=\"text-[10px] text-zinc-550 uppercase font-semibold\">в”ҖГүв”ңГә hoв”ңГЎn thв”ңГЎnh</span>\r\n                    <span className=\"text-lg font-bold text-emerald-400 mt-0.5\">{restaurant.stats?.completedBookings || 0}</span>\r\n                  </div>\r\n                  <div className=\"bg-[#13161C] border border-zinc-800/60 p-3 rounded-lg flex flex-col\">\r\n                    <span className=\"text-[10px] text-zinc-550 uppercase font-semibold\">в”ҖГүв”ңГә hГҹв•—Вәy</span>\r\n                    <span className=\"text-lg font-bold text-rose-450 mt-0.5\">{restaurant.stats?.cancelledBookings || 0}</span>\r\n                  </div>\r\n                  <div className=\"bg-[#13161C] border border-zinc-800/60 p-3 rounded-lg flex flex-col\">\r\n                    <span className=\"text-[10px] text-zinc-550 uppercase font-semibold\">в”ҖГүв”ңГӯnh giв”ңГӯ TB</span>\r\n                    <span className=\"text-lg font-bold text-amber-500 mt-0.5 flex items-center gap-1\">\r\n                      {restaurant.stats?.averageRating?.toFixed(1) || '0.0'} <span className=\"text-sm\">О“ВЎГү</span>\r\n                    </span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Moderation Warnings */}\r\n              {(restaurant.rejectionReason || restaurant.suspensionReason || restaurant.deleteReason) && (\r\n                <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg border-l-4 border-l-orange-500\">\r\n                  <h3 className=\"text-sm font-bold text-orange-400 mb-3 uppercase tracking-wide\">Ghi chв”ңв•‘ KiГҹв•—Гўm duyГҹв•—Г§t</h3>\r\n                  <div className=\"space-y-2.5 text-xs\">\r\n                    {restaurant.rejectionReason && (\r\n                      <div className=\"p-2.5 bg-rose-500/5 border border-rose-550/10 rounded-lg text-rose-350\">\r\n                        <strong className=\"block mb-0.5\">Lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi duyГҹв•—Г§t:</strong> {restaurant.rejectionReason}\r\n                      </div>\r\n                    )}\r\n                    {restaurant.suspensionReason && (\r\n                      <div className=\"p-2.5 bg-orange-500/5 border border-orange-500/10 rounded-lg text-orange-350\">\r\n                        <strong className=\"block mb-0.5\">Lв”ңв•ң do tГҹв•‘Гӯm ngв•һв–‘ng:</strong> {restaurant.suspensionReason}\r\n                      </div>\r\n                    )}\r\n                    {restaurant.deleteReason && (\r\n                      <div className=\"p-2.5 bg-red-500/5 border border-red-500/10 rounded-lg text-red-350\">\r\n                        <strong className=\"block mb-0.5\">Lв”ңв•ң do xв”ңв”Ӯa nhв”ңГЎ hв”ңГЎng:</strong> {restaurant.deleteReason}\r\n                      </div>\r\n                    )}\r\n                  </div>\r\n                </div>\r\n              )}\r\n\r\n              {/* Admin configuration settings */}\r\n              {!isDeleted && (\r\n                <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                  <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">CГҹв•‘Г‘u hв”ңВјnh Admin</h3>\r\n                  {!isEditingSettings ? (\r\n                    <div className=\"space-y-4\">\r\n                      <div className=\"flex justify-between items-center text-xs\">\r\n                        <span className=\"text-zinc-500\">TГҹв•—в•– lГҹв•—Г§ hoa hГҹв•—Гҙng:</span>\r\n                        <span className=\"font-bold text-amber-550\">{restaurant.commissionRate ?? 10}%</span>\r\n                      </div>\r\n                      <div className=\"flex justify-between items-center text-xs\">\r\n                        <span className=\"text-zinc-500\">Ghi nhГҹв•‘ВЎn nГҹв•—ГІi bГҹв•‘ВЎt:</span>\r\n                        <span className=\"font-semibold text-zinc-300\">{restaurant.featured ? 'в”ҖГүang BГҹв•‘ВЎt' : 'в”ҖГүang TГҹв•‘В»t'}</span>\r\n                      </div>\r\n                      <button \r\n                        className=\"w-full flex items-center justify-center py-2 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-black font-semibold text-xs rounded-lg transition\"\r\n                        onClick={() => setIsEditingSettings(true)}\r\n                      >\r\n                        ChГҹв•—Г«nh sГҹв•—ВЎa cГҹв•‘Г‘u hв”ңВјnh\r\n                      </button>\r\n                    </div>\r\n                  ) : (\r\n                    <div className=\"space-y-4\">\r\n                      <div className=\"flex flex-col gap-1.5\">\r\n                        <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">TГҹв•—в•– lГҹв•—Г§ hoa hГҹв•—Гҙng (%)</label>\r\n                        <input\r\n                          type=\"number\"\r\n                          className=\"w-full bg-[#13161C] border border-zinc-800 rounded-lg px-3 py-2 text-sm text-zinc-205 focus:outline-none focus:ring-1 focus:ring-amber-500\"\r\n                          min=\"0\"\r\n                          max=\"100\"\r\n                          value={editCommissionRate}\r\n                          onChange={(e) => setEditCommissionRate(Number(e.target.value))}\r\n                        />\r\n                      </div>\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <input\r\n                          type=\"checkbox\"\r\n                          id=\"featured-check\"\r\n                          checked={editFeatured}\r\n                          onChange={(e) => setEditFeatured(e.target.checked)}\r\n                          className=\"w-4 h-4 rounded border-zinc-850 bg-zinc-900 text-amber-550 focus:ring-amber-500 cursor-pointer\"\r\n                        />\r\n                        <label htmlFor=\"featured-check\" className=\"text-xs text-zinc-300 font-semibold cursor-pointer\">Ghim nГҹв•—ГІi bГҹв•‘ВЎt (Featured)</label>\r\n                      </div>\r\n                      <div className=\"flex items-center gap-2 pt-2\">\r\n                        <button \r\n                          className=\"flex-1 py-2 border border-zinc-800 hover:bg-zinc-850 text-zinc-300 font-semibold text-xs rounded-lg transition\" \r\n                          onClick={() => { setIsEditingSettings(false); setEditCommissionRate(restaurant.commissionRate ?? 10); setEditFeatured(restaurant.featured ?? false); }}\r\n                        >\r\n                          HГҹв•—Вәy\r\n                        </button>\r\n                        <button \r\n                          className=\"flex-1 py-2 bg-amber-500 hover:bg-amber-600 text-black font-bold text-xs rounded-lg transition\" \r\n                          onClick={handleSaveSettings} \r\n                          disabled={actionLoading}\r\n                        >\r\n                          {actionLoading ? 'Lв•һв–‘u...' : 'Lв•һв–‘u lГҹв•‘Гӯi'}\r\n                        </button>\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              )}\r\n\r\n              {/* Gallery Images */}\r\n              {restaurant.images && restaurant.images.length > 0 && (\r\n                <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                  <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">Hв”ңВјnh Гҹв•‘Гәnh nhв”ңГЎ hв”ңГЎng</h3>\r\n                  <div className=\"grid grid-cols-2 gap-2.5\">\r\n                    {restaurant.images.map((img, idx) => (\r\n                      <div key={idx} className=\"relative aspect-video rounded-lg overflow-hidden border border-zinc-800 bg-zinc-900 group\">\r\n                        <img src={img.url} alt=\"\" className=\"w-full h-full object-cover group-hover:scale-105 transition duration-300\" />\r\n                        {img.isPrimary && (\r\n                          <span className=\"absolute top-1.5 left-1.5 px-1.5 py-0.5 bg-amber-500 text-black text-[9px] font-bold uppercase rounded\">Chв”ңВЎnh</span>\r\n                        )}\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                </div>\r\n              )}\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        {/* Tab 2: FINANCIAL & LEGAL */}\r\n        {activeTab === 'financial' && (\r\n          <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n            <div className=\"space-y-6\">\r\n              {/* Financial Balance Info */}\r\n              <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide flex items-center gap-1.5\"><Landmark size={14} /> TГҹв•—ГІng quan tв”ңГЎi chв”ңВЎnh</h3>\r\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">SГҹв•—ГҰ dв•һв–‘ hiГҹв•—Г§n tГҹв•‘Гӯi (Balance)</span>\r\n                    <span className=\"text-base font-bold text-emerald-450\">{restaurant.balance?.toLocaleString('vi-VN')} в”ҖГҰ</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">Doanh thu tГҹв•—ГІng</span>\r\n                    <span className=\"text-sm text-zinc-200 font-semibold\">{restaurant.totalRevenue?.toLocaleString('vi-VN')} в”ҖГҰ</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">Hoa hГҹв•—Гҙng в”ҖГҰв”ңГә thu</span>\r\n                    <span className=\"text-sm text-amber-500 font-bold\">{restaurant.totalCommission?.toLocaleString('vi-VN')} в”ҖГҰ</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">TГҹв•—в•– lГҹв•—Г§ chiГҹв•‘в”җt khГҹв•‘Г‘u</span>\r\n                    <span className=\"text-sm text-zinc-300 font-semibold\">{restaurant.commissionRate ?? 10}%</span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Bank Transfer Details */}\r\n              <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide\">Thв”ңв”Өng tin tв”ңГЎi khoГҹв•‘Гәn ngв”ңГіn hв”ңГЎng</h3>\r\n                {restaurant.bankInfo && restaurant.bankInfo.bankName ? (\r\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n                    <div className=\"flex flex-col gap-1\">\r\n                      <span className=\"text-xs text-zinc-500\">Ngв”ңГіn hв”ңГЎng nhГҹв•‘ВЎn</span>\r\n                      <span className=\"text-sm font-bold text-zinc-200\">{restaurant.bankInfo.bankName}</span>\r\n                    </div>\r\n                    <div className=\"flex flex-col gap-1\">\r\n                      <span className=\"text-xs text-zinc-500\">SГҹв•—ГҰ tв”ңГЎi khoГҹв•‘Гәn</span>\r\n                      <span className=\"text-sm font-bold text-amber-500 font-mono\">{restaurant.bankInfo.accountNumber}</span>\r\n                    </div>\r\n                    <div className=\"flex flex-col gap-1\">\r\n                      <span className=\"text-xs text-zinc-500\">ChГҹв•—Вә tв”ңГЎi khoГҹв•‘Гәn</span>\r\n                      <span className=\"text-sm font-semibold text-zinc-200 capitalize\">{restaurant.bankInfo.accountHolder}</span>\r\n                    </div>\r\n                    <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                      <span className=\"text-xs text-zinc-500\">Chi nhв”ңГӯnh ngв”ңГіn hв”ңГЎng</span>\r\n                      <span className=\"text-sm text-zinc-300\">{restaurant.bankInfo.branch || 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt'}</span>\r\n                    </div>\r\n                  </div>\r\n                ) : (\r\n                  <p className=\"text-xs text-zinc-500 italic py-2\">ChГҹв•—Вә nhв”ңГЎ hв”ңГЎng chв•һв–‘a thiГҹв•‘в”җt lГҹв•‘ВЎp thв”ңв”Өng tin ngв”ңГіn hв”ңГЎng rв”ңв•‘t tiГҹв•—Гјn.</p>\r\n                )}\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"space-y-6\">\r\n              {/* Business License & Tax Code */}\r\n              <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n                <h3 className=\"text-sm font-bold text-zinc-200 mb-4 pb-2 border-b border-zinc-805 uppercase tracking-wide flex items-center gap-1.5\"><FileText size={14} /> HГҹв•—Гҙ sв•һГӯ phв”ңГӯp lв”ңв•ң</h3>\r\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">Mв”ңГә sГҹв•—ГҰ thuГҹв•‘в”җ doanh nghiГҹв•—Г§p</span>\r\n                    <span className=\"text-sm font-bold text-zinc-200 font-mono\">{restaurant.taxCode || 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt'}</span>\r\n                  </div>\r\n                  <div className=\"flex flex-col gap-1\">\r\n                    <span className=\"text-xs text-zinc-500\">SГҹв•—ГҰ giГҹв•‘Г‘y phв”ңвҢҗp kinh doanh</span>\r\n                    <span className=\"text-sm font-bold text-zinc-200 font-mono\">{restaurant.businessLicense?.number || 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt'}</span>\r\n                  </div>\r\n                  {restaurant.businessLicense?.verifiedAt && (\r\n                    <div className=\"flex flex-col gap-1 sm:col-span-2\">\r\n                      <span className=\"text-xs text-zinc-500\">Ngв”ңГЎy xв”ңГӯc thГҹв•—в–’c GPKD</span>\r\n                      <span className=\"text-sm text-zinc-400 font-mono\">{new Date(restaurant.businessLicense.verifiedAt).toLocaleDateString('vi-VN')}</span>\r\n                    </div>\r\n                  )}\r\n                  {restaurant.businessLicense?.imageUrl && (\r\n                    <div className=\"flex flex-col gap-1.5 sm:col-span-2\">\r\n                      <span className=\"text-xs text-zinc-500\">Гҹв•‘Гіnh chГҹв•—Г‘p GiГҹв•‘Г‘y phв”ңвҢҗp kinh doanh</span>\r\n                      <div \r\n                        className=\"relative max-w-sm rounded-lg overflow-hidden border border-zinc-800/80 bg-zinc-900 group cursor-pointer\" \r\n                        onClick={() => setShowLicenseViewer(true)}\r\n                      >\r\n                        <img src={restaurant.businessLicense.imageUrl} alt=\"GPKD\" className=\"w-full h-auto object-cover max-h-56 group-hover:brightness-90 transition\" />\r\n                        <div className=\"absolute inset-0 flex flex-col items-center justify-center bg-black/50 opacity-0 group-hover:opacity-100 transition duration-150 gap-1.5\">\r\n                          <Eye size={20} className=\"text-amber-500\" />\r\n                          <span className=\"text-[11px] text-zinc-200 font-semibold uppercase tracking-wider\">Click xem Гҹв•‘Гәnh lГҹв•—Вўn</span>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        {/* Tab 3: ACTIVITY LOGS */}\r\n        {activeTab === 'logs' && (\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg\">\r\n            <h3 className=\"text-sm font-bold text-zinc-200 mb-6 pb-2 border-b border-zinc-805 uppercase tracking-wide\">NhГҹв•‘ВЎt kв”ңв•ң hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng cГҹв•—Вәa nhв”ңГЎ hв”ңГЎng</h3>\r\n            <ActivityTimeline\r\n              logs={logs}\r\n              loading={logsLoading}\r\n              hasMore={logsPage < logsTotalPages}\r\n              onLoadMore={handleLoadMoreLogs}\r\n            />\r\n          </div>\r\n        )}\r\n      </div>\r\n\r\n      {/* Fullscreen business license image viewer */}\r\n      {showLicenseViewer && restaurant.businessLicense?.imageUrl && (\r\n        <div \r\n          className=\"fixed inset-0 z-50 flex flex-col items-center justify-center bg-black/90 backdrop-blur-sm p-4 animate-in fade-in duration-200\" \r\n          onClick={() => setShowLicenseViewer(false)}\r\n        >\r\n          <div className=\"relative max-w-4xl w-full flex flex-col\" onClick={(e) => e.stopPropagation()}>\r\n            <div className=\"flex justify-between items-center mb-3\">\r\n              <h4 className=\"text-sm font-bold text-zinc-100\">GiГҹв•‘Г‘y phв”ңвҢҗp kinh doanh - {restaurant.name}</h4>\r\n              <button \r\n                className=\"px-3 py-1 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 text-xs font-semibold rounded-lg transition\"\r\n                onClick={() => setShowLicenseViewer(false)}\r\n              >\r\n                в”ҖГүв”ңв”Ӯng\r\n              </button>\r\n            </div>\r\n            <div className=\"bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden p-2 flex items-center justify-center max-h-[80vh]\">\r\n              <img src={restaurant.businessLicense.imageUrl} alt=\"GPKD Fullscreen\" className=\"max-w-full max-h-[75vh] object-contain rounded-lg\" />\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Approve Modal */}\r\n      <ApproveModal\r\n        isOpen={activeModal === 'approve'}\r\n        restaurant={restaurant}\r\n        onConfirm={onApproveConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Reject Modal */}\r\n      <RejectModal\r\n        isOpen={activeModal === 'reject'}\r\n        restaurant={restaurant}\r\n        onConfirm={onRejectConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Suspend Modal */}\r\n      <SuspendModal\r\n        isOpen={activeModal === 'suspend'}\r\n        restaurant={restaurant}\r\n        onConfirm={onSuspendConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Unsuspend Modal */}\r\n      <UnsuspendModal\r\n        isOpen={activeModal === 'unsuspend'}\r\n        restaurant={restaurant}\r\n        onConfirm={onUnsuspendConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Delete Modal */}\r\n      <DeleteModal\r\n        isOpen={activeModal === 'delete'}\r\n        restaurant={restaurant}\r\n        onConfirm={onDeleteConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Restore Modal */}\r\n      <RestoreModal\r\n        isOpen={activeModal === 'restore'}\r\n        restaurant={restaurant}\r\n        onConfirm={onRestoreConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n    </AdminLayout>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminRestaurants.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  64 |\n  65 |   useEffect(() => {\n> 66 |     fetchRestaurants(1);\n     |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  67 |   }, [fetchRestaurants]);\n  68 |\n  69 |   const handleSearchSubmit = (e) => {","line":66,"column":5,"endLine":66,"endColumn":21}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useCallback } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport { adminApi } from '../../api/adminApi';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport toast from 'react-hot-toast';\r\nimport {\r\n  Search, Eye, EyeOff, CheckCircle, XCircle, PauseCircle, Play,\r\n  RefreshCw, ChevronLeft, ChevronRight, Store, Star, Trash2, Undo\r\n} from 'lucide-react';\r\n\r\n// Badge & Modals Components\r\nimport RestaurantStatusBadge from '../../components/admin/RestaurantStatusBadge';\r\nimport ApproveModal from '../../components/admin/ApproveModal';\r\nimport RejectModal from '../../components/admin/RejectModal';\r\nimport SuspendModal from '../../components/admin/SuspendModal';\r\nimport UnsuspendModal from '../../components/admin/UnsuspendModal';\r\nimport DeleteModal from '../../components/admin/DeleteModal';\r\nimport RestoreModal from '../../components/admin/RestoreModal';\r\n\r\nconst STATUS_TABS = [\r\n  { value: '', label: 'TГҹв•‘Г‘t cГҹв•‘Гә' },\r\n  { value: 'pending', label: 'ChГҹв•—ВҘ duyГҹв•—Г§t' },\r\n  { value: 'approved', label: 'HoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng' },\r\n  { value: 'suspended', label: 'TГҹв•‘Гӯm ngв•һв–‘ng' },\r\n  { value: 'rejected', label: 'TГҹв•—ВҪ chГҹв•—ГҰi' },\r\n  { value: 'deleted', label: 'в”ҖГүв”ңГә xв”ңв”Ӯa' },\r\n];\r\n\r\nexport default function AdminRestaurants() {\r\n  const navigate = useNavigate();\r\n  const [restaurants, setRestaurants] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [pagination, setPagination] = useState({ page: 1, totalPages: 1, total: 0 });\r\n  const [filters, setFilters] = useState({ \r\n    search: '', \r\n    approvalStatus: '', \r\n    deleted: 'false',\r\n    sortBy: 'createdAt',\r\n    sortOrder: 'desc'\r\n  });\r\n  const [searchInput, setSearchInput] = useState('');\r\n  const [actionLoading, setActionLoading] = useState(false);\r\n\r\n  // Modals state\r\n  const [selectedRest, setSelectedRest] = useState(null);\r\n  const [activeModal, setActiveModal] = useState(null); // 'approve' | 'reject' | 'suspend' | 'unsuspend' | 'delete' | 'restore'\r\n\r\n  const fetchRestaurants = useCallback(async (page = 1) => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await adminApi.getRestaurants({ page, limit: 15, ...filters });\r\n      setRestaurants(res.data.restaurants);\r\n      setPagination({\r\n        page: res.data.page,\r\n        totalPages: res.data.totalPages,\r\n        total: res.data.total,\r\n      });\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch nhв”ңГЎ hв”ңГЎng');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [filters]);\r\n\r\n  useEffect(() => {\r\n    fetchRestaurants(1);\r\n  }, [fetchRestaurants]);\r\n\r\n  const handleSearchSubmit = (e) => {\r\n    e.preventDefault();\r\n    setFilters((prev) => ({ ...prev, search: searchInput }));\r\n  };\r\n\r\n  const handleTabChange = (tabValue) => {\r\n    setSearchInput('');\r\n    if (tabValue === 'deleted') {\r\n      setFilters((prev) => ({\r\n        ...prev,\r\n        search: '',\r\n        approvalStatus: '',\r\n        deleted: 'true',\r\n      }));\r\n    } else {\r\n      setFilters((prev) => ({\r\n        ...prev,\r\n        search: '',\r\n        approvalStatus: tabValue,\r\n        deleted: 'false',\r\n      }));\r\n    }\r\n  };\r\n\r\n  const handleToggleFeatured = async (restaurant) => {\r\n    try {\r\n      const targetState = !restaurant.featured;\r\n      await adminApi.updateRestaurant(restaurant.id, { featured: targetState });\r\n      toast.success(targetState ? 'в”ҖГүв”ңГә ghim nГҹв•—ГІi bГҹв•‘ВЎt nhв”ңГЎ hв”ңГЎng' : 'в”ҖГүв”ңГә hГҹв•—Вәy ghim nГҹв•—ГІi bГҹв•‘ВЎt');\r\n      \r\n      // Update state locally to avoid full refetch stutter\r\n      setRestaurants(prev => prev.map(r => r.id === restaurant.id ? { ...r, featured: targetState } : r));\r\n    } catch (err) {\r\n      toast.error(err.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt nГҹв•—ГІi bГҹв•‘ВЎt thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    }\r\n  };\r\n\r\n  const handleToggleActive = async (restaurant) => {\r\n    try {\r\n      const targetState = !restaurant.active;\r\n      await adminApi.updateRestaurant(restaurant.id, { active: targetState });\r\n      toast.success(targetState ? 'в”ҖГүв”ңГә bГҹв•‘ВЎt hiГҹв•—Гўn thГҹв•—ГҜ nhв”ңГЎ hв”ңГЎng' : 'в”ҖГүв”ңГә Гҹв•‘вҢҗn nhв”ңГЎ hв”ңГЎng');\r\n      \r\n      // Update state locally\r\n      setRestaurants(prev => prev.map(r => r.id === restaurant.id ? { ...r, active: targetState } : r));\r\n    } catch (err) {\r\n      toast.error(err.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt hiГҹв•—Гўn thГҹв•—ГҜ thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    }\r\n  };\r\n\r\n  const onApproveConfirm = async (id, commissionRate) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.approveRestaurant(id, commissionRate);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә duyГҹв•—Г§t nhв”ңГЎ hв”ңГЎng thв”ңГЎnh cв”ңв”Өng');\r\n      setActiveModal(null);\r\n      fetchRestaurants(pagination.page);\r\n    } catch (err) {\r\n      toast.error(err.message || 'DuyГҹв•—Г§t nhв”ңГЎ hв”ңГЎng thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onRejectConfirm = async (id, reason) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.rejectRestaurant(id, reason);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә tГҹв•—ВҪ chГҹв•—ГҰi hГҹв•—Гҙ sв•һГӯ nhв”ңГЎ hв”ңГЎng');\r\n      setActiveModal(null);\r\n      fetchRestaurants(pagination.page);\r\n    } catch (err) {\r\n      toast.error(err.message || 'TГҹв•—ВҪ chГҹв•—ГҰi thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onSuspendConfirm = async (id, reason) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.suspendRestaurant(id, reason);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә tГҹв•‘Гӯm ngв•һв–‘ng hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng nhв”ңГЎ hв”ңГЎng');\r\n      setActiveModal(null);\r\n      fetchRestaurants(pagination.page);\r\n    } catch (err) {\r\n      toast.error(err.message || 'TГҹв•‘Гӯm ngв•һв–‘ng thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onUnsuspendConfirm = async (id) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.unsuspendRestaurant(id);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә gГҹв•—Гӯ tГҹв•‘Гӯm ngв•һв–‘ng hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng');\r\n      setActiveModal(null);\r\n      fetchRestaurants(pagination.page);\r\n    } catch (err) {\r\n      toast.error(err.message || 'GГҹв•—Гӯ tГҹв•‘Гӯm ngв•һв–‘ng thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onDeleteConfirm = async (id, reason) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.deleteRestaurant(id, reason);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә xв”ңв”Ӯa nhв”ңГЎ hв”ңГЎng thв”ңГЎnh cв”ңв”Өng');\r\n      setActiveModal(null);\r\n      fetchRestaurants(pagination.page);\r\n    } catch (err) {\r\n      toast.error(err.message || 'Xв”ңв”Ӯa nhв”ңГЎ hв”ңГЎng thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const onRestoreConfirm = async (id) => {\r\n    setActionLoading(true);\r\n    try {\r\n      const res = await adminApi.restoreRestaurant(id);\r\n      toast.success(res.message || 'в”ҖГүв”ңГә khв”ңв”Өi phГҹв•—Г‘c nhв”ңГЎ hв”ңГЎng thв”ңГЎnh cв”ңв”Өng');\r\n      setActiveModal(null);\r\n      fetchRestaurants(pagination.page);\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өi phГҹв•—Г‘c thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setActionLoading(false);\r\n    }\r\n  };\r\n\r\n  const openActionModal = (modalType, restaurant) => {\r\n    setSelectedRest(restaurant);\r\n    setActiveModal(modalType);\r\n  };\r\n\r\n  return (\r\n    <AdminLayout title=\"QuГҹв•‘Гәn lв”ңв•ң Nhв”ңГЎ hв”ңГЎng\" subtitle={`TГҹв•—ГІng cГҹв•—Г–ng ${pagination.total} nhв”ңГЎ hв”ңГЎng`}>\r\n      {/* Tabs Filter */}\r\n      <div className=\"flex border-b border-zinc-800 mb-6 overflow-x-auto whitespace-nowrap scrollbar-none gap-2\">\r\n        {STATUS_TABS.map((tab) => {\r\n          const isActive = filters.deleted === 'true' \r\n            ? tab.value === 'deleted' \r\n            : filters.approvalStatus === tab.value && tab.value !== 'deleted';\r\n          return (\r\n            <button\r\n              key={tab.value}\r\n              className={`px-4 py-2 text-xs font-semibold tracking-wide uppercase border-b-2 transition duration-200 outline-none ${\r\n                isActive \r\n                  ? 'border-amber-500 text-amber-500' \r\n                  : 'border-transparent text-zinc-400 hover:text-zinc-200'\r\n              }`}\r\n              onClick={() => handleTabChange(tab.value)}\r\n            >\r\n              {tab.label}\r\n            </button>\r\n          );\r\n        })}\r\n      </div>\r\n\r\n      {/* Toolbar */}\r\n      <div className=\"flex flex-col md:flex-row gap-4 justify-between items-stretch md:items-center mb-6\">\r\n        <form onSubmit={handleSearchSubmit} className=\"relative flex-1 max-w-md\">\r\n          <span className=\"absolute inset-y-0 left-0 pl-3 flex items-center text-zinc-500\">\r\n            <Search size={16} />\r\n          </span>\r\n          <input\r\n            type=\"text\"\r\n            placeholder=\"Tв”ңВјm theo tв”ңВ¬n, email, sв”ҖГҰt...\"\r\n            value={searchInput}\r\n            onChange={(e) => setSearchInput(e.target.value)}\r\n            className=\"w-full bg-[#1A1D24] border border-zinc-800 text-zinc-200 placeholder-zinc-500 rounded-lg text-sm pl-10 pr-4 py-2 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n          />\r\n        </form>\r\n\r\n        <div className=\"flex items-center gap-3\">\r\n          <select\r\n            value={filters.sortBy}\r\n            onChange={(e) => setFilters((p) => ({ ...p, sortBy: e.target.value }))}\r\n            className=\"bg-[#1A1D24] border border-zinc-800 text-zinc-300 rounded-lg text-sm px-3 py-2 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n          >\r\n            <option value=\"createdAt\">в”ҖГүв”ҖГўng kв”ңв•ң mГҹв•—Вўi nhГҹв•‘Г‘t</option>\r\n            <option value=\"name\">Tв”ңВ¬n nhв”ңГЎ hв”ңГЎng A-Z</option>\r\n            <option value=\"stats.averageRating\">в”ҖГүв”ңГӯnh giв”ңГӯ cao nhГҹв•‘Г‘t</option>\r\n            <option value=\"stats.totalBookings\">Lв•һв–‘Гҹв•—Гәt в”ҖГҰГҹв•‘в•–t bв”ңГЎn nhiГҹв•—Гјu nhГҹв•‘Г‘t</option>\r\n          </select>\r\n          <select\r\n            value={filters.sortOrder}\r\n            onChange={(e) => setFilters((p) => ({ ...p, sortOrder: e.target.value }))}\r\n            className=\"bg-[#1A1D24] border border-zinc-800 text-zinc-300 rounded-lg text-sm px-3 py-2 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n          >\r\n            <option value=\"desc\">GiГҹв•‘Гәm dГҹв•‘Вәn</option>\r\n            <option value=\"asc\">Tв”ҖГўng dГҹв•‘Вәn</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Table */}\r\n      {loading ? (\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-3 bg-[#1A1D24] border border-zinc-800 rounded-xl\">\r\n          <div className=\"w-8 h-8 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\r\n          <span className=\"text-sm\">в”ҖГүang tГҹв•‘Гәi danh sв”ңГӯch...</span>\r\n        </div>\r\n      ) : restaurants.length === 0 ? (\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-4 bg-[#1A1D24] border border-zinc-800 rounded-xl\">\r\n          <Store size={48} className=\"opacity-40 text-amber-500\" />\r\n          <p className=\"text-sm\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y nhв”ңГЎ hв”ңГЎng nв”ңГЎo phв”ңв•Ј hГҹв•—Гәp vГҹв•—Вўi bГҹв•—Г– lГҹв•—Г¬c</p>\r\n          <button \r\n            className=\"inline-flex items-center gap-1.5 px-3 py-1.5 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 text-xs font-semibold rounded-lg transition\"\r\n            onClick={() => { setFilters({ search: '', approvalStatus: '', deleted: 'false', sortBy: 'createdAt', sortOrder: 'desc' }); setSearchInput(''); }}\r\n          >\r\n            <RefreshCw size={14} /> Xв”ңв”Ӯa bГҹв•—Г– lГҹв•—Г¬c\r\n          </button>\r\n        </div>\r\n      ) : (\r\n        <>\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl overflow-hidden shadow-lg\">\r\n            <div className=\"overflow-x-auto\">\r\n              <table className=\"w-full text-left border-collapse text-zinc-350 text-sm\">\r\n                <thead>\r\n                  <tr className=\"bg-zinc-900/50 border-b border-zinc-800 text-zinc-450 font-medium\">\r\n                    <th className=\"p-4 text-center w-20\">HiГҹв•—Гўn thГҹв•—ГҜ</th>\r\n                    <th className=\"p-4\">Nhв”ңГЎ hв”ңГЎng</th>\r\n                    <th className=\"p-4\">ChГҹв•—Вә sГҹв•—Ж’ hГҹв•—В»u</th>\r\n                    <th className=\"p-4\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n                    <th className=\"p-4\">TГҹв•—Г«nh/Thв”ңГЎnh phГҹв•—ГҰ</th>\r\n                    <th className=\"p-4\">в”ҖГүв”ңГӯnh giв”ңГӯ</th>\r\n                    <th className=\"p-4\">Ngв”ңГЎy в”ҖГҰв”ҖГўng kв”ңв•ң</th>\r\n                    <th className=\"p-4 text-right\">Thao tв”ңГӯc</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody className=\"divide-y divide-zinc-800/60\">\r\n                  {restaurants.map((restaurant) => {\r\n                    const isDeleted = !!restaurant.deletedAt;\r\n                    return (\r\n                      <tr key={restaurant.id} className=\"hover:bg-zinc-850/30 transition-colors\">\r\n                        <td className=\"p-4 text-center\">\r\n                          {!isDeleted && (\r\n                            <div className=\"flex items-center justify-center gap-2\">\r\n                              <button\r\n                                className={`p-1.5 rounded-lg border transition ${\r\n                                  restaurant.featured \r\n                                    ? 'bg-amber-500/10 text-amber-500 border-amber-500/20' \r\n                                    : 'border-zinc-800 text-zinc-500 hover:text-zinc-350'\r\n                                }`}\r\n                                onClick={() => handleToggleFeatured(restaurant)}\r\n                                title={restaurant.featured ? 'HГҹв•—Вәy ghim nГҹв•—ГІi bГҹв•‘ВЎt' : 'Ghim nГҹв•—ГІi bГҹв•‘ВЎt'}\r\n                              >\r\n                                <Star size={14} fill={restaurant.featured ? 'currentColor' : 'none'} />\r\n                              </button>\r\n                              <button\r\n                                className={`p-1.5 rounded-lg border transition ${\r\n                                  restaurant.active \r\n                                    ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' \r\n                                    : 'border-zinc-805 text-zinc-500 hover:text-zinc-350'\r\n                                }`}\r\n                                onClick={() => handleToggleActive(restaurant)}\r\n                                title={restaurant.active ? 'в”ҖГүang hiГҹв•—Гўn thГҹв•—ГҜ - NhГҹв•‘Г‘n в”ҖГҰГҹв•—Гў Гҹв•‘вҢҗn' : 'в”ҖГүang Гҹв•‘вҢҗn - NhГҹв•‘Г‘n в”ҖГҰГҹв•—Гў hiГҹв•—Гўn thГҹв•—ГҜ'}\r\n                              >\r\n                                {restaurant.active ? <Eye size={14} /> : <EyeOff size={14} />}\r\n                              </button>\r\n                            </div>\r\n                          )}\r\n                        </td>\r\n                        <td className=\"p-4\">\r\n                          <div className=\"flex items-center gap-3\">\r\n                            <div className=\"w-10 h-10 rounded-lg bg-zinc-805 border border-zinc-800 overflow-hidden flex items-center justify-center text-zinc-400\">\r\n                              {restaurant.logo ? (\r\n                                <img src={restaurant.logo} alt=\"\" className=\"w-full h-full object-cover\" />\r\n                              ) : (\r\n                                <Store size={18} />\r\n                              )}\r\n                            </div>\r\n                            <div>\r\n                              <div className=\"font-semibold text-zinc-200\">{restaurant.name}</div>\r\n                              <div className=\"text-xs text-zinc-400 font-mono\">{restaurant.phoneNumber}</div>\r\n                            </div>\r\n                          </div>\r\n                        </td>\r\n                        <td className=\"p-4\">\r\n                          <div>\r\n                            <div className=\"font-medium text-zinc-300\">{restaurant.ownerId?.fullName || 'N/A'}</div>\r\n                            <div className=\"text-xs text-zinc-500\">{restaurant.ownerId?.email || 'N/A'}</div>\r\n                          </div>\r\n                        </td>\r\n                        <td className=\"p-4\">\r\n                          <RestaurantStatusBadge status={isDeleted ? 'deleted' : restaurant.approvalStatus} />\r\n                        </td>\r\n                        <td className=\"p-4 text-xs text-zinc-300\">\r\n                          {restaurant.address?.city || 'N/A'}\r\n                        </td>\r\n                        <td className=\"p-4\">\r\n                          <div className=\"flex items-center gap-1 text-xs text-zinc-350 font-medium\">\r\n                            <Star size={13} fill=\"#fbbf24\" color=\"#fbbf24\" />\r\n                            <span>{restaurant.stats?.averageRating ? restaurant.stats.averageRating.toFixed(1) : '0.0'}</span>\r\n                          </div>\r\n                        </td>\r\n                        <td className=\"p-4 text-xs text-zinc-400 font-mono\">\r\n                          {new Date(restaurant.createdAt).toLocaleDateString('vi-VN')}\r\n                        </td>\r\n                        <td className=\"p-4 text-right\">\r\n                          <div className=\"flex items-center justify-end gap-1.5\">\r\n                            <button\r\n                              className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-amber-500 rounded-lg transition\"\r\n                              title=\"Xem chi tiГҹв•‘в”җt\"\r\n                              onClick={() => navigate(`/admin/restaurants/${restaurant.id}`)}\r\n                            >\r\n                              <Eye size={14} />\r\n                            </button>\r\n\r\n                            {/* Dynamic Actions based on Status */}\r\n                            {isDeleted ? (\r\n                              <button\r\n                                className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-emerald-500 rounded-lg transition\"\r\n                                title=\"Khв”ңв”Өi phГҹв•—Г‘c nhв”ңГЎ hв”ңГЎng\"\r\n                                onClick={() => openActionModal('restore', restaurant)}\r\n                              >\r\n                                <Undo size={14} />\r\n                              </button>\r\n                            ) : (\r\n                              <>\r\n                                {restaurant.approvalStatus === 'pending' && (\r\n                                  <>\r\n                                    <button\r\n                                      className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-emerald-500 rounded-lg transition\"\r\n                                      title=\"DuyГҹв•—Г§t\"\r\n                                      onClick={() => openActionModal('approve', restaurant)}\r\n                                    >\r\n                                      <CheckCircle size={14} />\r\n                                    </button>\r\n                                    <button\r\n                                      className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-rose-500 rounded-lg transition\"\r\n                                      title=\"TГҹв•—ВҪ chГҹв•—ГҰi\"\r\n                                      onClick={() => openActionModal('reject', restaurant)}\r\n                                    >\r\n                                      <XCircle size={14} />\r\n                                    </button>\r\n                                  </>\r\n                                )}\r\n\r\n                                {restaurant.approvalStatus === 'approved' && (\r\n                                  <button\r\n                                    className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-orange-500 rounded-lg transition\"\r\n                                    title=\"TГҹв•‘Гӯm ngв•һв–‘ng hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng\"\r\n                                    onClick={() => openActionModal('suspend', restaurant)}\r\n                                  >\r\n                                    <PauseCircle size={14} />\r\n                                  </button>\r\n                                )}\r\n                                \r\n                                {restaurant.approvalStatus === 'suspended' && (\r\n                                  <button\r\n                                    className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-emerald-500 rounded-lg transition\"\r\n                                    title=\"GГҹв•—Гӯ tГҹв•‘Гӯm ngв•һв–‘ng\"\r\n                                    onClick={() => openActionModal('unsuspend', restaurant)}\r\n                                  >\r\n                                    <Play size={14} />\r\n                                  </button>\r\n                                )}\r\n\r\n                                {restaurant.approvalStatus === 'rejected' && (\r\n                                  <button\r\n                                    className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-emerald-500 rounded-lg transition\"\r\n                                    title=\"DuyГҹв•—Г§t lГҹв•‘Гӯi\"\r\n                                    onClick={() => openActionModal('approve', restaurant)}\r\n                                  >\r\n                                    <CheckCircle size={14} />\r\n                                  </button>\r\n                                )}\r\n\r\n                                <button\r\n                                  className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-rose-505 rounded-lg transition\"\r\n                                  title=\"Xв”ңв”Ӯa nhв”ңГЎ hв”ңГЎng\"\r\n                                  onClick={() => openActionModal('delete', restaurant)}\r\n                                >\r\n                                  <Trash2 size={14} />\r\n                                </button>\r\n                              </>\r\n                            )}\r\n                          </div>\r\n                        </td>\r\n                      </tr>\r\n                    );\r\n                  })}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Pagination */}\r\n          {pagination.totalPages > 1 && (\r\n            <div className=\"flex items-center justify-center gap-4 mt-6\">\r\n              <button\r\n                disabled={pagination.page <= 1}\r\n                onClick={() => fetchRestaurants(pagination.page - 1)}\r\n                className=\"p-2 border border-zinc-800 hover:bg-zinc-800 text-zinc-400 disabled:opacity-50 rounded-lg transition\"\r\n              >\r\n                <ChevronLeft size={16} />\r\n              </button>\r\n              <span className=\"text-xs text-zinc-400\">\r\n                Trang {pagination.page} / {pagination.totalPages}\r\n              </span>\r\n              <button\r\n                disabled={pagination.page >= pagination.totalPages}\r\n                onClick={() => fetchRestaurants(pagination.page + 1)}\r\n                className=\"p-2 border border-zinc-800 hover:bg-zinc-800 text-zinc-400 disabled:opacity-50 rounded-lg transition\"\r\n              >\r\n                <ChevronRight size={16} />\r\n              </button>\r\n            </div>\r\n          )}\r\n        </>\r\n      )}\r\n\r\n      {/* Approve Modal */}\r\n      <ApproveModal\r\n        isOpen={activeModal === 'approve'}\r\n        restaurant={selectedRest}\r\n        onConfirm={onApproveConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Reject Modal */}\r\n      <RejectModal\r\n        isOpen={activeModal === 'reject'}\r\n        restaurant={selectedRest}\r\n        onConfirm={onRejectConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Suspend Modal */}\r\n      <SuspendModal\r\n        isOpen={activeModal === 'suspend'}\r\n        restaurant={selectedRest}\r\n        onConfirm={onSuspendConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Unsuspend Modal */}\r\n      <UnsuspendModal\r\n        isOpen={activeModal === 'unsuspend'}\r\n        restaurant={selectedRest}\r\n        onConfirm={onUnsuspendConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Delete Modal */}\r\n      <DeleteModal\r\n        isOpen={activeModal === 'delete'}\r\n        restaurant={selectedRest}\r\n        onConfirm={onDeleteConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n\r\n      {/* Restore Modal */}\r\n      <RestoreModal\r\n        isOpen={activeModal === 'restore'}\r\n        restaurant={selectedRest}\r\n        onConfirm={onRestoreConfirm}\r\n        onClose={() => setActiveModal(null)}\r\n        loading={actionLoading}\r\n      />\r\n    </AdminLayout>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminRevenue.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  59 |\n  60 |   useEffect(() => {\n> 61 |     loadData();\n     |     ^^^^^^^^ Avoid calling setState() directly within an effect\n  62 |   }, []);\n  63 |\n  64 |   useEffect(() => {","line":61,"column":5,"endLine":61,"endColumn":13},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  63 |\n  64 |   useEffect(() => {\n> 65 |     loadWithdrawals();\n     |     ^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  66 |   }, [statusFilter]);\n  67 |\n  68 |   const handleOpenActionModal = (withdrawal, action) => {","line":65,"column":5,"endLine":65,"endColumn":20},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadWithdrawals'. Either include it or remove the dependency array.","line":66,"column":6,"endLine":66,"endColumn":20,"suggestions":[{"desc":"Update the dependencies array to be: [loadWithdrawals, statusFilter]","fix":{"range":[2435,2449],"text":"[loadWithdrawals, statusFilter]"}}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState } from 'react';\nimport { TrendingUp, RefreshCcw, Users, Wallet, Check, X, CreditCard, AlertCircle } from 'lucide-react';\nimport AdminLayout from '../../components/admin/AdminLayout';\nimport { adminGetRevenue, adminGetPayments } from '../../api/paymentApi';\nimport { adminGetWithdrawals, adminApproveWithdrawal, adminRejectWithdrawal, adminCompleteWithdrawal } from '../../api/withdrawalApi';\n\nconst formatMoney = (v) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND', maximumFractionDigits: 0 }).format(v || 0);\nconst formatDate = (d) => d ? new Date(d).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'О“ГҮГ¶';\n\nexport default function AdminRevenue() {\n  const [revenue, setRevenue] = useState(null);\n  const [recentPayments, setRecentPayments] = useState([]);\n  const [loading, setLoading] = useState(false);\n\n  // Withdrawal requests States\n  const [withdrawals, setWithdrawals] = useState([]);\n  const [withdrawalLoading, setWithdrawalLoading] = useState(false);\n  const [statusFilter, setStatusFilter] = useState('pending'); // default show pending to process\n  \n  // Modal states\n  const [showModal, setShowModal] = useState(false);\n  const [selectedWithdrawal, setSelectedWithdrawal] = useState(null);\n  const [modalAction, setModalAction] = useState(''); // 'approve' | 'reject' | 'complete'\n  const [adminNote, setAdminNote] = useState('');\n  const [actionLoading, setActionLoading] = useState(false);\n  const [actionError, setActionError] = useState(null);\n\n  const loadData = async () => {\n    setLoading(true);\n    try {\n      const [revRes, payRes] = await Promise.all([\n        adminGetRevenue(),\n        adminGetPayments({ limit: 8, status: 'paid' }),\n      ]);\n      setRevenue(revRes.data);\n      setRecentPayments(payRes.data || []);\n    } catch (e) {\n      console.error(e);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const loadWithdrawals = async () => {\n    setWithdrawalLoading(true);\n    try {\n      const params = {};\n      if (statusFilter) {\n        params.status = statusFilter;\n      }\n      const res = await adminGetWithdrawals(params);\n      setWithdrawals(res.data || []);\n    } catch (e) {\n      console.error(e);\n    } finally {\n      setWithdrawalLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    loadData();\n  }, []);\n\n  useEffect(() => {\n    loadWithdrawals();\n  }, [statusFilter]);\n\n  const handleOpenActionModal = (withdrawal, action) => {\n    setSelectedWithdrawal(withdrawal);\n    setModalAction(action);\n    setAdminNote(action === 'approve' ? 'в”ҖГүв”ңГә duyГҹв•—Г§t yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn' : action === 'complete' ? 'в”ҖГүв”ңГә chuyГҹв•—Гўn tiГҹв•—Гјn hoв”ңГЎn tГҹв•‘Г‘t' : '');\n    setActionError(null);\n    setShowModal(true);\n  };\n\n  const handleCloseModal = () => {\n    setShowModal(false);\n    setSelectedWithdrawal(null);\n    setModalAction('');\n    setAdminNote('');\n    setActionError(null);\n  };\n\n  const handleConfirmAction = async () => {\n    if (!selectedWithdrawal) return;\n    \n    if (modalAction === 'reject' && !adminNote.trim()) {\n      setActionError('Lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi lв”ңГЎ bГҹв•‘В»t buГҹв•—Г–c.');\n      return;\n    }\n\n    setActionLoading(true);\n    setActionError(null);\n    \n    try {\n      if (modalAction === 'approve') {\n        await adminApproveWithdrawal(selectedWithdrawal._id, { adminNote });\n      } else if (modalAction === 'reject') {\n        await adminRejectWithdrawal(selectedWithdrawal._id, { adminNote });\n      } else if (modalAction === 'complete') {\n        await adminCompleteWithdrawal(selectedWithdrawal._id, { adminNote });\n      }\n      \n      handleCloseModal();\n      loadWithdrawals();\n      loadData(); // reload stats just in case\n    } catch (err) {\n      setActionError(err.message || 'Thao tв”ңГӯc thГҹв•‘Г‘t bГҹв•‘Гӯi.');\n    } finally {\n      setActionLoading(false);\n    }\n  };\n\n  return (\n    <AdminLayout title=\"Doanh thu\" subtitle=\"QuГҹв•‘Гәn lв”ңв•ң dв”ңв–“ng tiГҹв•—Гјn, doanh thu & yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn toв”ңГЎn sв”ңГЎn BookEat\">\n      <div className=\"flex flex-col sm:flex-row gap-4 justify-between items-stretch sm:items-center mb-6\">\n        <h1 className=\"text-xl font-extrabold text-zinc-100 uppercase tracking-wide flex items-center gap-2\">\n          <TrendingUp className=\"text-amber-500\" /> Bв”ңГӯo cв”ңГӯo doanh thu & Rв”ңв•‘t tiГҹв•—Гјn\n        </h1>\n        <button \n          className=\"inline-flex items-center gap-1.5 px-4 py-2 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 text-xs font-semibold rounded-lg transition disabled:opacity-50 cursor-pointer\" \n          onClick={() => { loadData(); loadWithdrawals(); }} \n          disabled={loading || withdrawalLoading}\n        >\n          <RefreshCcw size={14} className={loading || withdrawalLoading ? 'animate-spin' : ''} /> Lв”ңГЎm mГҹв•—Вўi\n        </button>\n      </div>\n\n      {loading && (\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-3 bg-[#1A1D24] border border-zinc-800 rounded-xl mb-6\">\n          <div className=\"w-8 h-8 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\n          <span className=\"text-sm\">в”ҖГүang tГҹв•‘Гәi dГҹв•—В» liГҹв•—Г§u...</span>\n        </div>\n      )}\n\n      {revenue && !loading && (\n        <>\n          {/* KPI Cards */}\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6 animate-in fade-in duration-200\">\n            <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col justify-between border-l-4 border-l-amber-500\">\n              <span className=\"text-xs text-zinc-400 uppercase tracking-wide font-semibold\">TГҹв•—ГІng doanh thu</span>\n              <strong className=\"text-2xl font-black text-amber-500 mt-1\">{formatMoney(revenue.totalRevenue)}</strong>\n              <span className=\"text-[10px] text-zinc-500 mt-2 font-mono\">Tв”ңВЎnh cГҹв•‘Гә в”ҖГҰв”ҖГўng kв”ңв•ң & cГҹв•—Г¬c bв”ңГЎn</span>\n            </div>\n            <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col justify-between border-l-4 border-l-blue-500\">\n              <span className=\"text-xs text-zinc-400 uppercase tracking-wide font-semibold\">Doanh thu gв”ңв”Ӯi</span>\n              <strong className=\"text-2xl font-black text-blue-400 mt-1\">{formatMoney(revenue.subscriptionRevenue?.total)}</strong>\n              <span className=\"text-[10px] text-zinc-500 mt-2 font-mono\">{revenue.subscriptionRevenue?.count || 0} giao dГҹв•—ГҜch</span>\n            </div>\n            <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col justify-between border-l-4 border-l-emerald-500\">\n              <span className=\"text-xs text-zinc-400 uppercase tracking-wide font-semibold\">Doanh thu в”ҖГҰГҹв•‘в•–t cГҹв•—Г¬c</span>\n              <strong className=\"text-2xl font-black text-emerald-400 mt-1\">{formatMoney(revenue.bookingRevenue?.total)}</strong>\n              <span className=\"text-[10px] text-zinc-500 mt-2 font-mono\">{revenue.bookingRevenue?.count || 0} giao dГҹв•—ГҜch</span>\n            </div>\n            <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col justify-between border-l-4 border-l-rose-500\">\n              <span className=\"text-xs text-zinc-400 uppercase tracking-wide font-semibold\">в”ҖГүв”ңГә hoв”ңГЎn tiГҹв•—Гјn</span>\n              <strong className=\"text-2xl font-black text-rose-400 mt-1\">{formatMoney(revenue.refundTotal?.total)}</strong>\n              <span className=\"text-[10px] text-zinc-500 mt-2 font-mono\">{revenue.refundTotal?.count || 0} giao dГҹв•—ГҜch</span>\n            </div>\n          </div>\n\n          {/* Net Revenue Summary */}\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6 animate-in fade-in duration-200\">\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-sm text-zinc-400 font-medium\">Doanh thu thГҹв•—в–’c nhГҹв•‘ВЎn (Net Revenue):</span>\n              <strong className=\"text-xl font-black text-emerald-450\">{formatMoney(revenue.netRevenue)}</strong>\n            </div>\n            <span className=\"inline-flex items-center gap-1.5 px-3 py-1.5 bg-[#13161C] border border-zinc-800 rounded-lg text-xs font-semibold text-zinc-300\">\n              <Users size={14} className=\"text-amber-500\" /> {revenue.activeSubscriptions || 0} gв”ңв”Ӯi в”ҖГҰang hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng\n            </span>\n          </div>\n\n          {/* Daily Revenue Chart */}\n          {revenue.dailyRevenue && revenue.dailyRevenue.length > 0 && (\n            <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg mb-6 animate-in fade-in duration-200\">\n              <h3 className=\"text-sm font-bold text-zinc-200 mb-6 pb-2 border-b border-zinc-800 uppercase tracking-wide\">Doanh thu 30 ngв”ңГЎy gГҹв•‘Вәn в”ҖГҰв”ңГіy</h3>\n              <div className=\"flex items-end justify-between h-48 pt-4 gap-1.5 overflow-x-auto scrollbar-none\">\n                {revenue.dailyRevenue.map((day) => {\n                  const maxVal = Math.max(...revenue.dailyRevenue.map(d => d.total));\n                  const height = maxVal > 0 ? (day.total / maxVal) * 100 : 0;\n                  return (\n                    <div key={day._id} className=\"flex flex-col items-center flex-1 min-w-[32px] group\" title={`${day._id}: ${formatMoney(day.total)}`}>\n                      <div className=\"w-full relative flex flex-col justify-end h-32\">\n                        {/* Tooltip */}\n                        <div className=\"absolute bottom-full left-1/2 -translate-x-1/2 mb-1 hidden group-hover:block bg-zinc-900 border border-zinc-800 text-[10px] text-zinc-200 px-2 py-0.5 rounded whitespace-nowrap shadow-md z-10\">\n                          {formatMoney(day.total)}\n                        </div>\n                        <div \n                          className=\"w-full bg-amber-500/80 hover:bg-amber-500 rounded-t-sm transition-all duration-300\" \n                          style={{ height: `${Math.max(height, 4)}%` }} \n                        />\n                      </div>\n                      <span className=\"text-[9px] text-zinc-500 mt-2 font-mono\">{day._id.slice(5)}</span>\n                    </div>\n                  );\n                })}\n              </div>\n            </div>\n          )}\n\n          {/* TWO MAIN COLUMNS: Left (Recent Payments), Right (Withdrawals Requests) */}\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 items-start\">\n            \n            {/* Left Column: Recent Payments (5/12 width) */}\n            <div className=\"lg:col-span-5 bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col gap-4\">\n              <h3 className=\"text-sm font-bold text-zinc-200 pb-2 border-b border-zinc-800 uppercase tracking-wide flex items-center gap-1.5\">\n                <CreditCard size={16} className=\"text-amber-500\" /> Giao dГҹв•—ГҜch gГҹв•‘Вәn в”ҖГҰв”ңГіy\n              </h3>\n              {recentPayments.length === 0 ? (\n                <p className=\"text-xs text-zinc-500 italic py-8 text-center\">Chв•һв–‘a cв”ңв”Ӯ giao dГҹв•—ГҜch nв”ңГЎo.</p>\n              ) : (\n                <div className=\"overflow-x-auto\">\n                  <table className=\"w-full text-left border-collapse text-zinc-300 text-xs\">\n                    <thead>\n                      <tr className=\"bg-zinc-900/50 border-b border-zinc-800 text-zinc-400 font-medium\">\n                        <th className=\"p-3\">Ngв”ңГЎy</th>\n                        <th className=\"p-3\">LoГҹв•‘Гӯi</th>\n                        <th className=\"p-3\">SГҹв•—ГҰ tiГҹв•—Гјn</th>\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-zinc-800\">\n                      {recentPayments.map((p) => (\n                        <tr key={p._id} className=\"hover:bg-zinc-800/30 transition-colors\">\n                          <td className=\"p-3 text-zinc-400 font-mono text-[10px]\">{new Date(p.paidAt || p.createdAt).toLocaleDateString('vi-VN')}</td>\n                          <td className=\"p-3\">\n                            <span className={`inline-flex px-1.5 py-0.5 rounded text-[10px] font-bold border ${\n                              p.targetType === 'subscription' \n                                ? 'bg-blue-500/10 text-blue-400 border-blue-500/20' \n                                : 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20'\n                            }`}>\n                              {p.targetType === 'subscription' ? 'Gв”ңв”Ӯi' : 'CГҹв•—Г¬c'}\n                            </span>\n                          </td>\n                          <td className=\"p-3 font-bold text-zinc-200 font-mono\">{formatMoney(p.amount)}</td>\n                        </tr>\n                      ))}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n\n            {/* Right Column: Withdrawals Requests (7/12 width) */}\n            <div className=\"lg:col-span-7 bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col gap-4\">\n              <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 border-b border-zinc-800 pb-2\">\n                <h3 className=\"text-sm font-bold text-zinc-200 uppercase tracking-wide flex items-center gap-1.5\">\n                  <Wallet size={16} className=\"text-amber-500\" /> Yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn\n                </h3>\n\n                {/* Filter statuses */}\n                <div className=\"flex bg-zinc-900/60 p-1 border border-zinc-800 rounded-lg gap-1\">\n                  {['pending', 'approved', 'completed', 'rejected', ''].map((st) => {\n                    const label = st === 'pending' ? 'ChГҹв•—ВҘ duyГҹв•—Г§t' : \n                                  st === 'approved' ? 'в”ҖГүв”ңГә duyГҹв•—Г§t' : \n                                  st === 'completed' ? 'Hoв”ңГЎn tГҹв•‘Г‘t' : \n                                  st === 'rejected' ? 'TГҹв•—ВҪ chГҹв•—ГҰi' : 'TГҹв•‘Г‘t cГҹв•‘Гә';\n                    return (\n                      <button\n                        key={st}\n                        onClick={() => setStatusFilter(st)}\n                        className={`px-2.5 py-1 text-[10px] font-bold rounded cursor-pointer transition ${\n                          statusFilter === st\n                            ? 'bg-amber-500 text-zinc-950 font-black'\n                            : 'text-zinc-400 hover:text-white'\n                        }`}\n                      >\n                        {label}\n                      </button>\n                    );\n                  })}\n                </div>\n              </div>\n\n              {withdrawalLoading ? (\n                <div className=\"flex flex-col items-center justify-center py-12 text-zinc-400 space-y-2\">\n                  <div className=\"w-6 h-6 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\n                  <span className=\"text-xs\">в”ҖГүang tГҹв•‘Гәi yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn...</span>\n                </div>\n              ) : withdrawals.length === 0 ? (\n                <p className=\"text-xs text-zinc-550 italic py-12 text-center\">Khв”ңв”Өng cв”ңв”Ӯ yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn nв”ңГЎo phв”ңв•Ј hГҹв•—Гәp.</p>\n              ) : (\n                <div className=\"overflow-x-auto\">\n                  <table className=\"w-full text-left border-collapse text-zinc-300 text-xs\">\n                    <thead>\n                      <tr className=\"bg-zinc-900/50 border-b border-zinc-800 text-zinc-400 font-medium\">\n                        <th className=\"p-3\">Nhв”ңГЎ hв”ңГЎng/ChГҹв•—Вә sГҹв•—Ж’ hГҹв•—В»u</th>\n                        <th className=\"p-3 text-right\">SГҹв•—ГҰ tiГҹв•—Гјn</th>\n                        <th className=\"p-3\">Tв”ңГЎi khoГҹв•‘Гәn nhГҹв•‘ВЎn</th>\n                        <th className=\"p-3 text-center\">Hв”ңГЎnh в”ҖГҰГҹв•—Г–ng</th>\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-zinc-800\">\n                      {withdrawals.map((w) => (\n                        <tr key={w._id} className=\"hover:bg-zinc-800/30 transition-colors\">\n                          <td className=\"p-3\">\n                            <div className=\"font-bold text-zinc-200\">{w.restaurantId?.name || 'Nhв”ңГЎ hв”ңГЎng Гҹв•‘вҢҗn'}</div>\n                            <div className=\"text-[10px] text-zinc-400 mt-0.5\">ChГҹв•—Вә: {w.ownerId?.fullName || 'О“ГҮГ¶'}</div>\n                            <div className=\"text-[9px] text-zinc-550 mt-1 font-mono\">{formatDate(w.createdAt)}</div>\n                          </td>\n                          <td className=\"p-3 text-right font-bold text-zinc-200 font-mono\">\n                            {formatMoney(w.amount)}\n                          </td>\n                          <td className=\"p-3\">\n                            <div className=\"font-semibold text-zinc-200\">{w.bankInfo?.bankName}</div>\n                            <div className=\"text-[10px] text-zinc-400 font-mono mt-0.5\">{w.bankInfo?.accountNumber}</div>\n                            <div className=\"text-[10px] text-zinc-400 capitalize\">{w.bankInfo?.accountHolder}</div>\n                            {w.note && <div className=\"text-[10px] italic text-zinc-500 mt-1\">Ghi chв”ңв•‘: {w.note}</div>}\n                          </td>\n                          <td className=\"p-3 text-center\">\n                            {w.status === 'pending' && (\n                              <div className=\"flex gap-1.5 justify-center\">\n                                <button\n                                  onClick={() => handleOpenActionModal(w, 'approve')}\n                                  className=\"p-1 px-2 text-[10px] font-bold rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/20 cursor-pointer\"\n                                  title=\"DuyГҹв•—Г§t yв”ңВ¬u cГҹв•‘Вәu\"\n                                >\n                                  DuyГҹв•—Г§t\n                                </button>\n                                <button\n                                  onClick={() => handleOpenActionModal(w, 'reject')}\n                                  className=\"p-1 px-2 text-[10px] font-bold rounded bg-rose-500/10 text-rose-400 border border-rose-500/20 hover:bg-rose-500/20 cursor-pointer\"\n                                  title=\"TГҹв•—ВҪ chГҹв•—ГҰi yв”ңВ¬u cГҹв•‘Вәu\"\n                                >\n                                  TГҹв•—ВҪ chГҹв•—ГҰi\n                                </button>\n                              </div>\n                            )}\n\n                            {w.status === 'approved' && (\n                              <div className=\"flex flex-col gap-1 items-center\">\n                                <button\n                                  onClick={() => handleOpenActionModal(w, 'complete')}\n                                  className=\"p-1 px-2 text-[10px] font-bold rounded bg-blue-500/10 text-blue-400 border border-blue-500/20 hover:bg-blue-500/20 cursor-pointer flex items-center gap-1\"\n                                >\n                                  Hoв”ңГЎn tГҹв•‘Г‘t\n                                </button>\n                                <span className=\"text-[9px] text-emerald-400 font-bold uppercase tracking-wider mt-0.5\">в”ҖГүв”ңГә duyГҹв•—Г§t</span>\n                              </div>\n                            )}\n\n                            {w.status === 'completed' && (\n                              <span className=\"inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-bold bg-blue-500/10 text-blue-400 border border-blue-500/20\">\n                                <Check size={10} /> Hoв”ңГЎn tГҹв•‘Г‘t\n                              </span>\n                            )}\n\n                            {w.status === 'rejected' && (\n                              <span className=\"inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-bold bg-zinc-800 text-zinc-500 border border-zinc-700\">\n                                <X size={10} /> TГҹв•—ВҪ chГҹв•—ГҰi\n                              </span>\n                            )}\n                          </td>\n                        </tr>\n                      ))}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n          </div>\n        </>\n      )}\n\n      {/* Action Modal Confirm */}\n      {showModal && selectedWithdrawal && (\n        <div className=\"fixed inset-0 z-[1000] flex items-center justify-center bg-black/80 backdrop-blur-sm p-4 animate-in fade-in duration-200\" onClick={handleCloseModal}>\n          <div \n            className=\"w-full max-w-[440px] bg-zinc-900 border border-zinc-800 rounded-2xl p-6 flex flex-col gap-5 shadow-2xl relative text-left\" \n            onClick={(e) => e.stopPropagation()}\n          >\n            <h3 className=\"font-serif text-lg text-zinc-100 font-bold border-b border-zinc-800 pb-3 flex items-center gap-2\">\n              <Wallet className=\"text-amber-500\" size={18} />\n              <span>\n                {modalAction === 'approve' ? 'DuyГҹв•—Г§t yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn' : \n                 modalAction === 'reject' ? 'TГҹв•—ВҪ chГҹв•—ГҰi yв”ңВ¬u cГҹв•‘Вәu rв”ңв•‘t tiГҹв•—Гјn' : 'Hoв”ңГЎn tГҹв•‘Г‘t giao dГҹв•—ГҜch rв”ңв•‘t tiГҹв•—Гјn'}\n              </span>\n            </h3>\n\n            {actionError && (\n              <div className=\"flex items-start gap-2.5 p-3 rounded-lg border border-destructive/20 bg-destructive/10 text-destructive text-xs leading-relaxed\">\n                <AlertCircle size={15} className=\"shrink-0 mt-0.5\" />\n                <span>{actionError}</span>\n              </div>\n            )}\n\n            <div className=\"flex flex-col gap-3 text-xs bg-zinc-950 p-4 border border-zinc-800 rounded-xl\">\n              <div className=\"flex justify-between\">\n                <span className=\"text-zinc-500\">Nhв”ңГЎ hв”ңГЎng:</span>\n                <span className=\"font-bold text-zinc-200\">{selectedWithdrawal.restaurantId?.name}</span>\n              </div>\n              <div className=\"flex justify-between\">\n                <span className=\"text-zinc-500\">SГҹв•—ГҰ tiГҹв•—Гјn rв”ңв•‘t:</span>\n                <span className=\"font-black text-amber-500 text-sm\">{formatMoney(selectedWithdrawal.amount)}</span>\n              </div>\n              <div className=\"flex flex-col gap-1 border-t border-zinc-800/80 pt-2.5 mt-1\">\n                <span className=\"text-zinc-500 font-semibold mb-1\">Tв”ңГЎi khoГҹв•‘Гәn nhГҹв•‘ВЎn:</span>\n                <div className=\"flex justify-between\">\n                  <span className=\"text-zinc-550\">Ngв”ңГіn hв”ңГЎng:</span>\n                  <span className=\"text-zinc-300 font-medium\">{selectedWithdrawal.bankInfo?.bankName}</span>\n                </div>\n                <div className=\"flex justify-between\">\n                  <span className=\"text-zinc-550\">SГҹв•—ГҰ tв”ңГЎi khoГҹв•‘Гәn:</span>\n                  <span className=\"text-zinc-300 font-mono font-medium\">{selectedWithdrawal.bankInfo?.accountNumber}</span>\n                </div>\n                <div className=\"flex justify-between\">\n                  <span className=\"text-zinc-550\">ChГҹв•—Вә tв”ңГЎi khoГҹв•‘Гәn:</span>\n                  <span className=\"text-zinc-300 capitalize font-medium\">{selectedWithdrawal.bankInfo?.accountHolder}</span>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"flex flex-col gap-1.5\">\n              <label htmlFor=\"adminNote\" className=\"text-xs font-semibold text-zinc-400\">\n                {modalAction === 'reject' ? 'Lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi *' : 'PhГҹв•‘Гәn hГҹв•—Гҙi / Ghi chв”ңв•‘ cho Owner'}\n              </label>\n              <textarea\n                id=\"adminNote\"\n                placeholder={modalAction === 'reject' ? 'BГҹв•‘В»t buГҹв•—Г–c nhГҹв•‘ВЎp lв”ңв•ң do tГҹв•—ВҪ chГҹв•—ГҰi...' : 'NhГҹв•‘ВЎp ghi chв”ңв•‘ phГҹв•‘Гәn hГҹв•—Гҙi...'}\n                value={adminNote}\n                onChange={(e) => setAdminNote(e.target.value)}\n                rows={3}\n                className=\"p-3 bg-zinc-950 border border-zinc-800 rounded-lg text-xs text-white placeholder:text-zinc-650 focus:outline-none focus:border-amber-500/50 transition-colors resize-none\"\n                required={modalAction === 'reject'}\n              />\n            </div>\n\n            <div className=\"flex justify-end gap-3 mt-2 border-t border-zinc-800 pt-4\">\n              <button\n                onClick={handleCloseModal}\n                className=\"h-10 px-4 rounded-lg border border-zinc-800 hover:bg-zinc-800 text-zinc-300 text-xs font-semibold cursor-pointer\"\n              >\n                HГҹв•—Вәy\n              </button>\n              <button\n                onClick={handleConfirmAction}\n                disabled={actionLoading}\n                className={`h-10 px-5 rounded-lg text-zinc-950 font-bold text-xs hover:opacity-95 transition-all flex items-center justify-center gap-1.5 cursor-pointer ${\n                  modalAction === 'reject' \n                    ? 'bg-rose-500 text-white' \n                    : modalAction === 'complete' \n                    ? 'bg-blue-500 text-white' \n                    : 'bg-amber-500'\n                }`}\n              >\n                {actionLoading ? (\n                  <>\n                    <div className=\"w-3.5 h-3.5 border-2 border-zinc-950 border-t-transparent rounded-full animate-spin\" />\n                    <span>в”ҖГүang lв•һв–‘u...</span>\n                  </>\n                ) : (\n                  <span>Xв”ңГӯc nhГҹв•‘ВЎn</span>\n                )}\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n    </AdminLayout>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminReviews.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  59 |\n  60 |   useEffect(() => {\n> 61 |     fetchReviews();\n     |     ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  62 |   }, [fetchReviews]);\n  63 |\n  64 |   // Reset page khi thay в”ҖГҰГҹв•—ГІi bГҹв•—Г– lГҹв•—Г¬c trГҹв•‘Гӯng thв”ңГӯi","line":61,"column":5,"endLine":61,"endColumn":17},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  64 |   // Reset page khi thay в”ҖГҰГҹв•—ГІi bГҹв•—Г– lГҹв•—Г¬c trГҹв•‘Гӯng thв”ңГӯi\n  65 |   useEffect(() => {\n> 66 |     setPage(1);\n     |     ^^^^^^^ Avoid calling setState() directly within an effect\n  67 |   }, [statusFilter]);\n  68 |\n  69 |   const handleUpdateStatus = async (reviewId, newStatus) => {","line":66,"column":5,"endLine":66,"endColumn":12}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState, useCallback } from 'react';\nimport toast from 'react-hot-toast';\nimport { EyeOff, CheckCircle, Loader2, AlertCircle, X, Shield } from 'lucide-react';\nimport AdminLayout from '../../components/admin/AdminLayout';\nimport { adminGetReviews, updateReviewStatus } from '../../api/reviewApi';\nimport { RatingStars } from '../../components/ui/RatingStars';\nimport { Card } from '../../components/ui/card';\nimport { Button } from '../../components/ui/button';\nimport { Badge } from '../../components/ui/badge';\nimport {\n  Table,\n  TableBody,\n  TableCell,\n  TableHead,\n  TableHeader,\n  TableRow,\n} from '../../components/ui/table';\n\nexport default function AdminReviews() {\n  const [reviews, setReviews] = useState([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState(null);\n  \n  // Filters & Pagination\n  const [statusFilter, setStatusFilter] = useState(''); // '', 'approved', 'hidden', 'reported'\n  const [page, setPage] = useState(1);\n  const [totalPages, setTotalPages] = useState(1);\n  const [totalReviews, setTotalReviews] = useState(0);\n  \n  const [actionLoadingId, setActionLoadingId] = useState(null);\n  const [activeLightboxImage, setActiveLightboxImage] = useState(null);\n\n  const fetchReviews = useCallback(async () => {\n    setLoading(true);\n    setError(null);\n    try {\n      const params = {\n        page,\n        limit: 10,\n      };\n      if (statusFilter) {\n        params.status = statusFilter;\n      }\n      const res = await adminGetReviews(params);\n      if (res.data?.success) {\n        setReviews(res.data.data || []);\n        setTotalPages(res.data.pagination?.totalPages || 1);\n        setTotalReviews(res.data.pagination?.total || 0);\n      } else {\n        setError(res.data?.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch в”ҖГҰв”ңГӯnh giв”ңГӯ');\n      }\n    } catch (err) {\n      console.error(err);\n      setError(err.response?.data?.message || err.message || 'LГҹв•—Г№i khi kГҹв•‘в”җt nГҹв•—ГҰi mв”ңГӯy chГҹв•—Вә');\n    } finally {\n      setLoading(false);\n    }\n  }, [page, statusFilter]);\n\n  useEffect(() => {\n    fetchReviews();\n  }, [fetchReviews]);\n\n  // Reset page khi thay в”ҖГҰГҹв•—ГІi bГҹв•—Г– lГҹв•—Г¬c trГҹв•‘Гӯng thв”ңГӯi\n  useEffect(() => {\n    setPage(1);\n  }, [statusFilter]);\n\n  const handleUpdateStatus = async (reviewId, newStatus) => {\n    setActionLoadingId(reviewId);\n    try {\n      const res = await updateReviewStatus(reviewId, newStatus);\n      if (res.data?.success) {\n        toast.success(`в”ҖГүв”ңГә cГҹв•‘ВЎp nhГҹв•‘ВЎt trГҹв•‘Гӯng thв”ңГӯi в”ҖГҰв”ңГӯnh giв”ңГӯ thв”ңГЎnh cв”ңв”Өng`);\n        // CГҹв•‘ВЎp nhГҹв•‘ВЎt reviews state cГҹв•—Г‘c bГҹв•—Г–\n        setReviews((prev) =>\n          prev.map((rev) =>\n            rev._id === reviewId ? { ...rev, status: newStatus } : rev\n          )\n        );\n      } else {\n        toast.error(res.data?.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt trГҹв•‘Гӯng thв”ңГӯi thГҹв•‘Г‘t bГҹв•‘Гӯi');\n      }\n    } catch (err) {\n      console.error(err);\n      toast.error(err.response?.data?.message || 'LГҹв•—Г№i khi cГҹв•‘ВЎp nhГҹв•‘ВЎt trГҹв•‘Гӯng thв”ңГӯi');\n    } finally {\n      setActionLoadingId(null);\n    }\n  };\n\n  // Tв”ңВЎnh thГҹв•—ГҰng kв”ңВ¬ nhanh trв”ңВ¬n Client\n  const hiddenCount = reviews.filter(r => r.status === 'hidden').length;\n\n  return (\n    <AdminLayout\n      title=\"QuГҹв•‘Гәn lв”ңв•ң в”ҖГҰв”ңГӯnh giв”ңГӯ\"\n      subtitle=\"Giв”ңГӯm sв”ңГӯt chГҹв•‘Г‘t lв•һв–‘Гҹв•—Гәng bв”ңВјnh luГҹв•‘ВЎn, hв”ңВјnh Гҹв•‘Гәnh vв”ңГЎ xГҹв•—ВЎ lв”ңв•ң bв”ңГӯo cв”ңГӯo vi phГҹв•‘Гӯm toв”ңГЎn sв”ңГЎn.\"\n    >\n      <div className=\"flex flex-col gap-6 text-left\">\n        {/* Statistics Widgets */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n          <Card className=\"p-5 bg-card border-border flex flex-col gap-2 min-h-[110px] shadow-sm justify-between\">\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground\">TГҹв•—ГІng sГҹв•—ГҰ в”ҖГҰв”ңГӯnh giв”ңГӯ</span>\n            <div className=\"flex items-baseline gap-2\">\n              <strong className=\"text-3xl font-serif font-bold text-white\">{totalReviews}</strong>\n              <span className=\"text-xs text-muted-foreground\">lв•һв–‘Гҹв•—Гәt</span>\n            </div>\n          </Card>\n          <Card className=\"p-5 bg-card border-border flex flex-col gap-2 min-h-[110px] shadow-sm justify-between\">\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground\">HiГҹв•—Гўn thГҹв•—ГҜ cв”ңв”Өng khai</span>\n            <div className=\"flex items-baseline gap-2\">\n              <strong className=\"text-3xl font-serif font-bold text-emerald-400\">\n                {statusFilter === 'approved' ? totalReviews : statusFilter === '' ? (totalReviews - hiddenCount) : 0}\n              </strong>\n              <span className=\"text-xs text-muted-foreground\">approved</span>\n            </div>\n          </Card>\n          <Card className=\"p-5 bg-card border-border flex flex-col gap-2 min-h-[110px] shadow-sm justify-between\">\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground\">BГҹв•—ГҜ Гҹв•‘вҢҗn / Vi phГҹв•‘Гӯm</span>\n            <div className=\"flex items-baseline gap-2\">\n              <strong className=\"text-3xl font-serif font-bold text-rose-400\">\n                {statusFilter === 'hidden' ? totalReviews : statusFilter === '' ? hiddenCount : 0}\n              </strong>\n              <span className=\"text-xs text-muted-foreground\">hidden</span>\n            </div>\n          </Card>\n        </div>\n\n        {/* Filter bar */}\n        <div className=\"flex flex-wrap items-center justify-between gap-4 bg-card p-4 rounded-xl border border-border\">\n          <div className=\"flex flex-wrap gap-1 bg-[#20242D] border border-border p-1 rounded-lg text-xs font-semibold\">\n            {[\n              { value: '', label: 'TГҹв•‘Г‘t cГҹв•‘Гә' },\n              { value: 'approved', label: 'Cв”ңв”Өng khai' },\n              { value: 'hidden', label: 'в”ҖГүв”ңГә Гҹв•‘вҢҗn' },\n            ].map((tab) => (\n              <button\n                key={tab.value}\n                onClick={() => setStatusFilter(tab.value)}\n                className={`px-4 py-2 rounded-md transition-all cursor-pointer ${\n                  statusFilter === tab.value\n                    ? 'bg-primary text-background font-bold'\n                    : 'text-muted-foreground hover:text-white hover:bg-secondary/40'\n                }`}\n              >\n                {tab.label}\n              </button>\n            ))}\n          </div>\n          <span className=\"text-xs text-muted-foreground\">\n            HiГҹв•—Гўn thГҹв•—ГҜ <strong className=\"text-white font-bold\">{reviews.length}</strong> dв”ңв–“ng\n          </span>\n        </div>\n\n        {/* Loading / Error / Empty states */}\n        {loading ? (\n          <div className=\"flex flex-col items-center justify-center py-20 text-muted-foreground gap-3\">\n            <Loader2 className=\"h-8 w-8 animate-spin text-primary\" />\n            <p className=\"text-sm font-medium\">в”ҖГүang tГҹв•‘Гәi danh sв”ңГӯch в”ҖГҰв”ңГӯnh giв”ңГӯ toв”ңГЎn sв”ңГЎn...</p>\n          </div>\n        ) : error ? (\n          <div className=\"flex items-center gap-3 p-4 rounded-xl border border-destructive/20 bg-destructive/10 text-destructive text-xs leading-relaxed max-w-lg mx-auto\">\n            <AlertCircle size={16} className=\"shrink-0\" />\n            <span>{error}</span>\n          </div>\n        ) : reviews.length === 0 ? (\n          <div className=\"text-center py-20 border border-dashed border-border bg-card/20 rounded-xl flex flex-col items-center justify-center gap-3\">\n            <Shield size={36} className=\"text-muted-foreground\" />\n            <h3 className=\"text-base font-bold text-white\">Khв”ңв”Өng cв”ңв”Ӯ в”ҖГҰв”ңГӯnh giв”ңГӯ nв”ңГЎo</h3>\n            <p className=\"text-xs text-muted-foreground max-w-xs leading-relaxed\">\n              Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y в”ҖГҰв”ңГӯnh giв”ңГӯ nв”ңГЎo tв•һв–‘в•һГӯng Гҹв•—вҢҗng vГҹв•—Вўi bГҹв•—Г– lГҹв•—Г¬c trГҹв•‘Гӯng thв”ңГӯi в”ҖГҰв•һв–‘Гҹв•—Гәc chГҹв•—Г¬n.\n            </p>\n          </div>\n        ) : (\n          <>\n            {/* Desktop Table View */}\n            <div className=\"hidden md:block border border-border rounded-xl bg-card overflow-hidden\">\n              <Table>\n                <TableHeader className=\"bg-[#20242D]/55\">\n                  <TableRow className=\"border-border hover:bg-transparent\">\n                    <TableHead className=\"text-xs font-bold text-muted-foreground py-4 w-44\">Khв”ңГӯch hв”ңГЎng</TableHead>\n                    <TableHead className=\"text-xs font-bold text-muted-foreground py-4 w-40\">Nhв”ңГЎ hв”ңГЎng</TableHead>\n                    <TableHead className=\"text-xs font-bold text-muted-foreground py-4 w-28\">в”ҖГүв”ңГӯnh giв”ңГӯ</TableHead>\n                    <TableHead className=\"text-xs font-bold text-muted-foreground py-4\">Bв”ңВјnh luГҹв•‘ВЎn & Гҹв•‘Гіnh</TableHead>\n                    <TableHead className=\"text-xs font-bold text-muted-foreground py-4 w-28\">TrГҹв•‘Гӯng thв”ңГӯi</TableHead>\n                    <TableHead className=\"text-xs font-bold text-muted-foreground py-4 text-right w-32\">Thao tв”ңГӯc</TableHead>\n                  </TableRow>\n                </TableHeader>\n                <TableBody>\n                  {reviews.map((rev) => (\n                    <TableRow key={rev._id} className=\"border-border hover:bg-secondary/15\">\n                      <TableCell className=\"align-top py-4\">\n                        <span className=\"block font-bold text-white text-xs\">{rev.userId?.fullName || 'N/A'}</span>\n                        <span className=\"block text-[10px] text-muted-foreground truncate mt-0.5\">{rev.userId?.email || ''}</span>\n                        <span className=\"block text-[9px] text-muted-foreground/80 mt-1\">\n                          {new Date(rev.createdAt).toLocaleString('vi-VN')}\n                        </span>\n                      </TableCell>\n                      <TableCell className=\"align-top font-semibold text-white py-4 text-xs\">\n                        {rev.restaurantId?.name || 'N/A'}\n                      </TableCell>\n                      <TableCell className=\"align-top py-4\">\n                        <RatingStars rating={rev.rating} size=\"sm\" />\n                        <span className=\"text-[10px] font-bold text-primary mt-1 block\">{rev.rating} sao</span>\n                      </TableCell>\n                      <TableCell className=\"align-top py-4 flex flex-col gap-2\">\n                        <p className=\"text-xs text-white leading-relaxed whitespace-pre-line pr-4\">{rev.comment}</p>\n                        {rev.images && rev.images.length > 0 && (\n                          <div className=\"flex gap-2.5 mt-1\">\n                            {rev.images.map((imgUrl, i) => (\n                              <img\n                                key={i}\n                                src={imgUrl}\n                                alt={`Admin preview ${i}`}\n                                onClick={() => setActiveLightboxImage(imgUrl)}\n                                className=\"h-10 w-10 rounded-md object-cover border border-border cursor-pointer hover:opacity-80 transition\"\n                              />\n                            ))}\n                          </div>\n                        )}\n                        {rev.ownerReply && rev.ownerReply.comment && (\n                          <div className=\"mt-2 p-2.5 bg-[#20242D]/60 border-l border-primary rounded text-[11px] text-muted-foreground leading-normal\">\n                            <strong className=\"text-primary block mb-0.5\">PhГҹв•‘Гәn hГҹв•—Гҙi cГҹв•—Вәa nhв”ңГЎ hв”ңГЎng:</strong>\n                            {rev.ownerReply.comment}\n                          </div>\n                        )}\n                      </TableCell>\n                      <TableCell className=\"align-top py-4\">\n                        <Badge\n                          variant=\"outline\"\n                          className={\n                            rev.status === 'approved'\n                              ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/25 text-[9px] uppercase font-bold'\n                              : 'bg-rose-500/10 text-rose-400 border-rose-500/25 text-[9px] uppercase font-bold'\n                          }\n                        >\n                          {rev.status === 'approved' ? 'Cв”ңв”Өng khai' : 'в”ҖГүв”ңГә Гҹв•‘вҢҗn'}\n                        </Badge>\n                      </TableCell>\n                      <TableCell className=\"align-top py-4 text-right\">\n                        <div className=\"flex justify-end gap-1.5\">\n                          {rev.status === 'approved' ? (\n                            <Button\n                              size=\"sm\"\n                              variant=\"destructive\"\n                              className=\"bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white text-xs h-7.5 px-2.5\"\n                              disabled={actionLoadingId === rev._id}\n                              onClick={() => handleUpdateStatus(rev._id, 'hidden')}\n                            >\n                              <EyeOff className=\"w-3.5 h-3.5 mr-1\" /> Гҹв•‘Вҝn review\n                            </Button>\n                          ) : (\n                            <Button\n                              size=\"sm\"\n                              className=\"bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 hover:bg-emerald-500 hover:text-white text-xs h-7.5 px-2.5\"\n                              disabled={actionLoadingId === rev._id}\n                              onClick={() => handleUpdateStatus(rev._id, 'approved')}\n                            >\n                              <CheckCircle className=\"w-3.5 h-3.5 mr-1\" /> DuyГҹв•—Г§t\n                            </Button>\n                          )}\n                        </div>\n                      </TableCell>\n                    </TableRow>\n                  ))}\n                </TableBody>\n              </Table>\n            </div>\n\n            {/* Mobile Cards Stack View */}\n            <div className=\"flex flex-col gap-4 md:hidden\">\n              {reviews.map((rev) => (\n                <Card key={rev._id} className=\"p-4 bg-card border-border flex flex-col gap-3.5\">\n                  <div className=\"flex justify-between items-start\">\n                    <div>\n                      <strong className=\"block text-white text-xs\">{rev.userId?.fullName || 'Khв”ңГӯch hв”ңГЎng'}</strong>\n                      <span className=\"text-[10px] text-muted-foreground\">{rev.restaurantId?.name || 'Nhв”ңГЎ hв”ңГЎng'}</span>\n                    </div>\n                    <Badge\n                      variant=\"outline\"\n                      className={\n                        rev.status === 'approved'\n                          ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/25 text-[9px] uppercase font-bold'\n                          : 'bg-rose-500/10 text-rose-400 border-rose-500/25 text-[9px] uppercase font-bold'\n                      }\n                    >\n                      {rev.status === 'approved' ? 'Cв”ңв”Өng khai' : 'в”ҖГүв”ңГә Гҹв•‘вҢҗn'}\n                    </Badge>\n                  </div>\n                  \n                  <div className=\"flex items-center gap-1.5\">\n                    <RatingStars rating={rev.rating} size=\"sm\" />\n                    <span className=\"text-[10px] text-muted-foreground\">({rev.rating} sao)</span>\n                  </div>\n\n                  <p className=\"text-xs text-white leading-relaxed\">{rev.comment}</p>\n\n                  {rev.images && rev.images.length > 0 && (\n                    <div className=\"flex gap-2\">\n                      {rev.images.map((imgUrl, i) => (\n                        <img\n                          key={i}\n                          src={imgUrl}\n                          alt={`Mobile admin preview ${i}`}\n                          onClick={() => setActiveLightboxImage(imgUrl)}\n                          className=\"h-12 w-12 rounded-lg object-cover border border-border cursor-pointer\"\n                        />\n                      ))}\n                    </div>\n                  )}\n\n                  <div className=\"flex justify-between items-center border-t border-border/40 pt-3 mt-1 text-xs\">\n                    <span className=\"text-[9px] text-muted-foreground\">\n                      {new Date(rev.createdAt).toLocaleString('vi-VN')}\n                    </span>\n                    <div>\n                      {rev.status === 'approved' ? (\n                        <Button\n                          size=\"sm\"\n                          variant=\"destructive\"\n                          className=\"bg-rose-500/10 text-rose-400 text-[10px] h-7 px-3\"\n                          disabled={actionLoadingId === rev._id}\n                          onClick={() => handleUpdateStatus(rev._id, 'hidden')}\n                        >\n                          Гҹв•‘Вҝn\n                        </Button>\n                      ) : (\n                        <Button\n                          size=\"sm\"\n                          className=\"bg-emerald-500/10 text-emerald-400 text-[10px] h-7 px-3\"\n                          disabled={actionLoadingId === rev._id}\n                          onClick={() => handleUpdateStatus(rev._id, 'approved')}\n                        >\n                          DuyГҹв•—Г§t\n                        </Button>\n                      )}\n                    </div>\n                  </div>\n                </Card>\n              ))}\n            </div>\n\n            {/* Pagination */}\n            {totalPages > 1 && (\n              <div className=\"mt-4 flex justify-center items-center gap-1.5\">\n                <Button\n                  disabled={page <= 1}\n                  onClick={() => setPage(page - 1)}\n                  variant=\"outline\"\n                  size=\"sm\"\n                  className=\"border-border text-xs text-white\"\n                >\n                  Trв•һв–‘Гҹв•—Вўc\n                </Button>\n                {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (\n                  <Button\n                    key={p}\n                    variant={p === page ? 'default' : 'outline'}\n                    size=\"icon\"\n                    className={`h-8 w-8 text-xs ${\n                      p === page ? 'bg-primary text-background font-bold' : 'border-border text-white'\n                    }`}\n                    onClick={() => setPage(p)}\n                  >\n                    {p}\n                  </Button>\n                ))}\n                <Button\n                  disabled={page >= totalPages}\n                  onClick={() => setPage(page + 1)}\n                  variant=\"outline\"\n                  size=\"sm\"\n                  className=\"border-border text-xs text-white\"\n                >\n                  Sau\n                </Button>\n              </div>\n            )}\n          </>\n        )}\n      </div>\n\n      {/* Lightbox Image Preview */}\n      {activeLightboxImage && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4 animate-in fade-in duration-200\">\n          <button\n            onClick={() => setActiveLightboxImage(null)}\n            className=\"absolute top-4 right-4 text-white/80 hover:text-white p-2 rounded-full hover:bg-white/10 transition cursor-pointer\"\n          >\n            <X className=\"w-6 h-6\" />\n          </button>\n          <img\n            src={activeLightboxImage}\n            alt=\"Review enlarged preview\"\n            className=\"max-w-full max-h-[90vh] object-contain rounded-lg shadow-2xl\"\n          />\n        </div>\n      )}\n    </AdminLayout>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminUserForm.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  23 |   useEffect(() => {\n  24 |     if (isEdit) {\n> 25 |       setFetching(true);\n     |       ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  26 |       adminApi\n  27 |         .getUserById(id)\n  28 |         .then((res) => {","line":25,"column":7,"endLine":25,"endColumn":18}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { useNavigate, useParams } from 'react-router-dom';\r\nimport { useForm } from 'react-hook-form';\r\nimport { adminApi } from '../../api/adminApi';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport toast from 'react-hot-toast';\r\nimport { Save, ArrowLeft } from 'lucide-react';\r\n\r\nexport default function AdminUserForm() {\r\n  const { id } = useParams();\r\n  const isEdit = Boolean(id);\r\n  const navigate = useNavigate();\r\n  const [loading, setLoading] = useState(false);\r\n  const [fetching, setFetching] = useState(isEdit);\r\n\r\n  const {\r\n    register,\r\n    handleSubmit,\r\n    formState: { errors },\r\n    reset,\r\n  } = useForm();\r\n\r\n  useEffect(() => {\r\n    if (isEdit) {\r\n      setFetching(true);\r\n      adminApi\r\n        .getUserById(id)\r\n        .then((res) => {\r\n          reset({\r\n            username:    res.data.username,\r\n            email:       res.data.email,\r\n            fullName:    res.data.fullName,\r\n            phoneNumber: res.data.phoneNumber || '',\r\n            address:     res.data.address || '',\r\n            role:        res.data.role,\r\n            active:      res.data.active,\r\n          });\r\n        })\r\n        .catch((err) => {\r\n          toast.error(err.message || 'Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y user');\r\n          navigate('/admin/users');\r\n        })\r\n        .finally(() => setFetching(false));\r\n    }\r\n  }, [id, isEdit, navigate, reset]);\r\n\r\n  const onSubmit = async (data) => {\r\n    setLoading(true);\r\n    try {\r\n      if (isEdit) {\r\n        const res = await adminApi.updateUser(id, {\r\n          fullName:    data.fullName,\r\n          phoneNumber: data.phoneNumber || null,\r\n          address:     data.address || null,\r\n          role:        data.role,\r\n          active:      data.active === 'true' || data.active === true,\r\n        });\r\n        toast.success(res.message || 'CГҹв•‘ВЎp nhГҹв•‘ВЎt thв”ңГЎnh cв”ңв”Өng');\r\n      } else {\r\n        const res = await adminApi.createUser({\r\n          username:    data.username,\r\n          email:       data.email,\r\n          password:    data.password,\r\n          fullName:    data.fullName,\r\n          phoneNumber: data.phoneNumber || null,\r\n          address:     data.address || null,\r\n          role:        data.role || 'customer',\r\n        });\r\n        toast.success(res.message || 'TГҹв•‘Гӯo thв”ңГЎnh cв”ңв”Өng');\r\n      }\r\n      navigate('/admin/users');\r\n    } catch (err) {\r\n      toast.error(err.message || 'Thao tв”ңГӯc thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  if (fetching) {\r\n    return (\r\n      <AdminLayout title={isEdit ? 'ChГҹв•—Г«nh sГҹв•—ВЎa User' : 'Thв”ңВ¬m User mГҹв•—Вўi'}>\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-3 bg-[#1A1D24] border border-zinc-800 rounded-xl\">\r\n          <div className=\"w-8 h-8 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\r\n          <span className=\"text-sm\">в”ҖГүang tГҹв•‘Гәi...</span>\r\n        </div>\r\n      </AdminLayout>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <AdminLayout\r\n      title={isEdit ? 'ChГҹв•—Г«nh sГҹв•—ВЎa User' : 'Thв”ңВ¬m User mГҹв•—Вўi'}\r\n      subtitle={isEdit ? 'CГҹв•‘ВЎp nhГҹв•‘ВЎt thв”ңв”Өng tin ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng' : 'TГҹв•‘Гӯo tв”ңГЎi khoГҹв•‘Гәn mГҹв•—Вўi trong hГҹв•—Г§ thГҹв•—ГҰng'}\r\n    >\r\n      <button \r\n        className=\"inline-flex items-center gap-1.5 px-3 py-1.5 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 text-xs font-semibold rounded-lg transition duration-150 mb-6\" \r\n        onClick={() => navigate('/admin/users')}\r\n      >\r\n        <ArrowLeft size={14} /> Quay lГҹв•‘Гӯi\r\n      </button>\r\n\r\n      <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-2xl p-6 shadow-xl max-w-3xl\">\r\n        <form className=\"space-y-6\" onSubmit={handleSubmit(onSubmit)}>\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\r\n            {/* Username */}\r\n            <div className=\"flex flex-col gap-1.5\">\r\n              <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">Username *</label>\r\n              <input\r\n                {...register('username', {\r\n                  required: 'Username lв”ңГЎ bГҹв•‘В»t buГҹв•—Г–c',\r\n                  minLength: { value: 3, message: 'в”ңГ¬t nhГҹв•‘Г‘t 3 kв”ңв•ң tГҹв•—в–’' },\r\n                })}\r\n                disabled={isEdit}\r\n                placeholder=\"NhГҹв•‘ВЎp username\"\r\n                className=\"bg-[#13161C] border border-zinc-800 text-zinc-250 placeholder-zinc-650 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 disabled:opacity-50\"\r\n              />\r\n              {errors.username && <span className=\"text-xs text-rose-400\">{errors.username.message}</span>}\r\n            </div>\r\n\r\n            {/* Email */}\r\n            <div className=\"flex flex-col gap-1.5\">\r\n              <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">Email *</label>\r\n              <input\r\n                type=\"email\"\r\n                {...register('email', {\r\n                  required: 'Email lв”ңГЎ bГҹв•‘В»t buГҹв•—Г–c',\r\n                  pattern: { value: /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/, message: 'Email khв”ңв”Өng hГҹв•—Гәp lГҹв•—Г§' },\r\n                })}\r\n                disabled={isEdit}\r\n                placeholder=\"NhГҹв•‘ВЎp email\"\r\n                className=\"bg-[#13161C] border border-zinc-800 text-zinc-250 placeholder-zinc-650 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 disabled:opacity-50\"\r\n              />\r\n              {errors.email && <span className=\"text-xs text-rose-400\">{errors.email.message}</span>}\r\n            </div>\r\n\r\n            {/* Password (only for create) */}\r\n            {!isEdit && (\r\n              <div className=\"flex flex-col gap-1.5\">\r\n                <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">MГҹв•‘ВЎt khГҹв•‘вҢҗu *</label>\r\n                <input\r\n                  type=\"password\"\r\n                  {...register('password', {\r\n                    required: 'MГҹв•‘ВЎt khГҹв•‘вҢҗu lв”ңГЎ bГҹв•‘В»t buГҹв•—Г–c',\r\n                    minLength: { value: 8, message: 'в”ңГ¬t nhГҹв•‘Г‘t 8 kв”ңв•ң tГҹв•—в–’' },\r\n                  })}\r\n                  placeholder=\"в”ңГ¬t nhГҹв•‘Г‘t 8 kв”ңв•ң tГҹв•—в–’\"\r\n                  className=\"bg-[#13161C] border border-zinc-800 text-zinc-250 placeholder-zinc-650 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n                />\r\n                {errors.password && <span className=\"text-xs text-rose-400\">{errors.password.message}</span>}\r\n              </div>\r\n            )}\r\n\r\n            {/* Full Name */}\r\n            <div className=\"flex flex-col gap-1.5\">\r\n              <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">HГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n *</label>\r\n              <input\r\n                {...register('fullName', { required: 'HГҹв•—Г¬ tв”ңВ¬n lв”ңГЎ bГҹв•‘В»t buГҹв•—Г–c' })}\r\n                placeholder=\"NhГҹв•‘ВЎp hГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n\"\r\n                className=\"bg-[#13161C] border border-zinc-800 text-zinc-250 placeholder-zinc-650 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n              />\r\n              {errors.fullName && <span className=\"text-xs text-rose-400\">{errors.fullName.message}</span>}\r\n            </div>\r\n\r\n            {/* Phone */}\r\n            <div className=\"flex flex-col gap-1.5\">\r\n              <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi</label>\r\n              <input\r\n                {...register('phoneNumber')}\r\n                placeholder=\"VD: 0901234567\"\r\n                className=\"bg-[#13161C] border border-zinc-800 text-zinc-250 placeholder-zinc-650 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n              />\r\n            </div>\r\n\r\n            {/* Address */}\r\n            <div className=\"flex flex-col gap-1.5\">\r\n              <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">в”ҖГүГҹв•—ГҜa chГҹв•—Г«</label>\r\n              <input\r\n                {...register('address')}\r\n                placeholder=\"NhГҹв•‘ВЎp в”ҖГҰГҹв•—ГҜa chГҹв•—Г«\"\r\n                className=\"bg-[#13161C] border border-zinc-800 text-zinc-250 placeholder-zinc-650 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n              />\r\n            </div>\r\n\r\n            {/* Role */}\r\n            <div className=\"flex flex-col gap-1.5\">\r\n              <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">Role *</label>\r\n              <select \r\n                {...register('role', { required: 'ChГҹв•—Г¬n role' })}\r\n                className=\"bg-[#13161C] border border-zinc-800 text-zinc-350 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n              >\r\n                <option value=\"customer\">Khв”ңГӯch hв”ңГЎng</option>\r\n                <option value=\"restaurant_owner\">ChГҹв•—Вә nhв”ңГЎ hв”ңГЎng</option>\r\n                <option value=\"admin\">Admin</option>\r\n              </select>\r\n              {errors.role && <span className=\"text-xs text-rose-400\">{errors.role.message}</span>}\r\n            </div>\r\n\r\n            {/* Active (only for edit) */}\r\n            {isEdit && (\r\n              <div className=\"flex flex-col gap-1.5\">\r\n                <label className=\"text-xs font-semibold text-zinc-400 tracking-wide uppercase\">TrГҹв•‘Гӯng thв”ңГӯi</label>\r\n                <select \r\n                  {...register('active')}\r\n                  className=\"bg-[#13161C] border border-zinc-800 text-zinc-355 rounded-lg text-sm px-3.5 py-2.5 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n                >\r\n                  <option value=\"true\">в”ҖГүang hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng</option>\r\n                  <option value=\"false\">Vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa</option>\r\n                </select>\r\n              </div>\r\n            )}\r\n          </div>\r\n\r\n          <div className=\"flex items-center justify-end gap-3 pt-4 border-t border-zinc-800\">\r\n            <button \r\n              type=\"button\" \r\n              className=\"px-4 py-2 border border-zinc-800 hover:bg-zinc-850 text-zinc-300 font-semibold text-xs rounded-lg transition duration-150\" \r\n              onClick={() => navigate('/admin/users')}\r\n            >\r\n              HГҹв•—Вәy\r\n            </button>\r\n            <button \r\n              type=\"submit\" \r\n              className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-black font-semibold text-xs rounded-lg transition duration-150 shadow-lg shadow-amber-500/10\" \r\n              disabled={loading}\r\n            >\r\n              <Save size={14} />\r\n              {loading ? 'в”ҖГүang lв•һв–‘u...' : isEdit ? 'CГҹв•‘ВЎp nhГҹв•‘ВЎt' : 'TГҹв•‘Гӯo user'}\r\n            </button>\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </AdminLayout>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminUsers.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  51 |\n  52 |   useEffect(() => {\n> 53 |     fetchUsers(1);\n     |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  54 |   }, [fetchUsers]);\n  55 |\n  56 |   const handleSearch = (e) => {","line":53,"column":5,"endLine":53,"endColumn":15}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useCallback } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport { adminApi } from '../../api/adminApi';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport toast from 'react-hot-toast';\r\nimport {\r\n  Search, Plus, Edit3, Trash2, ShieldCheck, ShieldOff,\r\n  RefreshCw, ChevronLeft, ChevronRight, Key,\r\n} from 'lucide-react';\r\n\r\nconst ROLES = [\r\n  { value: '', label: 'TГҹв•‘Г‘t cГҹв•‘Гә role' },\r\n  { value: 'customer', label: 'Khв”ңГӯch hв”ңГЎng' },\r\n  { value: 'restaurant_owner', label: 'ChГҹв•—Вә nhв”ңГЎ hв”ңГЎng' },\r\n  { value: 'admin', label: 'Admin' },\r\n];\r\n\r\nconst STATUSES = [\r\n  { value: '', label: 'TГҹв•‘Г‘t cГҹв•‘Гә trГҹв•‘Гӯng thв”ңГӯi' },\r\n  { value: 'active', label: 'в”ҖГүang hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng' },\r\n  { value: 'inactive', label: 'в”ҖГүв”ңГә vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa' },\r\n];\r\n\r\nexport default function AdminUsers() {\r\n  const navigate = useNavigate();\r\n  const [users, setUsers] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [pagination, setPagination] = useState({ page: 1, totalPages: 1, total: 0 });\r\n  const [filters, setFilters] = useState({ search: '', role: '', status: '' });\r\n  const [searchInput, setSearchInput] = useState('');\r\n  const [confirmDelete, setConfirmDelete] = useState(null);\r\n  const [resetPwModal, setResetPwModal] = useState(null);\r\n  const [newPassword, setNewPassword] = useState('');\r\n\r\n  const fetchUsers = useCallback(async (page = 1) => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await adminApi.getUsers({ page, limit: 20, ...filters });\r\n      setUsers(res.data.users);\r\n      setPagination({\r\n        page: res.data.page,\r\n        totalPages: res.data.totalPages,\r\n        total: res.data.total,\r\n      });\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [filters]);\r\n\r\n  useEffect(() => {\r\n    fetchUsers(1);\r\n  }, [fetchUsers]);\r\n\r\n  const handleSearch = (e) => {\r\n    e.preventDefault();\r\n    setFilters((prev) => ({ ...prev, search: searchInput }));\r\n  };\r\n\r\n  const handleToggleStatus = async (user) => {\r\n    try {\r\n      const res = await adminApi.toggleUserStatus(user.id, !user.active);\r\n      toast.success(res.message);\r\n      fetchUsers(pagination.page);\r\n    } catch (err) {\r\n      toast.error(err.message || 'Thao tв”ңГӯc thГҹв•‘Г‘t bГҹв•‘Гӯi');\r\n    }\r\n  };\r\n\r\n  const handleDelete = async () => {\r\n    if (!confirmDelete) return;\r\n    try {\r\n      const res = await adminApi.deleteUser(confirmDelete.id);\r\n      toast.success(res.message);\r\n      setConfirmDelete(null);\r\n      fetchUsers(pagination.page);\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў xв”ңв”Ӯa');\r\n    }\r\n  };\r\n\r\n  const handleResetPassword = async () => {\r\n    if (!resetPwModal || !newPassword) return;\r\n    try {\r\n      const res = await adminApi.resetUserPassword(resetPwModal.id, newPassword);\r\n      toast.success(res.message);\r\n      setResetPwModal(null);\r\n      setNewPassword('');\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў в”ҖГҰГҹв•‘в•–t lГҹв•‘Гӯi mГҹв•‘ВЎt khГҹв•‘вҢҗu');\r\n    }\r\n  };\r\n\r\n  const getRoleBadge = (role) => {\r\n    switch (role) {\r\n      case 'admin':\r\n        return <span className=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-purple-500/10 text-purple-400 border border-purple-500/20\">Admin</span>;\r\n      case 'restaurant_owner':\r\n        return <span className=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-500/10 text-amber-400 border border-amber-500/20\">ChГҹв•—Вә NH</span>;\r\n      case 'customer':\r\n      default:\r\n        return <span className=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-500/10 text-blue-400 border border-blue-500/20\">Khв”ңГӯch hв”ңГЎng</span>;\r\n    }\r\n  };\r\n\r\n  return (\r\n    <AdminLayout title=\"QuГҹв•‘Гәn lв”ңв•ң Users\" subtitle={`TГҹв•—ГІng cГҹв•—Г–ng ${pagination.total} ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng`}>\r\n      {/* Toolbar */}\r\n      <div className=\"flex flex-col md:flex-row gap-4 justify-between items-stretch md:items-center mb-6\">\r\n        <form onSubmit={handleSearch} className=\"relative flex-1 max-w-md\">\r\n          <span className=\"absolute inset-y-0 left-0 pl-3 flex items-center text-zinc-500\">\r\n            <Search size={16} />\r\n          </span>\r\n          <input\r\n            type=\"text\"\r\n            placeholder=\"Tв”ңВјm username, email, tв”ңВ¬n...\"\r\n            value={searchInput}\r\n            onChange={(e) => setSearchInput(e.target.value)}\r\n            className=\"w-full bg-[#1A1D24] border border-zinc-800 text-zinc-200 placeholder-zinc-500 rounded-lg text-sm pl-10 pr-4 py-2 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n          />\r\n        </form>\r\n\r\n        <div className=\"flex flex-wrap items-center gap-3\">\r\n          <select\r\n            value={filters.role}\r\n            onChange={(e) => setFilters((p) => ({ ...p, role: e.target.value }))}\r\n            className=\"bg-[#1A1D24] border border-zinc-800 text-zinc-300 rounded-lg text-sm px-3 py-2 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n          >\r\n            {ROLES.map((r) => (\r\n              <option key={r.value} value={r.value}>{r.label}</option>\r\n            ))}\r\n          </select>\r\n          <select\r\n            value={filters.status}\r\n            onChange={(e) => setFilters((p) => ({ ...p, status: e.target.value }))}\r\n            className=\"bg-[#1A1D24] border border-zinc-800 text-zinc-300 rounded-lg text-sm px-3 py-2 outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500\"\r\n          >\r\n            {STATUSES.map((s) => (\r\n              <option key={s.value} value={s.value}>{s.label}</option>\r\n            ))}\r\n          </select>\r\n\r\n          <button \r\n            className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-black font-semibold text-sm rounded-lg transition duration-150 shadow-lg shadow-amber-500/10\" \r\n            onClick={() => navigate('/admin/users/create')}\r\n          >\r\n            <Plus size={16} /> Thв”ңВ¬m user\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Table */}\r\n      {loading ? (\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-3 bg-[#1A1D24] border border-zinc-800 rounded-xl\">\r\n          <div className=\"w-8 h-8 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\r\n          <span className=\"text-sm\">в”ҖГүang tГҹв•‘Гәi...</span>\r\n        </div>\r\n      ) : users.length === 0 ? (\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-4 bg-[#1A1D24] border border-zinc-800 rounded-xl\">\r\n          <p className=\"text-sm\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y user nв”ңГЎo</p>\r\n          <button \r\n            className=\"inline-flex items-center gap-1.5 px-3 py-1.5 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 text-xs font-medium rounded-lg transition duration-150\"\r\n            onClick={() => { setFilters({ search: '', role: '', status: '' }); setSearchInput(''); }}\r\n          >\r\n            <RefreshCw size={14} /> Xв”ңв”Ӯa bГҹв•—Г– lГҹв•—Г¬c\r\n          </button>\r\n        </div>\r\n      ) : (\r\n        <>\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl overflow-hidden shadow-lg\">\r\n            <div className=\"overflow-x-auto\">\r\n              <table className=\"w-full text-left border-collapse text-zinc-300 text-sm\">\r\n                <thead>\r\n                  <tr className=\"bg-zinc-900/50 border-b border-zinc-800 text-zinc-450 font-medium\">\r\n                    <th className=\"p-4\">User</th>\r\n                    <th className=\"p-4\">Role</th>\r\n                    <th className=\"p-4\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n                    <th className=\"p-4\">Email verified</th>\r\n                    <th className=\"p-4\">в”ҖГүв”ҖГўng nhГҹв•‘ВЎp cuГҹв•—ГҰi</th>\r\n                    <th className=\"p-4\">Ngв”ңГЎy tГҹв•‘Гӯo</th>\r\n                    <th className=\"p-4 text-right\">Thao tв”ңГӯc</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody className=\"divide-y divide-zinc-800/60\">\r\n                  {users.map((user) => (\r\n                    <tr key={user.id} className=\"hover:bg-zinc-850/30 transition-colors\">\r\n                      <td className=\"p-4\">\r\n                        <div className=\"flex items-center gap-3\">\r\n                          <div className=\"w-10 h-10 rounded-full bg-zinc-800 border border-zinc-700 overflow-hidden flex items-center justify-center text-sm font-semibold text-amber-500\">\r\n                            {user.avatarUrl ? (\r\n                              <img src={user.avatarUrl} alt=\"\" className=\"w-full h-full object-cover\" />\r\n                            ) : (\r\n                              user.fullName?.[0]?.toUpperCase() || '?'\r\n                            )}\r\n                          </div>\r\n                          <div>\r\n                            <div className=\"font-semibold text-zinc-200\">{user.fullName}</div>\r\n                            <div className=\"text-xs text-zinc-400\">{user.email}</div>\r\n                            <div className=\"text-xs text-zinc-500 font-mono\">@{user.username}</div>\r\n                          </div>\r\n                        </div>\r\n                      </td>\r\n                      <td className=\"p-4\">{getRoleBadge(user.role)}</td>\r\n                      <td className=\"p-4\">\r\n                        <span className={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium border ${\r\n                          user.active \r\n                            ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' \r\n                            : 'bg-zinc-500/10 text-zinc-400 border-zinc-550/20'\r\n                        }`}>\r\n                          <span className={`w-1.5 h-1.5 rounded-full ${user.active ? 'bg-emerald-400 animate-pulse' : 'bg-zinc-500'}`} />\r\n                          {user.active ? 'Active' : 'Inactive'}\r\n                        </span>\r\n                      </td>\r\n                      <td className=\"p-4\">\r\n                        <span className={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium border ${\r\n                          user.emailVerified \r\n                            ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' \r\n                            : 'bg-rose-500/10 text-rose-450 border-rose-500/20'\r\n                        }`}>\r\n                          {user.emailVerified ? 'в”ҖГүв”ңГә xв”ңГӯc minh' : 'Chв•һв–‘a'}\r\n                        </span>\r\n                      </td>\r\n                      <td className=\"p-4 text-xs text-zinc-400 font-mono\">\r\n                        {user.lastLogin\r\n                          ? new Date(user.lastLogin).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })\r\n                          : 'О“ГҮГ¶'}\r\n                      </td>\r\n                      <td className=\"p-4 text-xs text-zinc-400 font-mono\">\r\n                        {new Date(user.createdAt).toLocaleDateString('vi-VN')}\r\n                      </td>\r\n                      <td className=\"p-4 text-right\">\r\n                        <div className=\"flex items-center justify-end gap-1.5\">\r\n                          <button\r\n                            className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-amber-500 rounded-lg transition\"\r\n                            title=\"ChГҹв•—Г«nh sГҹв•—ВЎa\"\r\n                            onClick={() => navigate(`/admin/users/${user.id}/edit`)}\r\n                          >\r\n                            <Edit3 size={14} />\r\n                          </button>\r\n                          <button\r\n                            className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-amber-500 rounded-lg transition\"\r\n                            title=\"в”ҖГүГҹв•‘в•–t lГҹв•‘Гӯi mГҹв•‘ВЎt khГҹв•‘вҢҗu\"\r\n                            onClick={() => setResetPwModal(user)}\r\n                          >\r\n                            <Key size={14} />\r\n                          </button>\r\n                          <button\r\n                            className={`p-1.5 hover:bg-zinc-800 rounded-lg transition ${\r\n                              user.active ? 'text-zinc-400 hover:text-rose-500' : 'text-zinc-400 hover:text-emerald-500'\r\n                            }`}\r\n                            title={user.active ? 'Vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa' : 'Kв”ңВЎch hoГҹв•‘Гӯt'}\r\n                            onClick={() => handleToggleStatus(user)}\r\n                          >\r\n                            {user.active ? <ShieldOff size={14} /> : <ShieldCheck size={14} />}\r\n                          </button>\r\n                          {user.role !== 'admin' && (\r\n                            <button\r\n                              className=\"p-1.5 hover:bg-zinc-850/80 text-zinc-400 hover:text-rose-500 rounded-lg transition\"\r\n                              title=\"Xв”ңв”Ӯa\"\r\n                              onClick={() => setConfirmDelete(user)}\r\n                            >\r\n                              <Trash2 size={14} />\r\n                            </button>\r\n                          )}\r\n                        </div>\r\n                      </td>\r\n                    </tr>\r\n                  ))}\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Pagination */}\r\n          {pagination.totalPages > 1 && (\r\n            <div className=\"flex items-center justify-center gap-4 mt-6\">\r\n              <button\r\n                disabled={pagination.page <= 1}\r\n                onClick={() => fetchUsers(pagination.page - 1)}\r\n                className=\"p-2 border border-zinc-800 hover:bg-zinc-800 text-zinc-400 disabled:opacity-50 rounded-lg transition\"\r\n              >\r\n                <ChevronLeft size={16} />\r\n              </button>\r\n              <span className=\"text-xs text-zinc-400\">\r\n                Trang {pagination.page} / {pagination.totalPages}\r\n              </span>\r\n              <button\r\n                disabled={pagination.page >= pagination.totalPages}\r\n                onClick={() => fetchUsers(pagination.page + 1)}\r\n                className=\"p-2 border border-zinc-800 hover:bg-zinc-800 text-zinc-400 disabled:opacity-50 rounded-lg transition\"\r\n              >\r\n                <ChevronRight size={16} />\r\n              </button>\r\n            </div>\r\n          )}\r\n        </>\r\n      )}\r\n\r\n      {/* Confirm Delete Modal */}\r\n      {confirmDelete && (\r\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 animate-in fade-in duration-200\" onClick={() => setConfirmDelete(null)}>\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-2xl w-full max-w-md p-6 shadow-2xl animate-in zoom-in-95 duration-200\" onClick={(e) => e.stopPropagation()}>\r\n            <h3 className=\"text-lg font-bold text-zinc-150 mb-2\">Xв”ңГӯc nhГҹв•‘ВЎn xв”ңв”Ӯa</h3>\r\n            <p className=\"text-sm text-zinc-400 mb-2\">BГҹв•‘Гӯn cв”ңв”Ӯ chГҹв•‘В»c muГҹв•—ГҰn xв”ңв”Ӯa user <strong className=\"text-zinc-200\">{confirmDelete.fullName}</strong>?</p>\r\n            <p className=\"text-xs text-rose-400 mb-4\">Tв”ңГЎi khoГҹв•‘Гәn sГҹв•‘в•ң bГҹв•—ГҜ vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa (soft delete).</p>\r\n            <div className=\"flex items-center justify-end gap-3 pt-2\">\r\n              <button \r\n                className=\"px-4 py-2 border border-zinc-800 hover:bg-zinc-850 text-zinc-300 font-medium text-xs rounded-lg transition duration-150\" \r\n                onClick={() => setConfirmDelete(null)}\r\n              >\r\n                HГҹв•—Вәy\r\n              </button>\r\n              <button \r\n                className=\"px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white font-semibold text-xs rounded-lg transition duration-150 shadow-lg shadow-rose-600/10\" \r\n                onClick={handleDelete}\r\n              >\r\n                Xв”ңв”Ӯa\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Reset Password Modal */}\r\n      {resetPwModal && (\r\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 animate-in fade-in duration-200\" onClick={() => { setResetPwModal(null); setNewPassword(''); }}>\r\n          <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-2xl w-full max-w-md p-6 shadow-2xl animate-in zoom-in-95 duration-200\" onClick={(e) => e.stopPropagation()}>\r\n            <h3 className=\"text-lg font-bold text-zinc-150 mb-2\">в”ҖГүГҹв•‘в•–t lГҹв•‘Гӯi mГҹв•‘ВЎt khГҹв•‘вҢҗu</h3>\r\n            <p className=\"text-sm text-zinc-400 mb-4\">в”ҖГүГҹв•‘в•–t mГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi cho <strong className=\"text-zinc-250\">{resetPwModal.fullName}</strong></p>\r\n            <input\r\n              type=\"password\"\r\n              className=\"w-full bg-[#13161C] border border-zinc-800 rounded-lg px-3 py-2 text-sm text-zinc-250 focus:outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 mb-4\"\r\n              placeholder=\"MГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi (в”ңВЎt nhГҹв•‘Г‘t 8 kв”ңв•ң tГҹв•—в–’)\"\r\n              value={newPassword}\r\n              onChange={(e) => setNewPassword(e.target.value)}\r\n              minLength={8}\r\n            />\r\n            <div className=\"flex items-center justify-end gap-3\">\r\n              <button \r\n                className=\"px-4 py-2 border border-zinc-800 hover:bg-zinc-850 text-zinc-300 font-medium text-xs rounded-lg transition duration-150\" \r\n                onClick={() => { setResetPwModal(null); setNewPassword(''); }}\r\n              >\r\n                HГҹв•—Вәy\r\n              </button>\r\n              <button \r\n                className=\"px-4 py-2 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-black font-semibold text-xs rounded-lg transition duration-150 shadow-lg shadow-amber-500/10 disabled:opacity-50\" \r\n                onClick={handleResetPassword} \r\n                disabled={newPassword.length < 8}\r\n              >\r\n                в”ҖГүГҹв•‘в•–t lГҹв•‘Гӯi\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </AdminLayout>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminVouchers.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  39 |\n  40 |   useEffect(() => {\n> 41 |     loadVouchers();\n     |     ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  42 |   }, []);\n  43 |\n  44 |   const handleCreateOrUpdate = async (data) => {","line":41,"column":5,"endLine":41,"endColumn":17}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState } from 'react';\r\nimport { Ticket, Plus, ToggleLeft, ToggleRight, Trash2, BarChart2 } from 'lucide-react';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport { getAdminVouchers, createVoucher, updateVoucher, deleteVoucher, getVoucherStats } from '../../api/voucherApi';\r\nimport VoucherFormModal from '../../components/voucher/VoucherFormModal';\r\nimport VoucherStatusBadge from '../../components/voucher/VoucherStatusBadge';\r\n\r\nconst formatMoney = (v) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND', maximumFractionDigits: 0 }).format(v || 0);\r\nconst formatDate = (d) => d ? new Date(d).toLocaleDateString('vi-VN') : 'Khв”ңв”Өng giГҹв•—Вўi hГҹв•‘Гӯn';\r\n\r\nexport default function AdminVouchers() {\r\n  const [vouchers, setVouchers] = useState([]);\r\n  const [loading, setLoading] = useState(false);\r\n  const [error, setError] = useState(null);\r\n  \r\n  // Modal states\r\n  const [isModalOpen, setIsModalOpen] = useState(false);\r\n  const [editingVoucher, setEditingVoucher] = useState(null);\r\n  \r\n  // Stats states\r\n  const [statsVoucher, setStatsVoucher] = useState(null);\r\n  const [statsData, setStatsData] = useState(null);\r\n  const [loadingStats, setLoadingStats] = useState(false);\r\n\r\n  const loadVouchers = async () => {\r\n    setLoading(true);\r\n    setError(null);\r\n    try {\r\n      const res = await getAdminVouchers();\r\n      if (res.data?.success) {\r\n        setVouchers(res.data.data);\r\n      }\r\n    } catch (err) {\r\n      setError(err.response?.data?.message || err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch voucher toв”ңГЎn hГҹв•—Г§ thГҹв•—ГҰng');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    loadVouchers();\r\n  }, []);\r\n\r\n  const handleCreateOrUpdate = async (data) => {\r\n    try {\r\n      if (editingVoucher) {\r\n        await updateVoucher(editingVoucher._id, data);\r\n      } else {\r\n        await createVoucher({ ...data, restaurantId: null });\r\n      }\r\n      setIsModalOpen(false);\r\n      loadVouchers();\r\n    } catch (err) {\r\n      alert(err.response?.data?.message || 'LГҹв•—Г№i lв•һв–‘u thв”ңв”Өng tin voucher');\r\n    }\r\n  };\r\n\r\n  const handleToggleStatus = async (voucher) => {\r\n    const nextStatus = voucher.status === 'active' ? 'paused' : 'active';\r\n    try {\r\n      await updateVoucher(voucher._id, { status: nextStatus });\r\n      loadVouchers();\r\n    } catch (err) {\r\n      alert(err.response?.data?.message || 'LГҹв•—Г№i thay в”ҖГҰГҹв•—ГІi trГҹв•‘Гӯng thв”ңГӯi');\r\n    }\r\n  };\r\n\r\n  const handleDelete = async (id) => {\r\n    if (!window.confirm('BГҹв•‘Гӯn cв”ңв”Ӯ chГҹв•‘В»c muГҹв•—ГҰn vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa voucher nв”ңГЎy? Khв”ңГӯch hв”ңГЎng sГҹв•‘в•ң khв”ңв”Өng thГҹв•—Гў lв•һв–‘u hay sГҹв•—ВЎ dГҹв•—Г‘ng в”ҖГҰв•һв–‘Гҹв•—Гәc nГҹв•—В»a.')) return;\r\n    try {\r\n      await deleteVoucher(id);\r\n      loadVouchers();\r\n    } catch (err) {\r\n      alert(err.response?.data?.message || 'LГҹв•—Г№i vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa voucher');\r\n    }\r\n  };\r\n\r\n  const handleShowStats = async (voucher) => {\r\n    setStatsVoucher(voucher);\r\n    setLoadingStats(true);\r\n    try {\r\n      const res = await getVoucherStats(voucher._id);\r\n      if (res.data?.success) {\r\n        setStatsData(res.data.data);\r\n      }\r\n    } catch (err) {\r\n      alert(err.response?.data?.message || 'LГҹв•—Г№i lГҹв•‘Г‘y bв”ңГӯo cв”ңГӯo thГҹв•—ГҰng kв”ңВ¬');\r\n      setStatsVoucher(null);\r\n    } finally {\r\n      setLoadingStats(false);\r\n    }\r\n  };\r\n\r\n  const globalVouchers = vouchers.filter(v => !v.restaurantId);\r\n  const restaurantVouchers = vouchers.filter(v => v.restaurantId);\r\n\r\n  return (\r\n    <AdminLayout title=\"QuГҹв•‘Гәn lв”ңв•ң Voucher KhuyГҹв•‘в”җn MГҹв•‘Гӯi\" subtitle=\"QuГҹв•‘Гәn trГҹв•—ГҜ mв”ңГә giГҹв•‘Гәm giв”ңГӯ toв”ңГЎn sв”ңГЎn vв”ңГЎ theo dв”ңв•Ўi mв”ңГә cГҹв•—Вәa cв”ңГӯc nhв”ңГЎ hв”ңГЎng\">\r\n      <div className=\"flex flex-col sm:flex-row gap-4 justify-between items-stretch sm:items-center mb-6\">\r\n        <h1 className=\"text-xl font-extrabold text-zinc-100 uppercase tracking-wide flex items-center gap-2\">\r\n          <Ticket className=\"text-amber-500\" /> Voucher KhuyГҹв•‘в”җn MГҹв•‘Гӯi\r\n        </h1>\r\n        <button \r\n          className=\"inline-flex items-center gap-1.5 px-4 py-2 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-black font-semibold text-sm rounded-lg transition duration-150 shadow-lg shadow-amber-500/10\" \r\n          onClick={() => {\r\n            setEditingVoucher(null);\r\n            setIsModalOpen(true);\r\n          }}\r\n        >\r\n          <Plus size={16} /> TГҹв•‘Гӯo Voucher Global\r\n        </button>\r\n      </div>\r\n\r\n      {/* ThГҹв•—ГҰng kв”ңВ¬ nhanh */}\r\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 mb-6\">\r\n        <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col justify-between\">\r\n          <span className=\"text-xs text-zinc-550 uppercase tracking-wide font-semibold\">Voucher Toв”ңГЎn Sв”ңГЎn</span>\r\n          <strong className=\"text-3xl font-extrabold text-zinc-150 mt-1\">{vouchers.length}</strong>\r\n          <span className=\"text-xs text-zinc-500 mt-2\">{globalVouchers.length} Global | {restaurantVouchers.length} Nhв”ңГЎ hв”ңГЎng</span>\r\n        </div>\r\n        <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl p-5 shadow-lg flex flex-col justify-between border-l-4 border-l-emerald-500\">\r\n          <span className=\"text-xs text-zinc-550 uppercase tracking-wide font-semibold\">в”ҖГүang hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng</span>\r\n          <strong className=\"text-3xl font-extrabold text-emerald-400 mt-1\">\r\n            {vouchers.filter(v => v.status === 'active').length}\r\n          </strong>\r\n          <span className=\"text-xs text-zinc-500 mt-2\">в”ҖГүang phв”ңГіn phГҹв•—ГҰi tГҹв•—Вўi khв”ңГӯch hв”ңГЎng</span>\r\n        </div>\r\n      </div>\r\n\r\n      {loading && (\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 space-y-3 bg-[#1A1D24] border border-zinc-800 rounded-xl mb-6\">\r\n          <div className=\"w-8 h-8 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\r\n          <span className=\"text-sm\">в”ҖГүang tГҹв•‘Гәi danh sв”ңГӯch voucher...</span>\r\n        </div>\r\n      )}\r\n      \r\n      {error && (\r\n        <div className=\"bg-rose-500/10 border border-rose-500/20 text-rose-450 p-4 rounded-xl text-sm mb-6\">\r\n          {error}\r\n        </div>\r\n      )}\r\n\r\n      {!loading && vouchers.length === 0 && (\r\n        <div className=\"flex flex-col items-center justify-center py-20 text-zinc-400 bg-[#1A1D24] border border-zinc-800 rounded-xl text-sm\">\r\n          Chв•һв–‘a cв”ңв”Ӯ voucher nв”ңГЎo trв”ңВ¬n hГҹв•—Г§ thГҹв•—ГҰng.\r\n        </div>\r\n      )}\r\n\r\n      {vouchers.length > 0 && (\r\n        <div className=\"bg-[#1A1D24] border border-zinc-800 rounded-xl overflow-hidden shadow-lg\">\r\n          <div className=\"overflow-x-auto\">\r\n            <table className=\"w-full text-left border-collapse text-zinc-350 text-sm\">\r\n              <thead>\r\n                <tr className=\"bg-zinc-900/50 border-b border-zinc-800 text-zinc-455 font-medium\">\r\n                  <th className=\"p-4\">Mв”ңГә Code</th>\r\n                  <th className=\"p-4\">PhГҹв•‘Гӯm vi</th>\r\n                  <th className=\"p-4\">LoГҹв•‘Гӯi giГҹв•‘Гәm</th>\r\n                  <th className=\"p-4\">Giв”ңГӯ trГҹв•—ГҜ giГҹв•‘Гәm</th>\r\n                  <th className=\"p-4\">в”ҖГүв•һГӯn tГҹв•—ГҰi thiГҹв•—Гўu</th>\r\n                  <th className=\"p-4\">HГҹв•‘Гӯn dв”ңв•Јng</th>\r\n                  <th className=\"p-4\">TrГҹв•‘Гӯng thв”ңГӯi</th>\r\n                  <th className=\"p-4 text-right\">Hв”ңГЎnh в”ҖГҰГҹв•—Г–ng</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody className=\"divide-y divide-zinc-800/60\">\r\n                {vouchers.map(v => (\r\n                  <tr key={v._id} className=\"hover:bg-zinc-850/30 transition-colors\">\r\n                    <td className=\"p-4 font-bold text-zinc-200 font-mono tracking-wider\">{v.code}</td>\r\n                    <td className=\"p-4\">\r\n                      {v.restaurantId ? (\r\n                        <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-amber-500/10 text-amber-400 border border-amber-500/20 max-w-[180px] truncate\">\r\n                          NH: {v.restaurantId?.name || 'О“ГҮГ¶'}\r\n                        </span>\r\n                      ) : (\r\n                        <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-blue-500/10 text-blue-400 border border-blue-500/20\">Global (Toв”ңГЎn sв”ңГЎn)</span>\r\n                      )}\r\n                    </td>\r\n                    <td className=\"p-4 text-xs text-zinc-300\">\r\n                      {v.discountType === 'percentage' ? 'PhГҹв•‘Вәn trв”ҖГўm (%)' : 'SГҹв•—ГҰ tiГҹв•—Гјn (в”ҖГҰ)'}\r\n                    </td>\r\n                    <td className=\"p-4 text-zinc-200 font-semibold font-mono\">\r\n                      {v.discountType === 'percentage' ? `${v.discountValue}%` : formatMoney(v.discountValue)}\r\n                    </td>\r\n                    <td className=\"p-4 font-mono text-zinc-400\">{formatMoney(v.minOrderAmount)}</td>\r\n                    <td className=\"p-4 text-xs text-zinc-400 font-mono\">{formatDate(v.endDate)}</td>\r\n                    <td className=\"p-4\">\r\n                      <VoucherStatusBadge status={v.status} />\r\n                    </td>\r\n                    <td className=\"p-4 text-right\">\r\n                      <div className=\"flex items-center justify-end gap-1.5\">\r\n                        <button \r\n                          className=\"p-1.5 hover:bg-zinc-800 text-zinc-400 hover:text-amber-500 rounded-lg transition\"\r\n                          title=\"Bв”ңГӯo cв”ңГӯo hiГҹв•—Г§u quГҹв•‘Гә\"\r\n                          onClick={() => handleShowStats(v)}\r\n                        >\r\n                          <BarChart2 size={14} />\r\n                        </button>\r\n                        \r\n                        {v.status !== 'disabled' && (\r\n                          <>\r\n                            <button \r\n                              className=\"p-1.5 hover:bg-zinc-800 rounded-lg transition text-zinc-400\"\r\n                              title={v.status === 'active' ? 'TГҹв•‘Гӯm dГҹв•—ВҪng' : 'Kв”ңВЎch hoГҹв•‘Гӯt'}\r\n                              onClick={() => handleToggleStatus(v)}\r\n                            >\r\n                              {v.status === 'active' ? (\r\n                                <ToggleRight size={18} className=\"text-emerald-400\" />\r\n                              ) : (\r\n                                <ToggleLeft size={18} className=\"text-zinc-550\" />\r\n                              )}\r\n                            </button>\r\n                            <button \r\n                              className=\"p-1.5 hover:bg-zinc-805 text-zinc-400 hover:text-rose-500 rounded-lg transition\"\r\n                              title=\"Vв”ңв”Ө hiГҹв•—Г§u hв”ңв”Ӯa\"\r\n                              onClick={() => handleDelete(v._id)}\r\n                            >\r\n                              <Trash2 size={14} />\r\n                            </button>\r\n                          </>\r\n                        )}\r\n                      </div>\r\n                    </td>\r\n                  </tr>\r\n                ))}\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {/* Modal tГҹв•‘Гӯo voucher Global */}\r\n      <VoucherFormModal\r\n        isOpen={isModalOpen}\r\n        onClose={() => setIsModalOpen(false)}\r\n        onSubmit={handleCreateOrUpdate}\r\n        voucher={editingVoucher}\r\n      />\r\n\r\n      {/* Drawer Bв”ңГӯo cв”ңГӯo thГҹв•—ГҰng kв”ңВ¬ */}\r\n      {statsVoucher && (\r\n        <div \r\n          className=\"fixed inset-0 z-50 flex items-center justify-end bg-black/60 backdrop-blur-sm p-4 animate-in fade-in duration-200\" \r\n          onClick={() => setStatsVoucher(null)}\r\n        >\r\n          <div \r\n            className=\"bg-[#1A1D24] border-l border-zinc-800 w-full max-w-md h-full p-6 shadow-2xl animate-in slide-in-from-right duration-250 flex flex-col justify-between\" \r\n            onClick={(e) => e.stopPropagation()}\r\n          >\r\n            <div className=\"flex justify-between items-center pb-4 border-b border-zinc-800 mb-6\">\r\n              <h4 className=\"font-bold text-zinc-150 text-sm uppercase tracking-wide\">HiГҹв•—Г§u quГҹв•‘Гә Voucher: {statsVoucher.code}</h4>\r\n              <button \r\n                className=\"text-zinc-500 hover:text-zinc-200 text-2xl font-semibold leading-none\" \r\n                onClick={() => setStatsVoucher(null)}\r\n              >\r\n                &times;\r\n              </button>\r\n            </div>\r\n\r\n            <div className=\"flex-1 overflow-y-auto space-y-6 scrollbar-none pr-1\">\r\n              {loadingStats ? (\r\n                <div className=\"flex flex-col items-center justify-center py-20 text-zinc-450 space-y-2\">\r\n                  <div className=\"w-6 h-6 border-2 border-amber-500 border-t-transparent rounded-full animate-spin\" />\r\n                  <span className=\"text-xs\">в”ҖГүang tв”ңВЎnh toв”ңГӯn sГҹв•—ГҰ liГҹв•—Г§u...</span>\r\n                </div>\r\n              ) : statsData ? (\r\n                <div className=\"space-y-6\">\r\n                  <div className=\"grid grid-cols-3 gap-3\">\r\n                    <div className=\"bg-[#13161C] border border-zinc-800 p-3 rounded-lg flex flex-col\">\r\n                      <span className=\"text-[10px] text-zinc-550 uppercase font-semibold\">в”ҖГүв”ңГә lв•һв–‘u</span>\r\n                      <h4 className=\"text-lg font-bold text-zinc-200 mt-1\">{statsData.savedCount}</h4>\r\n                    </div>\r\n                    <div className=\"bg-[#13161C] border border-zinc-800 p-3 rounded-lg flex flex-col\">\r\n                      <span className=\"text-[10px] text-zinc-550 uppercase font-semibold\">в”ҖГүв”ңГә dв”ңв•Јng</span>\r\n                      <h4 className=\"text-lg font-bold text-zinc-200 mt-1\">{statsData.usedCount}</h4>\r\n                    </div>\r\n                    <div className=\"bg-[#13161C] border border-zinc-800 p-3 rounded-lg flex flex-col\">\r\n                      <span className=\"text-[10px] text-zinc-550 uppercase font-semibold\">в”ҖГүв”ңГә giГҹв•‘Гәm</span>\r\n                      <h4 className=\"text-xs font-bold text-amber-500 mt-1 truncate\">{formatMoney(statsData.totalDiscount)}</h4>\r\n                    </div>\r\n                  </div>\r\n\r\n                  <div className=\"space-y-3\">\r\n                    <h5 className=\"text-xs font-bold text-zinc-300 uppercase tracking-wide\">LГҹв•—ГҜch sГҹв•—ВЎ sГҹв•—ВЎ dГҹв•—Г‘ng chi tiГҹв•‘в”җt</h5>\r\n                    {statsData.redemptions?.length === 0 ? (\r\n                      <div className=\"text-xs text-zinc-500 italic py-4\">Chв•һв–‘a cв”ңв”Ӯ lв•һв–‘Гҹв•—Гәt sГҹв•—ВЎ dГҹв•—Г‘ng nв”ңГЎo cho mв”ңГә nв”ңГЎy.</div>\r\n                    ) : (\r\n                      <div className=\"divide-y divide-zinc-805\">\r\n                        {statsData.redemptions.map((r, idx) => (\r\n                          <div key={idx} className=\"py-3 text-xs space-y-1\">\r\n                            <div className=\"flex justify-between items-center\">\r\n                              <strong className=\"text-zinc-200\">Booking #{r.bookingId?.toString().slice(-6).toUpperCase()}</strong>\r\n                              <span className=\"text-zinc-500 font-mono text-[10px]\">\r\n                                {new Date(r.usedAt).toLocaleDateString('vi-VN')}\r\n                              </span>\r\n                            </div>\r\n                            <div className=\"text-[11px] text-zinc-400\">\r\n                              в”ҖГүв•һГӯn gГҹв•—ГҰc: {formatMoney(r.amountBefore)} | GiГҹв•‘Гәm: -{formatMoney(r.discountApplied)} | Thanh toв”ңГӯn: {formatMoney(r.amountAfter)}\r\n                            </div>\r\n                          </div>\r\n                        ))}\r\n                      </div>\r\n                    )}\r\n                  </div>\r\n                </div>\r\n              ) : (\r\n                <div className=\"text-xs text-rose-400 text-center py-10\">Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi bв”ңГӯo cв”ңГӯo.</div>\r\n              )}\r\n            </div>\r\n\r\n            <div className=\"pt-4 border-t border-zinc-800 mt-6 flex justify-end\">\r\n              <button \r\n                className=\"px-4 py-2 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 font-semibold text-xs rounded-lg transition\"\r\n                onClick={() => setStatsVoucher(null)}\r\n              >\r\n                в”ҖГүв”ңв”Ӯng\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </AdminLayout>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\admin\\AdminWaitlists.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  63 |\n  64 |   useEffect(() => {\n> 65 |     fetchWaitlists(1);\n     |     ^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  66 |     fetchStats();\n  67 |   }, [fetchStats, fetchWaitlists]);\n  68 |","line":65,"column":5,"endLine":65,"endColumn":19}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useCallback, useEffect, useState } from 'react';\r\nimport toast from 'react-hot-toast';\r\nimport { CheckCircle2, Clock, RefreshCw, Search, Users, XCircle } from 'lucide-react';\r\nimport AdminLayout from '../../components/admin/AdminLayout';\r\nimport {\r\n  getAdminWaitlistStats,\r\n  getAdminWaitlists,\r\n  updateAdminWaitlistStatus,\r\n} from '../../api/waitlistApi';\r\nimport WaitlistStatusBadge from '../../components/waitlist/WaitlistStatusBadge';\r\n\r\nconst STATUSES = [\r\n  { value: '', label: 'TГҹв•‘Г‘t cГҹв•‘Гә' },\r\n  { value: 'pending', label: 'в”ҖГүang chГҹв•—ВҘ' },\r\n  { value: 'confirmed', label: 'в”ҖГүв”ңГә xв”ңГӯc nhГҹв•‘ВЎn' },\r\n  { value: 'cancelled', label: 'в”ҖГүв”ңГә hГҹв•—Вәy' },\r\n  { value: 'expired', label: 'HГҹв•‘в”җt hГҹв•‘Гӯn' },\r\n];\r\n\r\nconst formatDate = (value) => value ? new Date(value).toLocaleDateString('vi-VN') : '--';\r\n\r\nexport default function AdminWaitlists() {\r\n  const [waitlists, setWaitlists] = useState([]);\r\n  const [stats, setStats] = useState(null);\r\n  const [loading, setLoading] = useState(true);\r\n  const [filters, setFilters] = useState({ status: '', search: '', fromDate: '', toDate: '' });\r\n  const [pagination, setPagination] = useState({ page: 1, totalPages: 1, total: 0 });\r\n\r\n  const fetchWaitlists = useCallback(async (page = 1) => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await getAdminWaitlists({\r\n        page,\r\n        limit: 20,\r\n        status: filters.status || undefined,\r\n        search: filters.search || undefined,\r\n        fromDate: filters.fromDate || undefined,\r\n        toDate: filters.toDate || undefined,\r\n      });\r\n      if (res.success) {\r\n        setWaitlists(res.data.waitlists || []);\r\n        setPagination({\r\n          page: res.data.page || page,\r\n          totalPages: res.data.totalPages || 1,\r\n          total: res.data.total || 0,\r\n        });\r\n      }\r\n    } catch (error) {\r\n      toast.error(error.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch chГҹв•—ВҘ');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [filters.fromDate, filters.search, filters.status, filters.toDate]);\r\n\r\n  const fetchStats = useCallback(async () => {\r\n    try {\r\n      const res = await getAdminWaitlistStats();\r\n      if (res.success) setStats(res.data);\r\n    } catch (error) {\r\n      console.error('Cannot fetch admin waitlist stats:', error);\r\n    }\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    fetchWaitlists(1);\r\n    fetchStats();\r\n  }, [fetchStats, fetchWaitlists]);\r\n\r\n  useEffect(() => {\r\n    const handler = () => {\r\n      fetchWaitlists(pagination.page);\r\n      fetchStats();\r\n    };\r\n    window.addEventListener('bookeat:waitlist-event', handler);\r\n    return () => window.removeEventListener('bookeat:waitlist-event', handler);\r\n  }, [fetchStats, fetchWaitlists, pagination.page]);\r\n\r\n  const updateStatus = async (waitlist, status) => {\r\n    const note = window.prompt(status === 'cancelled' ? 'Lв”ңв•ң do hГҹв•—Вәy?' : 'Lв”ңв•ң do в”ҖГҰв”ңГӯnh dГҹв•‘Г‘u hГҹв•‘в”җt hГҹв•‘Гӯn?');\r\n    if (note === null) return;\r\n    try {\r\n      const res = await updateAdminWaitlistStatus(waitlist.id, { status, note });\r\n      if (res.success) {\r\n        toast.success('в”ҖГүв”ңГә cГҹв•‘ВЎp nhГҹв•‘ВЎt trГҹв•‘Гӯng thв”ңГӯi waitlist');\r\n        fetchWaitlists(pagination.page);\r\n        fetchStats();\r\n      }\r\n    } catch (error) {\r\n      toast.error(error.message || 'Khв”ңв”Өng thГҹв•—Гў cГҹв•‘ВЎp nhГҹв•‘ВЎt trГҹв•‘Гӯng thв”ңГӯi');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <AdminLayout title=\"QuГҹв•‘Гәn lв”ңв•ң Danh sв”ңГӯch chГҹв•—