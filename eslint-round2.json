= searchParams.get('orderCode');\r\n  const targetType = searchParams.get('targetType');\r\n\r\n  useEffect(() => {\r\n    if (orderCode) {\r\n      verifyPayment();\r\n    } else {\r\n      setChecking(false);\r\n      setVerified(true); // Assume success if no orderCode (came from webhook)\r\n    }\r\n  }, [orderCode]);\r\n\r\n  const verifyPayment = async () => {\r\n    try {\r\n      const res = await checkPaymentStatus(orderCode);\r\n      setVerified(res.data?.status === 'paid');\r\n    } catch {\r\n      setVerified(false);\r\n    } finally {\r\n      setChecking(false);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen w-full bg-[#0F1115] relative flex items-center justify-center p-4 overflow-hidden before:absolute before:inset-0 before:bg-[radial-gradient(circle_at_center,rgba(212,150,83,0.06)_0%,transparent_70%)]\">\r\n      {/* Background decoration blur */}\r\n      <div className=\"absolute top-0 left-0 w-full h-full pointer-events-none opacity-20 z-0\">\r\n        <div className=\"absolute top-1/4 left-10 w-96 h-96 bg-primary/10 rounded-full blur-3xl\" />\r\n        <div className=\"absolute bottom-1/4 right-10 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl\" />\r\n      </div>\r\n\r\n      <div className=\"w-full max-w-[480px] p-8 md:p-10 bg-card/90 border border-border rounded-2xl flex flex-col items-center gap-6 shadow-2xl relative backdrop-blur-md z-10 text-center\">\r\n        {checking ? (\r\n          <div className=\"flex flex-col items-center gap-4 py-4\">\r\n            <Loader2 className=\"h-10 w-10 animate-spin text-primary\" />\r\n            <h1 className=\"font-serif text-2xl text-white font-bold tracking-tight\">в”ҖГүang kiГҹв•—Гўm tra giao dГҹв•—ГҜch...</h1>\r\n            <p className=\"text-xs text-muted-foreground max-w-[320px] leading-relaxed\">\r\n              Vui lв”ңв–“ng в”ҖГҰГҹв•—Гәi hГҹв•—Г§ thГҹв•—ГҰng xв”ңГӯc nhГҹв•‘ВЎn thanh toв”ңГӯn tГҹв•—ВҪ cГҹв•—ГІng PayOS.\r\n            </p>\r\n          </div>\r\n        ) : verified ? (\r\n          <div className=\"flex flex-col items-center gap-4 py-2\">\r\n            <div className=\"h-16 w-16 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400\">\r\n              <CheckCircle size={36} />\r\n            </div>\r\n            <h1 className=\"font-serif text-2xl text-white font-bold tracking-tight\">Thanh toв”ңГӯn thв”ңГЎnh cв”ңв”Өng!</h1>\r\n            <p className=\"text-xs text-muted-foreground max-w-[320px] leading-relaxed\">\r\n              {targetType === 'subscription'\r\n                ? 'Gв”ңв”Ӯi dГҹв•—ГҜch vГҹв•—Г‘ в”ҖГҰв”ңГә в”ҖГҰв•һв–‘Гҹв•—Гәc kв”ңВЎch hoГҹв•‘Гӯt thв”ңГЎnh cв”ңв”Өng cho nhв”ңГЎ hв”ңГЎng cГҹв•—Вәa bГҹв•‘Гӯn.'\r\n                : 'в”ҖГүГҹв•‘в•–t cГҹв•—Г¬c thв”ңГЎnh cв”ңв”Өng. Yв”ңВ¬u cГҹв•‘Вәu в”ҖГҰГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa bГҹв•‘Гӯn в”ҖГҰв”ңГә в”ҖГҰв•һв–‘Гҹв•—Гәc hГҹв•—Г§ thГҹв•—ГҰng xв”ңГӯc nhГҹв•‘ВЎn.'}\r\n            </p>\r\n          </div>\r\n        ) : (\r\n          <div className=\"flex flex-col items-center gap-4 py-2\">\r\n            <div className=\"h-16 w-16 rounded-full bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-500\">\r\n              <Clock size={36} />\r\n            </div>\r\n            <h1 className=\"font-serif text-2xl text-white font-bold tracking-tight\">в”ҖГүang chГҹв•—ВҘ xв”ңГӯc nhГҹв•‘ВЎn</h1>\r\n            <p className=\"text-xs text-muted-foreground max-w-[320px] leading-relaxed\">\r\n              Thanh toв”ңГӯn chв•һв–‘a в”ҖГҰв•һв–‘Гҹв•—Гәc xв”ңГӯc nhГҹв•‘ВЎn hoв”ңГЎn tГҹв•‘Г‘t. Vui lв”ңв–“ng в”ҖГҰГҹв•—Гәi hoГҹв•‘в•–c kiГҹв•—Гўm tra lГҹв•‘Гӯi.\r\n            </p>\r\n            <button \r\n              className=\"mt-1 h-10 px-5 rounded-xl border border-border bg-transparent text-muted-foreground hover:text-white hover:bg-white/5 transition-all text-xs font-semibold flex items-center justify-center gap-1.5 cursor-pointer\" \r\n              onClick={verifyPayment}\r\n            >\r\n              <RotateCw size={14} />\r\n              <span>KiГҹв•—Гўm tra lГҹв•‘Гӯi trГҹв•‘Гӯng thв”ңГӯi</span>\r\n            </button>\r\n          </div>\r\n        )}\r\n\r\n        <div className=\"w-full border-t border-border/40 pt-6 mt-2\">\r\n          {targetType === 'subscription' ? (\r\n            <button \r\n              className=\"w-full h-12 rounded-xl bg-primary text-[#0F1115] font-bold text-sm tracking-wide hover:bg-primary/95 transition-all flex items-center justify-center gap-2 cursor-pointer\" \r\n              onClick={() => navigate('/owner/billing')}\r\n            >\r\n              <ArrowLeft size={16} /> \r\n              <span>VГҹв•—Гј trang gв”ңв”Ӯi dГҹв•—ГҜch vГҹв•—Г‘</span>\r\n            </button>\r\n          ) : (\r\n            <button \r\n              className=\"w-full h-12 rounded-xl bg-primary text-[#0F1115] font-bold text-sm tracking-wide hover:bg-primary/95 transition-all flex items-center justify-center gap-2 cursor-pointer\" \r\n              onClick={() => navigate('/my-bookings')}\r\n            >\r\n              <ArrowLeft size={16} /> \r\n              <span>VГҹв•—Гј danh sв”ңГӯch в”ҖГҰГҹв•‘в•–t bв”ңГЎn</span>\r\n            </button>\r\n          )}\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\profile\\MyFavoritesPage.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  55 |\n  56 |   useEffect(() => {\n> 57 |     loadFavorites();\n     |     ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  58 |   }, [loadFavorites]);\n  59 |\n  60 |   const handleSearchSubmit = (e) => {","line":57,"column":5,"endLine":57,"endColumn":18}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState, useCallback } from 'react';\nimport { Link, useNavigate } from 'react-router-dom';\nimport { Heart, Search, Star, MapPin, Loader2, Compass, RotateCcw } from 'lucide-react';\nimport Header from '../../components/Header';\nimport { useAuth } from '../../context/useAuth';\nimport { getMyFavorites, removeFavorite } from '../../api/favoriteApi';\nimport { Card } from '../../components/ui/card';\nimport { Button } from '../../components/ui/button';\nimport { Input } from '../../components/ui/input';\nimport toast from 'react-hot-toast';\n\n\nexport default function MyFavoritesPage() {\n  const { isAuthenticated, user } = useAuth();\n  const navigate = useNavigate();\n\n  // States\n  const [favorites, setFavorites] = useState([]);\n  const [loading, setLoading] = useState(true);\n  const [search, setSearch] = useState('');\n  const [page, setPage] = useState(1);\n  const [totalPages, setTotalPages] = useState(1);\n  const [total, setTotal] = useState(0);\n\n  // Security guard\n  useEffect(() => {\n    if (!isAuthenticated) {\n      toast.error('Vui lв”ңв–“ng в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp в”ҖГҰГҹв•—Гў xem danh sв”ңГӯch yв”ңВ¬u thв”ңВЎch');\n      navigate('/auth/login?redirect=/my-favorites');\n    }\n  }, [isAuthenticated, navigate]);\n\n  const loadFavorites = useCallback(async () => {\n    if (!isAuthenticated || user?.role !== 'customer') return;\n    try {\n      setLoading(true);\n      const res = await getMyFavorites({\n        page,\n        limit: 9,\n        search: search.trim()\n      });\n      if (res && res.success) {\n        setFavorites(res.data || []);\n        if (res.pagination) {\n          setTotalPages(res.pagination.totalPages || 1);\n          setTotal(res.pagination.total || 0);\n        }\n      }\n    } catch (err) {\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch yв”ңВ¬u thв”ңВЎch');\n    } finally {\n      setLoading(false);\n    }\n  }, [page, search, isAuthenticated, user]);\n\n  useEffect(() => {\n    loadFavorites();\n  }, [loadFavorites]);\n\n  const handleSearchSubmit = (e) => {\n    e.preventDefault();\n    setPage(1);\n    loadFavorites();\n  };\n\n  const handleUnfavorite = async (restaurantId, e) => {\n    e.preventDefault();\n    e.stopPropagation();\n\n    try {\n      const res = await removeFavorite(restaurantId);\n      if (res && res.success) {\n        setFavorites(prev => prev.filter(fav => fav.restaurantId?._id !== restaurantId));\n        setTotal(t => Math.max(0, t - 1));\n        toast.success('в”ҖГүв”ңГә xв”ңв”Ӯa khГҹв•—Г…i danh sв”ңГӯch yв”ңВ¬u thв”ңВЎch');\n      }\n    } catch (err) {\n      toast.error(err.message || 'LГҹв•—Г№i khi bГҹв•—Г… yв”ңВ¬u thв”ңВЎch');\n    }\n  };\n\n  const clearFilters = () => {\n    setSearch('');\n    setPage(1);\n  };\n\n  if (!isAuthenticated || user?.role !== 'customer') {\n    return null;\n  }\n\n  return (\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\n      <Header />\n\n      <main className=\"flex-1 max-w-[1280px] w-full mx-auto px-4 sm:px-6 lg:px-8 py-10\">\n        \n        {/* Header Title */}\n        <div className=\"mb-8 text-left border-b border-border/40 pb-5\">\n          <h1 className=\"text-3xl font-extrabold tracking-tight text-white flex items-center gap-3\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\n            <Heart className=\"fill-rose-500 text-rose-500 h-8 w-8 shrink-0\" />\n            <span>Nhв”ңГЎ hв”ңГЎng yв”ңВ¬u thв”ңВЎch cГҹв•—Вәa tв”ңв”Өi</span>\n          </h1>\n          <p className=\"mt-2 text-sm text-muted-foreground\">\n            QuГҹв•‘Гәn lв”ңв•ң vв”ңГЎ в”ҖГҰГҹв•‘в•–t bв”ңГЎn nhanh chв”ңв”Ӯng tГҹв•‘Гӯi cв”ңГӯc в”ҖГҰГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm Гҹв•‘вҢҗm thГҹв•—в–’c bГҹв•‘Гӯn в”ҖГҰв”ңГә lв•һв–‘u.\n          </p>\n        </div>\n\n        {/* Search tool bar */}\n        <div className=\"flex flex-col sm:flex-row gap-4 justify-between items-stretch sm:items-center mb-6\">\n          <form onSubmit={handleSearchSubmit} className=\"flex gap-2 w-full max-w-md\">\n            <div className=\"relative flex-1\">\n              <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\n              <Input\n                type=\"text\"\n                placeholder=\"Tв”ңВјm tв”ңВ¬n, loГҹв•‘Гӯi Гҹв•‘вҢҗm thГҹв•—в–’c, в”ҖГҰГҹв•—ГҜa chГҹв•—Г«...\"\n                value={search}\n                onChange={(e) => setSearch(e.target.value)}\n                className=\"pl-9 h-10 bg-card border-border text-xs focus-visible:ring-1 focus-visible:ring-primary\"\n              />\n            </div>\n            <Button type=\"submit\" size=\"sm\" className=\"bg-primary hover:bg-primary/95 text-background font-bold px-5 h-10 text-xs cursor-pointer\">\n              Tв”ңВјm kiГҹв•‘в”җm\n            </Button>\n          </form>\n\n          {search && (\n            <button\n              onClick={clearFilters}\n              className=\"inline-flex items-center gap-1.5 px-3 py-2 border border-border hover:bg-secondary/40 text-muted-foreground hover:text-white text-xs font-semibold rounded-lg transition cursor-pointer\"\n            >\n              <RotateCcw size={14} /> Xв”ңв”Ӯa tв”ңВјm kiГҹв•‘в”җm\n            </button>\n          )}\n        </div>\n\n        {/* Main Content Area */}\n        {loading ? (\n          <div className=\"flex flex-col items-center justify-center py-24 text-muted-foreground gap-3\">\n            <Loader2 className=\"h-8 w-8 animate-spin text-primary\" />\n            <p className=\"text-sm font-medium\">в”ҖГүang tГҹв•‘Гәi danh sв”ңГӯch yв”ңВ¬u thв”ңВЎch...</p>\n          </div>\n        ) : favorites.length === 0 ? (\n          <div className=\"text-center py-20 border border-dashed border-border bg-card/20 rounded-xl flex flex-col items-center justify-center gap-4 max-w-xl mx-auto my-10\">\n            <div className=\"h-16 w-16 rounded-full bg-rose-500/10 flex items-center justify-center border border-rose-500/20 text-rose-500\">\n              <Heart size={28} className=\"animate-pulse\" />\n            </div>\n            <h3 className=\"text-lg font-bold text-white\">Chв•һв–‘a tв”ңВјm thГҹв•‘Г‘y nhв”ңГЎ hв”ңГЎng nв”ңГЎo</h3>\n            <p className=\"text-xs text-muted-foreground leading-relaxed max-w-sm\">\n              {search \n                ? 'Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y nhв”ңГЎ hв”ңГЎng yв”ңВ¬u thв”ңВЎch nв”ңГЎo khГҹв•—Вўp vГҹв•—Вўi tГҹв•—ВҪ khв”ңв”Ӯa tв”ңВјm kiГҹв•‘в”җm cГҹв•—Вәa bГҹв•‘Гӯn.' \n                : 'BГҹв•‘Гӯn chв•һв–‘a lв•һв–‘u nhв”ңГЎ hв”ңГЎng yв”ңВ¬u thв”ңВЎch nв”ңГЎo. Hв”ңГәy khв”ңГӯm phв”ңГӯ vв”ңГЎ lв•һв–‘u lГҹв•‘Гӯi nhГҹв•—В»ng в”ҖГҰГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm Гҹв•‘вҢҗm thГҹв•—в–’c tuyГҹв•—Г§t vГҹв•—ВҘi nhв”ңвҢҗ!'}\n            </p>\n            <Link to=\"/restaurants\">\n              <Button className=\"bg-primary hover:bg-primary/90 text-background text-xs font-bold px-6 h-10 cursor-pointer\">\n                <Compass className=\"h-4 w-4 mr-2\" /> Khв”ңГӯm phв”ңГӯ nhв”ңГЎ hв”ңГЎng ngay\n              </Button>\n            </Link>\n          </div>\n        ) : (\n          <div className=\"flex flex-col gap-8\">\n            <div className=\"text-xs text-muted-foreground text-left\">\n              в”ҖГүang hiГҹв•—Гўn thГҹв•—ГҜ <strong className=\"text-white font-bold\">{total}</strong> nhв”ңГЎ hв”ңГЎng yв”ңВ¬u thв”ңВЎch cГҹв•—Вәa bГҹв•‘Гӯn\n            </div>\n\n            {/* Grid display */}\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n              {favorites.map((fav) => {\n                const res = fav.restaurantId;\n                if (!res) return null;\n                return (\n                  <Card\n                    key={fav._id}\n                    className=\"overflow-hidden bg-card border-border hover:border-primary/40 transition-all duration-300 group flex flex-col relative\"\n                  >\n                    {/* Image block */}\n                    <div className=\"relative aspect-[4/3] overflow-hidden bg-secondary\">\n                      {res.coverImageUrl || res.logo ? (\n                        <img\n                          src={res.coverImageUrl || res.logo}\n                          alt={res.name}\n                          loading=\"lazy\"\n                          className=\"w-full h-full object-cover group-hover:scale-105 transition duration-500\"\n                        />\n                      ) : (\n                        <div className=\"w-full h-full flex items-center justify-center text-4xl\">вүЎЖ’Г¬в•ңвҲ©в••Г…</div>\n                      )}\n                      \n                      {/* Heart Button to Unfavorite */}\n                      <button\n                        type=\"button\"\n                        onClick={(e) => handleUnfavorite(res._id, e)}\n                        className=\"absolute top-3.5 right-3.5 p-2 rounded-full bg-black/55 hover:bg-black/70 border border-white/10 text-white transition-colors cursor-pointer z-10 flex items-center justify-center\"\n                        aria-label=\"Xв”ңв”Ӯa khГҹв•—Г…i yв”ңВ¬u thв”ңВЎch\"\n                      >\n                        <Heart\n                          size={16}\n                          className=\"fill-rose-500 text-rose-500 scale-110\"\n                        />\n                      </button>\n                    </div>\n\n                    {/* Info details block */}\n                    <div className=\"p-4 flex-1 flex flex-col text-left\">\n                      <div className=\"flex-1\">\n                        <div className=\"flex items-start justify-between gap-2\">\n                          <h3 className=\"text-base font-bold text-white truncate group-hover:text-primary transition-colors\" title={res.name}>\n                            {res.name}\n                          </h3>\n                          <div className=\"flex items-center gap-0.5 text-xs text-primary shrink-0 font-semibold\">\n                            <Star className=\"h-3.5 w-3.5 fill-primary text-primary\" />\n                            <span>{res.averageRating ? res.averageRating.toFixed(1) : '0.0'}</span>\n                          </div>\n                        </div>\n\n                        <div className=\"flex items-center gap-1.5 text-xs text-muted-foreground mt-1.5\">\n                          <span className=\"text-primary font-medium\">{res.cuisineTypes?.join(', ') || 'Chв•һв–‘a phв”ңГіn loГҹв•‘Гӯi'}</span>\n                          <span>в”¬в•–</span>\n                          <span className=\"font-semibold\">\n                            {res.averagePrice ? `~ ${res.averagePrice.toLocaleString('vi-VN')} в”ҖГҰ` : 'Giв”ңГӯ liв”ңВ¬n hГҹв•—Г§'}\n                          </span>\n                        </div>\n\n                        <p className=\"text-xs text-muted-foreground mt-3 line-clamp-2 leading-relaxed\">\n                          {res.description || 'Chв•һв–‘a cв”ңв”Ӯ mв”ңв”Ө tГҹв•‘Гә chi tiГҹв•‘в”җt cho nhв”ңГЎ hв”ңГЎng nв”ңГЎy.'}\n                        </p>\n\n                        <div className=\"mt-3.5 flex items-center gap-1 text-[11px] text-muted-foreground\">\n                          <MapPin className=\"h-3.5 w-3.5 text-primary flex-shrink-0\" />\n                          <span className=\"truncate\" title={res.address?.fullAddress || res.address}>{res.address?.fullAddress || res.address}</span>\n                        </div>\n                      </div>\n\n                      {/* Action buttons footer */}\n                      <div className=\"mt-5 pt-3 border-t border-border/40 grid grid-cols-2 gap-2\">\n                        <Link\n                          to={`/restaurants/${res._id}`}\n                          className=\"flex items-center justify-center h-8 text-xs font-semibold rounded bg-secondary hover:bg-secondary/80 text-white transition-colors text-center\"\n                        >\n                          Chi tiГҹв•‘в”җt\n                        </Link>\n                        <Link\n                          to={`/restaurants/${res._id}/booking`}\n                          className=\"flex items-center justify-center h-8 text-xs font-bold rounded bg-primary hover:bg-primary/95 text-background transition-colors text-center\"\n                        >\n                          в”ҖГүГҹв•‘в•–t bв”ңГЎn\n                        </Link>\n                      </div>\n                    </div>\n                  </Card>\n                );\n              })}\n            </div>\n\n            {/* Pagination controls */}\n            {totalPages > 1 && (\n              <div className=\"mt-4 flex justify-center items-center gap-1.5\">\n                <Button\n                  disabled={page <= 1}\n                  onClick={() => setPage(page - 1)}\n                  variant=\"outline\"\n                  size=\"sm\"\n                  className=\"border-border text-xs text-white\"\n                >\n                  Trв•һв–‘Гҹв•—Вўc\n                </Button>\n                {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (\n                  <Button\n                    key={p}\n                    variant={p === page ? 'default' : 'outline'}\n                    size=\"icon\"\n                    className={`h-8 w-8 text-xs ${\n                      p === page ? 'bg-primary text-background font-bold' : 'border-border text-white'\n                    }`}\n                    onClick={() => setPage(p)}\n                  >\n                    {p}\n                  </Button>\n                ))}\n                <Button\n                  disabled={page >= totalPages}\n                  onClick={() => setPage(page + 1)}\n                  variant=\"outline\"\n                  size=\"sm\"\n                  className=\"border-border text-xs text-white\"\n                >\n                  Sau\n                </Button>\n              </div>\n            )}\n          </div>\n        )}\n      </main>\n\n      {/* Footer */}\n      <footer className=\"border-t border-border bg-[#090B0E] py-8 text-center text-xs text-muted-foreground mt-16\">\n        <div className=\"mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4\">\n          <span style={{ fontFamily: \"'Playfair Display', serif\" }} className=\"text-sm font-bold text-white tracking-wider\">BookEat</span>\n          <span>в”¬вҢҗ 2026 BookEat. MГҹв•—Г¬i quyГҹв•—Гјn в”ҖГҰв•һв–‘Гҹв•—Гәc bГҹв•‘Гәo lв•һв–‘u.</span>\n        </div>\n      </footer>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\profile\\ProfilePage.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n   96 |   // Sync form khi user thay в”ҖГҰГҹв•—ГІi\n   97 |   useEffect(() => {\n>  98 |     setForm({\n      |     ^^^^^^^ Avoid calling setState() directly within an effect\n   99 |       fullName: user?.fullName || '',\n  100 |       phoneNumber: user?.phoneNumber || '',\n  101 |       address: user?.address || '',","line":98,"column":5,"endLine":98,"endColumn":12}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState } from 'react';\r\nimport { Link } from 'react-router-dom';\r\nimport {\r\n  User,\r\n  Mail,\r\n  Phone,\r\n  MapPin,\r\n  Shield,\r\n  Clock,\r\n  Lock,\r\n  Eye,\r\n  EyeOff,\r\n  CheckCircle,\r\n  AlertCircle,\r\n  Save,\r\n  Calendar,\r\n  ChevronRight,\r\n  Loader2,\r\n} from 'lucide-react';\r\nimport { useAuth } from '../../context/useAuth';\r\nimport { profileApi } from '../../api/profileApi';\r\nimport Header from '../../components/Header';\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Helpers\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nconst PHONE_REGEX = /^(0[35789])[0-9]{8}$/;\r\n\r\nconst ROLE_LABELS = {\r\n  customer: 'Khв”ңГӯch hв”ңГЎng',\r\n  restaurant_owner: 'ChГҹв•—Вә nhв”ңГЎ hв”ңГЎng',\r\n  admin: 'QuГҹв•‘Гәn trГҹв•—ГҜ viв”ңВ¬n',\r\n};\r\n\r\nconst formatDate = (dateStr) => {\r\n  if (!dateStr) return null;\r\n  try {\r\n    return new Intl.DateTimeFormat('vi-VN', {\r\n      day: '2-digit',\r\n      month: '2-digit',\r\n      year: 'numeric',\r\n    }).format(new Date(dateStr));\r\n  } catch {\r\n    return null;\r\n  }\r\n};\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Toast component\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction ProfileAlert({ type, message, onClose }) {\r\n  useEffect(() => {\r\n    if (!message) return;\r\n    const t = setTimeout(onClose, 5000);\r\n    return () => clearTimeout(t);\r\n  }, [message, onClose]);\r\n\r\n  if (!message) return null;\r\n\r\n  return (\r\n    <div\r\n      className={`flex items-start gap-3 p-4 rounded-xl border text-xs leading-relaxed transition-all animate-in fade-in duration-200 ${\r\n        type === 'success'\r\n          ? 'border-emerald-500/20 bg-emerald-500/10 text-emerald-400'\r\n          : 'border-destructive/20 bg-destructive/10 text-destructive'\r\n      }`}\r\n      role=\"alert\"\r\n    >\r\n      {type === 'success' ? (\r\n        <CheckCircle size={16} className=\"shrink-0 mt-0.5\" />\r\n      ) : (\r\n        <AlertCircle size={16} className=\"shrink-0 mt-0.5\" />\r\n      )}\r\n      <span>{message}</span>\r\n    </div>\r\n  );\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Tab: Thв”ңв”Өng tin tв”ңГЎi khoГҹв•‘Гәn (display + edit)\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction TabInfo({ user, onUserUpdated }) {\r\n  const [editing, setEditing] = useState(false);\r\n  const [loading, setLoading] = useState(false);\r\n  const [alert, setAlert] = useState({ type: '', message: '' });\r\n  const [form, setForm] = useState({\r\n    fullName: user?.fullName || '',\r\n    phoneNumber: user?.phoneNumber || '',\r\n    address: user?.address || '',\r\n  });\r\n  const [errors, setErrors] = useState({});\r\n\r\n  // Sync form khi user thay в”ҖГҰГҹв•—ГІi\r\n  useEffect(() => {\r\n    setForm({\r\n      fullName: user?.fullName || '',\r\n      phoneNumber: user?.phoneNumber || '',\r\n      address: user?.address || '',\r\n    });\r\n  }, [user]);\r\n\r\n  const validate = () => {\r\n    const errs = {};\r\n    if (!form.fullName.trim()) errs.fullName = 'HГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n khв”ңв”Өng в”ҖГҰв•һв–‘Гҹв•—Гәc в”ҖГҰГҹв•—Гў trГҹв•—ГҰng';\r\n    if (form.phoneNumber && !PHONE_REGEX.test(form.phoneNumber)) {\r\n      errs.phoneNumber = 'SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi phГҹв•‘Гәi 10 sГҹв•—ГҰ, bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu bГҹв•‘в–’ng 03/05/07/08/09';\r\n    }\r\n    return errs;\r\n  };\r\n\r\n  const handleChange = (e) => {\r\n    const { name, value } = e.target;\r\n    setForm((prev) => ({ ...prev, [name]: value }));\r\n    setErrors((prev) => ({ ...prev, [name]: '' }));\r\n  };\r\n\r\n  const handleSubmit = async (e) => {\r\n    e.preventDefault();\r\n    const errs = validate();\r\n    if (Object.keys(errs).length) {\r\n      setErrors(errs);\r\n      return;\r\n    }\r\n    setLoading(true);\r\n    setAlert({ type: '', message: '' });\r\n    try {\r\n      const res = await profileApi.updateMyProfile({\r\n        fullName: form.fullName.trim(),\r\n        phoneNumber: form.phoneNumber.trim() || null,\r\n        address: form.address.trim() || null,\r\n      });\r\n      onUserUpdated(res.user);\r\n      setEditing(false);\r\n      setAlert({ type: 'success', message: 'CГҹв•‘ВЎp nhГҹв•‘ВЎt thв”ңв”Өng tin thв”ңГЎnh cв”ңв”Өng!' });\r\n    } catch (err) {\r\n      setAlert({ type: 'error', message: err?.message || 'Khв”ңв”Өng thГҹв•—Гў cГҹв•‘ВЎp nhГҹв•‘ВЎt thв”ңв”Өng tin' });\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const handleCancel = () => {\r\n    setEditing(false);\r\n    setErrors({});\r\n    setForm({\r\n      fullName: user?.fullName || '',\r\n      phoneNumber: user?.phoneNumber || '',\r\n      address: user?.address || '',\r\n    });\r\n  };\r\n\r\n  return (\r\n    <div className=\"flex flex-col gap-6 w-full\">\r\n      {/* О“Г¶ГҮО“Г¶ГҮ Thв”ңв”Өng tin hiГҹв•—Гўn thГҹв•—ГҜ О“Г¶ГҮО“Г¶ГҮ */}\r\n      <div className=\"p-6 md:p-8 bg-card border border-border rounded-2xl shadow-lg flex flex-col gap-6\">\r\n        <div className=\"border-b border-border/40 pb-4\">\r\n          <h2 className=\"font-serif text-xl text-white font-bold\">Thв”ңв”Өng tin tв”ңГЎi khoГҹв•‘Гәn</h2>\r\n          <p className=\"text-xs text-muted-foreground mt-1\">Thв”ңв”Өng tin в”ҖГҰв•һв–‘Гҹв•—Гәc liв”ңВ¬n kГҹв•‘в”җt vГҹв•—Вўi tв”ңГЎi khoГҹв•‘Гәn BookEat cГҹв•—Вәa bГҹв•‘Гӯn.</p>\r\n        </div>\r\n\r\n        <ProfileAlert\r\n          type={alert.type}\r\n          message={alert.message}\r\n          onClose={() => setAlert({ type: '', message: '' })}\r\n        />\r\n\r\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\r\n          <div className=\"flex flex-col gap-1.5\">\r\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground/80 flex items-center gap-1.5\">\r\n              <User size={12} className=\"text-primary/70\" />\r\n              HГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n\r\n            </span>\r\n            <span className=\"text-sm font-medium text-white\">{user?.fullName || 'О“ГҮГ¶'}</span>\r\n          </div>\r\n\r\n          <div className=\"flex flex-col gap-1.5\">\r\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground/80 flex items-center gap-1.5\">\r\n              <Mail size={12} className=\"text-primary/70\" />\r\n              Email\r\n            </span>\r\n            <span className=\"text-sm font-medium text-white break-all\">{user?.email || 'О“ГҮГ¶'}</span>\r\n          </div>\r\n\r\n          <div className=\"flex flex-col gap-1.5\">\r\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground/80 flex items-center gap-1.5\">\r\n              <User size={12} className=\"text-primary/70\" />\r\n              Tв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp\r\n            </span>\r\n            <span className=\"text-sm font-medium text-white\">@{user?.username || 'О“ГҮГ¶'}</span>\r\n          </div>\r\n\r\n          <div className=\"flex flex-col gap-1.5\">\r\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground/80 flex items-center gap-1.5\">\r\n              <Phone size={12} className=\"text-primary/70\" />\r\n              SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi\r\n            </span>\r\n            <span className={`text-sm font-medium text-white ${!user?.phoneNumber ? 'text-muted-foreground italic' : ''}`}>\r\n              {user?.phoneNumber || 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt'}\r\n            </span>\r\n          </div>\r\n\r\n          <div className=\"flex flex-col gap-1.5\">\r\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground/80 flex items-center gap-1.5\">\r\n              <MapPin size={12} className=\"text-primary/70\" />\r\n              в”ҖГүГҹв•—ГҜa chГҹв•—Г«\r\n            </span>\r\n            <span className={`text-sm font-medium text-white ${!user?.address ? 'text-muted-foreground italic' : ''}`}>\r\n              {user?.address || 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt'}\r\n            </span>\r\n          </div>\r\n\r\n          <div className=\"flex flex-col gap-1.5\">\r\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground/80 flex items-center gap-1.5\">\r\n              <Shield size={12} className=\"text-primary/70\" />\r\n              Vai trв”ңв–“\r\n            </span>\r\n            <span className=\"text-sm font-medium text-white\">\r\n              {ROLE_LABELS[user?.role] || user?.role || 'О“ГҮГ¶'}\r\n            </span>\r\n          </div>\r\n\r\n          <div className=\"flex flex-col gap-1.5\">\r\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground/80 flex items-center gap-1.5\">\r\n              <Clock size={12} className=\"text-primary/70\" />\r\n              Ngв”ңГЎy tham gia\r\n            </span>\r\n            <span className=\"text-sm font-medium text-white\">\r\n              {formatDate(user?.createdAt) || 'О“ГҮГ¶'}\r\n            </span>\r\n          </div>\r\n\r\n          <div className=\"flex flex-col gap-1.5\">\r\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-muted-foreground/80 flex items-center gap-1.5\">\r\n              <Clock size={12} className=\"text-primary/70\" />\r\n              в”ҖГүв”ҖГўng nhГҹв•‘ВЎp gГҹв•‘Вәn nhГҹв•‘Г‘t\r\n            </span>\r\n            <span className={`text-sm font-medium text-white ${!user?.lastLogin ? 'text-muted-foreground italic' : ''}`}>\r\n              {formatDate(user?.lastLogin) || 'Chв•һв–‘a ghi nhГҹв•‘ВЎn'}\r\n            </span>\r\n          </div>\r\n        </div>\r\n\r\n        {!editing && (\r\n          <div className=\"border-t border-border/40 pt-4 flex\">\r\n            <button\r\n              type=\"button\"\r\n              id=\"btn-edit-profile\"\r\n              className=\"h-11 px-6 rounded-xl bg-primary text-[#0F1115] font-bold text-sm hover:bg-primary/95 transition-all cursor-pointer\"\r\n              onClick={() => setEditing(true)}\r\n            >\r\n              ChГҹв•—Г«nh sГҹв•—ВЎa thв”ңв”Өng tin\r\n            </button>\r\n          </div>\r\n        )}\r\n      </div>\r\n\r\n      {/* О“Г¶ГҮО“Г¶ГҮ Form chГҹв•—Г«nh sГҹв•—ВЎa О“Г¶ГҮО“Г¶ГҮ */}\r\n      {editing && (\r\n        <div className=\"p-6 md:p-8 bg-card border border-border rounded-2xl shadow-lg flex flex-col gap-6\">\r\n          <div className=\"border-b border-border/40 pb-4\">\r\n            <h2 className=\"font-serif text-xl text-white font-bold\">ChГҹв•—Г«nh sГҹв•—ВЎa thв”ңв”Өng tin</h2>\r\n            <p className=\"text-xs text-muted-foreground mt-1\">Email vв”ңГЎ tв”ңВ¬n в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp khв”ңв”Өng thГҹв•—Гў thay в”ҖГҰГҹв•—ГІi tГҹв•‘Гӯi в”ҖГҰв”ңГіy.</p>\r\n          </div>\r\n\r\n          <form className=\"flex flex-col gap-5\" onSubmit={handleSubmit} id=\"form-update-profile\">\r\n            {/* HГҹв•—Г¬ tв”ңВ¬n */}\r\n            <div className=\"flex flex-col gap-1.5\">\r\n              <label htmlFor=\"fullName\" className=\"text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-2\">\r\n                <User size={14} />\r\n                HГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n <span className=\"text-primary\">*</span>\r\n              </label>\r\n              <input\r\n                type=\"text\"\r\n                id=\"fullName\"\r\n                name=\"fullName\"\r\n                value={form.fullName}\r\n                onChange={handleChange}\r\n                placeholder=\"NhГҹв•‘ВЎp hГҹв•—Г¬ vв”ңГЎ tв”ңВ¬n\"\r\n                disabled={loading}\r\n                autoFocus\r\n                className={`flex h-11 w-full rounded-xl border bg-[#20242D] px-4 py-2 text-sm text-white placeholder-muted-foreground/60 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary disabled:cursor-not-allowed disabled:opacity-50 transition-all ${\r\n                  errors.fullName ? 'border-destructive' : 'border-border'\r\n                }`}\r\n              />\r\n              {errors.fullName && (\r\n                <span className=\"text-xs text-destructive font-medium mt-0.5\">{errors.fullName}</span>\r\n              )}\r\n            </div>\r\n\r\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\r\n              {/* SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi */}\r\n              <div className=\"flex flex-col gap-1.5\">\r\n                <label htmlFor=\"phoneNumber\" className=\"text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-2\">\r\n                  <Phone size={14} />\r\n                  SГҹв•—ГҰ в”ҖГҰiГҹв•—Г§n thoГҹв•‘Гӯi\r\n                </label>\r\n                <input\r\n                  type=\"tel\"\r\n                  id=\"phoneNumber\"\r\n                  name=\"phoneNumber\"\r\n                  value={form.phoneNumber}\r\n                  onChange={handleChange}\r\n                  placeholder=\"VD: 0912345678\"\r\n                  disabled={loading}\r\n                  className={`flex h-11 w-full rounded-xl border bg-[#20242D] px-4 py-2 text-sm text-white placeholder-muted-foreground/60 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary disabled:cursor-not-allowed disabled:opacity-50 transition-all ${\r\n                    errors.phoneNumber ? 'border-destructive' : 'border-border'\r\n                  }`}\r\n                />\r\n                {errors.phoneNumber ? (\r\n                  <span className=\"text-xs text-destructive font-medium mt-0.5\">{errors.phoneNumber}</span>\r\n                ) : (\r\n                  <span className=\"text-[10px] text-muted-foreground/50 mt-0.5\">10 sГҹв•—ГҰ, bГҹв•‘В»t в”ҖГҰГҹв•‘Вәu bГҹв•‘в–’ng 03/05/07/08/09</span>\r\n                )}\r\n              </div>\r\n\r\n              {/* в”ҖГүГҹв•—ГҜa chГҹв•—Г« */}\r\n              <div className=\"flex flex-col gap-1.5\">\r\n                <label htmlFor=\"address\" className=\"text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-2\">\r\n                  <MapPin size={14} />\r\n                  в”ҖГүГҹв•—ГҜa chГҹв•—Г«\r\n                </label>\r\n                <input\r\n                  type=\"text\"\r\n                  id=\"address\"\r\n                  name=\"address\"\r\n                  value={form.address}\r\n                  onChange={handleChange}\r\n                  placeholder=\"NhГҹв•‘ВЎp в”ҖГҰГҹв•—ГҜa chГҹв•—Г« cГҹв•—Вәa bГҹв•‘Гӯn\"\r\n                  disabled={loading}\r\n                  className=\"flex h-11 w-full rounded-xl border border-border bg-[#20242D] px-4 py-2 text-sm text-white placeholder-muted-foreground/60 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary disabled:cursor-not-allowed disabled:opacity-50 transition-all\"\r\n                />\r\n              </div>\r\n            </div>\r\n\r\n            {/* Email О“ГҮГ¶ readonly */}\r\n            <div className=\"flex flex-col gap-1.5\">\r\n              <label htmlFor=\"email-readonly\" className=\"text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-2\">\r\n                <Mail size={14} />\r\n                Email (khв”ңв”Өng thГҹв•—Гў thay в”ҖГҰГҹв•—ГІi)\r\n              </label>\r\n              <input\r\n                type=\"email\"\r\n                id=\"email-readonly\"\r\n                value={user?.email || ''}\r\n                disabled\r\n                readOnly\r\n                className=\"flex h-11 w-full rounded-xl border border-border bg-[#1A1D24] opacity-55 px-4 py-2 text-sm text-muted-foreground cursor-not-allowed focus:outline-none\"\r\n              />\r\n              <span className=\"text-[10px] text-muted-foreground/50 mt-0.5\">Liв”ңВ¬n hГҹв•—Г§ bГҹв•—Г– phГҹв•‘ВЎn hГҹв•—Г№ trГҹв•—Гә nГҹв•‘в”җu bГҹв•‘Гӯn cГҹв•‘Вәn thay в”ҖГҰГҹв•—ГІi email в”ҖГҰв”ҖГўng kв”ңв•ң.</span>\r\n            </div>\r\n\r\n            <div className=\"flex flex-col sm:flex-row gap-3 border-t border-border/40 pt-4 mt-2\">\r\n              <button\r\n                type=\"submit\"\r\n                id=\"btn-save-profile\"\r\n                className=\"h-11 px-6 rounded-xl bg-primary text-[#0F1115] font-bold text-sm hover:bg-primary/95 transition-all flex items-center justify-center gap-2 cursor-pointer\"\r\n                disabled={loading}\r\n              >\r\n                <Save size={16} />\r\n                <span>{loading ? 'в”ҖГүang lв•һв–‘u...' : 'Lв•һв–‘u thay в”ҖГҰГҹв•—ГІi'}</span>\r\n              </button>\r\n              <button\r\n                type=\"button\"\r\n                id=\"btn-cancel-edit\"\r\n                className=\"h-11 px-6 rounded-xl border border-border bg-transparent text-muted-foreground hover:text-white hover:bg-white/5 transition-all flex items-center justify-center cursor-pointer\"\r\n                onClick={handleCancel}\r\n                disabled={loading}\r\n              >\r\n                HuГҹв•—в•–\r\n              </button>\r\n            </div>\r\n          </form>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Tab: в”ҖГүГҹв•—ГІi mГҹв•‘ВЎt khГҹв•‘вҢҗu\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction TabPassword({ isGoogleUser }) {\r\n  const [form, setForm] = useState({\r\n    currentPassword: '',\r\n    newPassword: '',\r\n    confirmPassword: '',\r\n  });\r\n  const [errors, setErrors] = useState({});\r\n  const [show, setShow] = useState({\r\n    currentPassword: false,\r\n    newPassword: false,\r\n    confirmPassword: false,\r\n  });\r\n  const [loading, setLoading] = useState(false);\r\n  const [alert, setAlert] = useState({ type: '', message: '' });\r\n\r\n  const toggleShow = (field) =>\r\n    setShow((prev) => ({ ...prev, [field]: !prev[field] }));\r\n\r\n  const handleChange = (e) => {\r\n    const { name, value } = e.target;\r\n    setForm((prev) => ({ ...prev, [name]: value }));\r\n    setErrors((prev) => ({ ...prev, [name]: '' }));\r\n  };\r\n\r\n  const validate = () => {\r\n    const errs = {};\r\n    if (!form.currentPassword) errs.currentPassword = 'MГҹв•‘ВЎt khГҹв•‘вҢҗu hiГҹв•—Г§n tГҹв•‘Гӯi khв”ңв”Өng в”ҖГҰв•һв–‘Гҹв•—Гәc в”ҖГҰГҹв•—Гў trГҹв•—ГҰng';\r\n    if (!form.newPassword || form.newPassword.length < 8)\r\n      errs.newPassword = 'MГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi phГҹв•‘Гәi cв”ңв”Ӯ в”ңВЎt nhГҹв•‘Г‘t 8 kв”ңв•ң tГҹв•—в–’';\r\n    if (!form.confirmPassword) errs.confirmPassword = 'Vui lв”ңв–“ng xв”ңГӯc nhГҹв•‘ВЎn mГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi';\r\n    else if (form.newPassword !== form.confirmPassword)\r\n      errs.confirmPassword = 'Xв”ңГӯc nhГҹв•‘ВЎn mГҹв•‘ВЎt khГҹв•‘вҢҗu khв”ңв”Өng khГҹв•—Вўp';\r\n    if (form.currentPassword && form.newPassword && form.currentPassword === form.newPassword)\r\n      errs.newPassword = 'MГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi khв”ңв”Өng в”ҖГҰв•һв–‘Гҹв•—Гәc trв”ңв•Јng mГҹв•‘ВЎt khГҹв•‘вҢҗu hiГҹв•—Г§n tГҹв•‘Гӯi';\r\n    return errs;\r\n  };\r\n\r\n  const handleSubmit = async (e) => {\r\n    e.preventDefault();\r\n    const errs = validate();\r\n    if (Object.keys(errs).length) {\r\n      setErrors(errs);\r\n      return;\r\n    }\r\n    setLoading(true);\r\n    setAlert({ type: '', message: '' });\r\n    try {\r\n      const res = await profileApi.changeMyPassword({\r\n        currentPassword: form.currentPassword,\r\n        newPassword: form.newPassword,\r\n        confirmPassword: form.confirmPassword,\r\n      });\r\n      setAlert({ type: 'success', message: res?.message || 'в”ҖГүГҹв•—ГІi mГҹв•‘ВЎt khГҹв•‘вҢҗu thв”ңГЎnh cв”ңв”Өng!' });\r\n      setForm({ currentPassword: '', newPassword: '', confirmPassword: '' });\r\n    } catch (err) {\r\n      setAlert({ type: 'error', message: err?.message || 'Khв”ңв”Өng thГҹв•—Гў в”ҖГҰГҹв•—ГІi mГҹв•‘ВЎt khГҹв•‘вҢҗu' });\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  if (isGoogleUser) {\r\n    return (\r\n      <div className=\"p-6 md:p-8 bg-card border border-border rounded-2xl shadow-lg flex flex-col gap-6\">\r\n        <div className=\"border-b border-border/40 pb-4\">\r\n          <h2 className=\"font-serif text-xl text-white font-bold\">в”ҖГүГҹв•—ГІi mГҹв•‘ВЎt khГҹв•‘вҢҗu</h2>\r\n        </div>\r\n        <div className=\"flex flex-col items-center justify-center py-12 px-4 border border-dashed border-border/40 bg-card/10 rounded-2xl text-center\">\r\n          <div className=\"h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center mb-4 border border-primary/20 text-primary\">\r\n            <Lock size={28} />\r\n          </div>\r\n          <h3 className=\"text-base font-bold text-white mb-2\">Tв”ңГЎi khoГҹв•‘Гәn Google</h3>\r\n          <p className=\"text-xs text-muted-foreground max-w-sm leading-relaxed\">\r\n            Tв”ңГЎi khoГҹв•‘Гәn cГҹв•—Вәa bГҹв•‘Гӯn в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp thв”ңв”Өng qua liв”ңВ¬n kГҹв•‘в”җt Google. MГҹв•—Г¬i tв”ңв•Јy chГҹв•—Г«nh bГҹв•‘Гәo mГҹв•‘ВЎt vв”ңГЎ mГҹв•‘ВЎt khГҹв•‘вҢҗu vui lв”ңв–“ng thГҹв•—в–’c hiГҹв•—Г§n trГҹв•—в–’c tiГҹв•‘в”җp trв”ңВ¬n trang quГҹв•‘Гәn lв”ңв•ң tв”ңГЎi khoГҹв•‘Гәn Google.\r\n          </p>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"p-6 md:p-8 bg-card border border-border rounded-2xl shadow-lg flex flex-col gap-6 w-full\">\r\n      <div className=\"border-b border-border/40 pb-4\">\r\n        <h2 className=\"font-serif text-xl text-white font-bold\">в”ҖГүГҹв•—ГІi mГҹв•‘ВЎt khГҹв•‘вҢҗu</h2>\r\n        <p className=\"text-xs text-muted-foreground mt-1\">\r\n          MГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi phГҹв•‘Гәi cв”ңв”Ӯ в”ңВЎt nhГҹв•‘Г‘t 8 kв”ңв•ң tГҹв•—в–’ vв”ңГЎ khв”ңГӯc mГҹв•‘ВЎt khГҹв•‘вҢҗu hiГҹв•—Г§n tГҹв•‘Гӯi.\r\n        </p>\r\n      </div>\r\n\r\n      <ProfileAlert\r\n        type={alert.type}\r\n        message={alert.message}\r\n        onClose={() => setAlert({ type: '', message: '' })}\r\n      />\r\n\r\n      <form className=\"flex flex-col gap-5\" onSubmit={handleSubmit} id=\"form-change-password\">\r\n        {/* MГҹв•‘ВЎt khГҹв•‘вҢҗu hiГҹв•—Г§n tГҹв•‘Гӯi */}\r\n        <div className=\"flex flex-col gap-1.5\">\r\n          <label htmlFor=\"currentPassword\" className=\"text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-2\">\r\n            <Lock size={14} />\r\n            MГҹв•‘ВЎt khГҹв•‘вҢҗu hiГҹв•—Г§n tГҹв•‘Гӯi <span className=\"text-primary\">*</span>\r\n          </label>\r\n          <div className=\"relative\">\r\n            <input\r\n              type={show.currentPassword ? 'text' : 'password'}\r\n              id=\"currentPassword\"\r\n              name=\"currentPassword\"\r\n              value={form.currentPassword}\r\n              onChange={handleChange}\r\n              placeholder=\"NhГҹв•‘ВЎp mГҹв•‘ВЎt khГҹв•‘вҢҗu hiГҹв•—Г§n tГҹв•‘Гӯi\"\r\n              disabled={loading}\r\n              autoComplete=\"current-password\"\r\n              className={`flex h-11 w-full rounded-xl border bg-[#20242D] pl-4 pr-11 py-2 text-sm text-white placeholder-muted-foreground/60 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary disabled:cursor-not-allowed disabled:opacity-50 transition-all ${\r\n                errors.currentPassword ? 'border-destructive' : 'border-border'\r\n              }`}\r\n            />\r\n            <button\r\n              type=\"button\"\r\n              className=\"absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-white transition-colors cursor-pointer outline-none\"\r\n              onClick={() => toggleShow('currentPassword')}\r\n              aria-label=\"HiГҹв•—Г§n/Гҹв•‘вҢҗn mГҹв•‘ВЎt khГҹв•‘вҢҗu\"\r\n            >\r\n              {show.currentPassword ? <EyeOff size={18} /> : <Eye size={18} />}\r\n            </button>\r\n          </div>\r\n          {errors.currentPassword && (\r\n            <span className=\"text-xs text-destructive font-medium mt-0.5\">{errors.currentPassword}</span>\r\n          )}\r\n        </div>\r\n\r\n        {/* MГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi */}\r\n        <div className=\"flex flex-col gap-1.5\">\r\n          <label htmlFor=\"newPassword\" className=\"text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-2\">\r\n            <Lock size={14} />\r\n            MГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi <span className=\"text-primary\">*</span>\r\n          </label>\r\n          <div className=\"relative\">\r\n            <input\r\n              type={show.newPassword ? 'text' : 'password'}\r\n              id=\"newPassword\"\r\n              name=\"newPassword\"\r\n              value={form.newPassword}\r\n              onChange={handleChange}\r\n              placeholder=\"TГҹв•—ГҰi thiГҹв•—Гўu 8 kв”ңв•ң tГҹв•—в–’\"\r\n              disabled={loading}\r\n              autoComplete=\"new-password\"\r\n              className={`flex h-11 w-full rounded-xl border bg-[#20242D] pl-4 pr-11 py-2 text-sm text-white placeholder-muted-foreground/60 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary disabled:cursor-not-allowed disabled:opacity-50 transition-all ${\r\n                errors.newPassword ? 'border-destructive' : 'border-border'\r\n              }`}\r\n            />\r\n            <button\r\n              type=\"button\"\r\n              className=\"absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-white transition-colors cursor-pointer outline-none\"\r\n              onClick={() => toggleShow('newPassword')}\r\n              aria-label=\"HiГҹв•—Г§n/Гҹв•‘вҢҗn mГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi\"\r\n            >\r\n              {show.newPassword ? <EyeOff size={18} /> : <Eye size={18} />}\r\n            </button>\r\n          </div>\r\n          {errors.newPassword && (\r\n            <span className=\"text-xs text-destructive font-medium mt-0.5\">{errors.newPassword}</span>\r\n          )}\r\n          {!errors.newPassword && form.newPassword.length > 0 && (\r\n            <span className=\"text-[10px] text-muted-foreground/50 mt-0.5\">\r\n              в”ҖГүГҹв•—Г– mГҹв•‘Гӯnh: {form.newPassword.length < 8 ? 'О“ГңГЎвҲ©в••Г… Quв”ңГӯ ngГҹв•‘В»n' : form.newPassword.length < 12 ? 'вүЎЖ’Ж’Гӯ Trung bв”ңВјnh' : 'О“ВЈГ  TГҹв•—ГҰt'}\r\n            </span>\r\n          )}\r\n        </div>\r\n\r\n        {/* Xв”ңГӯc nhГҹв•‘ВЎn mГҹв•‘ВЎt khГҹв•‘вҢҗu */}\r\n        <div className=\"flex flex-col gap-1.5\">\r\n          <label htmlFor=\"confirmPassword\" className=\"text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-2\">\r\n            <Lock size={14} />\r\n            Xв”ңГӯc nhГҹв•‘ВЎn mГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi <span className=\"text-primary\">*</span>\r\n          </label>\r\n          <div className=\"relative\">\r\n            <input\r\n              type={show.confirmPassword ? 'text' : 'password'}\r\n              id=\"confirmPassword\"\r\n              name=\"confirmPassword\"\r\n              value={form.confirmPassword}\r\n              onChange={handleChange}\r\n              placeholder=\"NhГҹв•‘ВЎp lГҹв•‘Гӯi mГҹв•‘ВЎt khГҹв•‘вҢҗu mГҹв•—Вўi\"\r\n              disabled={loading}\r\n              autoComplete=\"new-password\"\r\n              className={`flex h-11 w-full rounded-xl border bg-[#20242D] pl-4 pr-11 py-2 text-sm text-white placeholder-muted-foreground/60 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary disabled:cursor-not-allowed disabled:opacity-50 transition-all ${\r\n                errors.confirmPassword ? 'border-destructive' : 'border-border'\r\n              }`}\r\n            />\r\n            <button\r\n              type=\"button\"\r\n              className=\"absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-white transition-colors cursor-pointer outline-none\"\r\n              onClick={() => toggleShow('confirmPassword')}\r\n              aria-label=\"HiГҹв•—Г§n/Гҹв•‘вҢҗn xв”ңГӯc nhГҹв•‘ВЎn mГҹв•‘ВЎt khГҹв•‘вҢҗu\"\r\n            >\r\n              {show.confirmPassword ? <EyeOff size={18} /> : <Eye size={18} />}\r\n            </button>\r\n          </div>\r\n          {errors.confirmPassword && (\r\n            <span className=\"text-xs text-destructive font-medium mt-0.5\">{errors.confirmPassword}</span>\r\n          )}\r\n          {!errors.confirmPassword &&\r\n            form.confirmPassword.length > 0 &&\r\n            form.newPassword === form.confirmPassword && (\r\n              <span className=\"text-[10px] text-emerald-400 font-medium mt-0.5\">\r\n                О“ВЈГ  MГҹв•‘ВЎt khГҹв•‘вҢҗu trв”ңв•Јng khГҹв•—Вўp\r\n              </span>\r\n            )}\r\n        </div>\r\n\r\n        <div className=\"border-t border-border/40 pt-4 flex mt-2\">\r\n          <button\r\n            type=\"submit\"\r\n            id=\"btn-change-password\"\r\n            className=\"h-11 px-6 rounded-xl bg-primary text-[#0F1115] font-bold text-sm hover:bg-primary/95 transition-all flex items-center justify-center gap-2 cursor-pointer\"\r\n            disabled={loading}\r\n          >\r\n            <Lock size={16} />\r\n            <span>{loading ? 'в”ҖГүang xГҹв•—ВЎ lв”ңв•ң...' : 'в”ҖГүГҹв•—ГІi mГҹв•‘ВЎt khГҹв•‘вҢҗu'}</span>\r\n          </button>\r\n        </div>\r\n      </form>\r\n    </div>\r\n  );\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Tab: LГҹв•—ГҜch sГҹв•—ВЎ в”ҖГҰГҹв•‘в•–t bв”ңГЎn (placeholder)\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nfunction TabBookings() {\r\n  return (\r\n    <div className=\"p-6 md:p-8 bg-card border border-border rounded-2xl shadow-lg flex flex-col gap-6 w-full\">\r\n      <div className=\"border-b border-border/40 pb-4\">\r\n        <h2 className=\"font-serif text-xl text-white font-bold\">LГҹв•—ГҜch sГҹв•—ВЎ в”ҖГҰГҹв•‘в•–t bв”ңГЎn</h2>\r\n        <p className=\"text-xs text-muted-foreground mt-1\">Danh sв”ңГӯch cв”ңГӯc lГҹв•‘Вәn в”ҖГҰГҹв•‘в•–t bв”ңГЎn cГҹв•—Вәa bГҹв•‘Гӯn tГҹв•‘Гӯi BookEat.</p>\r\n      </div>\r\n      <div className=\"flex flex-col items-center justify-center py-12 px-4 border border-dashed border-border/40 bg-card/10 rounded-2xl text-center\">\r\n        <div className=\"h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center mb-4 border border-primary/20 text-primary\">\r\n          <Calendar size={28} />\r\n        </div>\r\n        <p className=\"text-base font-bold text-white mb-2\">Chв•һв–‘a cв”ңв”Ӯ lГҹв•—ГҜch sГҹв•—ВЎ в”ҖГҰГҹв•‘в•–t bв”ңГЎn</p>\r\n        <p className=\"text-xs text-muted-foreground max-w-xs leading-relaxed mb-5\">\r\n          BГҹв•‘Гӯn chв•һв–‘a в”ҖГҰГҹв•‘в•–t bв”ңГЎn tГҹв•‘Гӯi nhв”ңГЎ hв”ңГЎng nв”ңГЎo trв”ңВ¬n hГҹв•—Г§ thГҹв•—ГҰng. Hв”ңГәy khв”ңГӯm phв”ңГӯ cв”ңГӯc в”ҖГҰГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm в”ҖГўn uГҹв•—ГҰng tuyГҹв•—Г§t vГҹв•—ВҘi ngay hв”ңв”Өm nay!\r\n        </p>\r\n        <Link\r\n          to=\"/restaurants\"\r\n          id=\"btn-explore-restaurants\"\r\n          className=\"h-11 px-6 rounded-xl bg-primary text-[#0F1115] font-bold text-sm hover:bg-primary/95 transition-all flex items-center justify-center gap-2 cursor-pointer\"\r\n        >\r\n          <span>Khв”ңГӯm phв”ңГӯ nhв”ңГЎ hв”ңГЎng</span>\r\n          <ChevronRight size={16} />\r\n        </Link>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n// Main ProfilePage\r\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n\r\nconst TABS = [\r\n  { id: 'info',     label: 'Thв”ңв”Өng tin',    icon: User },\r\n  { id: 'password', label: 'MГҹв•‘ВЎt khГҹв•‘вҢҗu',     icon: Lock },\r\n  { id: 'bookings', label: 'в”ҖГүГҹв•‘в•–t bв”ңГЎn',      icon: Calendar },\r\n];\r\n\r\nexport default function ProfilePage() {\r\n  const { user: authUser, loading: authLoading, updateUser } = useAuth();\r\n  const [profileUser, setProfileUser] = useState(null);\r\n  const [pageLoading, setPageLoading] = useState(true);\r\n  const [pageError, setPageError] = useState('');\r\n  const [activeTab, setActiveTab] = useState('info');\r\n\r\n  useEffect(() => {\r\n    document.title = 'Tв”ңГЎi khoГҹв•‘Гәn cГҹв•—Вәa tв”ңв”Өi О“ГҮГ¶ BookEat';\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    if (authLoading) return;\r\n\r\n    const fetchProfile = async () => {\r\n      try {\r\n        const data = await profileApi.getMyProfile();\r\n        setProfileUser(data);\r\n      } catch (err) {\r\n        setPageError(err?.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi thв”ңв”Өng tin tв”ңГЎi khoГҹв•‘Гәn');\r\n      } finally {\r\n        setPageLoading