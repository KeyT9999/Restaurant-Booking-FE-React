bg-primary text-[#0F1115] font-bold text-sm hover:bg-primary/95 transition-all flex items-center justify-center cursor-pointer\"\r\n            >\r\n              в”ҖГүв”ҖГўng nhГҹв•‘ВЎp lГҹв•‘Гӯi\r\n            </Link>\r\n          </div>\r\n        </main>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const user = profileUser || authUser;\r\n  const isGoogleUser = Boolean(user?.googleId || (!user?.phoneNumber && user?.emailVerified && !user?.username?.startsWith('@')));\r\n\r\n  const avatarLetter = (user?.fullName || user?.username || '?')[0].toUpperCase();\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n\r\n      <main className=\"flex-1 w-full max-w-5xl mx-auto px-4 py-8 md:py-12 flex flex-col gap-6\" id=\"profile-main\">\r\n        {/* О“Г¶ГҮО“Г¶ГҮ Page Header О“Г¶ГҮО“Г¶ГҮ */}\r\n        <div className=\"border-b border-border/40 pb-6\">\r\n          <nav className=\"flex items-center gap-2 text-xs text-muted-foreground mb-3\" aria-label=\"Breadcrumb\">\r\n            <Link to=\"/\" className=\"text-primary hover:underline transition-all\">Trang chГҹв•—Вә</Link>\r\n            <ChevronRight size={10} />\r\n            <span>Tв”ңГЎi khoГҹв•‘Гәn</span>\r\n          </nav>\r\n          <h1 className=\"font-serif text-3xl md:text-4xl text-white font-bold tracking-tight\">Tв”ңГЎi khoГҹв•‘Гәn cГҹв•—Вәa tв”ңв”Өi</h1>\r\n          <p className=\"text-xs md:text-sm text-muted-foreground mt-1\">QuГҹв•‘Гәn lв”ңв•ң thв”ңв”Өng tin cв”ңГӯ nhв”ңГіn vв”ңГЎ bГҹв•‘Гәo mГҹв•‘ВЎt tв”ңГЎi khoГҹв•‘Гәn</p>\r\n        </div>\r\n\r\n        {/* О“Г¶ГҮО“Г¶ГҮ Layout О“Г¶ГҮО“Г¶ГҮ */}\r\n        <div className=\"grid grid-cols-1 md:grid-cols-[260px_1fr] gap-8 mt-2 items-start\">\r\n          {/* О“Г¶ГҮО“Г¶ГҮ Sidebar О“Г¶ГҮО“Г¶ГҮ */}\r\n          <aside className=\"flex flex-col gap-6 md:sticky md:top-24\">\r\n            {/* Avatar card */}\r\n            <div className=\"flex flex-col items-center gap-4 p-6 bg-card border border-border rounded-2xl text-center shadow-lg\">\r\n              <div className=\"relative w-24 h-24\">\r\n                {user?.avatarUrl ? (\r\n                  <img\r\n                    src={user.avatarUrl}\r\n                    alt={user.fullName}\r\n                    className=\"w-24 h-24 rounded-full object-cover border-2 border-primary/40 shadow-inner\"\r\n                  />\r\n                ) : (\r\n                  <div className=\"w-24 h-24 rounded-full border-2 border-primary/40 flex items-center justify-center bg-primary/10 text-primary font-serif text-3xl font-bold shadow-md\" aria-label=\"Avatar\">\r\n                    {avatarLetter}\r\n                  </div>\r\n                )}\r\n              </div>\r\n\r\n              <div>\r\n                <h2 className=\"font-serif text-lg font-bold text-white tracking-tight leading-tight\">{user?.fullName || 'Ngв•һв–‘Гҹв•—ВҘi dв”ңв•Јng'}</h2>\r\n                {user?.username && (\r\n                  <p className=\"text-xs text-muted-foreground mt-1\">@{user.username}</p>\r\n                )}\r\n              </div>\r\n\r\n              {/* Badges */}\r\n              <div className=\"flex flex-wrap gap-2 justify-center mt-1\">\r\n                <span className={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${\r\n                  user?.emailVerified \r\n                    ? 'bg-emerald-500/10 border border-emerald-500/20 text-emerald-400' \r\n                    : 'bg-destructive/10 border border-destructive/20 text-destructive'\r\n                }`}>\r\n                  {user?.emailVerified ? 'О“ВЈГҙ в”ҖГүв”ңГә xв”ңГӯc minh' : 'О“ГңГЎ Chв•һв–‘a xв”ңГӯc minh'}\r\n                </span>\r\n                {user?.role && (\r\n                  <span className=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-primary/10 border border-primary/20 text-primary\">\r\n                    {ROLE_LABELS[user.role] || user.role}\r\n                  </span>\r\n                )}\r\n              </div>\r\n            </div>\r\n\r\n            {/* Tab nav */}\r\n            <nav className=\"flex flex-row md:flex-col border border-border bg-card/60 rounded-2xl overflow-hidden shadow-md\" aria-label=\"Profile sections\">\r\n              {TABS.map((tab) => {\r\n                const Icon = tab.icon;\r\n                const isActive = activeTab === tab.id;\r\n                return (\r\n                  <button\r\n                    key={tab.id}\r\n                    type=\"button\"\r\n                    id={`tab-${tab.id}`}\r\n                    className={`flex-1 md:flex-none flex items-center justify-center md:justify-start gap-3 px-5 py-4 text-sm font-medium transition-all cursor-pointer border-b-2 md:border-b-0 md:border-l-2 active:outline-none ${\r\n                      isActive \r\n                        ? 'bg-primary/5 text-primary border-primary font-semibold' \r\n                        : 'text-muted-foreground hover:bg-[#20242D]/45 hover:text-white border-transparent'\r\n                    }`}\r\n                    onClick={() => setActiveTab(tab.id)}\r\n                    aria-current={activeTab === tab.id ? 'page' : undefined}\r\n                  >\r\n                    <Icon size={16} className=\"shrink-0\" />\r\n                    <span className=\"hidden sm:inline md:inline\">{tab.label}</span>\r\n                  </button>\r\n                );\r\n              })}\r\n            </nav>\r\n          </aside>\r\n\r\n          {/* О“Г¶ГҮО“Г¶ГҮ Content О“Г¶ГҮО“Г¶ГҮ */}\r\n          <section className=\"w-full\" aria-label={TABS.find((t) => t.id === activeTab)?.label}>\r\n            {activeTab === 'info' && (\r\n              <TabInfo user={user} onUserUpdated={handleUserUpdated} />\r\n            )}\r\n            {activeTab === 'password' && (\r\n              <TabPassword isGoogleUser={isGoogleUser} />\r\n            )}\r\n            {activeTab === 'bookings' && (\r\n              <TabBookings />\r\n            )}\r\n          </section>\r\n        </div>\r\n      </main>\r\n\r\n      {/* Footer */}\r\n      <footer className=\"w-full py-6 px-4 md:px-12 border-t border-border/40 bg-card/20 mt-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted-foreground\">\r\n        <span className=\"font-serif font-bold text-white tracking-wide\">BookEat</span>\r\n        <span>в”¬вҢҗ 2026 BookEat. MГҹв•—Г¬i quyГҹв•—Гјn в”ҖГҰв•һв–‘Гҹв•—Гәc bГҹв•‘Гәo lв•һв–‘u.</span>\r\n      </footer>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\profile\\SavedVouchers.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  26 |\n  27 |   useEffect(() => {\n> 28 |     loadSavedVouchers();\n     |     ^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  29 |   }, [loadSavedVouchers]);\n  30 |\n  31 |   const tabs = [","line":28,"column":5,"endLine":28,"endColumn":22}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useCallback } from 'react';\r\nimport { getMyVouchers } from '../../api/voucherApi';\r\nimport VoucherCard from '../../components/voucher/VoucherCard';\r\nimport { Ticket, Loader2, AlertCircle } from 'lucide-react';\r\n\r\nexport default function SavedVouchers() {\r\n  const [vouchers, setVouchers] = useState([]);\r\n  const [loading, setLoading] = useState(false);\r\n  const [error, setError] = useState(null);\r\n  const [activeTab, setActiveTab] = useState('unused'); // unused, used, expired\r\n\r\n  const loadSavedVouchers = useCallback(async () => {\r\n    setLoading(true);\r\n    setError(null);\r\n    try {\r\n      const res = await getMyVouchers({ filter: activeTab });\r\n      if (res.data?.success) {\r\n        setVouchers(res.data.data);\r\n      }\r\n    } catch (err) {\r\n      setError(err.response?.data?.message || err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi vв”ңВЎ voucher cГҹв•—Вәa bГҹв•‘Гӯn');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [activeTab]);\r\n\r\n  useEffect(() => {\r\n    loadSavedVouchers();\r\n  }, [loadSavedVouchers]);\r\n\r\n  const tabs = [\r\n    { key: 'unused', label: 'Chв•һв–‘a sГҹв•—ВЎ dГҹв•—Г‘ng' },\r\n    { key: 'used', label: 'в”ҖГүв”ңГә sГҹв•—ВЎ dГҹв•—Г‘ng' },\r\n    { key: 'expired', label: 'HГҹв•‘в”җt hГҹв•‘Гӯn' },\r\n  ];\r\n\r\n  return (\r\n    <div className=\"min-h-[80vh] py-16 bg-background\">\r\n      <div className=\"max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8\">\r\n        {/* Header Section */}\r\n        <div className=\"mb-10\">\r\n          <span className=\"font-sans text-xs font-semibold tracking-widest text-primary uppercase block mb-2\">\r\n            в•һВ»u в”ҖГҰв”ңГәi cв”ңГӯ nhв”ңГіn\r\n          </span>\r\n          <h2 className=\"font-serif text-3xl sm:text-4xl lg:text-5xl text-white font-bold tracking-tight mb-3\">\r\n            Vв”ңВЎ Voucher CГҹв•—Вәa Tв”ңв”Өi\r\n          </h2>\r\n          <p className=\"font-sans text-sm sm:text-base text-muted-foreground max-w-2xl leading-relaxed\">\r\n            Lв•һв–‘u trГҹв•—В» vв”ңГЎ theo dв”ңв•Ўi cв”ңГӯc mв”ңГә giГҹв•‘Гәm giв”ңГӯ в”ҖГҰГҹв•‘в•–t bв”ңГЎn bГҹв•‘Гӯn в”ҖГҰв”ңГә thu thГҹв•‘ВЎp tГҹв•—ВҪ cв”ңГӯc nhв”ңГЎ hв”ңГЎng в”ҖГҰГҹв•—Гў nhГҹв•‘ВЎn в•һв–‘u в”ҖГҰв”ңГәi в”ҖГҰГҹв•‘в•–c quyГҹв•—Гјn khi в”ҖГўn uГҹв•—ГҰng.\r\n          </p>\r\n        </div>\r\n\r\n        {/* Tabs Filter */}\r\n        <div className=\"flex gap-6 border-b border-border/40 mb-8 pb-px\">\r\n          {tabs.map(tab => {\r\n            const isActive = activeTab === tab.key;\r\n            return (\r\n              <button\r\n                key={tab.key}\r\n                className={`pb-3 text-sm font-medium transition-all relative cursor-pointer outline-none ${\r\n                  isActive ? 'text-primary' : 'text-muted-foreground hover:text-white'\r\n                }`}\r\n                onClick={() => setActiveTab(tab.key)}\r\n              >\r\n                {tab.label}\r\n                {isActive && (\r\n                  <span className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-primary rounded-full\" />\r\n                )}\r\n              </button>\r\n            );\r\n          })}\r\n        </div>\r\n\r\n        {/* Content Area */}\r\n        {loading ? (\r\n          <div className=\"flex flex-col items-center justify-center py-20 text-muted-foreground gap-3\">\r\n            <Loader2 className=\"h-8 w-8 animate-spin text-primary\" />\r\n            <p className=\"text-sm font-medium\">в”ҖГүang mГҹв•—Ж’ vв”ңВЎ voucher...</p>\r\n          </div>\r\n        ) : error ? (\r\n          <div className=\"flex items-center gap-3 p-4 rounded-xl border border-destructive/20 bg-destructive/10 text-destructive text-sm max-w-2xl mx-auto justify-center\">\r\n            <AlertCircle className=\"h-5 w-5 shrink-0\" />\r\n            <span>{error}</span>\r\n          </div>\r\n        ) : vouchers.length === 0 ? (\r\n          <div className=\"flex flex-col items-center justify-center py-16 px-4 border border-dashed border-border/40 bg-card/10 rounded-2xl max-w-xl mx-auto text-center\">\r\n            <div className=\"h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center mb-5 border border-primary/20\">\r\n              <Ticket className=\"h-8 w-8 text-primary\" />\r\n            </div>\r\n            <h3 className=\"text-lg font-semibold text-white mb-2\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y voucher</h3>\r\n            <p className=\"text-sm text-muted-foreground max-w-sm\">\r\n              {activeTab === 'unused'\r\n                ? 'Vв”ңВЎ cГҹв•—Вәa bГҹв•‘Гӯn hiГҹв•—Г§n tГҹв•‘Гӯi chв•һв–‘a cв”ңв”Ӯ voucher nв”ңГЎo khГҹв•‘Гә dГҹв•—Г‘ng.'\r\n                : 'Khв”ңв”Өng cв”ңв”Ӯ voucher nв”ңГЎo trong mГҹв•—Г‘c nв”ңГЎy.'}\r\n            </p>\r\n            {activeTab === 'unused' && (\r\n              <p className=\"text-xs text-muted-foreground/60 mt-3 max-w-xs leading-relaxed\">\r\n                Hв”ңГәy ghв”ңвҢҗ thв”ҖГўm trang chi tiГҹв•‘в”җt cГҹв•—Вәa cв”ңГӯc nhв”ңГЎ hв”ңГЎng в”ҖГҰГҹв•—Гў thu thГҹв•‘ВЎp thв”ңВ¬m nhiГҹв•—Гјu в•һв–‘u в”ҖГҰв”ңГәi hГҹв•‘Г‘p dГҹв•‘ВҪn nhв”ңвҢҗ!\r\n              </p>\r\n            )}\r\n          </div>\r\n        ) : (\r\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\r\n            {vouchers.map(item => (\r\n              <VoucherCard\r\n                key={item._id}\r\n                voucher={item.voucherId}\r\n                disabled={activeTab !== 'unused'}\r\n                isSaved={activeTab === 'unused'}\r\n              />\r\n            ))}\r\n          </div>\r\n        )}\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\restaurants\\RestaurantDetailPage.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'_reviewsTotal' is assigned a value but never used.","line":60,"column":10,"messageId":"unusedVar","endLine":60,"endColumn":23,"suggestions":[{"messageId":"removeVar","data":{"varName":"_reviewsTotal"},"fix":{"range":[2223,2236],"text":""},"desc":"Remove unused variable '_reviewsTotal'."}]},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n   99 |   useEffect(() => {\n  100 |     if (activeTab === 'reviews') {\n> 101 |       fetchReviews();\n      |       ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  102 |     }\n  103 |   }, [activeTab, fetchReviews]);\n  104 |","line":101,"column":7,"endLine":101,"endColumn":19},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  104 |\n  105 |   useEffect(() => {\n> 106 |     setReviewsPage(1);\n      |     ^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  107 |   }, [selectedRatingFilter]);\n  108 |\n  109 |   const handleSaveVoucher = async (voucher) => {","line":106,"column":5,"endLine":106,"endColumn":19},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  158 |\n  159 |   useEffect(() => {\n> 160 |     fetchRestaurantData();\n      |     ^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  161 |     fetchVouchers();\n  162 |   }, [fetchRestaurantData, fetchVouchers]);\n  163 |","line":160,"column":5,"endLine":160,"endColumn":24}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState, useCallback } from 'react';\r\nimport { useParams, useNavigate, Link } from 'react-router-dom';\r\nimport {\r\n  Utensils,\r\n  Armchair,\r\n  MapPin,\r\n  Phone,\r\n  Globe,\r\n  Star,\r\n  DollarSign,\r\n  Clock,\r\n  Search,\r\n  MessageCircle,\r\n  CalendarDays,\r\n  ArrowLeft,\n  Check,\r\n  ChevronRight,\r\n  ShieldAlert,\r\n  Info,\r\n  X\r\n} from 'lucide-react';\r\nimport Header from '../../components/Header';\r\nimport { getPublicRestaurantDetail } from '../../api/restaurantApi';\r\nimport * as menuApi from '../../api/menuApi';\r\nimport * as tableApi from '../../api/tableApi';\r\nimport { useAuth } from '../../context/useAuth';\r\nimport { useChatWidget } from '../../context/useChatWidget';\r\nimport toast from 'react-hot-toast';\r\nimport { getRestaurantVouchers, saveVoucher } from '../../api/voucherApi';\r\nimport VoucherCard from '../../components/voucher/VoucherCard';\r\nimport { Button } from '../../components/ui/button';\r\nimport { Card } from '../../components/ui/card';\r\nimport { Badge } from '../../components/ui/badge';\r\nimport { Input } from '../../components/ui/input';\r\nimport { Tabs, TabsList, TabsTrigger, TabsContent } from '../../components/ui/tabs';\r\nimport { getRestaurantReviews } from '../../api/reviewApi';\r\nimport { RatingStars } from '../../components/ui/RatingStars';\r\n\r\nexport default function RestaurantDetailPage() {\r\n  const { id } = useParams();\r\n  const navigate = useNavigate();\r\n  const { isAuthenticated, user } = useAuth();\r\n  const { openCustomerRestaurantChat } = useChatWidget();\r\n\r\n  const [restaurant, setRestaurant] = useState(null);\r\n  const [menuItems, setMenuItems] = useState([]);\r\n  const [categories, setCategories] = useState([]);\r\n  const [tables, setTables] = useState([]);\r\n  const [vouchers, setVouchers] = useState([]);\r\n\r\n  const [loading, setLoading] = useState(true);\r\n  const [activeTab, setActiveTab] = useState('menu'); // 'menu' | 'tables' | 'info'\r\n  const [searchQuery, setSearchQuery] = useState('');\r\n  const [selectedCategory, setSelectedCategory] = useState('');\r\n\r\n  // Review states\r\n  const [reviews, setReviews] = useState([]);\r\n  const [reviewsPage, setReviewsPage] = useState(1);\r\n  const [reviewsTotalPages, setReviewsTotalPages] = useState(1);\r\n  const [_reviewsTotal, setReviewsTotal] = useState(0);\r\n  const [selectedRatingFilter, setSelectedRatingFilter] = useState('');\r\n  const [reviewsLoading, setReviewsLoading] = useState(false);\r\n  const [activeLightboxImage, setActiveLightboxImage] = useState(null);\r\n\r\n  const fetchVouchers = useCallback(async () => {\r\n    try {\r\n      const res = await getRestaurantVouchers(id);\r\n      if (res.data?.success) {\r\n        setVouchers(res.data.data);\r\n      }\r\n    } catch (e) {\r\n      console.warn('LГҹв•—Г№i tГҹв•‘Гәi voucher nhв”ңГЎ hв”ңГЎng:', e.message);\r\n    }\r\n  }, [id]);\r\n\r\n  const fetchReviews = useCallback(async () => {\r\n    setReviewsLoading(true);\r\n    try {\r\n      const params = {\r\n        page: reviewsPage,\r\n        limit: 5,\r\n      };\r\n      if (selectedRatingFilter) {\r\n        params.rating = selectedRatingFilter;\r\n      }\r\n      const res = await getRestaurantReviews(id, params);\r\n      if (res.data?.success) {\r\n        setReviews(res.data.data || []);\r\n        setReviewsTotalPages(res.data.pagination?.totalPages || 1);\r\n        setReviewsTotal(res.data.pagination?.total || 0);\r\n      }\r\n    } catch (e) {\r\n      console.warn('LГҹв•—Г№i tГҹв•‘Гәi в”ҖГҰв”ңГӯnh giв”ңГӯ nhв”ңГЎ hв”ңГЎng:', e.message);\r\n    } finally {\r\n      setReviewsLoading(false);\r\n    }\r\n  }, [id, reviewsPage, selectedRatingFilter]);\r\n\r\n  useEffect(() => {\r\n    if (activeTab === 'reviews') {\r\n      fetchReviews();\r\n    }\r\n  }, [activeTab, fetchReviews]);\r\n\r\n  useEffect(() => {\r\n    setReviewsPage(1);\r\n  }, [selectedRatingFilter]);\r\n\r\n  const handleSaveVoucher = async (voucher) => {\r\n    if (!isAuthenticated) {\r\n      toast.error('Vui lв”ңв–“ng в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp в”ҖГҰГҹв•—Гў lв•һв–‘u voucher');\r\n      navigate(`/auth/login?redirect=${encodeURIComponent(window.location.pathname)}`);\r\n      return;\r\n    }\r\n    try {\r\n      const res = await saveVoucher({ voucherId: voucher._id });\r\n      if (res.data?.success) {\r\n        toast.success(`в”ҖГүв”ңГә lв•һв–‘u mв”ңГә ${voucher.code} vв”ңГЎo vв”ңВЎ thв”ңГЎnh cв”ңв”Өng!`);\r\n        setVouchers(prev => prev.map(v => v._id === voucher._id ? { ...v, isSaved: true } : v));\r\n      }\r\n    } catch (err) {\r\n      toast.error(err.response?.data?.message || 'Khв”ңв”Өng thГҹв•—Гў lв•һв–‘u voucher');\r\n    }\r\n  };\r\n\r\n  const fetchRestaurantData = useCallback(async () => {\r\n    setLoading(true);\r\n    try {\r\n      const [detailRes, menuRes, tableRes] = await Promise.all([\r\n        getPublicRestaurantDetail(id),\r\n        menuApi.getPublicMenu(id),\r\n        tableApi.getPublicTables(id)\r\n      ]);\r\n\r\n      if (detailRes?.success) {\r\n        setRestaurant(detailRes.data);\r\n      } else {\r\n        throw new Error('Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi thв”ңв”Өng tin chi tiГҹв•‘в”җt nhв”ңГЎ hв”ңГЎng');\r\n      }\r\n\r\n      if (menuRes?.success) {\r\n        setMenuItems(menuRes.data?.items || []);\r\n        setCategories(menuRes.data?.categories || []);\r\n      }\r\n\r\n      if (tableRes?.success) {\r\n        setTables(tableRes.data?.tables || []);\r\n      }\r\n\r\n    } catch (err) {\r\n      console.error(err);\r\n      toast.error(err.message || 'LГҹв•—Г№i tГҹв•‘Гәi dГҹв•—В» liГҹв•—Г§u nhв”ңГЎ hв”ңГЎng');\r\n      navigate('/restaurants');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [id, navigate]);\r\n\r\n  useEffect(() => {\r\n    fetchRestaurantData();\r\n    fetchVouchers();\r\n  }, [fetchRestaurantData, fetchVouchers]);\r\n\r\n  const handleChatRestaurant = async () => {\r\n    if (!isAuthenticated) {\r\n      toast.error('Vui lв”ңв–“ng в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp в”ҖГҰГҹв•—Гў chat vГҹв•—Вўi nhв”ңГЎ hв”ңГЎng');\r\n      navigate(`/auth/login?redirect=${encodeURIComponent(window.location.pathname)}`);\r\n      return;\r\n    }\r\n\r\n    if (user?.role !== 'customer') {\r\n      toast.error('ChГҹв•—Г« tв”ңГЎi khoГҹв•‘Гәn khв”ңГӯch hв”ңГЎng mГҹв•—Вўi cв”ңв”Ӯ thГҹв•—Гў chat vГҹв•—Вўi nhв”ңГЎ hв”ңГЎng');\r\n      return;\r\n    }\r\n\r\n    try {\r\n      await openCustomerRestaurantChat(id);\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў mГҹв•—Ж’ chat vГҹв•—Вўi nhв”ңГЎ hв”ңГЎng');\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n        <Header />\r\n        <div className=\"flex-1 flex flex-col items-center justify-center gap-3\">\r\n          <div className=\"h-10 w-10 border-4 border-primary border-t-transparent rounded-full animate-spin\" />\r\n          <p className=\"text-sm text-muted-foreground animate-pulse\">в”ҖГүang tГҹв•‘Гәi thв”ңв”Өng tin chi tiГҹв•‘в”җt nhв”ңГЎ hв”ңГЎng...</p>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (!restaurant) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n        <Header />\r\n        <div className=\"flex-1 flex flex-col items-center justify-center p-6 gap-4\">\r\n          <ShieldAlert className=\"h-12 w-12 text-rose-500\" />\r\n          <p className=\"text-muted-foreground text-sm\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y thв”ңв”Өng tin chi tiГҹв•‘в”җt cГҹв•—Вәa nhв”ңГЎ hв”ңГЎng nв”ңГЎy.</p>\r\n          <Button onClick={() => navigate('/restaurants')} className=\"bg-primary hover:bg-primary/95 text-background font-semibold\">\r\n            <ArrowLeft className=\"h-4 w-4 mr-2\" /> Quay lГҹв•‘Гӯi danh sв”ңГӯch\r\n          </Button>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const filteredMenuItems = menuItems.filter(item => {\r\n    const matchesSearch = item.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\r\n                          (item.description && item.description.toLowerCase().includes(searchQuery.toLowerCase()));\r\n    const matchesCategory = !selectedCategory || item.categoryId === selectedCategory;\r\n    return matchesSearch && matchesCategory;\r\n  });\r\n\r\n  const formatPrice = (price) => {\r\n    return new Intl.NumberFormat('vi-VN').format(price) + 'О“Г©ВҪ';\r\n  };\r\n\r\n  const getPriceRangeText = (range) => {\r\n    if (range === 'low') return 'TiГҹв•‘в”җt kiГҹв•—Г§m (Dв•һв–‘Гҹв•—Вўi 200k)';\r\n    if (range === 'medium') return 'TГҹв•‘Вәm trung (200k - 500k)';\r\n    if (range === 'high') return 'Cao cГҹв•‘Г‘p (Trв”ңВ¬n 500k)';\r\n    return 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt';\r\n  };\r\n\r\n  const formatAddress = (address) => {\r\n    if (!address) return 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt';\r\n    if (typeof address === 'string') return address;\r\n    return address.fullAddress || [address.street, address.ward, address.district, address.city].filter(Boolean).join(', ') || 'Chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt';\r\n  };\r\n\r\n  const tableStats = {\r\n    total: tables.length,\r\n    available: tables.filter(t => t.status === 'available').length,\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n\r\n      {/* Banner Area */}\r\n      <section className=\"relative h-80 sm:h-[400px] bg-secondary overflow-hidden\">\r\n        <div className=\"absolute inset-0 bg-gradient-to-t from-background via-background/40 to-black/35 z-10\" />\r\n        {restaurant.coverImageUrl ? (\r\n          <img className=\"w-full h-full object-cover\" src={restaurant.coverImageUrl} alt={restaurant.name} />\r\n        ) : (\r\n          <div className=\"w-full h-full flex items-center justify-center text-6xl\">вүЎЖ’Г¬в•ңвҲ©в••Г…</div>\r\n        )}\r\n\r\n        <div className=\"absolute inset-x-0 bottom-0 z-20 mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 pb-8 flex flex-col justify-end h-full\">\r\n          {/* Breadcrumbs */}\r\n          <div className=\"flex items-center gap-1.5 text-xs text-muted-foreground mb-4\">\r\n            <Link to=\"/\" className=\"hover:text-white transition\">Trang chГҹв•—Вә</Link>\r\n            <ChevronRight size={12} />\r\n            <Link to=\"/restaurants\" className=\"hover:text-white transition\">Nhв”ңГЎ hв”ңГЎng</Link>\r\n            <ChevronRight size={12} />\r\n            <span className=\"text-white truncate max-w-[200px]\">{restaurant.name}</span>\r\n          </div>\r\n\r\n          {/* Title and details block */}\r\n          <div className=\"flex items-end gap-5\">\r\n            {restaurant.logo && (\r\n              <img className=\"h-20 w-20 sm:h-24 sm:w-24 rounded-xl object-cover bg-card border border-border/80 shadow-2xl flex-shrink-0\" src={restaurant.logo} alt=\"Logo\" />\r\n            )}\r\n            <div className=\"min-w-0\">\r\n              <h1 className=\"text-2xl sm:text-4xl font-extrabold text-white tracking-tight\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\r\n                {restaurant.name}\r\n              </h1>\r\n              <div className=\"flex flex-wrap gap-2 mt-3.5 items-center\">\r\n                {restaurant.cuisineType && (\r\n                  <Badge className=\"bg-primary text-background border-none font-semibold\">\r\n                    {restaurant.cuisineType}\r\n                  </Badge>\r\n                )}\r\n                {restaurant.featured && (\r\n                  <Badge className=\"bg-amber-500/10 text-amber-400 border border-amber-500/20 font-bold uppercase tracking-wider text-[10px]\">\r\n                    О“ГҝГ  NГҹв•—Г¶I BГҹв•‘ВјT\r\n                  </Badge>\r\n                )}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* Main Page Layout */}\r\n      <div className=\"mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 py-10 w-full flex-1\">\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8 items-start\">\r\n\r\n          {/* Left Block: Infos, vouchers, tabs */}\r\n          <div className=\"lg:col-span-2 flex flex-col gap-8\">\r\n\r\n            {/* Quick Info Grid */}\r\n            <Card className=\"p-5 bg-card border-border grid grid-cols-1 sm:grid-cols-3 gap-6\">\r\n              <div className=\"flex gap-3\">\r\n                <MapPin className=\"h-5 w-5 text-primary flex-shrink-0 mt-0.5\" />\r\n                <div className=\"min-w-0\">\r\n                  <span className=\"block text-[10px] text-muted-foreground uppercase font-semibold\">в”ҖГүГҹв•—ГҜa chГҹв•—Г«</span>\r\n                  <span className=\"text-xs text-white leading-relaxed line-clamp-2 mt-1\">{formatAddress(restaurant.address)}</span>\r\n                </div>\r\n              </div>\r\n              <div className=\"flex gap-3\">\r\n                <Clock className=\"h-5 w-5 text-primary flex-shrink-0 mt-0.5\" />\r\n                <div>\r\n                  <span className=\"block text-[10px] text-muted-foreground uppercase font-semibold\">GiГҹв•—ВҘ hoГҹв•‘Гӯt в”ҖГҰГҹв•—Г–ng</span>\r\n                  <span className=\"text-xs text-white font-semibold mt-1 block\">\r\n                    {restaurant.operatingHours?.open || '08:00'} - {restaurant.operatingHours?.close || '22:00'}\r\n                  </span>\r\n                </div>\r\n              </div>\r\n              <div className=\"flex gap-3\">\r\n                <DollarSign className=\"h-5 w-5 text-primary flex-shrink-0 mt-0.5\" />\r\n                <div>\r\n                  <span className=\"block text-[10px] text-muted-foreground uppercase font-semibold\">KhoГҹв•‘Гәng giв”ңГӯ trung bв”ңВјnh</span>\r\n                  <span className=\"text-xs text-white font-semibold mt-1 block\">\r\n                    {restaurant.averagePrice ? `${restaurant.averagePrice.toLocaleString('vi-VN')} в”ҖГҰ` : getPriceRangeText(restaurant.priceRange)}\r\n                  </span>\r\n                </div>\r\n              </div>\r\n            </Card>\r\n\r\n            {/* Voucher offers list */}\r\n            {vouchers.length > 0 && (\r\n              <div className=\"flex flex-col gap-4\">\r\n                <div className=\"text-left\">\r\n                  <span className=\"text-xs text-primary uppercase font-bold tracking-wider\">в•һВ»u в”ҖГҰв”ңГәi hГҹв•‘Г‘p dГҹв•‘ВҪn</span>\r\n                  <h3 style={{ fontFamily: \"'Playfair Display', serif\" }} className=\"text-xl font-bold text-white mt-1\">KhuyГҹв•‘в”җn mГҹв•‘Гӯi в”ҖГҰГҹв•—Г–c quyГҹв•—Гјn</h3>\r\n                </div>\r\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n                  {vouchers.map(v => (\r\n                    <VoucherCard\r\n                      key={v._id}\r\n                      voucher={v}\r\n                      isSaved={v.isSaved}\r\n                      onAction={handleSaveVoucher}\r\n                      actionText=\"Lв•һв–‘u mв”ңГә\"\r\n                    />\r\n                  ))}\r\n                </div>\r\n              </div>\r\n            )}\r\n\r\n            {/* Tab navigation workspace */}\r\n            <div className=\"flex flex-col gap-5\">\r\n              <Tabs value={activeTab} onValueChange={setActiveTab} className=\"w-full\">\r\n                <TabsList className=\"bg-[#20242D] border border-border p-1 w-full justify-start rounded-lg h-11\">\r\n                  <TabsTrigger value=\"menu\" className=\"flex items-center gap-1.5 text-xs font-semibold px-4 rounded-md h-9 data-[state=active]:bg-primary data-[state=active]:text-background transition-all\">\r\n                    <Utensils size={14} /> ThГҹв•—в–’c в”ҖГҰв•һГӯn\r\n                  </TabsTrigger>\r\n                  <TabsTrigger value=\"tables\" className=\"flex items-center gap-1.5 text-xs font-semibold px-4 rounded-md h-9 data-[state=active]:bg-primary data-[state=active]:text-background transition-all\">\r\n                    <Armchair size={14} /> Sв•һГӯ в”ҖГҰГҹв•—Гҙ bв”ңГЎn ({tableStats.available}/{tableStats.total})\r\n                  </TabsTrigger>\r\n                  <TabsTrigger value=\"info\" className=\"flex items-center gap-1.5 text-xs font-semibold px-4 rounded-md h-9 data-[state=active]:bg-primary data-[state=active]:text-background transition-all\">\r\n                    <Globe size={14} /> GiГҹв•—Вўi thiГҹв•—Г§u chi tiГҹв•‘в”җt\r\n                  </TabsTrigger>\r\n                  <TabsTrigger value=\"reviews\" className=\"flex items-center gap-1.5 text-xs font-semibold px-4 rounded-md h-9 data-[state=active]:bg-primary data-[state=active]:text-background transition-all\">\r\n                    <Star size={14} /> в”ҖГүв”ңГӯnh giв”ңГӯ ({restaurant.stats?.totalReviews || 0})\r\n                  </TabsTrigger>\r\n                </TabsList>\r\n\r\n                {/* Tab content area */}\r\n                <div className=\"mt-6\">\r\n                  {/* Menu Panel */}\r\n                  <TabsContent value=\"menu\" className=\"flex flex-col gap-5 focus-visible:outline-none\">\r\n                    <div className=\"flex flex-col sm:flex-row gap-3 items-center justify-between bg-card p-3 rounded-lg border border-border\">\r\n                      <div className=\"relative w-full sm:w-72\">\r\n                        <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\r\n                        <Input\r\n                          type=\"text\"\r\n                          placeholder=\"Tв”ңВјm mв”ңв”Ӯn в”ҖГўn trong thГҹв•—в–’c в”ҖГҰв•һГӯn...\"\r\n                          value={searchQuery}\r\n                          onChange={(e) => setSearchQuery(e.target.value)}\r\n                          className=\"pl-9 bg-secondary/40 border-border text-xs focus-visible:ring-1 focus-visible:ring-primary h-9\"\r\n                        />\r\n                      </div>\r\n\r\n                      {categories.length > 0 && (\r\n                        <div className=\"flex flex-wrap gap-1.5 w-full sm:w-auto items-center\">\r\n                          <button\r\n                            onClick={() => setSelectedCategory('')}\r\n                            className={`text-xs px-3 py-1.5 rounded-full transition font-medium ${\r\n                              !selectedCategory ? 'bg-primary text-background' : 'bg-secondary hover:bg-[#2C313C] text-muted-foreground hover:text-white'\r\n                            }`}\r\n                          >\r\n                            TГҹв•‘Г‘t cГҹв•‘Гә\r\n                          </button>\r\n                          {categories.map(cat => (\r\n                            <button\r\n                              key={cat.id}\r\n                              onClick={() => setSelectedCategory(cat.id)}\r\n                              className={`text-xs px-3 py-1.5 rounded-full transition font-medium ${\r\n                                selectedCategory === cat.id ? 'bg-primary text-background' : 'bg-secondary hover:bg-[#2C313C] text-muted-foreground hover:text-white'\r\n                              }`}\r\n                            >\r\n                              {cat.name}\r\n                            </button>\r\n                          ))}\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n\r\n                    {filteredMenuItems.length > 0 ? (\r\n                      <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\r\n                        {filteredMenuItems.map(item => (\r\n                          <Card key={item.id} className=\"p-4 bg-card border-border flex gap-4 hover:border-primary/20 transition group\">\r\n                            <div className=\"h-20 w-20 rounded-lg overflow-hidden bg-secondary flex-shrink-0 border border-border\">\r\n                              {item.image ? (\r\n                                <img src={item.image} alt={item.name} className=\"w-full h-full object-cover group-hover:scale-105 transition duration-300\" />\r\n                              ) : (\r\n                                <div className=\"w-full h-full flex items-center justify-center text-2xl bg-secondary text-muted-foreground\">вүЎЖ’Г¬в•ңвҲ©в••Г…</div>\r\n                              )}\r\n                            </div>\r\n                            <div className=\"min-w-0 flex-1 flex flex-col justify-between\">\r\n                              <div>\r\n                                <div className=\"flex items-start justify-between gap-2\">\r\n                                  <h4 className=\"text-sm font-bold text-white group-hover:text-primary transition-colors truncate\">{item.name}</h4>\r\n                                  <span className=\"text-xs text-primary font-bold\">{formatPrice(item.price)}</span>\r\n                                </div>\r\n                                {item.description && (\r\n                                  <p className=\"text-xs text-muted-foreground line-clamp-2 mt-1 leading-relaxed\">{item.description}</p>\r\n                                )}\r\n                              </div>\r\n                              <div className=\"mt-3.5 flex items-center justify-between text-[10px] text-muted-foreground\">\r\n                                <span className=\"bg-secondary px-2 py-0.5 rounded font-medium\">{item.categoryName || 'Mв”ңв”Ӯn в”ҖГўn'}</span>\r\n                                <span className={`font-semibold ${item.isAvailable ? 'text-emerald-400' : 'text-rose-400'}`}>\r\n                                  {item.isAvailable ? 'Cв”ңв–“n mв”ңв”Ӯn' : 'HГҹв•‘в”җt mв”ңв”Ӯn'}\r\n                                </span>\r\n                              </div>\r\n                            </div>\r\n                          </Card>\r\n                        ))}\r\n                      </div>\r\n                    ) : (\r\n                      <div className=\"text-center py-16 bg-card/10 border border-dashed border-border rounded-xl\">\r\n                        <Utensils className=\"mx-auto text-muted-foreground mb-3\" />\r\n                        <p className=\"text-muted-foreground text-sm font-medium\">Khв”ңв”Өng tв”ңВјm thГҹв•‘Г‘y mв”ңв”Ӯn в”ҖГўn nв”ңГЎo phв”ңв•Ј hГҹв•—Гәp vГҹв•—Вўi tв”ңВјm kiГҹв•‘в”җm.</p>\r\n                      </div>\r\n                    )}\r\n                  </TabsContent>\r\n\r\n                  {/* Sв•һГӯ в”ҖГҰГҹв•—Гҙ bв”ңГЎn Panel */}\r\n                  <TabsContent value=\"tables\" className=\"flex flex-col gap-4 focus-visible:outline-none\">\r\n                    <div className=\"flex gap-2 items-center bg-primary/5 border border-primary/20 p-3.5 rounded-lg text-xs text-primary/95 leading-relaxed mb-1\">\r\n                      <Info className=\"h-4.5 w-4.5 flex-shrink-0\" />\r\n                      <span>Xem danh sв”ңГӯch sв•һГӯ в”ҖГҰГҹв•—Гҙ bв”ңГЎn cГҹв•—Вәa nhв”ңГЎ hв”ңГЎng. TrГҹв•‘Гӯng thв”ңГӯi bв”ңГЎn trГҹв•—ГҰng thГҹв•—в–’c tГҹв•‘в”җ cв”ңв”Ӯ thГҹв•—Гў thay в”ҖГҰГҹв•—ГІi tв”ңв•Јy thuГҹв•—Г–c vв”ңГЎo thГҹв•—ВҘi gian cГҹв•—Г‘ thГҹв•—Гў bГҹв•‘Гӯn в”ҖГҰв”ҖГўng kв”ңв•ң в”ҖГҰГҹв•‘в•–t bв”ңГЎn.</span>\r\n                    </div>\r\n\r\n                    {tables.length > 0 ? (\r\n                      <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-4\">\r\n                        {tables.map(table => (\r\n                          <Card\r\n                            key={table.id}\r\n                            className={`p-4 bg-card border transition ${\r\n                              table.status === 'available' ? 'border-emerald-500/25 bg-emerald-500/5' : 'border-border'\r\n                            }`}\r\n                          >\r\n                            <div className=\"flex justify-between items-start\">\r\n                              <h4 className=\"text-sm font-bold text-white\">Bв”ңГЎn {table.tableNumber}</h4>\r\n                              <Badge\r\n                                className={`text-[9px] uppercase border font-bold ${\r\n                                  table.status === 'available' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' :\r\n                                  table.status === 'occupied' ? 'bg-rose-500/10 text-rose-400 border-rose-500/20' :\r\n                                  table.status === 'reserved' ? 'bg-amber-500/10 text-amber-400 border-amber-500/20' :\r\n                                  'bg-secondary text-muted-foreground border-border'\r\n                                }`}\r\n                              >\r\n                                {table.status === 'available' ? 'TrГҹв•—ГҰng' :\r\n                                 table.status === 'occupied' ? 'BГҹв•‘ВЎn' :\r\n                                 table.status === 'reserved' ? 'в”ҖГүв”ңГә в”ҖГҰГҹв•‘в•–t' : 'BГҹв•‘Гәo trв”ңВј'}\r\n                              </Badge>\r\n                            </div>\r\n                            <div className=\"mt-3.5 flex flex-col gap-1 text-[11px] text-muted-foreground\">\r\n                              <div className=\"flex justify-between\">\r\n                                <span>SГҹв•—вҢҗc chГҹв•—вҢҗa:</span>\r\n                                <span className=\"font-semibold text-white\">{table.capacity} ngв•һв–‘Гҹв•—ВҘi</span>\r\n                              </div>\r\n                              {table.zone && (\r\n                                <div className=\"flex justify-between\">\r\n                                  <span>Khu vГҹв•—в–’c:</span>\r\n                                  <span className=\"font-semibold text-white\">{table.zone}</span>\r\n                                </div>\r\n                              )}\r\n                              {table.depositAmount > 0 && (\r\n                                <div className=\"flex justify-between text-primary\">\r\n                                  <span>TiГҹв•—Гјn в”ҖГҰГҹв•‘в•–t cГҹв•—Г¬c:</span>\r\n                                  <span className=\"font-bold\">{formatPrice(table.depositAmount)}</span>\r\n                                </div>\r\n                              )}\r\n                              {table.note && (\r\n                                <p className=\"text-[10px] italic border-t border-border/40 pt-1.5 mt-1.5 text-muted-foreground/80 leading-relaxed\">\r\n                                  вүЎЖ’ГҶГӯ {table.note}\r\n                                </p>\r\n                              )}\r\n                            </div>\r\n                          </Card>\r\n                        ))}\r\n                      </div>\r\n                    ) : (\r\n                      <div className=\"text-center py-16 bg-card/10 border border-dashed border-border rounded-xl\">\r\n                        <Armchair className=\"mx-auto text-muted-foreground mb-3\" />\r\n                        <p className=\"text-muted-foreground text-sm font-medium\">Nhв”ңГЎ hв”ңГЎng chв•һв–‘a cГҹв•‘ВЎp nhГҹв•‘ВЎt sв•һГӯ в”ҖГҰГҹв•—Гҙ bв”ңГЎn chв”ңВЎnh thГҹв•—вҢҗc.</p>\r\n                      </div>\r\n                    )}\r\n                  </TabsContent>\r\n\r\n                  {/* Info Panel */}\r\n                  <TabsContent value=\"info\" className=\"flex flex-col gap-6 focus-visible:outline-none\">\r\n                    <div className=\"bg-card p-6 border border-border rounded-xl flex flex-col gap-6\">\r\n                      <div className=\"flex flex-col gap-2\">\r\n                        <h4 className=\"text-sm font-bold text-white border-l-2 border-primary pl-2 uppercase tracking-wide\">GiГҹв•—Вўi thiГҹв•—Г§u vГҹв•—Гј chв”ңв•‘ng tв”ңв”Өi</h4>\r\n                        <p className=\"text-xs text-muted-foreground leading-relaxed mt-1\">{restaurant.description || 'Chв•һв–‘a cв”ңв”Ӯ bв”ңГЎi viГҹв•‘в”җt giГҹв•—Вўi thiГҹв•—Г§u chi tiГҹв•‘в”җt cho nhв”ңГЎ hв”ңГЎng nв”ңГЎy.'}</p>\r\n                      </div>\r\n\r\n                      {restaurant.signatureDishes && restaurant.signatureDishes.length > 0 && (\r\n                        <div className=\"flex flex-col gap-2\">\r\n                          <h4 className=\"text-sm font-bold text-white border-l-2 border-primary pl-2 uppercase tracking-wide\">Mв”ңв”Ӯn в”ҖГўn в”ҖГҰГҹв•‘в•–c trв•һв–‘ng nГҹв•—ГІi tiГҹв•‘в”җng</h4>\r\n                          <div className=\"flex flex-wrap gap-1.5 mt-2\">\r\n                            {restaurant.signatureDishes.map((dish, i) => (\r\n                              <Badge key={i} variant=\"secondary\" className=\"text-xs text-white border-border px-3 py-1 font-semibold\">\r\n                                {dish}\r\n                              </Badge>\r\n                            ))}\r\n                          </div>\r\n                        </div>\r\n                      )}\r\n\r\n                      {restaurant.amenities && restaurant.amenities.length > 0 && (\r\n                        <div className=\"flex flex-col gap-2\">\r\n                          <h4 className=\"text-sm font-bold text-white border-l-2 border-primary pl-2 uppercase tracking-wide\">TiГҹв•—Г§n в”ңВЎch phГҹв•—Г‘c vГҹв•—Г‘</h4>\r\n                          <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-3 mt-2\">\r\n                            {restaurant.amenities.map((item, i) => (\r\n                              <div key={i} className=\"text-xs text-muted-foreground flex items-center gap-1.5 font-medium\">\r\n                                <Check size={14} className=\"text-primary\" />\r\n                                <span>{item}</span>\r\n                              </div>\r\n                            ))}\r\n                          </div>\r\n                        </div>\r\n                      )}\r\n\r\n                      {restaurant.policyRules && restaurant.policyRules.length > 0 && (\r\n                        <div className=\"flex flex-col gap-2\">\r\n                          <h4 className=\"text-sm font-bold text-white border-l-2 border-primary pl-2 uppercase tracking-wide\">Chв”ңВЎnh sв”ңГӯch & Quy в”ҖГҰГҹв•—ГҜnh</h4>\r\n                          <ul className=\"list-disc pl-4 text-xs text-muted-foreground leading-relaxed space-y-1.5 mt-1.5\">\r\n                            {restaurant.policyRules.map((rule, i) => (\r\n                              <li key={i}>{rule}</li>\r\n                            ))}\r\n                          </ul>\r\n                        </div>\r\n                      )}\r\n\r\n                      <div className=\"flex flex-col gap-2.5 pt-4 border-t border-border/60\">\r\n                        <h4 className=\"text-sm font-bold text-white uppercase tracking-wide\">Thв”ңв”Өng tin liв”ңВ¬n hГҹв•—Г§ trГҹв•—в–’c tiГҹв•‘в”җp</h4>\r\n                        <div className=\"flex flex-col gap-2 mt-1.5 text-xs text-muted-foreground\">\r\n                          {restaurant.phoneNumber && (\r\n                            <p className=\"flex items-center gap-2\">\r\n                              <Phone size={14} className=\"text-primary\" />\r\n                              <span>в”ҖГүiГҹв•—Г§n thoГҹв•‘Гӯi: <strong className=\"text-white\">{restaurant.phoneNumber}</strong></span>\r\n                            </p>\r\n                          )}\r\n                          {restaurant.email && (\r\n                            <p className=\"flex items-center gap-2\">\r\n                              <Globe size={14} className=\"text-primary\" />\r\n                              <span>Email: <strong className=\"text-white\">{restaurant.email}</strong></span>\r\n                            </p>\r\n                          )}\r\n                          {restaurant.websiteUrl && (\r\n                            <p className=\"flex items-center gap-2\">\r\n                              <Globe size={14} className=\"text-primary\" />\r\n                              <span>Website:{' '}\r\n                                <a href={restaurant.websiteUrl} target=\"_blank\" rel=\"noopener noreferrer\" className=\"text-primary hover:underline font-semibold\">\r\n                                  {restaurant.websiteUrl}\r\n                                </a>\r\n                              </span>\r\n                            </p>\r\n                          )}\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  </TabsContent>\r\n\r\n                  {/* Reviews Panel */}\r\n                  <TabsContent value=\"reviews\" className=\"flex flex-col gap-6 focus-visible:outline-none\">\r\n                    {/* Rating Summary Block */}\r\n                    <Card className=\"p-6 bg-card border-border flex flex-col md:flex-row gap-6 items-center\">\r\n                      {/* Left: Avg Score */}\r\n                      <div className=\"flex flex-col items-center justify-center border-b md:border-b-0 md:border-r border-[#2C313C]/60 pb-6 md:pb-0 md:pr-10 shrink-0 w-full md:w-auto\">\r\n                        <span className=\"text-5xl font-extrabold text-[#D49653] font-serif\">\r\n                          {restaurant.stats?.averageRating || 0}\r\n                        </span>\r\n                        <div className=\"mt-2.5\">\r\n                          <RatingStars rating={restaurant.stats?.averageRating || 0} size=\"md\" />\r\n                        </div>\r\n                        <span className=\"text-xs text-[#A5ADBA] mt-2 block\">\r\n                          TГҹв•—ВҪ {restaurant.stats?.totalReviews || 0} в”ҖГҰв”ңГӯnh giв”ңГӯ\r\n                        </span>\r\n                      </div>\r\n\r\n                      {/* Right: Stars Filter Buttons */}\r\n                      <div className=\"flex-1 w-full text-left\">\r\n                        <span className=\"text-xs text-[#A5ADBA] uppercase tracking-wider font-semibold block mb-2.5\">\r\n                          LГҹв•—Г¬c theo в”ҖГҰв”ңГӯnh giв”ңГӯ\r\n                        </span>\r\n                        <div className=\"flex flex-wrap gap-2\">\r\n                          {[\r\n                            { value: '', label: 'TГҹв•‘Г‘t cГҹв•‘Гә' },\r\n                            { value: '5', label: '5 О“ГҝГ ' },\r\n                            { value: '4', label: '4 О“ГҝГ ' },\r\n                            { value: '3', label: '3 О“ГҝГ ' },\r\n                            { value: '2', label: '2 О“ГҝГ ' },\r\n                            { value: '1', label: '1 О“ГҝГ ' },\r\n                          ].map((filterItem) => (\r\n                            <button\r\n                              key={filterItem.value}\r\n                              onClick={() => setSelectedRatingFilter(filterItem.value)}\r\n                              className={`text-xs font-semibold px-4 py-2 rounded-md border transition-all cursor-pointer ${\r\n                                selectedRatingFilter === filterItem.value\r\n                                  ? 'bg-[#D49653] text-[#0F1115] border-[#D49653]'\r\n                                  : 'border-[#2C313C] text-[#A5ADBA] hover:text-white hover:bg-[#20242D]'\r\n                              }`}\r\n                            >\r\n                              {filterItem.label}\r\n                            </button>\r\n                          ))}\r\n                        </div>\r\n                      </div>\r\n                    </Card>\r\n\r\n                    {/* Reviews List */}\r\n                    {reviewsLoading ? (\r\n                      <div className=\"flex flex-col gap-4\">\r\n                        {[1, 2].map((n) => (\r\n                          <Card key={n} className=\"h-32 bg-card border-border animate-pulse\" />\r\n                        ))}\r\n                      </div>\r\n                    ) : reviews.length === 0 ? (\r\n                      <div className=\"text-center py-16 bg-card/10 border border-dashed border-[#2C313C] rounded-xl flex flex-col items-center justify-center gap-3\">\r\n                        <Star className=\"text-muted-foreground w-8 h-8\" />\r\n                        <p className=\"text-muted-foreground text-sm font-medium\">Chв•һв–‘a cв”ңв”Ӯ в”ҖГҰв”ңГӯnh giв”ңГӯ nв”ңГЎo tв•һв–‘в•һГӯng Гҹв•—вҢҗng vГҹв•—Вўi bГҹв•—Г– lГҹв•—Г¬c nв”ңГЎy.</p>\r\n                      </div>\r\n                    ) : (\r\n                      <div className=\"flex flex-col gap-4 text-left\">\r\n                        {reviews.map((rev) => (\r\n                          <Card key={rev._id} className=\"p-5 bg-card border-border flex flex-col gap-4\">\r\n                            {/* Review Header */}\r\n                            <div className=\"flex items-center justify-between gap-3\">\r\n                              <div className=\"flex items-center gap-3 min-w-0\">\r\n                                <div className=\"h-10 w-10 rounded-full bg-[#20242D] border border-border overflow-hidden shrink-0\">\r\n                                  {rev.userId?.avatarUrl ? (\r\n                                    <img src={rev.userId.avatarUrl} alt={rev.userId.fullName} className=\"w-full h-full object-cover\" />\r\n                                  ) : (\r\n                                    <div className=\"w-full h-full flex items-center justify-center text-sm font-bold text-[#D49653]\">\r\n                                      {rev.userId?.fullName?.charAt(0).toUpperCase() || 'U'}\r\n                                    </div>\r\n                                  )}\r\n                                </div>\r\n                                <div className=\"min-w-0\">\r\n                                  <span className=\"block text-sm font-bold text-white truncate\">\r\n                                    {rev.userId?.fullName || 'Khв”ңГӯch hв”ңГЎng'}\r\n                                  </span>\r\n                                  <span className=\"block text-[10px] text-[#A5ADBA]\">\r\n                                    {new Date(rev.createdAt).toLocaleString('vi-VN')}\r\n                                  </span>\r\n                                </div>\r\n                              </div>\r\n                              <RatingStars rating={rev.rating} size=\"sm\" />\r\n                            </div>\r\n\r\n                            {/* Review Comment */}\r\n                            <p className=\"text-xs sm:text-sm text-white leading-relaxed whitespace-pre-line\">\r\n                              {rev.comment}\r\n                            </p>\r\n\r\n                            {/* Review Images */}\r\n                            {rev.images && rev.images.length > 0 && (\r\n                              <div className=\"flex flex-wrap gap-2 pt-1\">\r\n                                {rev.images.map((imgUrl, i) => (\r\n                                  <img\r\n                                    key={i}\r\n                                    src={imgUrl}\r\n                                    alt={`Review thumbnail ${i + 1}`}\r\n                                    onClick={() => setActiveLightboxImage(imgUrl)}\r\n                                    className=\"h-16 w-16 rounded-lg object-cover border border-border cursor-pointer hover:opacity-85 transition\"\r\n                                  />\r\n                                ))}\r\n                              </div>\r\n                            )}\r\n\r\n                            {/* Owner Reply */}\r\n                            {rev.ownerReply && rev.ownerReply.comment && (\r\n                              <div className=\"ml-4 md:ml-6 mt-2 p-4 bg-[#20242D] border-l-2 border-[#D49653] rounded-lg\">\r\n                                <span className=\"block text-xs font-bold text-[#D49653] mb-1\">\r\n                                  PhГҹв•‘Гәn hГҹв•—Гҙi tГҹв•—ВҪ nhв”ңГЎ hв”ңГЎng\r\n                                </span>\r\n                                <p className=\"text-xs sm:text-sm text-[#A5ADBA] leading-relaxed whitespace-pre-line\">\r\n                                  {rev.ownerReply.comment}\r\n                                </p>\r\n                                <span className=\"block text-[10px] text-muted-foreground mt-2\">\r\n                                  {new Date(rev.ownerReply.repliedAt).toLocaleString('vi-VN')}\r\n                                </span>\r\n                              </div>\r\n                            )}\r\n                          </Card>\r\n                        ))}\r\n\r\n                        {/* Pagination */}\r\n                        {reviewsTotalPages > 1 && (\r\n                          <div className=\"mt-6 flex justify-center items-center gap-1.5\">\r\n                            <Button\r\n                              disabled={reviewsPage <= 1}\r\n                              onClick={() => setReviewsPage(reviewsPage - 1)}\r\n                              variant=\"outline\"\r\n                              size=\"sm\"\r\n                              className=\"border-border text-xs text-white\"\r\n                            >\r\n                              Trв•һв–‘Гҹв•—Вўc\r\n                            </Button>\r\n                            {Array.from({ length: reviewsTotalPages }, (_, i) => i + 1).map((p) => (\r\n                              <Button\r\n                                key={p}\r\n                                variant={p === reviewsPage ? 'default' : 'outline'}\r\n                                size=\"icon\"\r\n                                className={`h-8 w-8 text-xs ${\r\n                                  p === reviewsPage ? 'bg-primary text-background font-bold' : 'border-border text-white'\r\n                                }`}\r\n                                onClick={() => setReviewsPage(p)}\r\n                              >\r\n                                {p}\r\n                              </Button>\r\n                            ))}\r\n                            <Button\r\n                              disabled={reviewsPage >= reviewsTotalPages}\r\n                              onClick={() => setReviewsPage(reviewsPage + 1)}\r\n                              variant=\"outline\"\r\n                              size=\"sm\"\r\n                              className=\"border-border text-xs text-white\"\r\n                            >\r\n                              Sau\r\n                            </Button>\r\n                          </div>\r\n                        )}\r\n                      </div>\r\n                    )}\r\n                  </TabsContent>\r\n                </div>\r\n              </Tabs>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Right Block: Actions / Booking Widget */}\r\n          <div className=\"lg:col-span-1\">\r\n            <Card className=\"p-6 bg-card border-border sticky top-24 flex flex-col gap-5 shadow-xl\">\r\n              <h3 style={{ fontFamily: \"'Playfair Display', serif\" }} className=\"text-lg font-bold text-white\">в”ҖГүГҹв•‘в•–t bв”ңГЎn online</h3>\r\n              <p className=\"text-xs text-muted-foreground leading-relaxed\">\r\n                в”ҖГүГҹв•‘Гәm bГҹв•‘Гәo chГҹв•—Г№ ngГҹв•—Гҙi lв”ңв•ң tв•һв–‘Гҹв•—Ж’ng cГҹв•—Вәa bГҹв•‘Гӯn tГҹв•‘Гӯi nhв”ңГЎ hв”ңГЎng {restaurant.name} chГҹв•—Г« trong vв”ңГЎi thao tв”ңГӯc trГҹв•—в–’c tuyГҹв•‘в”җn в”ҖГҰв•һГӯn giГҹв•‘Гәn.\r\n              </p>\r\n\r\n              <Button\r\n                onClick={() => navigate(`/restaurants/${restaurant.id}/booking`)}\r\n                className=\"bg-primary hover:bg-primary/95 text-background font-bold h-11 w-full gap-2 text-xs uppercase tracking-wider shadow-lg shadow-primary/15\"\r\n              >\r\n                <CalendarDays size={16} /> в”ҖГүГҹв•‘в•–t bв”ңГЎn ngay lГҹв•‘ВЎp tГҹв•—вҢҗc\r\n              </Button>\r\n\r\n              <Button\r\n                variant=\"outline\"\r\n                onClick={handleChatRestaurant}\r\n                className=\"border-border text-white hover:bg-secondary/65 hover:text-white h-11 w-full gap-2 text-xs font-semibold\"\r\n              >\r\n                <MessageCircle size={16} className=\"text-primary\" /> Chat vГҹв•—Вўi nhв”ңГЎ hв”ңГЎng\r\n              </Button>\r\n\r\n              {restaurant.bookingNotes && (\r\n                <div className=\"bg-secondary/40 border border-border rounded-lg p-3.5 mt-2\">\r\n                  <span className=\"block text-[10px] uppercase tracking-wider text-muted-foreground font-bold mb-1\">Lв•һв–‘u в”ңв•ң в”ҖГҰГҹв•‘в•–t bв”ңГЎn:</span>\r\n                  <p className=\"text-[11px] text-muted-foreground leading-relaxed\">{restaurant.bookingNotes}</p>\r\n                </div>\r\n              )}\r\n            </Card>\r\n          </div>\r\n\r\n        </div>\r\n      </div>\r\n\r\n      {/* Footer */}\r\n      <footer className=\"border-t border-border bg-[#090B0E] py-8 text-center text-xs text-muted-foreground mt-16\">\r\n        <div className=\"mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4\">\r\n          <span style={{ fontFamily: \"'Playfair Display', serif\" }} className=\"text-sm font-bold text-white tracking-wider\">BookEat</span>\r\n          <span>в”¬вҢҗ 2026 BookEat. MГҹв•—Г¬i quyГҹв•—Гјn в”ҖГҰв•һв–‘Гҹв•—Гәc bГҹв•‘Гәo lв•һв–‘u.</span>\r\n        </div>\r\n      </footer>\r\n\r\n      {/* Lightbox Image Preview */}\r\n      {activeLightboxImage && (\r\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4 animate-in fade-in duration-200\">\r\n          <button\r\n            onClick={() => setActiveLightboxImage(null)}\r\n            className=\"absolute top-4 right-4 text-white/80 hover:text-white p-2 rounded-full hover:bg-white/10 transition cursor-pointer\"\r\n          >\r\n            <X className=\"w-6 h-6\" />\r\n          </button>\r\n          <img\r\n            src={activeLightboxImage}\r\n            alt=\"Review enlarged preview\"\r\n            className=\"max-w-full max-h-[90vh] object-contain rounded-lg shadow-2xl\"\r\n          />\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"F:\\LEARN Kв”ңГ® 7\\BookEat_Ki7\\BookEat_FE_React\\src\\pages\\restaurants\\RestaurantsPage.jsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  40 |\n  41 |   useEffect(() => {\n> 42 |     loadFavoriteIds();\n     |     ^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  43 |   }, [isAuthenticated, user]);\n  44 |\n  45 |   const handleToggleFavorite = async (restaurantId, e) => {","line":42,"column":5,"endLine":42,"endColumn":20},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadFavoriteIds'. Either include it or remove the dependency array.","line":43,"column":6,"endLine":43,"endColumn":29,"suggestions":[{"desc":"Update the dependencies array to be: [isAuthenticated, loadFavoriteIds, user]","fix":{"range":[1751,1774],"text":"[isAuthenticated, loadFavoriteIds, user]"}}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useCallback } from 'react';\r\nimport { useNavigate, useSearchParams, Link } from 'react-router-dom';\r\nimport Header from '../../components/Header';\r\nimport { getPublicRestaurants, getPublicCuisineTypes } from '../../api/restaurantApi';\r\nimport { Search, Star, MapPin, Compass, RotateCcw, MessageSquare, Heart } from 'lucide-react';\r\nimport { useAuth } from '../../context/useAuth';\r\nimport { useChatWidget } from '../../context/useChatWidget';\r\nimport { Button } from '../../components/ui/button';\r\nimport { Card } from '../../components/ui/card';\r\nimport { Badge } from '../../components/ui/badge';\r\nimport { Input } from '../../components/ui/input';\r\nimport toast from 'react-hot-toast';\r\nimport { getFavoriteIds, addFavorite, removeFavorite } from '../../api/favoriteApi';\r\n\r\nexport default function RestaurantsPage() {\r\n  const navigate = useNavigate();\r\n  const { isAuthenticated, user } = useAuth();\r\n  const { openCustomerRestaurantChat } = useChatWidget();\r\n  const [searchParams, setSearchParams] = useSearchParams();\r\n\r\n  // States\r\n  const [restaurants, setRestaurants] = useState([]);\r\n  const [cuisineTypes, setCuisineTypes] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [favoriteIds, setFavoriteIds] = useState([]);\r\n\r\n  // TГҹв•‘Гәi danh sв”ңГӯch ID yв”ңВ¬u thв”ңВЎch nГҹв•‘в”җu в”ҖГҰв”ңГә в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp vв”ңГЎ lв”ңГЎ customer\r\n  const loadFavoriteIds = async () => {\r\n    if (isAuthenticated && user?.role === 'customer') {\r\n      try {\r\n        const res = await getFavoriteIds();\r\n        if (res && res.success) {\r\n          setFavoriteIds(res.data || []);\r\n        }\r\n      } catch (err) {\r\n        console.error('LГҹв•—Г№i tГҹв•‘Гәi ID yв”ңВ¬u thв”ңВЎch:', err);\r\n      }\r\n    }\r\n  };\r\n\r\n  useEffect(() => {\r\n    loadFavoriteIds();\r\n  }, [isAuthenticated, user]);\r\n\r\n  const handleToggleFavorite = async (restaurantId, e) => {\r\n    e.preventDefault();\r\n    e.stopPropagation();\r\n\r\n    if (!isAuthenticated) {\r\n      toast.error('Vui lв”ңв–“ng в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp в”ҖГҰГҹв•—Гў lв•һв–‘u nhв”ңГЎ hв”ңГЎng yв”ңВ¬u thв”ңВЎch');\r\n      navigate(`/auth/login?redirect=${encodeURIComponent(window.location.pathname + window.location.search)}`);\r\n      return;\r\n    }\r\n\r\n    if (user?.role !== 'customer') {\r\n      toast.error('ChГҹв•—Г« khв”ңГӯch hв”ңГЎng mГҹв•—Вўi cв”ңв”Ӯ thГҹв•—Гў lв•һв–‘u nhв”ңГЎ hв”ңГЎng yв”ңВ¬u thв”ңВЎch');\r\n      return;\r\n    }\r\n\r\n    const isFav = favoriteIds.includes(restaurantId);\r\n    try {\r\n      if (isFav) {\r\n        const res = await removeFavorite(restaurantId);\r\n        if (res && res.success) {\r\n          setFavoriteIds(prev => prev.filter(id => id !== restaurantId));\r\n          toast.success('в”ҖГүв”ңГә xв”ңв”Ӯa khГҹв•—Г…i danh sв”ңГӯch yв”ңВ¬u thв”ңВЎch');\r\n        }\r\n      } else {\r\n        const res = await addFavorite(restaurantId);\r\n        if (res && res.success) {\r\n          setFavoriteIds(prev => [...prev, restaurantId]);\r\n          toast.success('в”ҖГүв”ңГә thв”ңВ¬m vв”ңГЎo danh sв”ңГӯch yв”ңВ¬u thв”ңВЎch');\r\n        }\r\n      }\r\n    } catch (err) {\r\n      toast.error(err.message || 'LГҹв•—Г№i thao tв”ңГӯc yв”ңВ¬u thв”ңВЎch');\r\n    }\r\n  };\r\n\r\n  // Filter states from URL\r\n  const [search, setSearch] = useState(searchParams.get('search') || '');\r\n  const [cuisineType, setCuisineType] = useState(searchParams.get('cuisineType') || '');\r\n  const [priceRange, setPriceRange] = useState(searchParams.get('priceRange') || '');\r\n  const [sortBy, setSortBy] = useState(searchParams.get('sortBy') || 'name');\r\n  const [sortDir, setSortDir] = useState(searchParams.get('sortDir') || 'asc');\r\n  const [page, setPage] = useState(parseInt(searchParams.get('page')) || 1);\r\n  const [totalPages, setTotalPages] = useState(1);\r\n  const [total, setTotal] = useState(0);\r\n\r\n  // Load cuisine types once\r\n  useEffect(() => {\r\n    const loadCuisineTypes = async () => {\r\n      try {\r\n        const res = await getPublicCuisineTypes();\r\n        if (res && res.success) {\r\n          setCuisineTypes(res.data || []);\r\n        }\r\n      } catch (err) {\r\n        console.error('Failed to load cuisine types:', err.message);\r\n      }\r\n    };\r\n    loadCuisineTypes();\r\n  }, []);\r\n\r\n  // Fetch restaurants function\r\n  const fetchRestaurants = useCallback(async () => {\r\n    setLoading(true);\r\n    try {\r\n      const params = {\r\n        page,\r\n        limit: 9,\r\n        search,\r\n        cuisineType,\r\n        priceRange,\r\n        sortBy,\r\n        sortDir,\r\n      };\r\n\r\n      const res = await getPublicRestaurants(params);\r\n      if (res && res.success) {\r\n        setRestaurants(res.data.restaurants || []);\r\n        setTotalPages(res.data.totalPages || 1);\r\n        setTotal(res.data.total || 0);\r\n      }\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў tГҹв•‘Гәi danh sв”ңГӯch nhв”ңГЎ hв”ңГЎng');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [page, search, cuisineType, priceRange, sortBy, sortDir]);\r\n\r\n  // Sync state with URL params\r\n  useEffect(() => {\r\n    const timeoutId = window.setTimeout(() => {\r\n      fetchRestaurants();\r\n    }, 0);\r\n    return () => window.clearTimeout(timeoutId);\r\n  }, [fetchRestaurants]);\r\n\r\n  // Handle URL updates\r\n  const updateURLParams = (newParams) => {\r\n    const currentParams = Object.fromEntries(searchParams.entries());\r\n    const combined = { ...currentParams, ...newParams };\r\n\r\n    // Clean empty values\r\n    Object.keys(combined).forEach(key => {\r\n      if (!combined[key]) delete combined[key];\r\n    });\r\n\r\n    setSearchParams(combined);\r\n  };\r\n\r\n  const handleSearchSubmit = (e) => {\r\n    e.preventDefault();\r\n    setPage(1);\r\n    updateURLParams({ search, page: 1 });\r\n  };\r\n\r\n  const handleCuisineChange = (val) => {\r\n    setCuisineType(val);\r\n    setPage(1);\r\n    updateURLParams({ cuisineType: val, page: 1 });\r\n  };\r\n\r\n  const handlePriceChange = (val) => {\r\n    setPriceRange(val);\r\n    setPage(1);\r\n    updateURLParams({ priceRange: val, page: 1 });\r\n  };\r\n\r\n  const handleSortChange = (val) => {\r\n    const [field, dir] = val.split('-');\r\n    setSortBy(field);\r\n    setSortDir(dir);\r\n    setPage(1);\r\n    updateURLParams({ sortBy: field, sortDir: dir, page: 1 });\r\n  };\r\n\r\n  const clearFilters = () => {\r\n    setSearch('');\r\n    setCuisineType('');\r\n    setPriceRange('');\r\n    setSortBy('name');\r\n    setSortDir('asc');\r\n    setPage(1);\r\n    setSearchParams({});\r\n  };\r\n\r\n  const handlePageChange = (newPage) => {\r\n    setPage(newPage);\r\n    updateURLParams({ page: newPage });\r\n    window.scrollTo({ top: 0, behavior: 'smooth' });\r\n  };\r\n\r\n  const handleChatRestaurant = async (restaurantId) => {\r\n    if (!isAuthenticated) {\r\n      toast.error('Vui lв”ңв–“ng в”ҖГҰв”ҖГўng nhГҹв•‘ВЎp в”ҖГҰГҹв•—Гў chat vГҹв•—Вўi nhв”ңГЎ hв”ңГЎng');\r\n      navigate(`/auth/login?redirect=${encodeURIComponent(window.location.pathname + window.location.search)}`);\r\n      return;\r\n    }\r\n\r\n    if (user?.role !== 'customer') {\r\n      toast.error('ChГҹв•—Г« tв”ңГЎi khoГҹв•‘Гәn khв”ңГӯch hв”ңГЎng mГҹв•—Вўi cв”ңв”Ӯ thГҹв•—Гў chat vГҹв•—Вўi nhв”ңГЎ hв”ңГЎng');\r\n      return;\r\n    }\r\n\r\n    try {\r\n      await openCustomerRestaurantChat(restaurantId);\r\n    } catch (err) {\r\n      toast.error(err.message || 'Khв”ңв”Өng thГҹв•—Гў mГҹв•—Ж’ chat vГҹв•—Вўi nhв”ңГЎ hв”ңГЎng');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background text-white flex flex-col\">\r\n      <Header />\r\n\r\n      <main className=\"flex-1 max-w-[1280px] w-full mx-auto px-4 sm:px-6 lg:px-8 py-10\">\r\n        {/* Listing Title */}\r\n        <div className=\"mb-10 text-left\">\r\n          <h1 className=\"text-3xl font-extrabold tracking-tight text-white sm:text-4xl\" style={{ fontFamily: \"'Playfair Display', serif\" }}>\r\n            Khв”ңГӯm phв”ңГӯ nhв”ңГЎ hв”ңГЎng\r\n          </h1>\r\n          <p className=\"mt-2 text-sm text-muted-foreground\">\r\n            Tв”ңВјm kiГҹв•‘в”җm vв”ңГЎ в”ҖГҰГҹв•‘в•–t chГҹв•—Г№ tГҹв•‘Гӯi cв”ңГӯc в”ҖГҰГҹв•—ГҜa в”ҖГҰiГҹв•—Гўm Гҹв•‘вҢҗm thГҹв•—в–’c chГҹв•‘Г‘t lв•һв–‘Гҹв•—Гәng hв”ңГЎng в”ҖГҰГҹв•‘Вәu в”ҖГҰв•һв–‘Гҹв•—Гәc в”ҖГҰГҹв•—ГҰi tв”ңГӯc BookEat kiГҹв•—Гўm chГҹв•—вҢҗng.\r\n          </p>\r\n        </div>\r\n\r\n        {/* Layout with Sidebar filter on Desktop and Grid on the Right */}\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-4 gap-8 items-start\">\r\n          {/* Left Sidebar Filter */}\r\n          <Card className=\"lg:col-span-1 p-5 bg-card border-border flex flex-col gap-6\">\r\n            <div className=\"flex items-center justify-between pb-4 border-b border-border/60\">\r\n              <h3 className=\"font-semibold text-white flex items-center gap-2 text-sm\">\r\n                <Compass className=\"h-4 w-4 text-primary\" /> BГҹв•—Г– lГҹв•—Г¬c tв”ңВјm kiГҹв•‘в”җm\r\n              </h3>\r\n              {(search || cuisineType || priceRange || sortBy !== 'name' || sortDir !== 'asc') && (\r\n                <button\r\n                  type=\"button\"\r\n                  onClick={clearFilters}\r\n                  className=\"text-xs text-primary hover:underline flex items-center gap-1 font-medium\"\r\n                >\r\n                  <RotateCcw className=\"h-3 w-3\" /> ThiГҹв•‘в”җt lГҹв•‘ВЎp lГҹв•‘Гӯi\r\n                </button>\r\n              )}\r\n            </div>\r\n\r\n            {/* Keyword Search form */}\r\n            <form onSubmit={handleSearchSubmit} className=\"flex flex-col gap-2\">\r\n              <label className=\"text-xs text-muted-foreground font-semibold uppercase tracking-wider\">TГҹв•—ВҪ khв”ңв”Ӯa</label>\r\n              <div className=\"relative\">\r\n                <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground\" />\r\n                <Input\r\n                  type=\"text\"\r\n                  placeholder=\"Tв”ңВ¬n nhв”ңГЎ hв”ңГЎng, mв”ңв”Ө tГҹв•‘Гә...\"\r\n                  value={search}\r\n                  onChange={(e) => setSearch(e.target.value)}\r\n                  className=\"pl-9 h-9 bg-secondary/40 border-border text-xs focus-visible:ring-1 f