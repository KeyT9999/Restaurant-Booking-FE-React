# ============================================================
# 🍽️ BookEat Frontend — Environment Variables Example
# ============================================================
# Sao chép file này thành .env và điền giá trị thực
# cp .env.example .env
# ============================================================
# ⚠️  LƯU Ý: Với Vite, biến môi trường BẮT BUỘC phải có prefix
#            VITE_ thì mới được expose ra phía client (browser).
#            Không có prefix VITE_ sẽ KHÔNG hoạt động!
# ============================================================

# ────────────────────────────────────────────────────────────
# 🚀 API BACKEND
# ────────────────────────────────────────────────────────────
# URL của Backend API
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Timeout cho mỗi request (ms)
VITE_API_TIMEOUT=10000

# ────────────────────────────────────────────────────────────
# ⚡ WEBSOCKET / SOCKET.IO (Real-time)
# ────────────────────────────────────────────────────────────
VITE_SOCKET_URL=http://localhost:3001

# ────────────────────────────────────────────────────────────
# 🔑 GOOGLE OAUTH (Client-side)
# ────────────────────────────────────────────────────────────
# Cùng Client ID với Backend (không cần secret ở FE)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ────────────────────────────────────────────────────────────
# 🌍 APP CONFIG
# ────────────────────────────────────────────────────────────
VITE_APP_NAME=BookEat
VITE_APP_VERSION=1.0.0

# URL của ứng dụng Frontend (dùng cho redirect OAuth, share link...)
VITE_APP_URL=http://localhost:5173

# ────────────────────────────────────────────────────────────
# 💳 PAYOS (Client-side redirect URLs)
# ────────────────────────────────────────────────────────────
VITE_PAYMENT_RETURN_URL=http://localhost:5173/payment/success
VITE_PAYMENT_CANCEL_URL=http://localhost:5173/payment/cancel

# ────────────────────────────────────────────────────────────
# 🖼️ CLOUDINARY (Public — Chỉ cần cloud name để hiển thị ảnh)
# ────────────────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ────────────────────────────────────────────────────────────
# 🛠️ DEVELOPMENT
# ────────────────────────────────────────────────────────────
# Bật/tắt logs debug (true | false)
VITE_DEBUG=true

# Bật React Query DevTools (true | false)
VITE_ENABLE_QUERY_DEVTOOLS=true
